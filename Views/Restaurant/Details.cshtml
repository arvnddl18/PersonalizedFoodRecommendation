@{
    ViewData["Title"] = "Restaurant Details";
    var placeId = ViewBag.PlaceId as string;
    var currentVersion = ViewBag.CurrentVersion as Capstone.Models.NomsaurModel.RestaurantVersion;
    var owner = ViewBag.Owner as Capstone.Models.NomsaurModel.RestaurantOwner;
    var isOwner = ViewBag.IsOwner as bool? ?? false;
    var isAdmin = ViewBag.IsAdmin as bool? ?? false;
    var openClaim = (Context.Request.Query["openClaim"].ToString() == "1");
}

<div class="min-h-screen bg-gradient-to-br from-[#FFF5E1] to-white py-8 px-4">
    <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
            @if (TempData["Success"] != null)
            {
                <div class="bg-green-50 border border-green-200 rounded-lg p-3 mb-4">
                    <p class="text-sm text-green-700">@TempData["Success"]</p>
                </div>
            }
            @if (TempData["Info"] != null)
            {
                <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 mb-4">
                    <p class="text-sm text-blue-700">@TempData["Info"]</p>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="bg-red-50 border border-red-200 rounded-lg p-3 mb-4">
                    <p class="text-sm text-red-700">@TempData["Error"]</p>
                </div>
            }

            <div class="flex items-center justify-between mb-4">
                <h1 class="text-3xl font-bold text-[#47682C]">@(currentVersion?.Name ?? "Restaurant")</h1>
                <div class="flex gap-2">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a href="@Url.Action("Edit", "Restaurant", new { placeId })" 
                           class="px-4 py-2 bg-[#196EF3] text-white rounded-lg hover:bg-[#1557c4] transition">
                            Edit
                        </a>
                        @if (owner == null)
                        {
                            <button type="button"
                                    onclick="openClaimModal()"
                                    class="px-4 py-2 bg-[#F7B32B] text-[#47682C] rounded-lg hover:bg-[#e5a020] transition font-semibold">
                                Claim
                            </button>
                        }
                    }
                    <a href="@Url.Action("History", "Restaurant", new { placeId })" 
                       class="px-4 py-2 bg-[#47682C] text-white rounded-lg hover:bg-[#3a5424] transition">
                        History
                    </a>
                </div>
            </div>

            <!-- Status Badges -->
            <div class="flex gap-2 mb-4">
                @if (owner != null)
                {
                    <span class="px-3 py-1 bg-[#F7B32B] text-[#47682C] rounded-full text-sm font-semibold">
                        ✓ Verified Owner
                    </span>
                }
                @if (currentVersion != null)
                {
                    <span class="px-3 py-1 bg-[#196EF3]/10 text-[#196EF3] rounded-full text-sm">
                        @currentVersion.Status
                    </span>
                }
            </div>
        </div>

        <!-- Restaurant Information -->
        <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
            <h2 class="text-2xl font-bold text-[#47682C] mb-4">Restaurant Information</h2>
            
            @if (currentVersion != null)
            {
                <div class="space-y-4">
                    @if (!string.IsNullOrEmpty(currentVersion.Address))
                    {
                        <div>
                            <span class="font-semibold text-[#47682C]">Address:</span>
                            <p class="text-gray-700">@currentVersion.Address</p>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(currentVersion.PhoneNumber))
                    {
                        <div>
                            <span class="font-semibold text-[#47682C]">Phone:</span>
                            <p class="text-gray-700">@currentVersion.PhoneNumber</p>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(currentVersion.Website))
                    {
                        <div>
                            <span class="font-semibold text-[#47682C]">Website:</span>
                            <a href="@currentVersion.Website" target="_blank" 
                               class="text-[#196EF3] hover:underline">@currentVersion.Website</a>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(currentVersion.CuisineType))
                    {
                        <div>
                            <span class="font-semibold text-[#47682C]">Cuisine Type:</span>
                            <p class="text-gray-700">@currentVersion.CuisineType</p>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(currentVersion.PriceRange))
                    {
                        <div>
                            <span class="font-semibold text-[#47682C]">Price Range:</span>
                            <p class="text-gray-700">@currentVersion.PriceRange</p>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(currentVersion.Description))
                    {
                        <div>
                            <span class="font-semibold text-[#47682C]">Description:</span>
                            <p class="text-gray-700 whitespace-pre-wrap">@currentVersion.Description</p>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(currentVersion.OpeningHours))
                    {
                        <div>
                            <span class="font-semibold text-[#47682C]">Opening Hours:</span>
                            <p class="text-gray-700">@currentVersion.OpeningHours</p>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(currentVersion.SpecialFeatures))
                    {
                        <div>
                            <span class="font-semibold text-[#47682C]">Special Features:</span>
                            <p class="text-gray-700">@currentVersion.SpecialFeatures</p>
                        </div>
                    }
                </div>

                <div class="mt-6 pt-6 border-t border-gray-200">
                    <p class="text-sm text-gray-500">
                        Last updated: @currentVersion.CreatedAt.ToString("MMMM dd, yyyy") by 
                        @currentVersion.CreatedByUser?.Name
                    </p>
                    @if (currentVersion.ApprovedByUser != null)
                    {
                        <p class="text-sm text-gray-500">
                            Approved by: @currentVersion.ApprovedByUser.Name on 
                            @currentVersion.ApprovedAt?.ToString("MMMM dd, yyyy")
                        </p>
                    }
                </div>
            }
            else
            {
                <p class="text-gray-500">No restaurant information available. Be the first to add details!</p>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="@Url.Action("Edit", "Restaurant", new { placeId })" 
                       class="mt-4 inline-block px-4 py-2 bg-[#196EF3] text-white rounded-lg hover:bg-[#1557c4] transition">
                        Add Information
                    </a>
                }
            }
        </div>

        <!-- Owner Information -->
        @if (owner != null)
        {
            <div class="bg-white rounded-2xl shadow-lg p-6">
                <h2 class="text-2xl font-bold text-[#47682C] mb-4">Owner Information</h2>
                <p class="text-gray-700">
                    <span class="font-semibold">Owner:</span> @owner.User.Name
                </p>
                <p class="text-gray-700">
                    <span class="font-semibold">Verified:</span> @owner.VerifiedAt?.ToString("MMMM dd, yyyy")
                </p>
            </div>
        }
    </div>
</div>

@if (User.Identity?.IsAuthenticated == true && owner == null)
{
    <!-- Claim Restaurant Modal -->
    <div id="claim-modal" class="fixed inset-0 bg-black/50 hidden items-center justify-center p-4 z-50" role="dialog" aria-modal="true" aria-hidden="true">
        <div class="w-full max-w-2xl bg-white rounded-2xl shadow-xl overflow-hidden">
            <div class="flex items-center justify-between p-5 border-b border-gray-200">
                <div>
                    <h2 class="text-xl font-bold text-[#47682C]">Claim Restaurant</h2>
                    <p class="text-sm text-gray-600">Provide business details for admin verification.</p>
                </div>
                <button type="button" onclick="closeClaimModal()" class="px-3 py-2 text-gray-600 hover:text-gray-900">
                    ✕
                </button>
            </div>

            <form asp-action="Claim" asp-controller="Restaurant" asp-route-placeId="@placeId" method="post" enctype="multipart/form-data" class="p-5">
                @Html.AntiForgeryToken()
                <input type="hidden" name="PlaceId" value="@placeId" />

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="md:col-span-2">
                        <label class="block text-sm font-semibold text-[#47682C] mb-2">Restaurant Name *</label>
                        <input name="RestaurantName"
                               value="@(currentVersion?.Name ?? "")"
                               required
                               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent" />
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-[#47682C] mb-2">Business Name (Legal Name)</label>
                        <input name="BusinessName"
                               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent" />
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-[#47682C] mb-2">Business Email</label>
                        <input name="BusinessEmail" type="email"
                               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent" />
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-[#47682C] mb-2">Business Phone</label>
                        <input name="BusinessPhone"
                               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent" />
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-[#47682C] mb-2">Business Address</label>
                        <textarea name="BusinessAddress" rows="2"
                                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent"></textarea>
                    </div>

                    <div class="md:col-span-2">
                        <label class="block text-sm font-semibold text-[#47682C] mb-2">Business License Document</label>
                        <input name="BusinessLicense" type="file" accept=".pdf,.jpg,.jpeg,.png"
                               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent" />
                        <p class="text-sm text-gray-500 mt-1">Upload a copy of your business license/registration document (PDF, JPG, PNG).</p>
                    </div>

                    <div class="md:col-span-2">
                        <label class="block text-sm font-semibold text-[#47682C] mb-2">Additional Notes</label>
                        <textarea name="AdditionalNotes" rows="4"
                                  class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent"
                                  placeholder="Any additional info that might help verify your ownership..."></textarea>
                    </div>
                </div>

                <div class="mt-6 flex items-center justify-end gap-3">
                    <button type="button" onclick="closeClaimModal()"
                            class="px-5 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition">
                        Cancel
                    </button>
                    <button type="submit"
                            class="px-5 py-2 bg-[#F7B32B] text-[#47682C] rounded-lg hover:bg-[#e5a020] transition font-semibold">
                        Submit Claim
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function openClaimModal() {
            const modal = document.getElementById('claim-modal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            modal.setAttribute('aria-hidden', 'false');
        }

        function closeClaimModal() {
            const modal = document.getElementById('claim-modal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            modal.setAttribute('aria-hidden', 'true');
        }

        // Close when clicking backdrop
        document.getElementById('claim-modal')?.addEventListener('click', (e) => {
            if (e.target && e.target.id === 'claim-modal') closeClaimModal();
        });

        // Open modal when redirected from old Claim URL
        if (@(openClaim ? "true" : "false")) {
            document.addEventListener('DOMContentLoaded', openClaimModal);
        }
    </script>
}

