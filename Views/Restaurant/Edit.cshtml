@model Capstone.Controllers.EditRestaurantViewModel
@{
    ViewData["Title"] = "Edit Restaurant";
    var placeId = ViewBag.PlaceId as string;
    var currentVersion = ViewBag.CurrentVersion as Capstone.Models.NomsaurModel.RestaurantVersion;
    var remainingEdits = ViewBag.RemainingEdits as int? ?? 0;
}

<div class="min-h-screen bg-gradient-to-br from-[#FFF5E1] to-white py-8 px-4">
    <div class="max-w-3xl mx-auto">
        <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
            <h1 class="text-3xl font-bold text-[#47682C] mb-2">Edit Restaurant</h1>
            <p class="text-gray-600 mb-4">Make changes to restaurant information. Your edits will be reviewed.</p>
            
            @if (remainingEdits > 0)
            {
                <div class="bg-[#196EF3]/10 border border-[#196EF3] rounded-lg p-3 mb-4">
                    <p class="text-sm text-[#196EF3]">
                        <strong>@remainingEdits</strong> edits remaining today (max 10 per day)
                    </p>
                </div>
            }
            else
            {
                <div class="bg-red-50 border border-red-200 rounded-lg p-3 mb-4">
                    <p class="text-sm text-red-600">
                        You have reached the daily edit limit. Please try again tomorrow.
                    </p>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="bg-red-50 border border-red-200 rounded-lg p-3 mb-4">
                    <p class="text-sm text-red-600">@TempData["Error"]</p>
                </div>
            }
        </div>

        <form asp-action="Edit" method="post" class="bg-white rounded-2xl shadow-lg p-6">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PlaceId" value="@placeId" />

            <div class="space-y-6">
                <div>
                    <label asp-for="Name" class="block text-sm font-semibold text-[#47682C] mb-2">Restaurant Name *</label>
                    <input asp-for="Name" 
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent" />
                    <span asp-validation-for="Name" class="text-red-500 text-sm"></span>
                </div>

                <div>
                    <label asp-for="Address" class="block text-sm font-semibold text-[#47682C] mb-2">Address</label>
                    <input asp-for="Address" 
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent" />
                    <span asp-validation-for="Address" class="text-red-500 text-sm"></span>
                </div>

                <div>
                    <label asp-for="PhoneNumber" class="block text-sm font-semibold text-[#47682C] mb-2">Phone Number</label>
                    <input asp-for="PhoneNumber" 
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent" />
                    <span asp-validation-for="PhoneNumber" class="text-red-500 text-sm"></span>
                </div>

                <div>
                    <label asp-for="Website" class="block text-sm font-semibold text-[#47682C] mb-2">Website URL</label>
                    <input asp-for="Website" type="url" 
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent" 
                           placeholder="https://example.com" />
                    <span asp-validation-for="Website" class="text-red-500 text-sm"></span>
                </div>

                <div>
                    <label asp-for="CuisineType" class="block text-sm font-semibold text-[#47682C] mb-2">Cuisine Type</label>
                    <input asp-for="CuisineType" 
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent" 
                           placeholder="e.g., Italian, Japanese, Filipino" />
                    <span asp-validation-for="CuisineType" class="text-red-500 text-sm"></span>
                </div>

                <div>
                    <label asp-for="PriceRange" class="block text-sm font-semibold text-[#47682C] mb-2">Price Range</label>
                    <select asp-for="PriceRange" 
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent">
                        <option value="">Select price range</option>
                        <option value="Budget">Budget ($)</option>
                        <option value="Moderate">Moderate ($$)</option>
                        <option value="Premium">Premium ($$$)</option>
                        <option value="Luxury">Luxury ($$$$)</option>
                    </select>
                    <span asp-validation-for="PriceRange" class="text-red-500 text-sm"></span>
                </div>

                <div>
                    <label asp-for="Description" class="block text-sm font-semibold text-[#47682C] mb-2">Description</label>
                    <textarea asp-for="Description" rows="5" 
                              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent"></textarea>
                    <span asp-validation-for="Description" class="text-red-500 text-sm"></span>
                </div>

                <div>
                    <label asp-for="OpeningHours" class="block text-sm font-semibold text-[#47682C] mb-2">Opening Hours</label>
                    <textarea asp-for="OpeningHours" rows="3" 
                              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent" 
                              placeholder="e.g., Mon-Fri: 9AM-10PM, Sat-Sun: 10AM-11PM"></textarea>
                    <span asp-validation-for="OpeningHours" class="text-red-500 text-sm"></span>
                </div>

                <div>
                    <label asp-for="SpecialFeatures" class="block text-sm font-semibold text-[#47682C] mb-2">Special Features</label>
                    <textarea asp-for="SpecialFeatures" rows="3" 
                              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent" 
                              placeholder="e.g., Vegetarian options, Outdoor seating, Wi-Fi, Parking"></textarea>
                    <span asp-validation-for="SpecialFeatures" class="text-red-500 text-sm"></span>
                </div>

                <div>
                    <label asp-for="FacebookUrl" class="block text-sm font-semibold text-[#47682C] mb-2">Facebook Page (optional)</label>
                    <input asp-for="FacebookUrl" type="url"
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent"
                           placeholder="https://facebook.com/yourpage" />
                    <span asp-validation-for="FacebookUrl" class="text-red-500 text-sm"></span>
                </div>

                <div>
                    <label asp-for="InstagramUrl" class="block text-sm font-semibold text-[#47682C] mb-2">Instagram Page (optional)</label>
                    <input asp-for="InstagramUrl" type="url"
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent"
                           placeholder="https://instagram.com/yourpage" />
                    <span asp-validation-for="InstagramUrl" class="text-red-500 text-sm"></span>
                </div>

                <div>
                    <label asp-for="ServiceOptions" class="block text-sm font-semibold text-[#47682C] mb-2">Service Options (optional)</label>
                    <textarea asp-for="ServiceOptions" rows="2"
                              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent"
                              placeholder="e.g., Dine-in, Takeout, Delivery"></textarea>
                    <span asp-validation-for="ServiceOptions" class="text-red-500 text-sm"></span>
                </div>

                <div>
                    <label asp-for="PopularFor" class="block text-sm font-semibold text-[#47682C] mb-2">Popular For (optional)</label>
                    <textarea asp-for="PopularFor" rows="2"
                              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent"
                              placeholder="e.g., Breakfast, Lunch, Dinner"></textarea>
                    <span asp-validation-for="PopularFor" class="text-red-500 text-sm"></span>
                </div>

                <div>
                    <label asp-for="MenuItemsAndIngredients" class="block text-sm font-semibold text-[#47682C] mb-2">Menu &amp; Ingredients (optional)</label>
                    <textarea asp-for="MenuItemsAndIngredients" rows="6"
                              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent"
                              placeholder="One per line. Example: Bulgogi - made with thinly sliced beef..."></textarea>
                    <span asp-validation-for="MenuItemsAndIngredients" class="text-red-500 text-sm"></span>
                </div>
            </div>

            <div class="mt-6 flex gap-4">
                <button type="submit" 
                        class="px-6 py-2 bg-[#196EF3] text-white rounded-lg hover:bg-[#1557c4] transition font-semibold"
                        @(remainingEdits == 0 ? "disabled" : "")>
                    Submit Edit
                </button>
                <a href="@Url.Action("Details", "Restaurant", new { placeId })" 
                   class="px-6 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

