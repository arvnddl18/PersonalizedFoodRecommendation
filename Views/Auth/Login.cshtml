@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@model Capstone.Models.NomsaurModel.User
@inject IHttpContextAccessor HttpContextAccessor
@{

    Layout = null;
    ViewData["Title"] = "Login";
    var userAgent = Context.Request.Headers["User-Agent"].ToString();
    bool isMobile = !string.IsNullOrEmpty(userAgent) && (
        userAgent.Contains("Mobi", System.StringComparison.OrdinalIgnoreCase) ||
        userAgent.Contains("Android", System.StringComparison.OrdinalIgnoreCase) ||
        userAgent.Contains("iPhone", System.StringComparison.OrdinalIgnoreCase) ||
        userAgent.Contains("iPad", System.StringComparison.OrdinalIgnoreCase) ||
        userAgent.Contains("Windows Phone", System.StringComparison.OrdinalIgnoreCase)
    );
}

@if (!isMobile)
{


    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Foodiesaur</title>
        <link rel="icon" type="image/svg+xml" href="~/images/titlelogo.svg">
        <link rel="alternate icon" type="image/png" href="~/images/titlelogo.png">
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/Capstone.styles.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
        <script src="https://cdn.tailwindcss.com"></script>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
        <script src="https://www.google.com/recaptcha/api.js" async defer></script>
        <style>
            @@keyframes fadeInUp {
                from {
                    opacity: 0;
                    transform: translateY(30px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }
            .animate-fade-in-up {
                animation: fadeInUp 0.6s ease-out;
            }
            /* High-quality image rendering for desktop */
            img[alt="FoodieSaur Illustration"] {
                image-rendering: -webkit-optimize-contrast;
                image-rendering: auto;
                -ms-interpolation-mode: bicubic;
                will-change: transform;
                backface-visibility: hidden;
                transform: translateZ(0);
                -webkit-font-smoothing: antialiased;
                -moz-osx-font-smoothing: grayscale;
            }
        </style>
    </head>


    <main role="main" class="pb-3">

        <body class="bg-white min-h-screen overflow-hidden">

            <div class="flex w-full h-screen animate-fade-in-up">

                <!-- Illustration sa Left (2/3) -->
                <div class="w-2/3 relative bg-white overflow-hidden flex items-center justify-center">
                    <img src="~/images/final 1.png" alt="FoodieSaur Illustration" 
                         class="w-full h-full object-contain object-center select-none" 
                         loading="eager"
                         decoding="async">
                </div>

                <!-- Form sa Right (1/3) -->
                <div class="w-1/3 bg-white flex items-center justify-center px-10">
                    <div class="w-full max-w-sm">
                        <!-- Header -->
                        <div class="text-center mb-8">
                            <h2 class="text-3xl font-bold mb-2 text-gray-900">Log In</h2>
                            <p class="text-gray-500 text-sm">Enter your Email and Password</p>
                        </div>

                        <form asp-action="Login" asp-controller="Auth" method="post">
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="ModelOnly" class="text-red-600 text-xs mb-4 text-center"></div>

                            <!--Email-->
                            <div class="mb-6">
                                <input asp-for="Email" type="email" placeholder="Email" class="w-full border-b-2 border-gray-300 focus:outline-none focus:border-gray-600 py-3 text-base text-gray-900 placeholder-gray-400 transition-colors bg-transparent">
                                <span asp-validation-for="Email" class="text-red-600 text-xs mt-1 block"></span>
                            </div>

                            <!-- Password -->
                            <div class="mb-6">
                                <input asp-for="Password" type="password" placeholder="Password" class="w-full border-b-2 border-gray-300 focus:outline-none focus:border-gray-600 py-3 text-base text-gray-900 placeholder-gray-400 transition-colors bg-transparent">
                                <span asp-validation-for="Password" class="text-red-600 text-xs mt-1 block"></span>
                                
                                <!-- Forgot Password Link -->
                                <div class="text-right mt-2">
                                    <a href="#" class="text-red-600 hover:underline text-sm font-medium">Forgot Password?</a>
                                </div>
                            </div>

                            <!-- reCAPTCHA -->
                            <div class="flex justify-center mb-6">
                                <div class="g-recaptcha" data-sitekey="6LdT_PcrAAAAANwssuXWWRSq0u5l6lEPcVAxjl-Y"></div>
                            </div>
                            <div id="recaptcha-error" class="text-red-600 text-xs text-center mb-4" style="display:none;">Please complete the reCAPTCHA verification.</div>

                            <!-- Loginbtn -->
                            <button type="submit" id="login-submit-btn" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3.5 mb-6 rounded-full hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 ease-out shadow-md hover:shadow-lg">
                                <span class="uppercase tracking-wide text-base">LOGIN</span>
                            </button>
                        </form>

                        <!-- Social Login Divider -->
                        <div class="flex items-center mb-6">
                            <div class="flex-grow border-t border-gray-300"></div>
                            <span class="px-4 text-gray-500 text-sm">Or sign in with</span>
                            <div class="flex-grow border-t border-gray-300"></div>
                        </div>

                        <!-- Social Login Icons -->
                        <div class="flex items-center justify-center space-x-6 mb-6">
                            <a asp-action="FacebookLogin" asp-controller="Auth" class="group hover:opacity-80 transition-all duration-200 hover:scale-110 active:scale-95">
                                <img src="/images/facebooksvg.svg" alt="Facebook" class="w-10 h-10 cursor-pointer">
                            </a>
                            <a asp-action="GoogleLogin" asp-controller="Auth" class="group hover:opacity-80 transition-all duration-200 hover:scale-110 active:scale-95">
                                <img src="/images/googlesvg.svg" alt="Google" class="w-10 h-10 cursor-pointer">
                            </a>
                        </div>

                        <!-- Sign Up Link -->
                        <p class="text-center text-sm text-gray-500">
                            Don't have an account?
                            <a asp-action="Register" asp-controller="Auth" class="text-red-600 hover:underline font-medium ml-1">Sign Up</a>
                        </p>
                    </div>
                </div>

            </div>

        </body>
        <script>
            document.querySelector('form').addEventListener('submit', function(e) {
                var recaptchaResponse = grecaptcha.getResponse();
                var errorDiv = document.getElementById('recaptcha-error');
                
                if (!recaptchaResponse) {
                    e.preventDefault();
                    if (errorDiv) {
                        errorDiv.style.display = 'block';
                    }
                    return false;
                }
                
                if (errorDiv) {
                    errorDiv.style.display = 'none';
                }
                return true;
            });
        </script>
    </main>

    </html>
}
else
{
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>@ViewData["Title"] - Capstone</title>
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/Capstone.styles.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
        <script src="https://cdn.tailwindcss.com"></script>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
        <script src="https://www.google.com/recaptcha/api.js" async defer></script>
        <style>
            @@keyframes fadeInUp {
                from {
                    opacity: 0;
                    transform: translateY(30px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }
            .animate-fade-in-up {
                animation: fadeInUp 0.6s ease-out;
            }
        </style>
    </head>


    <main role="main" class="pb-3">

        <!-- Mobile  -->
        <div class="min-h-screen bg-gray-50">
            <!-- Image Curved header -->

            <div class="relative w-full">
                <img src="/images/Header.png" alt="img" class="w-full h-auto">

            </div>


            <!-- Body -->
            <div class="max-w-sm mx-auto px-6 animate-fade-in-up">
                <p class="text-center text-gray-500 text-sm mb-6"> Enter your email and password </p>


                <form asp-action="Login" asp-controller="Auth" method="post" class=" p-6 w-full max-w-sm space-y-4">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm"></div>
                    <!-- Email Field -->
                    <div>
                        <input asp-for="Email" type="email" placeholder="Email" class="w-full border-b border-gray-300 focus:outline-none focus:border-gray-500 p-2">
                        <span asp-validation-for="Email" class="text-red-600 text-sm"></span>
                    </div>

                    <!-- Password Field -->

                    <div class="relative">
                        <input asp-for="Password" type="password" placeholder="Password" class="w-full border-b border-gray-300 focus:outline-none focus:border-gray-500 p-2 pr-10">
                        <span asp-validation-for="Password" class="text-red-600 text-sm"></span>

                        <!-- Forgot Password Link -->
                        <div class="text-right mt-1">
                            <a href="#" class="text-red-600 hover:underline text-sm">Forgot Password?</a>
                        </div>
                    </div>

                    <!-- reCAPTCHA -->
                    <div class="flex justify-center mb-4 mt-4">
                        <div class="g-recaptcha" data-sitekey="6LdT_PcrAAAAANwssuXWWRSq0u5l6lEPcVAxjl-Y"></div>
                    </div>
                    <div id="recaptcha-error-mobile" class="text-red-600 text-sm text-center mb-2" style="display:none;">Please complete the reCAPTCHA verification.</div>

                    <!-- Login Button -->
                    <button type="submit" id="login-submit-btn-mobile" class="group w-full bg-sky-600 hover:bg-sky-700 text-white font-semibold py-2 rounded-3xl hover:scale-105 active:scale-95 transition-all duration-300 ease-out shadow-lg hover:shadow-xl relative overflow-hidden">
                        <span class="relative z-10">SIGN IN</span>
                        <div class="absolute inset-0 bg-gradient-to-r from-sky-500/20 to-blue-500/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                    </button>
                </form>

                <!-- svg logo -->
                <div class="flex items-center p-3">
                    <div class="flex-grow border-t border-gray-300"></div>
                    <span class="px-3 text-gray-500 text-sm">Or sign in with</span>
                    <div class="flex-grow border-t border-gray-300"></div>
                </div>

                <div class="flex items-center justify-center space-x-4">
                    <a asp-action="FacebookLogin" asp-controller="Auth" class="group hover:opacity-80 transition-all duration-300 hover:scale-110 active:scale-95">
                        <img src="/images/facebooksvg.svg" alt="Facebook" class="w-8 h-8 cursor-pointer group-hover:drop-shadow-lg transition-all duration-300">
                    </a>
                    <a asp-action="GoogleLogin" asp-controller="Auth" class="group hover:opacity-80 transition-all duration-300 hover:scale-110 active:scale-95">
                        <img src="/images/googlesvg.svg" alt="Google" class="w-8 h-8 cursor-pointer group-hover:drop-shadow-lg transition-all duration-300">
                    </a>
                </div>

                <p class="text-center mt-4 text-sm text-gray-500">
                    Don't have an account?
                    <a asp-action="Register" asp-controller="Auth" class="text-red-500 hover:underline">Sign Up</a>
                </p>


            </div>
        </div>

        <script>
            document.querySelectorAll('button[data-toggle="password"]').forEach(function(btn){
                btn.addEventListener('click', function(){
                  var selector = btn.getAttribute('data-target');
                  var input = document.querySelector(selector);
                  if (!input) return;
                  input.type = input.type === 'password' ? 'text' : 'password';
                });
             });
             
             // reCAPTCHA validation for mobile
             var mobileForm = document.querySelector('.max-w-sm form');
             if (mobileForm) {
                 mobileForm.addEventListener('submit', function(e) {
                     var recaptchaResponse = grecaptcha.getResponse();
                     var errorDiv = document.getElementById('recaptcha-error-mobile');
                     
                     if (!recaptchaResponse) {
                         e.preventDefault();
                         if (errorDiv) {
                             errorDiv.style.display = 'block';
                         }
                         return false;
                     }
                     
                     if (errorDiv) {
                         errorDiv.style.display = 'none';
                     }
                     return true;
                 });
             }
        </script>
    </main>

    </html>

}