@{
    ViewData["Title"] = "Pending Edits";
    var pendingEdits = ViewBag.PendingEdits as List<Capstone.Models.NomsaurModel.RestaurantVersion> ?? new List<Capstone.Models.NomsaurModel.RestaurantVersion>();
}

<div class="min-h-screen bg-gradient-to-br from-[#FFF5E1] to-white py-8 px-4">
    <div class="max-w-6xl mx-auto">
        <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
            <h1 class="text-3xl font-bold text-[#47682C] mb-2">Pending Edits</h1>
            <p class="text-gray-600">Review and approve edits for restaurants without owners</p>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="bg-green-50 border border-green-200 rounded-lg p-3 mb-4">
                <p class="text-sm text-green-600">@TempData["Success"]</p>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="bg-red-50 border border-red-200 rounded-lg p-3 mb-4">
                <p class="text-sm text-red-600">@TempData["Error"]</p>
            </div>
        }

        @if (pendingEdits.Any())
        {
            <div class="space-y-4">
                @foreach (var edit in pendingEdits)
                {
                    <div class="bg-white rounded-2xl shadow-lg p-6">
                        <div class="flex items-center justify-between mb-4">
                            <div>
                                <h3 class="text-xl font-bold text-[#47682C]">@edit.Name</h3>
                                <p class="text-sm text-gray-600">Version @edit.VersionNumber</p>
                                <p class="text-sm text-gray-500">Created by @edit.CreatedByUser?.Name on @edit.CreatedAt.ToString("MMMM dd, yyyy")</p>
                            </div>
                            <span class="px-3 py-1 bg-yellow-100 text-yellow-700 rounded-full text-sm font-semibold">Pending</span>
                        </div>

                        <div class="space-y-2 mb-4">
                            @if (!string.IsNullOrEmpty(edit.Address))
                            {
                                <p><span class="font-semibold text-[#47682C]">Address:</span> @edit.Address</p>
                            }
                            @if (!string.IsNullOrEmpty(edit.CuisineType))
                            {
                                <p><span class="font-semibold text-[#47682C]">Cuisine:</span> @edit.CuisineType</p>
                            }
                            @if (!string.IsNullOrEmpty(edit.Description))
                            {
                                <p><span class="font-semibold text-[#47682C]">Description:</span> @edit.Description</p>
                            }
                        </div>

                        <div class="flex gap-3 mt-4">
                            <form asp-action="ApproveEdit" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="versionId" value="@edit.VersionId" />
                                <button type="submit" 
                                        class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition">
                                    Approve
                                </button>
                            </form>
                            <form asp-action="RejectEdit" method="post" class="inline" onsubmit="return confirmReject(this);">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="versionId" value="@edit.VersionId" />
                                <input type="text" name="reason" placeholder="Rejection reason" required 
                                       class="px-3 py-2 border border-gray-300 rounded-lg mr-2" />
                                <button type="submit" 
                                        class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition">
                                    Reject
                                </button>
                            </form>
                            <a href="/Restaurant/Details?placeId=@edit.PlaceId" 
                               class="px-4 py-2 bg-[#196EF3] text-white rounded-lg hover:bg-[#1557c4] transition">
                                View Restaurant
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="bg-white rounded-2xl shadow-lg p-6 text-center">
                <p class="text-gray-500">No pending edits.</p>
            </div>
        }
    </div>
</div>

<script>
    function confirmReject(form) {
        const reason = form.querySelector('input[name="reason"]').value;
        if (!reason || reason.trim() === '') {
            alert('Please provide a rejection reason.');
            return false;
        }
        return confirm('Are you sure you want to reject this edit?');
    }
</script>

