@{
    ViewData["Title"] = "User Roles";
    var admins = ViewBag.Admins as List<Capstone.Models.NomsaurModel.UserRole> ?? new List<Capstone.Models.NomsaurModel.UserRole>();
    var moderators = ViewBag.Moderators as List<Capstone.Models.NomsaurModel.UserRole> ?? new List<Capstone.Models.NomsaurModel.UserRole>();
}

<div class="min-h-screen bg-gradient-to-br from-[#FFF5E1] to-white py-8 px-4">
    <div class="max-w-6xl mx-auto">
        <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
            <h1 class="text-3xl font-bold text-[#47682C] mb-2">User Roles Management</h1>
            <p class="text-gray-600">Grant and revoke admin and moderator roles</p>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="bg-green-50 border border-green-200 rounded-lg p-3 mb-4">
                <p class="text-sm text-green-600">@TempData["Success"]</p>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="bg-red-50 border border-red-200 rounded-lg p-3 mb-4">
                <p class="text-sm text-red-600">@TempData["Error"]</p>
            </div>
        }

        <!-- Grant Role Form -->
        <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
            <h2 class="text-2xl font-bold text-[#47682C] mb-4">Grant Role</h2>
            <form asp-action="GrantRole" method="post" class="space-y-4">
                @Html.AntiForgeryToken()
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div>
                        <label for="UserEmail" class="block text-sm font-semibold text-[#47682C] mb-2">User Email</label>
                        <input type="email" name="UserEmail" required 
                               class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent" />
                    </div>
                    <div>
                        <label for="RoleType" class="block text-sm font-semibold text-[#47682C] mb-2">Role Type</label>
                        <select name="RoleType" required 
                                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#196EF3] focus:border-transparent">
                            <option value="">Select role</option>
                            <option value="Admin">Admin</option>
                            <option value="Moderator">Moderator</option>
                        </select>
                    </div>
                    <div class="flex items-end">
                        <button type="submit" 
                                class="w-full px-4 py-2 bg-[#196EF3] text-white rounded-lg hover:bg-[#1557c4] transition">
                            Grant Role
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <!-- Admins List -->
        <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
            <h2 class="text-2xl font-bold text-[#47682C] mb-4">Admins (@admins.Count)</h2>
            @if (admins.Any())
            {
                <div class="space-y-3">
                    @foreach (var admin in admins)
                    {
                        <div class="border border-gray-200 rounded-lg p-4 flex items-center justify-between">
                            <div>
                                <h3 class="font-semibold text-[#47682C]">@admin.User.Name</h3>
                                <p class="text-sm text-gray-600">@admin.User.Email</p>
                                <p class="text-sm text-gray-500">Granted on: @admin.GrantedAt.ToString("MMMM dd, yyyy")</p>
                                @if (admin.GrantedByUser != null)
                                {
                                    <p class="text-sm text-gray-500">Granted by: @admin.GrantedByUser.Name</p>
                                }
                            </div>
                            <form asp-action="RevokeRole" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="roleId" value="@admin.RoleId" />
                                <button type="submit" 
                                        onclick="return confirm('Are you sure you want to revoke this role?');"
                                        class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition">
                                    Revoke
                                </button>
                            </form>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-gray-500">No admins found.</p>
            }
        </div>

        <!-- Moderators List -->
        <div class="bg-white rounded-2xl shadow-lg p-6">
            <h2 class="text-2xl font-bold text-[#47682C] mb-4">Moderators (@moderators.Count)</h2>
            @if (moderators.Any())
            {
                <div class="space-y-3">
                    @foreach (var moderator in moderators)
                    {
                        <div class="border border-gray-200 rounded-lg p-4 flex items-center justify-between">
                            <div>
                                <h3 class="font-semibold text-[#47682C]">@moderator.User.Name</h3>
                                <p class="text-sm text-gray-600">@moderator.User.Email</p>
                                <p class="text-sm text-gray-500">Granted on: @moderator.GrantedAt.ToString("MMMM dd, yyyy")</p>
                                @if (moderator.GrantedByUser != null)
                                {
                                    <p class="text-sm text-gray-500">Granted by: @moderator.GrantedByUser.Name</p>
                                }
                            </div>
                            <form asp-action="RevokeRole" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="roleId" value="@moderator.RoleId" />
                                <button type="submit" 
                                        onclick="return confirm('Are you sure you want to revoke this role?');"
                                        class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition">
                                    Revoke
                                </button>
                            </form>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-gray-500">No moderators found.</p>
            }
        </div>
    </div>
</div>

