@model Capstone.Models.NomsaurModel.User
@{
    ViewData["Title"] = "Account Settings";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Foodiesaur</title>
    <link rel="icon" type="image/svg+xml" href="~/images/titlelogo.svg">
    <link rel="alternate icon" type="image/png" href="~/images/titlelogo.png">  
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: linear-gradient(135deg, #FFF5E1 0%, rgba(71, 104, 44, 0.05) 50%, #FFF5E1 100%);
            min-height: 100vh;
            padding: 0.5rem 1rem 1.5rem 1rem;
            position: relative;
            line-height: 1.6;
        }

            body::before {
                content: '';
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: radial-gradient(circle at 20% 80%, rgba(247, 179, 43, 0.1) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(71, 104, 44, 0.1) 0%, transparent 50%), radial-gradient(circle at 40% 40%, rgba(25, 110, 243, 0.05) 0%, transparent 50%);
                pointer-events: none;
                z-index: -1;
            }

        .container {
            max-width: 1000px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
            animation: fadeInUp 0.6s ease-out;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .header {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 2rem;
            position: relative;
            padding: 0.5rem 0;
            flex-direction: column;
            gap: 1rem;
        }

        .header-left {
            position: absolute;
            left: 0;
            top: 0;
        }

        .header-center {
            text-align: center;
            width: 100%;
        }

            .header-center::before {
                content: '';
                width: 250px;
                height: 250px;
                background-image: url('/images/chatbotlogo.svg');
                background-size: contain;
                background-repeat: no-repeat;
                background-position: center;
                display: block;
                margin: auto;
                animation: float 3s ease-in-out infinite;
            }

        @@keyframes float {
            0%, 100% {
                transform: translateY(0px);
            }

            50% {
                transform: translateY(-10px);
            }
        }

        .header-center h1 {
            font-size: 2.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, #47682C 0%, #F7B32B 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 0.5rem;
            letter-spacing: -0.025em;
            text-shadow: 0 2px 4px rgba(71, 104, 44, 0.1);
        }

        .header-center p {
            color: #6b7280;
            font-size: 1rem;
            font-weight: 500;
        }

        .back-button {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.875rem 1.75rem;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(16px);
            color: #47682C;
            border: 2px solid rgba(71, 104, 44, 0.15);
            border-radius: 16px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 4px 20px rgba(71, 104, 44, 0.08);
            position: relative;
            overflow: hidden;
        }

            .back-button::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
                transition: left 0.5s;
            }

            .back-button:hover::before {
                left: 100%;
            }

            .back-button:hover {
                background: linear-gradient(135deg, #47682C 0%, #5a823a 100%);
                color: white;
                transform: translateY(-2px) scale(1.02);
                box-shadow: 0 8px 30px rgba(71, 104, 44, 0.25);
                border-color: #47682C;
            }

            .back-button:active {
                transform: translateY(-1px) scale(0.98);
            }

        .alert {
            padding: 1.25rem 1.5rem;
            border-radius: 16px;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-weight: 500;
            animation: slideInDown 0.4s ease-out;
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        @@keyframes slideInDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .alert-success {
            background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(16, 185, 129, 0.05) 100%);
            border: 2px solid #10b981;
            color: #065f46;
            box-shadow: 0 4px 20px rgba(16, 185, 129, 0.15);
        }

        .alert-error {
            background: linear-gradient(135deg, rgba(239, 68, 68, 0.1) 0%, rgba(239, 68, 68, 0.05) 100%);
            border: 2px solid #ef4444;
            color: #991b1b;
            box-shadow: 0 4px 20px rgba(239, 68, 68, 0.15);
        }

        .card {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(20px);
            border-radius: 20px;
            box-shadow: 0 8px 40px rgba(71, 104, 44, 0.08);
            padding: 20px;
            margin-bottom: 2rem;
            border: 1px solid rgba(255, 255, 255, 0.4);
            position: relative;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            animation: cardSlideIn 0.6s ease-out;
        }

        @@keyframes cardSlideIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, #47682C 0%, #F7B32B 50%, #196EF3 100%);
            border-radius: 16px 16px 0 0;
        }

        .card:hover {
            transform: translateY(-4px) scale(1.01);
            box-shadow: 0 20px 60px rgba(71, 104, 44, 0.15);
        }

        .card:nth-child(1) {
            animation-delay: 0.1s;
        }

        .card:nth-child(2) {
            animation-delay: 0.2s;
        }

        .card:nth-child(3) {
            animation-delay: 0.3s;
        }

        .card:nth-child(4) {
            animation-delay: 0.4s;
        }

        .card-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 2px solid rgba(71, 104, 44, 0.1);
        }

            .card-header h2 {
                font-size: 1.5rem;
                font-weight: 700;
                color: #47682C;
                letter-spacing: -0.025em;
            }

        .card-icon {
            width: 2rem;
            height: 2rem;
            color: #F7B32B;
        }

        .form-group {
            margin-bottom: 1.75rem;
            position: relative;
        }

            .form-group.has-error .form-input {
                border-color: #ef4444;
                box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.15);
            }

            .form-group.has-success .form-input {
                border-color: #10b981;
                box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.15);
            }

        .form-error {
            color: #ef4444;
            font-size: 0.875rem;
            margin-top: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            animation: slideInDown 0.3s ease-out;
        }

        .form-success {
            color: #10b981;
            font-size: 0.875rem;
            margin-top: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            animation: slideInDown 0.3s ease-out;
        }

        .form-label {
            display: block;
            font-weight: 600;
            color: #47682C;
            margin-bottom: 0.5rem;
            font-size: 0.95rem;
        }

        .form-input {
            width: 100%;
            padding: 1.125rem 1.5rem;
            border: 2px solid #e5e7eb;
            border-radius: 16px;
            font-size: 1rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(12px);
            position: relative;
        }

            .form-input::placeholder {
                color: #9ca3af;
                font-weight: 400;
            }

            .form-input:focus {
                outline: none;
                border-color: #47682C;
                box-shadow: 0 0 0 4px rgba(71, 104, 44, 0.15), 0 4px 20px rgba(71, 104, 44, 0.1);
                background: white;
                transform: translateY(-2px);
            }

            .form-input:invalid {
                border-color: #ef4444;
                box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.15);
            }

            .form-input:valid {
                border-color: #10b981;
            }

            .form-input:disabled {
                background: #f3f4f6;
                color: #9ca3af;
                cursor: not-allowed;
            }

        .btn {
            padding: 1.125rem 2.25rem;
            border: none;
            border-radius: 16px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: inline-flex;
            align-items: center;
            gap: 0.75rem;
            text-decoration: none;
            position: relative;
            overflow: hidden;
            min-height: 3.5rem;
            justify-content: center;
        }

            .btn::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
                transition: left 0.5s;
            }

            .btn:hover::before {
                left: 100%;
            }

        .btn-primary {
            background: linear-gradient(135deg, #47682C 0%, #5a823a 100%);
            color: white;
            box-shadow: 0 4px 12px rgba(71, 104, 44, 0.3);
        }

            .btn-primary:hover {
                transform: translateY(-3px) scale(1.02);
                box-shadow: 0 12px 35px rgba(71, 104, 44, 0.4);
            }

            .btn-primary:active {
                transform: translateY(-1px) scale(0.98);
            }

        .btn-danger {
            background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
            color: white;
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
        }

            .btn-danger:hover {
                transform: translateY(-3px) scale(1.02);
                box-shadow: 0 12px 35px rgba(239, 68, 68, 0.4);
            }

            .btn-danger:active {
                transform: translateY(-1px) scale(0.98);
            }

        .badge {
            display: inline-flex;
            padding: 0.5rem 1rem;
            border-radius: 9999px;
            font-size: 0.875rem;
            font-weight: 600;
            backdrop-filter: blur(8px);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .badge-oauth {
            background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
            color: #1e40af;
            border: 1px solid rgba(25, 110, 243, 0.2);
        }

        .badge-regular {
            background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
            color: #065f46;
            border: 1px solid rgba(71, 104, 44, 0.2);
        }

        .info-box {
            background: linear-gradient(135deg, rgba(247, 179, 43, 0.1) 0%, rgba(247, 179, 43, 0.05) 100%);
            border: 2px solid #F7B32B;
            border-radius: 12px;
            padding: 1.25rem;
            margin-bottom: 1.5rem;
            backdrop-filter: blur(8px);
            position: relative;
            overflow: hidden;
        }

            .info-box::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: linear-gradient(90deg, #F7B32B 0%, #f59e0b 100%);
            }

            .info-box p {
                color: #92400e;
                font-size: 0.9rem;
                line-height: 1.6;
            }

        .danger-zone {
            border: 2px solid #ef4444;
            background: linear-gradient(135deg, rgba(239, 68, 68, 0.08) 0%, rgba(220, 38, 38, 0.05) 100%);
            position: relative;
            overflow: hidden;
        }

            .danger-zone::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 4px;
                background: linear-gradient(90deg, #ef4444 0%, #dc2626 100%);
                border-radius: 20px 20px 0 0;
            }

            .danger-zone .card-header {
                border-bottom-color: rgba(239, 68, 68, 0.2);
            }

                .danger-zone .card-header h2 {
                    color: #dc2626;
                }

            .danger-zone .card-icon {
                color: #ef4444;
            }

        .user-info {
            display: flex;
            align-items: center;
            gap: 2rem;
            padding: 2rem;
            background: linear-gradient(135deg, rgba(71, 104, 44, 0.08) 0%, rgba(247, 179, 43, 0.08) 100%);
            border-radius: 20px;
            margin-bottom: 2rem;
            border: 2px solid rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(16px);
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }

            .user-info:hover {
                transform: translateY(-2px);
                box-shadow: 0 12px 40px rgba(71, 104, 44, 0.15);
            }

            .user-info::before {
                content: '';
                position: absolute;
                top: -50%;
                right: -50%;
                width: 200%;
                height: 200%;
                background: radial-gradient(circle, rgba(247, 179, 43, 0.1) 0%, transparent 70%);
                pointer-events: none;
            }

        .user-avatar {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: linear-gradient(135deg, #47682C 0%, #F7B32B 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            font-weight: 700;
            color: white;
            border: 4px solid rgba(255, 255, 255, 0.95);
            box-shadow: 0 8px 30px rgba(71, 104, 44, 0.25);
            position: relative;
            z-index: 1;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

            .user-avatar:hover {
                transform: scale(1.08) rotate(5deg);
                box-shadow: 0 15px 45px rgba(71, 104, 44, 0.4);
            }

            .user-avatar::after {
                content: '';
                position: absolute;
                top: -2px;
                left: -2px;
                right: -2px;
                bottom: -2px;
                background: linear-gradient(45deg, #47682C, #F7B32B, #196EF3, #FE395C);
                border-radius: 50%;
                z-index: -1;
                opacity: 0;
                transition: opacity 0.3s ease;
            }

            .user-avatar:hover::after {
                opacity: 1;
            }

        .user-details h3 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #47682C;
            margin-bottom: 0.25rem;
        }

        .user-details p {
            color: #6b7280;
            font-size: 0.95rem;
        }

        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(8px);
            animation: fadeIn 0.3s ease-out;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        @@keyframes fadeOut {
            from {
                opacity: 1;
            }

            to {
                opacity: 0;
            }
        }

        .modal-content {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(20px);
            margin: 10% auto;
            padding: 2.5rem;
            border-radius: 20px;
            max-width: 500px;
            box-shadow: 0 25px 80px rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.3);
            animation: slideInUp 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        @@keyframes slideInUp {
            from {
                opacity: 0;
                transform: translateY(30px) scale(0.95);
            }

            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

            .modal-header h3 {
                font-size: 1.5rem;
                font-weight: 700;
                color: #dc2626;
            }

        .close-modal {
            background: none;
            border: none;
            font-size: 2rem;
            color: #6b7280;
            cursor: pointer;
            line-height: 1;
        }

            .close-modal:hover {
                color: #111827;
            }

        /* Preferences Modal Styles */
        .preferences-modal-content {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(20px);
            margin: 2% auto;
            padding: 0;
            border-radius: 24px;
            max-width: 900px;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 32px 100px rgba(71, 104, 44, 0.25);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        .preferences-modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 2.5rem;
            border-bottom: 2px solid rgba(71, 104, 44, 0.1);
            background: linear-gradient(135deg, rgba(71, 104, 44, 0.08) 0%, rgba(247, 179, 43, 0.08) 100%);
            border-radius: 24px 24px 0 0;
            position: relative;
            overflow: hidden;
        }

            .preferences-modal-header::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 4px;
                background: linear-gradient(90deg, #47682C 0%, #F7B32B 50%, #196EF3 100%);
            }

        .preferences-header-info {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .preferences-header-icon {
            width: 2.5rem;
            height: 2.5rem;
            color: #47682C;
        }

        .preferences-header-info h3 {
            font-size: 1.75rem;
            font-weight: 700;
            color: #47682C;
            margin: 0;
            letter-spacing: -0.025em;
        }

        .preferences-header-info p {
            color: #6b7280;
            font-size: 0.95rem;
            margin: 0.25rem 0 0 0;
        }

        .preferences-section {
            padding: 2.5rem;
            border-bottom: 1px solid rgba(71, 104, 44, 0.1);
            position: relative;
        }

            .preferences-section:last-of-type {
                border-bottom: none;
            }

        /* Section-specific styling */
        .food-types-section {
            background: linear-gradient(135deg, rgba(71, 104, 44, 0.02) 0%, rgba(247, 179, 43, 0.02) 100%);
            border-left: 4px solid #47682C;
        }

        .dietary-restrictions-section {
            background: linear-gradient(135deg, rgba(247, 179, 43, 0.02) 0%, rgba(25, 110, 243, 0.02) 100%);
            border-left: 4px solid #F7B32B;
        }

        .health-conditions-section {
            background: linear-gradient(135deg, rgba(25, 110, 243, 0.02) 0%, rgba(254, 57, 92, 0.02) 100%);
            border-left: 4px solid #196EF3;
        }

        .location-budget-section {
            background: linear-gradient(135deg, rgba(254, 57, 92, 0.02) 0%, rgba(71, 104, 44, 0.02) 100%);
            border-left: 4px solid #FE395C;
        }

        .section-header {
            display: flex;
            align-items: flex-start;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .section-icon-container {
            flex-shrink: 0;
            width: 3rem;
            height: 3rem;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255, 255, 255, 0.8);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .section-icon {
            width: 1.5rem;
            height: 1.5rem;
        }

        .food-types-section .section-icon {
            color: #47682C;
        }

        .dietary-restrictions-section .section-icon {
            color: #F7B32B;
        }

        .health-conditions-section .section-icon {
            color: #196EF3;
        }

        .location-budget-section .section-icon {
            color: #FE395C;
        }

        .section-title {
            flex: 1;
        }

            .section-title h4 {
                font-size: 1.5rem;
                font-weight: 700;
                color: #47682C;
                margin: 0 0 0.5rem 0;
                letter-spacing: -0.025em;
            }

            .section-title p {
                color: #6b7280;
                font-size: 0.95rem;
                margin: 0;
                line-height: 1.5;
            }

        /* Section completion states */
        .section-completed {
            position: relative;
        }

            .section-completed::after {
                content: '✓';
                position: absolute;
                top: 0;
                right: 0;
                width: 2rem;
                height: 2rem;
                background: #10b981;
                color: white;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: bold;
                font-size: 0.875rem;
                box-shadow: 0 2px 8px rgba(16, 185, 129, 0.3);
            }

        .btn-disabled {
            background: #f3f4f6 !important;
            color: #9ca3af !important;
            border-color: #d1d5db !important;
            cursor: not-allowed !important;
            transform: none !important;
            box-shadow: none !important;
        }

            .btn-disabled:hover {
                background: #f3f4f6 !important;
                color: #9ca3af !important;
                border-color: #d1d5db !important;
                transform: none !important;
                box-shadow: none !important;
            }

        /* Preferences Buttons Grid */
        .preferences-buttons-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .preference-btn {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1.5rem;
            border: 2px solid rgba(71, 104, 44, 0.1);
            border-radius: 16px;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(16px);
            cursor: pointer;
            transition: all 0.3s ease;
            text-align: left;
            width: 100%;
            position: relative;
            overflow: hidden;
        }

            .preference-btn::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, transparent 100%);
                opacity: 0;
                transition: opacity 0.3s ease;
            }

            .preference-btn:hover {
                transform: translateY(-3px);
                box-shadow: 0 12px 35px rgba(71, 104, 44, 0.2);
                border-color: rgba(71, 104, 44, 0.3);
            }

                .preference-btn:hover::before {
                    opacity: 1;
                }

        .btn-icon {
            flex-shrink: 0;
            width: 3.5rem;
            height: 3.5rem;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255, 255, 255, 0.9);
            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
            position: relative;
            z-index: 1;
        }

            .btn-icon svg {
                width: 1.75rem;
                height: 1.75rem;
            }

        .btn-content {
            flex: 1;
        }

            .btn-content h4 {
                font-size: 1.125rem;
                font-weight: 700;
                color: #47682C;
                margin: 0 0 0.25rem 0;
                letter-spacing: -0.025em;
            }

            .btn-content p {
                color: #6b7280;
                font-size: 0.875rem;
                margin: 0;
                line-height: 1.4;
                font-weight: 500;
            }

        /* Button-specific styling */
        .food-types-btn {
            border-color: rgba(71, 104, 44, 0.2);
            background: linear-gradient(135deg, rgba(71, 104, 44, 0.05) 0%, rgba(247, 179, 43, 0.05) 100%);
        }

            .food-types-btn:hover {
                border-color: #47682C;
                box-shadow: 0 8px 25px rgba(71, 104, 44, 0.2);
            }

            .food-types-btn .btn-icon {
                background: rgba(71, 104, 44, 0.1);
            }

                .food-types-btn .btn-icon svg {
                    color: #47682C;
                }

        .dietary-restrictions-btn {
            border-color: rgba(247, 179, 43, 0.2);
            background: linear-gradient(135deg, rgba(247, 179, 43, 0.05) 0%, rgba(25, 110, 243, 0.05) 100%);
        }

            .dietary-restrictions-btn:hover {
                border-color: #F7B32B;
                box-shadow: 0 8px 25px rgba(247, 179, 43, 0.2);
            }

            .dietary-restrictions-btn .btn-icon {
                background: rgba(247, 179, 43, 0.1);
            }

                .dietary-restrictions-btn .btn-icon svg {
                    color: #F7B32B;
                }

        .health-conditions-btn {
            border-color: rgba(25, 110, 243, 0.2);
            background: linear-gradient(135deg, rgba(25, 110, 243, 0.05) 0%, rgba(254, 57, 92, 0.05) 100%);
        }

            .health-conditions-btn:hover {
                border-color: #196EF3;
                box-shadow: 0 8px 25px rgba(25, 110, 243, 0.2);
            }

            .health-conditions-btn .btn-icon {
                background: rgba(25, 110, 243, 0.1);
            }

                .health-conditions-btn .btn-icon svg {
                    color: #196EF3;
                }

        .location-budget-btn {
            border-color: rgba(254, 57, 92, 0.2);
            background: linear-gradient(135deg, rgba(254, 57, 92, 0.05) 0%, rgba(71, 104, 44, 0.05) 100%);
        }

            .location-budget-btn:hover {
                border-color: #FE395C;
                box-shadow: 0 8px 25px rgba(254, 57, 92, 0.2);
            }

            .location-budget-btn .btn-icon {
                background: rgba(254, 57, 92, 0.1);
            }

                .location-budget-btn .btn-icon svg {
                    color: #FE395C;
                }

        /* Selection indicators */
        .selection-indicator {
            position: absolute;
            top: -0.5rem;
            right: -0.5rem;
            background: #10b981;
            color: white;
            border-radius: 50%;
            width: 1.5rem;
            height: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            font-weight: 600;
            box-shadow: 0 2px 8px rgba(16, 185, 129, 0.3);
            z-index: 10;
        }

        .preference-btn {
            position: relative;
        }

        .preferences-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 0.75rem;
            max-height: 300px;
            overflow-y: auto;
            padding: 0.5rem;
            border: 2px solid rgba(71, 104, 44, 0.1);
            border-radius: 12px;
            background: rgba(71, 104, 44, 0.02);
        }

        /* Search input styles */
        #foodTypesSearch:focus {
            border-color: #47682C;
            box-shadow: 0 0 0 3px rgba(71, 104, 44, 0.1);
            background: rgba(255, 255, 255, 0.95);
        }

        #foodTypesSearch:hover {
            border-color: #9ca3af;
            background: rgba(255, 255, 255, 0.95);
        }

        #clearSearchBtn:hover {
            color: #374151;
            background: rgba(0, 0, 0, 0.05);
            border-radius: 50%;
        }

        .no-results-message {
            animation: fadeIn 0.3s ease-in-out;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .preferences-list {
            max-height: 300px;
            overflow-y: auto;
            padding: 0.5rem;
            border: 2px solid rgba(71, 104, 44, 0.1);
            border-radius: 12px;
            background: rgba(71, 104, 44, 0.02);
        }

        .preference-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.875rem 1rem;
            border: 2px solid rgba(71, 104, 44, 0.1);
            border-radius: 10px;
            background: white;
            transition: all 0.2s;
            margin-bottom: 0.5rem;
        }

            .preference-item:hover {
                border-color: #47682C;
                box-shadow: 0 2px 8px rgba(71, 104, 44, 0.1);
                transform: translateY(-1px);
            }

            .preference-item.selected {
                border-color: #47682C;
                background: rgba(71, 104, 44, 0.05);
            }

        /* Section-specific preference item styling */
        .food-types-section .preference-item {
            border-color: rgba(71, 104, 44, 0.15);
        }

            .food-types-section .preference-item:hover {
                border-color: #47682C;
                box-shadow: 0 2px 8px rgba(71, 104, 44, 0.15);
            }

            .food-types-section .preference-item.selected {
                border-color: #47682C;
                background: rgba(71, 104, 44, 0.08);
            }

        .dietary-restrictions-section .preference-item {
            border-color: rgba(247, 179, 43, 0.15);
        }

            .dietary-restrictions-section .preference-item:hover {
                border-color: #F7B32B;
                box-shadow: 0 2px 8px rgba(247, 179, 43, 0.15);
            }

            .dietary-restrictions-section .preference-item.selected {
                border-color: #F7B32B;
                background: rgba(247, 179, 43, 0.08);
            }

        .health-conditions-section .preference-item {
            border-color: rgba(25, 110, 243, 0.15);
        }

            .health-conditions-section .preference-item:hover {
                border-color: #196EF3;
                box-shadow: 0 2px 8px rgba(25, 110, 243, 0.15);
            }

            .health-conditions-section .preference-item.selected {
                border-color: #196EF3;
                background: rgba(25, 110, 243, 0.08);
            }

        .location-budget-section .preference-item {
            border-color: rgba(254, 57, 92, 0.15);
        }

            .location-budget-section .preference-item:hover {
                border-color: #FE395C;
                box-shadow: 0 2px 8px rgba(254, 57, 92, 0.15);
            }

            .location-budget-section .preference-item.selected {
                border-color: #FE395C;
                background: rgba(254, 57, 92, 0.08);
            }

        .preference-checkbox {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            flex: 1;
        }

            .preference-checkbox input[type="checkbox"] {
                width: 1.25rem;
                height: 1.25rem;
                accent-color: #47682C;
                cursor: pointer;
            }

            .preference-checkbox label {
                font-weight: 500;
                color: #374151;
                cursor: pointer;
                margin: 0;
            }

        .preference-level {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            opacity: 0;
            transition: opacity 0.2s;
        }

        .preference-item.selected .preference-level {
            opacity: 1;
        }

        .preference-level label {
            font-size: 0.875rem;
            color: #6b7280;
            font-weight: 500;
        }

        .preference-level select {
            padding: 0.375rem 0.75rem;
            border: 2px solid #e5e7eb;
            border-radius: 6px;
            font-size: 0.875rem;
            background: white;
            color: #374151;
            min-width: 4rem;
        }

            .preference-level select:focus {
                outline: none;
                border-color: #47682C;
                box-shadow: 0 0 0 3px rgba(71, 104, 44, 0.1);
            }

        .preferences-form-fields {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }

        .preferences-modal-actions {
            display: flex;
            justify-content: flex-end;
            gap: 1rem;
            padding: 2.5rem;
            background: linear-gradient(135deg, rgba(71, 104, 44, 0.05) 0%, rgba(247, 179, 43, 0.05) 100%);
            border-radius: 0 0 24px 24px;
        }

        .btn-secondary {
            background: #f3f4f6;
            color: #374151;
            border: 2px solid #d1d5db;
        }

            .btn-secondary:hover {
                background: #e5e7eb;
                border-color: #9ca3af;
            }

        .loading-placeholder {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            color: #6b7280;
        }

        .loading-spinner {
            width: 2rem;
            height: 2rem;
            border: 3px solid #e5e7eb;
            border-top: 3px solid #47682C;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-bottom: 1rem;
        }

        @@keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        /* Enhanced Mobile Responsiveness */
        @@media (max-width: 1024px) {
            .container {
                max-width: 95%;
                padding: 0 1rem;
            }

            .card {
                padding: 2rem;
            }
        }

        @@media (max-width: 768px) {
            body {
                padding: 1rem 0.75rem;
            }

            .container {
                max-width: 100%;
            }

            .header {
                flex-direction: column;
                gap: 1.5rem;
                text-align: center;
                margin-bottom: 2rem;
                padding: 1rem 0;
            }

            .header-left {
                flex: none;
                order: 2;
            }

            .header-center {
                flex: none;
                order: 1;
            }

                .header-center h1 {
                    font-size: 2.25rem;
                    margin-bottom: 0.75rem;
                }

                .header-center p {
                    font-size: 1.1rem;
                }

            .card {
                padding: 1.75rem;
                margin-bottom: 1.5rem;
            }

            .user-info {
                flex-direction: column;
                text-align: center;
                gap: 1.5rem;
                padding: 1.75rem;
            }

            .user-avatar {
                width: 90px;
                height: 90px;
                font-size: 2.25rem;
            }

            .user-details h3 {
                font-size: 1.375rem;
            }

            .form-input {
                padding: 1rem 1.25rem;
                font-size: 1rem;
            }

            .btn {
                padding: 1rem 1.75rem;
                min-height: 3.25rem;
                font-size: 0.95rem;
            }

            .preferences-modal-content {
                margin: 2% auto;
                max-width: 98%;
                max-height: 96vh;
                border-radius: 20px;
            }

            .preferences-modal-header {
                padding: 1.75rem;
                flex-direction: column;
                gap: 1rem;
                text-align: center;
            }

            .preferences-header-info {
                flex-direction: column;
                gap: 0.75rem;
            }

                .preferences-header-info h3 {
                    font-size: 1.5rem;
                }

            .preferences-section {
                padding: 1.75rem;
            }

            .section-header {
                flex-direction: column;
                align-items: center;
                text-align: center;
                gap: 1rem;
            }

            .section-icon-container {
                width: 2.75rem;
                height: 2.75rem;
            }

            .section-title h4 {
                font-size: 1.375rem;
            }

            .preferences-grid {
                grid-template-columns: 1fr;
                max-height: 300px;
                gap: 0.5rem;
            }

            .preferences-form-fields {
                grid-template-columns: 1fr;
                gap: 1.25rem;
            }

            .preferences-modal-actions {
                flex-direction: column;
                padding: 1.75rem;
                gap: 1rem;
            }

                .preferences-modal-actions .btn {
                    width: 100%;
                    justify-content: center;
                    min-height: 3.5rem;
                }

            .preferences-buttons-grid {
                grid-template-columns: 1fr;
                gap: 1rem;
            }

            .preference-btn {
                padding: 1.25rem;
                flex-direction: column;
                text-align: center;
                gap: 1rem;
            }

            .btn-icon {
                width: 3rem;
                height: 3rem;
            }

            .btn-content h4 {
                font-size: 1.125rem;
            }

            .btn-content p {
                font-size: 0.9rem;
            }

            .modal-content {
                margin: 5% auto;
                max-width: 95%;
                padding: 1.5rem;
            }
        }

        @@media (max-width: 480px) {
            .header-center h1 {
                font-size: 1.875rem;
            }

            .card {
                padding: 1.5rem;
            }

            .user-info {
                padding: 1.5rem;
            }

            .user-avatar {
                width: 80px;
                height: 80px;
                font-size: 2rem;
            }

            .form-input {
                padding: 0.875rem 1rem;
            }

            .btn {
                padding: 0.875rem 1.5rem;
                min-height: 3rem;
            }

            .preferences-modal-content {
                margin: 1% auto;
                max-width: 100%;
                max-height: 98vh;
            }

            .preferences-modal-header {
                padding: 1.5rem;
            }

            .preferences-section {
                padding: 1.5rem;
            }

            .preferences-modal-actions {
                padding: 1.5rem;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="header-left">
                <a href="/Home/Chat" class="back-button">
                    <svg style="width: 1.25rem; height: 1.25rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path>
                    </svg>
                    Back to Chat
                </a>
            </div>
            <div class="header-center">
                <h1>Account Settings</h1>
                <p>Manage your FoodieSaur account and preferences</p>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                <svg style="width: 1.5rem; height: 1.5rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-error">
                <svg style="width: 1.5rem; height: 1.5rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                @TempData["ErrorMessage"]
            </div>
        }

        <!-- User Info Card -->
        <div class="card">
            <div class="user-info">
                <div class="user-avatar">
                    @((Model?.Name ?? "U").Substring(0, 1).ToUpper())
                </div>
                <div class="user-details">
                    <h3>@Model?.Name</h3>
                    <p>@Model?.Email</p>
                    @if (!string.IsNullOrEmpty(Model?.Provider))
                    {
                        <span class="badge badge-oauth">@Model.Provider.ToUpper() Account</span>
                    }
                    else
                    {
                        <span class="badge badge-regular">Regular Account</span>
                    }
                </div>
            </div>
        </div>

        <!-- Profile Information Card -->
        <div class="card">
            <div class="card-header">
                <svg class="card-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
                <h2>Profile Information</h2>
            </div>

            <form method="post" action="/Account/UpdateProfile" id="profileForm">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label" for="name">Full Name</label>
                    <input type="text" id="name" name="name" class="form-input" value="@Model?.Name" required>
                </div>

                <div class="form-group">
                    <label class="form-label" for="email">Email Address</label>
                    <input type="email" id="email" name="email" class="form-input" value="@Model?.Email" required>
                </div>

                <button type="submit" class="btn btn-primary">
                    <svg style="width: 1.25rem; height: 1.25rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    Save Changes
                </button>
            </form>
        </div>

        <!-- Change Password Card -->
        @if (string.IsNullOrEmpty(Model?.Provider))
        {
            <div class="card">
                <div class="card-header">
                    <svg class="card-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                    </svg>
                    <h2>Change Password</h2>
                </div>

                <form method="post" action="/Account/ChangePassword" id="passwordForm">
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <label class="form-label" for="currentPassword">Current Password</label>
                        <input type="password" id="currentPassword" name="currentPassword" class="form-input" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="newPassword">New Password</label>
                        <input type="password" id="newPassword" name="newPassword" class="form-input" minlength="6" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="confirmPassword">Confirm New Password</label>
                        <input type="password" id="confirmPassword" name="confirmPassword" class="form-input" minlength="6" required>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <svg style="width: 1.25rem; height: 1.25rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        Update Password
                    </button>
                </form>
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-header">
                    <svg class="card-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                    </svg>
                    <h2>Password</h2>
                </div>

                <div class="info-box">
                    <p>🔒 Your account is linked with <strong>@Model.Provider.ToUpper()</strong>. Password management is handled through your @Model.Provider account.</p>
                </div>
            </div>
        }

        <!-- Account Actions Card -->
        <div class="card">
            <div class="card-header">
                <svg class="card-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <h2>Edit Preferences</h2>
            </div>

            <div class="preferences-buttons-grid">
                <button type="button" class="preference-btn food-types-btn" onclick="openSectionModal('foodTypes')">
                    <div class="btn-icon">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                        </svg>
                    </div>
                    <div class="btn-content">
                        <h4>Food Types</h4>
                        <p>Manage your favorite cuisines</p>
                    </div>
                </button>

                <button type="button" class="preference-btn dietary-restrictions-btn" onclick="openSectionModal('dietaryRestrictions')">
                    <div class="btn-icon">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <div class="btn-content">
