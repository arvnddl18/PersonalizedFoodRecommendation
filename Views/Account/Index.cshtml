    <script>
        // Enhanced form validation and user feedback
        document.addEventListener('DOMContentLoaded', function() {
            initializeFormValidation();
            initializeAnimations();
            initializeAccessibility();
        });

        function initializeFormValidation() {
            const forms = document.querySelectorAll('form');
            forms.forEach(form => {
                const inputs = form.querySelectorAll('input[required], select[required]');
                inputs.forEach(input => {
                    input.addEventListener('blur', validateField);
                    input.addEventListener('input', clearFieldError);
                });
            });
        }

        function validateField(event) {
            const field = event.target;
            const formGroup = field.closest('.form-group');
            const value = field.value.trim();

            // Remove existing validation classes
            formGroup.classList.remove('has-error', 'has-success');
            const existingError = formGroup.querySelector('.form-error');
            const existingSuccess = formGroup.querySelector('.form-success');
            if (existingError) existingError.remove();
            if (existingSuccess) existingSuccess.remove();

            if (!value) {
                showFieldError(formGroup, 'This field is required');
                return false;
            }

            // Email validation
            if (field.type === 'email' && !isValidEmail(value)) {
                showFieldError(formGroup, 'Please enter a valid email address');
                return false;
            }

            // Password validation
            if (field.type === 'password' && field.name === 'newPassword') {
                if (value.length < 6) {
                    showFieldError(formGroup, 'Password must be at least 6 characters');
                    return false;
                }
            }

            // Confirm password validation
            if (field.name === 'confirmPassword') {
                const newPassword = document.querySelector('input[name="newPassword"]');
                if (newPassword && value !== newPassword.value) {
                    showFieldError(formGroup, 'Passwords do not match');
                    return false;
                }
            }

            showFieldSuccess(formGroup, 'Looks good!');
            return true;
        }

        function clearFieldError(event) {
            const field = event.target;
            const formGroup = field.closest('.form-group');
            formGroup.classList.remove('has-error');
            const existingError = formGroup.querySelector('.form-error');
            if (existingError) existingError.remove();
        }

        function showFieldError(formGroup, message) {
            formGroup.classList.add('has-error');
            const errorDiv = document.createElement('div');
            errorDiv.className = 'form-error';
            errorDiv.innerHTML = `
                <svg style="width: 1rem; height: 1rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                ${message}
            `;
            formGroup.appendChild(errorDiv);
        }

        function showFieldSuccess(formGroup, message) {
            formGroup.classList.add('has-success');
            const successDiv = document.createElement('div');
            successDiv.className = 'form-success';
            successDiv.innerHTML = `
                <svg style="width: 1rem; height: 1rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                ${message}
            `;
            formGroup.appendChild(successDiv);
        }

        function isValidEmail(email) {
            // Simple email validation without at symbols
            if (!email || typeof email !== 'string') return false;

            const atSymbol = String.fromCharCode(64); // at symbol
            const parts = email.split(atSymbol);
            if (parts.length !== 2) return false;

            const [local, domain] = parts;
            if (!local || !domain) return false;

            const domainParts = domain.split('.');
            if (domainParts.length < 2) return false;

            return local.length > 0 && domain.length > 0;
        }

        function initializeAnimations() {
            // Add staggered animation to cards
            const cards = document.querySelectorAll('.card');
            cards.forEach((card, index) => {
                card.style.animationDelay = `${index * 0.1}s`;
            });

            // Add hover effects to interactive elements
            const interactiveElements = document.querySelectorAll('.btn, .preference-btn, .back-button');
            interactiveElements.forEach(element => {
                element.addEventListener('mouseenter', function() {
                    this.style.transform = 'translateY(-2px) scale(1.02)';
                });
                element.addEventListener('mouseleave', function() {
                    this.style.transform = 'translateY(0) scale(1)';
                });
            });
        }

        function initializeAccessibility() {
            // Add keyboard navigation support
            const focusableElements = document.querySelectorAll('button, input, select, a[href]');
            focusableElements.forEach(element => {
                element.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter' || e.key === ' ') {
                        if (this.tagName === 'BUTTON' || this.tagName === 'A') {
                            e.preventDefault();
                            this.click();
                        }
                    }
                });
            });

            // Add ARIA labels for better screen reader support
            const buttons = document.querySelectorAll('.btn');
            buttons.forEach(button => {
                if (!button.getAttribute('aria-label')) {
                    button.setAttribute('aria-label', button.textContent.trim());
                }
            });
        }

        function openDeleteModal() {
            const modal = document.getElementById('deleteModal');
            modal.style.display = 'block';
            modal.style.animation = 'fadeIn 0.3s ease-out';

            // Focus on the email input for better UX
            setTimeout(() => {
                const emailInput = document.getElementById('confirmEmail');
                if (emailInput) emailInput.focus();
            }, 100);
        }

        function closeDeleteModal() {
            const modal = document.getElementById('deleteModal');
            modal.style.animation = 'fadeOut 0.3s ease-out';
            setTimeout(() => {
                modal.style.display = 'none';
            }, 300);
        }

        // Section-specific Modal Functions
        function openSectionModal(sectionType) {
            console.log('Opening modal for section:', sectionType);
            
            const modalId = sectionType + 'Modal';
            const modal = document.getElementById(modalId);
            
            if (modal) {
                modal.style.display = 'block';
                modal.style.animation = 'fadeIn 0.3s ease-out';
                console.log('Modal displayed:', modalId);

                // Load data for the specific section
                loadSectionData(sectionType);
            } else {
                console.error('Modal not found:', modalId);
            }
        }


        function closeModal(modalId) {
            const modal = document.getElementById(modalId);
            if (modal) {
                modal.style.animation = 'fadeOut 0.3s ease-out';
                setTimeout(() => {
                    modal.style.display = 'none';
                }, 300);
            }
        }

        function closePreferencesModal() {
            closeModal('preferencesModal');
        }

        async function loadSectionData(sectionType) {
            console.log('Loading section data for:', sectionType);
            try {
                switch(sectionType) {
                    case 'foodTypes':
                        console.log('Loading food types...');
                        showLoadingState('foodTypesGrid', 'Loading food types...');
                        await loadFoodTypes();
                        break;
                    case 'dietaryRestrictions':
                        console.log('Loading dietary restrictions...');
                        showLoadingState('dietaryRestrictionsList', 'Loading dietary restrictions...');
                        await loadDietaryRestrictions();
                        break;
                    case 'healthConditions':
                        console.log('Loading health conditions...');
                        showLoadingState('healthConditionsList', 'Loading health conditions...');
                        await loadHealthConditions();
                        break;
                    case 'locationBudget':
                        console.log('Location & Budget section - no dynamic loading needed');
                        // Location & Budget doesn't need dynamic loading
                        break;
                }

                // Load current preferences for the section
                console.log('Loading current preferences...');
                await loadCurrentPreferences();

                // Add event listeners for location and budget fields
                if (sectionType === 'locationBudget') {
                    const locationField = document.getElementById('preferredLocation');
                    const budgetField = document.getElementById('priceRange');

                    if (locationField) {
                        locationField.addEventListener('input', updateButtonIndicators);
                    }
                    if (budgetField) {
                        budgetField.addEventListener('change', updateButtonIndicators);
                    }
                }

                // Update button indicators after loading
                updateButtonIndicators();
                console.log('Section data loading completed for:', sectionType);
            } catch (error) {
                console.error(`Error loading ${sectionType}:`, error);
                const containerId = sectionType === 'foodTypes' ? 'foodTypesGrid' : 
                                  sectionType === 'dietaryRestrictions' ? 'dietaryRestrictionsList' : 
                                  sectionType === 'healthConditions' ? 'healthConditionsList' : '';
                if (containerId) {
                    showSectionError(containerId, `Failed to load ${sectionType}`);
                }
            }
        }

        // Load user preferences data
        async function loadUserPreferences() {
            try {
                // Show loading states for each section
                showLoadingState('foodTypesGrid', 'Loading food types...');
                showLoadingState('dietaryRestrictionsList', 'Loading dietary restrictions...');
                showLoadingState('healthConditionsList', 'Loading health conditions...');

                // Load all sections in parallel for better performance
                const [foodTypesResult, dietaryResult, healthResult, currentPrefsResult] = await Promise.allSettled([
                    loadFoodTypes(),
                    loadDietaryRestrictions(),
                    loadHealthConditions(),
                    loadCurrentPreferences()
                ]);

                // Handle any failed sections
                if (foodTypesResult.status === 'rejected') {
                    showSectionError('foodTypesGrid', 'Failed to load food types');
                }
                if (dietaryResult.status === 'rejected') {
                    showSectionError('dietaryRestrictionsList', 'Failed to load dietary restrictions');
                }
                if (healthResult.status === 'rejected') {
                    showSectionError('healthConditionsList', 'Failed to load health conditions');
                }
                if (currentPrefsResult.status === 'rejected') {
                    console.warn('Failed to load current preferences, using defaults');
                }

            } catch (error) {
                console.error('Error loading preferences:', error);
                showErrorState('Failed to load preferences. Please try again.');
            }
        }

        function showLoadingState(containerId, message = 'Loading...') {
            const container = document.getElementById(containerId);
            container.innerHTML = `
                <div class="loading-placeholder">
                    <div class="loading-spinner"></div>
                    <p>${message}</p>
                </div>
            `;
        }

        function showSectionError(containerId, message) {
            const container = document.getElementById(containerId);
            container.innerHTML = `
                <div class="loading-placeholder">
                    <p style="color: #ef4444;">${message}</p>
                    <button onclick="retryLoadSection('${containerId}')" class="btn btn-primary" style="margin-top: 1rem; padding: 0.5rem 1rem; font-size: 0.875rem;">
                        Retry
                    </button>
                </div>
            `;
        }

        function showErrorState(message) {
            const containers = ['foodTypesGrid', 'dietaryRestrictionsList', 'healthConditionsList'];
            containers.forEach(id => {
                const container = document.getElementById(id);
                container.innerHTML = `
                    <div class="loading-placeholder">
                        <p style="color: #ef4444;">${message}</p>
                    </div>
                `;
            });
        }

        async function retryLoadSection(containerId) {
            showLoadingState(containerId, 'Retrying...');

            try {
                if (containerId === 'foodTypesGrid') {
                    await loadFoodTypes();
                } else if (containerId === 'dietaryRestrictionsList') {
                    await loadDietaryRestrictions();
                } else if (containerId === 'healthConditionsList') {
                    await loadHealthConditions();
                }
            } catch (error) {
                showSectionError(containerId, 'Failed to load. Please try again.');
            }
        }

        async function loadFoodTypes() {
            try {
                console.log('Loading food types...');
                const response = await fetch('/Account/GetFoodTypes');
                console.log('Response status:', response.status);
                
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                
                const data = await response.json();
                console.log('Food types data:', data);

                const container = document.getElementById('foodTypesGrid');
                container.innerHTML = '';

                if (data && data.length > 0) {
                    data.forEach((foodType, index) => {
                        const item = createFoodTypeItem(foodType, index);
                        container.appendChild(item);
                    });
                    console.log(`Loaded ${data.length} food types`);
                } else {
                    container.innerHTML = `
                        <div class="loading-placeholder">
                            <p style="color: #6b7280;">No food types available</p>
                        </div>
                    `;
                }
            } catch (error) {
                console.error('Error loading food types:', error);
                document.getElementById('foodTypesGrid').innerHTML = `
                    <div class="loading-placeholder">
                        <p style="color: #ef4444;">Failed to load food types: ${error.message}</p>
                        <button onclick="loadFoodTypes()" class="btn btn-primary" style="margin-top: 1rem; padding: 0.5rem 1rem; font-size: 0.875rem;">
                            Retry
                        </button>
                    </div>
                `;
            }
        }

        async function loadDietaryRestrictions() {
            try {
                const response = await fetch('/Account/GetDietaryRestrictions');
                const data = await response.json();

                const container = document.getElementById('dietaryRestrictionsList');
                container.innerHTML = '';

                data.forEach((restriction, index) => {
                    const item = createDietaryRestrictionItem(restriction, index);
                    container.appendChild(item);
                });
            } catch (error) {
                console.error('Error loading dietary restrictions:', error);
                document.getElementById('dietaryRestrictionsList').innerHTML = `
                    <div class="loading-placeholder">
                        <p style="color: #ef4444;">Failed to load dietary restrictions</p>
                    </div>
                `;
            }
        }

        async function loadHealthConditions() {
            try {
                const response = await fetch('/Account/GetHealthConditions');
                const data = await response.json();

                const container = document.getElementById('healthConditionsList');
                container.innerHTML = '';

                data.forEach((condition, index) => {
                    const item = createHealthConditionItem(condition, index);
                    container.appendChild(item);
                });
            } catch (error) {
                console.error('Error loading health conditions:', error);
                document.getElementById('healthConditionsList').innerHTML = `
                    <div class="loading-placeholder">
                        <p style="color: #ef4444;">Failed to load health conditions</p>
                    </div>
                `;
            }
        }

        async function loadCurrentPreferences() {
            try {
                const response = await fetch('/Account/GetCurrentPreferences');
                const data = await response.json();

                // Set location and budget (only if elements exist)
                const locationInput = document.getElementById('preferredLocation');
                const priceRangeSelect = document.getElementById('priceRange');
                
                if (locationInput && data.preferredLocation) {
                    locationInput.value = data.preferredLocation;
                }
                if (priceRangeSelect && data.priceRange) {
                    priceRangeSelect.value = data.priceRange;
                }

                // Set selected food types (only if food types grid exists)
                const foodTypesGrid = document.getElementById('foodTypesGrid');
                if (foodTypesGrid && data.selectedFoodTypes && data.selectedFoodTypes.length > 0) {
                    data.selectedFoodTypes.forEach(id => {
                        const checkbox = document.querySelector(`input[data-food-type-id="${id}"]`);
                        if (checkbox) {
                            checkbox.checked = true;
                            checkbox.closest('.preference-item').classList.add('selected');
                        }
                    });
                }

                // Set selected dietary restrictions (only if dietary restrictions list exists)
                const dietaryList = document.getElementById('dietaryRestrictionsList');
                if (dietaryList && data.selectedDietaryRestrictions && data.selectedDietaryRestrictions.length > 0) {
                    data.selectedDietaryRestrictions.forEach(item => {
                        const checkbox = document.querySelector(`input[data-dietary-id="${item.id}"]`);
                        if (checkbox) {
                            checkbox.checked = true;
                            checkbox.closest('.preference-item').classList.add('selected');
                            const levelSelect = checkbox.closest('.preference-item').querySelector('.preference-level select');
                            if (levelSelect) {
                                levelSelect.value = item.importanceLevel || 1;
                            }
                        }
                    });
                }

                // Set selected health conditions (only if health conditions list exists)
                const healthList = document.getElementById('healthConditionsList');
                if (healthList && data.selectedHealthConditions && data.selectedHealthConditions.length > 0) {
                    data.selectedHealthConditions.forEach(item => {
                        const checkbox = document.querySelector(`input[data-health-id="${item.id}"]`);
                        if (checkbox) {
                            checkbox.checked = true;
                            checkbox.closest('.preference-item').classList.add('selected');
                            const levelSelect = checkbox.closest('.preference-item').querySelector('.preference-level select');
                            if (levelSelect) {
                                levelSelect.value = item.severityLevel || 1;
                            }
                        }
                    });
                }

                // Update section validation after loading preferences (only if elements exist)
                updateSectionValidation();

                // Update button indicators to show current selections (only if function exists)
                if (typeof updateButtonIndicators === 'function') {
                    updateButtonIndicators();
                }
            } catch (error) {
                console.error('Error loading current preferences:', error);
            }
        }

        function createFoodTypeItem(foodType, index) {
            const item = document.createElement('div');
            item.className = 'preference-item';
            item.setAttribute('data-food-name', foodType.name.toLowerCase());
            item.innerHTML = `
                <div class="preference-checkbox">
                    <input type="checkbox"
                           data-food-type-id="${foodType.foodTypeId}"
                           name="FoodTypes[${index}].IsSelected"
                           onchange="togglePreferenceItem(this)"
                           id="food-${foodType.foodTypeId}">
                    <label for="food-${foodType.foodTypeId}">${foodType.name}</label>
                </div>
                <input type="hidden" name="FoodTypes[${index}].FoodTypeId" value="${foodType.foodTypeId}">
                <input type="hidden" name="FoodTypes[${index}].Name" value="${foodType.name}">
            `;
            return item;
        }

        // Search functionality for food types
        function filterFoodTypes() {
            const searchInput = document.getElementById('foodTypesSearch');
            const clearBtn = document.getElementById('clearSearchBtn');
            const searchTerm = searchInput.value.toLowerCase().trim();
            
            // Show/hide clear button
            if (searchTerm.length > 0) {
                clearBtn.style.display = 'block';
            } else {
                clearBtn.style.display = 'none';
            }
            
            // Get all food type items
            const foodItems = document.querySelectorAll('#foodTypesGrid .preference-item');
            let visibleCount = 0;
            
            foodItems.forEach(item => {
                const foodName = item.getAttribute('data-food-name');
                const matches = foodName.includes(searchTerm);
                
                if (matches) {
                    item.style.display = 'block';
                    item.style.opacity = '1';
                    item.style.transform = 'scale(1)';
                    visibleCount++;
                } else {
                    item.style.display = 'none';
                    item.style.opacity = '0';
                    item.style.transform = 'scale(0.95)';
                }
            });
            
            // Show "no results" message if no matches
            let noResultsMsg = document.getElementById('noResultsMsg');
            if (visibleCount === 0 && searchTerm.length > 0) {
                if (!noResultsMsg) {
                    noResultsMsg = document.createElement('div');
                    noResultsMsg.id = 'noResultsMsg';
                    noResultsMsg.className = 'no-results-message';
                    noResultsMsg.style.cssText = `
                        text-align: center;
                        padding: 2rem;
                        color: #6b7280;
                        font-style: italic;
                        background: rgba(255, 255, 255, 0.5);
                        border-radius: 12px;
                        margin: 1rem 0;
                    `;
                    noResultsMsg.innerHTML = `
                        <svg style="width: 3rem; height: 3rem; margin-bottom: 1rem; opacity: 0.5;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                        </svg>
                        <p>No food types found matching "${searchTerm}"</p>
                    `;
                    document.getElementById('foodTypesGrid').appendChild(noResultsMsg);
                }
            } else if (noResultsMsg) {
                noResultsMsg.remove();
            }
        }

        function clearFoodTypesSearch() {
            const searchInput = document.getElementById('foodTypesSearch');
            const clearBtn = document.getElementById('clearSearchBtn');
            
            searchInput.value = '';
            clearBtn.style.display = 'none';
            
            // Show all items
            const foodItems = document.querySelectorAll('#foodTypesGrid .preference-item');
            foodItems.forEach(item => {
                item.style.display = 'block';
                item.style.opacity = '1';
                item.style.transform = 'scale(1)';
            });
            
            // Remove no results message
            const noResultsMsg = document.getElementById('noResultsMsg');
            if (noResultsMsg) {
                noResultsMsg.remove();
            }
        }

        function createDietaryRestrictionItem(restriction, index) {
            const item = document.createElement('div');
            item.className = 'preference-item';
            item.innerHTML = `
                <div class="preference-checkbox">
                    <input type="checkbox"
                           data-dietary-id="${restriction.dietaryRestrictionId}"
                           name="DietaryRestrictions[${index}].IsSelected"
                           onchange="togglePreferenceItem(this)"
                           id="dietary-${restriction.dietaryRestrictionId}">
                    <label for="dietary-${restriction.dietaryRestrictionId}">${restriction.name}</label>
                </div>
                <div class="preference-level">
                    <label>Importance:</label>
                    <select name="DietaryRestrictions[${index}].ImportanceLevel">
                        ${Array.from({length: 10}, (_, i) =>
                            `<option value="${i + 1}">${i + 1}</option>`
                        ).join('')}
                    </select>
                </div>
                <input type="hidden" name="DietaryRestrictions[${index}].DietaryRestrictionId" value="${restriction.dietaryRestrictionId}">
                <input type="hidden" name="DietaryRestrictions[${index}].Name" value="${restriction.name}">
            `;
            return item;
        }

        function createHealthConditionItem(condition, index) {
            const item = document.createElement('div');
            item.className = 'preference-item';
            item.innerHTML = `
                <div class="preference-checkbox">
                    <input type="checkbox"
                           data-health-id="${condition.healthConditionId}"
                           name="HealthConditions[${index}].IsSelected"
                           onchange="togglePreferenceItem(this)"
                           id="health-${condition.healthConditionId}">
                    <label for="health-${condition.healthConditionId}">${condition.name}</label>
                </div>
                <div class="preference-level">
                    <label>Severity:</label>
                    <select name="HealthConditions[${index}].SeverityLevel">
                        ${Array.from({length: 10}, (_, i) =>
                            `<option value="${i + 1}">${i + 1}</option>`
                        ).join('')}
                    </select>
                </div>
                <input type="hidden" name="HealthConditions[${index}].HealthConditionId" value="${condition.healthConditionId}">
                <input type="hidden" name="HealthConditions[${index}].Name" value="${condition.name}">
            `;
            return item;
        }

        function togglePreferenceItem(checkbox) {
            const item = checkbox.closest('.preference-item');
            if (checkbox.checked) {
                item.classList.add('selected');
            } else {
                item.classList.remove('selected');
            }

            // Update section validation state
            updateSectionValidation();

            // Update button indicators (only if function exists)
            if (typeof updateButtonIndicators === 'function') {
                updateButtonIndicators();
            }
        }

        function updateSectionValidation() {
            // Check each section for selections
            const sections = [
                { container: 'foodTypesGrid', name: 'Food Types' },
                { container: 'dietaryRestrictionsList', name: 'Dietary Restrictions' },
                { container: 'healthConditionsList', name: 'Health Conditions' }
            ];

            let hasAnySelections = false;

            sections.forEach(section => {
                const container = document.getElementById(section.container);
                if (container) {
                    const selectedItems = container.querySelectorAll('.preference-item.selected');
                    const sectionHeader = container.closest('.preferences-section')?.querySelector('.section-header');

                    if (selectedItems.length > 0) {
                        sectionHeader?.classList.add('section-completed');
                        hasAnySelections = true;
                    } else {
                        sectionHeader?.classList.remove('section-completed');
                    }
                }
            });

            // Update save button state for the current modal
            const currentModal = document.querySelector('.modal[style*="block"]');
            if (currentModal) {
                const saveButton = currentModal.querySelector('button[type="submit"]');
                if (saveButton) {
                    if (hasAnySelections) {
                        saveButton.disabled = false;
                        saveButton.classList.remove('btn-disabled');
                    } else {
                        saveButton.disabled = true;
                        saveButton.classList.add('btn-disabled');
                    }
                }
            }
        }

        // Update button indicators to show current selection counts
        function updateButtonIndicators() {
            // Update Food Types button (only if grid exists)
            const foodTypesGrid = document.getElementById('foodTypesGrid');
            if (foodTypesGrid) {
                const foodTypesSelected = foodTypesGrid.querySelectorAll('.preference-item.selected').length;
                updateButtonIndicator('foodTypes', foodTypesSelected);
            }

            // Update Dietary Restrictions button (only if list exists)
            const dietaryList = document.getElementById('dietaryRestrictionsList');
            if (dietaryList) {
                const dietarySelected = dietaryList.querySelectorAll('.preference-item.selected').length;
                updateButtonIndicator('dietaryRestrictions', dietarySelected);
            }

            // Update Health Conditions button (only if list exists)
            const healthList = document.getElementById('healthConditionsList');
            if (healthList) {
                const healthSelected = healthList.querySelectorAll('.preference-item.selected').length;
                updateButtonIndicator('healthConditions', healthSelected);
            }

            // Update Location & Budget button (check if fields have values)
            const locationInput = document.getElementById('preferredLocation');
            const priceRangeSelect = document.getElementById('priceRange');
            if (locationInput || priceRangeSelect) {
                const locationValue = locationInput?.value || '';
                const budgetValue = priceRangeSelect?.value || '';
                const locationBudgetSelected = (locationValue.trim() !== '' || budgetValue !== '') ? 1 : 0;
                updateButtonIndicator('locationBudget', locationBudgetSelected);
            }
        }

        function updateButtonIndicator(sectionType, count) {
            const button = document.querySelector(`.${sectionType}-btn`);
            if (button) {
                let indicator = button.querySelector('.selection-indicator');
                if (!indicator) {
                    indicator = document.createElement('div');
                    indicator.className = 'selection-indicator';
                    button.appendChild(indicator);
                }

                if (count > 0) {
                    indicator.textContent = count;
                    indicator.style.display = 'flex';
                } else {
                    indicator.style.display = 'none';
                }
            }
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const deleteModal = document.getElementById('deleteModal');
            const foodTypesModal = document.getElementById('foodTypesModal');
            const dietaryRestrictionsModal = document.getElementById('dietaryRestrictionsModal');
            const healthConditionsModal = document.getElementById('healthConditionsModal');
            const locationBudgetModal = document.getElementById('locationBudgetModal');

            if (event.target == deleteModal) {
                closeDeleteModal();
            }
            if (event.target == foodTypesModal) {
                closeModal('foodTypesModal');
            }
            if (event.target == dietaryRestrictionsModal) {
                closeModal('dietaryRestrictionsModal');
            }
            if (event.target == healthConditionsModal) {
                closeModal('healthConditionsModal');
            }
            if (event.target == locationBudgetModal) {
                closeModal('locationBudgetModal');
            }
        }

        // Handle form submissions for each modal
        function setupFormSubmission(formId, modalId) {
            const form = document.getElementById(formId);
            if (form) {
                form.addEventListener('submit', function(e) {
                    e.preventDefault();

                    // Validate form before submission
                    const hasSelections = validateFormSelections(formId);
                    if (!hasSelections) {
                        showErrorMessage('Please select at least one preference before saving.');
                        return;
                    }

                    const formData = new FormData(this);
                    formData.append('source', 'modal');

                    // Show loading state on save button
                    const saveButton = this.querySelector('button[type="submit"]');
                    const originalText = saveButton.innerHTML;
                    saveButton.innerHTML = `
                        <div class="loading-spinner" style="width: 1rem; height: 1rem; margin-right: 0.5rem;"></div>
                        Saving...
                    `;
                    saveButton.disabled = true;

                    fetch(this.action, {
                        method: 'POST',
                        body: formData
                    })
                    .then(response => {
                        if (!response.ok) {
                            throw new Error(`HTTP error! status: ${response.status}`);
                        }
                        return response.json();
                    })
                    .then(data => {
                        if (data.success) {
                            closeModal(modalId);
                            showSuccessMessage(data.message || 'Preferences updated successfully!');
                        } else {
                            throw new Error(data.error || 'Failed to save preferences');
                        }
                    })
                    .catch(error => {
                        console.error('Error saving preferences:', error);
                        showErrorMessage(error.message || 'Failed to save preferences. Please try again.');
                    })
                    .finally(() => {
                        // Restore save button
                        saveButton.innerHTML = originalText;
                        saveButton.disabled = false;
                    });
                });
            }
        }

        // Initialize form submissions
        document.addEventListener('DOMContentLoaded', function() {
            setupFormSubmission('foodTypesForm', 'foodTypesModal');
            setupFormSubmission('dietaryRestrictionsForm', 'dietaryRestrictionsModal');
            setupFormSubmission('healthConditionsForm', 'healthConditionsModal');
            setupFormSubmission('locationBudgetForm', 'locationBudgetModal');
            setupPageFormSubmission('profileForm', 'Profile updated successfully!');
            setupPageFormSubmission('passwordForm', 'Password updated successfully!');
        });

        // Handle page form submissions (profile and password)
        function setupPageFormSubmission(formId, successMessage) {
            const form = document.getElementById(formId);
            if (form) {
                form.addEventListener('submit', function(e) {
                    e.preventDefault();

                    // Show loading state on submit button
                    const submitButton = this.querySelector('button[type="submit"]');
                    const originalText = submitButton.innerHTML;
                    submitButton.innerHTML = `
                        <div class="loading-spinner" style="width: 1rem; height: 1rem; margin-right: 0.5rem;"></div>
                        Saving...
                    `;
                    submitButton.disabled = true;

                    const formData = new FormData(this);
                    
                    // Debug: Log form data
                    console.log('Form action:', this.action);
                    console.log('Form data being sent:');
                    for (let [key, value] of formData.entries()) {
                        console.log(key, ':', value);
                    }

                    fetch(this.action, {
                        method: 'POST',
                        body: formData
                    })
                    .then(response => {
                        if (!response.ok) {
                            throw new Error(`HTTP error! status: ${response.status}`);
                        }
                        return response.json();
                    })
                    .then(data => {
                        if (data.success) {
                            showSuccessMessage(data.message || successMessage);
                            // Clear password fields if it's the password form
                            if (formId === 'passwordForm') {
                                this.reset();
                            }
                        } else {
                            throw new Error(data.error || 'Failed to save changes');
                        }
                    })
                    .catch(error => {
                        console.error('Error saving changes:', error);
                        showErrorMessage(error.message || 'Failed to save changes. Please try again.');
                    })
                    .finally(() => {
                        // Restore submit button
                        submitButton.innerHTML = originalText;
                        submitButton.disabled = false;
                    });
                });
            }
        }

        // Validate form selections
        function validateFormSelections(formId) {
            if (formId === 'foodTypesForm') {
                const foodTypesSelected = document.querySelectorAll('#foodTypesGrid .preference-item.selected').length;
                return foodTypesSelected > 0;
            } else if (formId === 'dietaryRestrictionsForm') {
                const dietarySelected = document.querySelectorAll('#dietaryRestrictionsList .preference-item.selected').length;
                return dietarySelected > 0;
            } else if (formId === 'healthConditionsForm') {
                const healthSelected = document.querySelectorAll('#healthConditionsList .preference-item.selected').length;
                return healthSelected > 0;
            } else if (formId === 'locationBudgetForm') {
                const locationValue = document.getElementById('preferredLocation')?.value?.trim() || '';
                const budgetValue = document.getElementById('priceRange')?.value || '';
                return locationValue !== '' || budgetValue !== '';
            }
            return false;
        }

        function showSuccessMessage(message) {
            // Create and show success alert
            const alert = document.createElement('div');
            alert.className = 'alert alert-success';
            alert.style.position = 'fixed';
            alert.style.top = '20px';
            alert.style.right = '20px';
            alert.style.zIndex = '9999';
            alert.innerHTML = `
                <svg style="width: 1.5rem; height: 1.5rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                ${message}
            `;
            document.body.appendChild(alert);

            setTimeout(() => {
                alert.remove();
            }, 3000);
        }

        function showErrorMessage(message) {
            // Create and show error alert
            const alert = document.createElement('div');
            alert.className = 'alert alert-error';
            alert.style.position = 'fixed';
            alert.style.top = '20px';
            alert.style.right = '20px';
            alert.style.zIndex = '9999';
            alert.innerHTML = `
                <svg style="width: 1.5rem; height: 1.5rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                ${message}
            `;
            document.body.appendChild(alert);

            setTimeout(() => {
                alert.remove();
            }, 5000);
        }
    </script>
</body>
</html>

