@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Foodie Guide - Your Personal Food Companion";
}
<head>
    <title>Foodiesaur</title>
    <link rel="icon" type="image/svg+xml" href="~/images/titlelogo.svg">
    <link rel="alternate icon" type="image/png" href="~/images/titlelogo.png">
</head>
<header>
    <nav class="shadow bg-[#47682C] text-white" style="background-color:#47682C;">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center flex-shrink-0">
                    <a asp-area="" asp-controller="Home" asp-action="Index" aria-label="Home" class="block">
                        <img src="~/images/Group 34.png" alt="Foodiesaur logo" class="block h-12 md:h-16 w-auto object-contain hover:scale-105 transition-transform duration-200" />
                    </a>
                </div>
                <div class="flex items-center gap-3 md:gap-4">
                    <!-- Web Scraping Test Link -->
             
                    @if (HttpContextAccessor?.HttpContext?.Session?.GetString("UserId") != null)
                    {
                        <div class="relative inline-block text-left">
                            <button type="button" id="user-menu-button" class="inline-flex items-center text-white p-2 hover:opacity-90 focus:outline-none" aria-expanded="false" aria-haspopup="true" aria-label="User menu">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                </svg>
                                <svg class="ml-1 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                                </svg>
                            </button>
                            <div id="user-menu" class="absolute right-0 z-10 mt-2 w-32 origin-top-right rounded-lg bg-white shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none hidden">
                                <div class="py-1">
                                    <form asp-controller="Auth" asp-action="Logout" method="post" class="block">
                                        <button type="submit" class="block w-full px-4 py-2 text-left text-sm text-gray-700 hover:bg-gray-100 rounded-lg">Logout</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <form asp-controller="Auth" asp-action="Login" method="get" class="inline">
                            <button type="submit" class="group inline-flex items-center rounded-3xl bg-white px-6 py-2.5 text-black text-sm font-semibold shadow-lg hover:shadow-xl hover:bg-gray-50 hover:scale-105 active:scale-95 transition-all duration-300 ease-out border-2 border-transparent hover:border-white/20">
                                <span class="relative z-10">Log In</span>
                                <div class="absolute inset-0 rounded-3xl bg-gradient-to-r from-emerald-400/20 to-amber-400/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                            </button>
                        </form>
                        <form asp-controller="Auth" asp-action="Register" method="get" class="inline">
                            <button type="submit" class="group inline-flex items-center rounded-3xl px-6 py-2.5 text-white text-sm font-semibold hover:bg-white/20 hover:scale-105 active:scale-95 transition-all duration-300 ease-out border-2 border-white/30 hover:border-white/60 hover:shadow-lg hover:shadow-white/20 relative overflow-hidden">
                                <span class="relative z-10">Sign Up</span>
                                <div class="absolute inset-0 bg-gradient-to-r from-emerald-500/20 to-amber-500/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                                <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700 ease-out"></div>
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </nav>


</header>
<div class="min-h-screen bg-gradient-to-br from-emerald-50 via-white to-amber-50">
    <!-- Hero Section -->
    <div class="container mx-auto px-4 py-20">
        <div class="text-center mb-20">
            <h1 class="text-6xl font-black text-emerald-900 mb-6 tracking-tight">
                Welcome to <span class="text-amber-600">FoodieSaur</span> Chatbot
            </h1>
            <p class="text-xl text-gray-700 max-w-2xl mx-auto leading-relaxed">
                Discover the best local restaurants and get personalized food recommendations powered by AI
            </p>
        </div>

        <!-- Features Grid -->
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-10 max-w-7xl mx-auto">
            <!-- Chatbot Card -->
            <div class="group bg-white rounded-2xl shadow-lg p-8 transform hover:scale-105 transition-all duration-300 hover:shadow-xl border border-gray-100">
                <div class="text-emerald-600 mb-6 group-hover:text-emerald-700 transition-colors">
                    <svg class="w-14 h-14 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path>
                    </svg>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-3">AI Food Assistant</h3>
                <p class="text-gray-600 leading-relaxed mb-6">Get personalized food recommendations based on your preferences and dietary needs</p>
                <button class="w-full bg-emerald-600 text-white px-6 py-3 rounded-xl text-lg font-semibold hover:bg-emerald-700 transition-colors shadow-md hover:shadow-lg"
                        onclick="window.location.href='/Home/Chat'">
                    Chat Now
                </button>

            </div>

            <!-- Map Card -->
            <div class="group bg-white rounded-2xl shadow-lg p-8 transform hover:scale-105 transition-all duration-300 hover:shadow-xl border border-gray-100">
                <div class="text-amber-600 mb-6 group-hover:text-amber-700 transition-colors">
                    <svg class="w-14 h-14 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-3">Interactive Map</h3>
                <p class="text-gray-600 leading-relaxed mb-6">Explore nearby restaurants and discover hidden gems in your area</p>
                <button class="w-full bg-amber-600 text-white px-6 py-3 rounded-xl text-lg font-semibold hover:bg-amber-700 transition-colors shadow-md hover:shadow-lg"
                        onclick="window.location.href='/Home/Chat'">
                    View Map
                </button>
            </div>

            <!-- Recommendations Card -->
            <div class="group bg-white rounded-2xl shadow-lg p-8 transform hover:scale-105 transition-all duration-300 hover:shadow-xl border border-gray-100">
                <div class="text-emerald-600 mb-6 group-hover:text-emerald-700 transition-colors">
                    <svg class="w-14 h-14 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                    </svg>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-3">Smart Recommendations</h3>
                <p class="text-gray-600 leading-relaxed mb-6">Get curated lists of restaurants based on your taste and preferences</p>
                <button class="w-full bg-emerald-600 text-white px-6 py-3 rounded-xl text-lg font-semibold hover:bg-emerald-700 transition-colors shadow-md hover:shadow-lg" 
                        onclick="window.location.href='/Home/Chat'">
                    Get Started
                </button>
            </div>
        </div>

        <!-- Call to Action -->
        <div class="text-center mt-24 bg-gradient-to-r from-emerald-600 to-amber-600 rounded-3xl p-12 shadow-2xl">
            <h2 class="text-4xl font-black text-white mb-6 tracking-tight">Ready to discover your next favorite meal?</h2>
            <p class="text-xl text-white/90 mb-10 max-w-2xl mx-auto">Join thousands of food lovers who trust Foodie Guide for their dining decisions</p>
            <button class="bg-white text-emerald-900 px-10 py-4 rounded-xl text-xl font-bold hover:bg-gray-100 transition-colors shadow-lg hover:shadow-xl transform hover:scale-105 duration-300">
                Start Exploring
            </button>
        </div>
    </div>
</div>



