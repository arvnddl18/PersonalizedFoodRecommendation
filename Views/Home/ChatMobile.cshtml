            document.body.style.overflow = '';
            document.body.style.position = '';
            document.body.style.width = '';
        };

        // Close when clicking outside the image or on the image itself
        function attachMenuImageModalHandlers() {
            const modal = document.getElementById('menu-image-modal');
            if (!modal) {
                console.warn('Menu image modal not found during initialization');
                return;
            }
            
            // Ensure modal is attached directly to body to avoid clipping from ancestor overflow/transform
            if (modal.parentElement !== document.body) {
                try { document.body.appendChild(modal); } catch (e) { 
                    console.error('Failed to move modal to body:', e);
                }
            }
            
            // Close when clicking the background (but not the image)
            modal.addEventListener('click', function (e) {
                if (e.target === modal) {
                    closeMenuImageModal();
                }
            });
            
            // Close when clicking the image itself
            const modalImg = document.getElementById('menu-image-modal-img');
            if (modalImg) {
                modalImg.addEventListener('click', function (e) {
                    e.stopPropagation();
                    closeMenuImageModal();
                });
            }
            
            // Close on Escape key
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape' && modal.style.display === 'flex') {
                    closeMenuImageModal();
                }
            });
            
            console.log('Menu image modal handlers attached');
        }
        
        // Initialize modal handlers when DOM is ready
        if (document.readyState === 'loading') {
