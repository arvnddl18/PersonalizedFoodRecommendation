        // Perform mobile map search
        async function performMobileMapSearch(parameters) {
            try {
                window.lastSearchParameters = parameters;
                
                let results = [];
                
                // If establishment name is provided, use text search for specific establishment
                if (parameters.establishmentName) {
                    let searchQuery = parameters.establishmentName;
                    // Add location context if available
                    if (parameters.location && parameters.location !== 'nearby' && parameters.location !== 'near me') {
                        searchQuery += ` ${parameters.location}`;
                    } else {
                        searchQuery += ' near me';
                    }
                    
                    // Use text search for specific establishment name
                    results = await textSearchCompat({
                        query: searchQuery.trim(),
                        location: userLocation,
                        radius: SEARCH_RADIUS_METERS,
                        type: 'restaurant'
                    });
                } else {
                    // Use nearbySearch for strict radius enforcement (existing logic)
                    results = await nearbySearchCompat({
                        location: userLocation,
                        radius: SEARCH_RADIUS_METERS,
                        type: 'restaurant',
                        keyword: parameters.food || 'restaurant'
                    });
                }
                
                if (results && results.length) {
                    displayMobileSearchResults(results, parameters);
                    openMobileSearch();
                } else {
                    if (parameters.establishmentName) {
                        addMessage('FoodieSaur Bot', `No results found for "${parameters.establishmentName}". Please check the spelling or try a different search.`);
                    } else {
                        addMessage('FoodieSaur Bot', 'No restaurants found within 10km of your location.');
                    }
                }
            } catch (error) {
                console.error('Error performing mobile map search:', error);
                addMessage('FoodieSaur Bot', 'Error searching for restaurants.');
            }
        }
        
        // Nearby search helper - enforces strict radius limits
        function nearbySearchCompat(request) {
            return new Promise((resolve) => {
                try {
                    const service = new google.maps.places.PlacesService(map);
                    const nearbyRequest = {
                        location: request.location,
                        radius: request.radius,
                        type: request.type,
                        keyword: request.keyword
                    };
                    
                    service.nearbySearch(nearbyRequest, (results, status) => {
                        if (status === google.maps.places.PlacesServiceStatus.OK) {
                            // Filter results to ensure they're within radius and calculate distances
                            const filteredResults = (results || []).filter(place => {
                                if (!place.geometry || !place.geometry.location) return false;
                                
                                // Calculate distance from user location
                                const distance = google.maps.geometry.spherical.computeDistanceBetween(
                                    new google.maps.LatLng(userLocation.lat, userLocation.lng),
                                    place.geometry.location
                                );
                                
                                // Only include results within the specified radius
                                return distance <= request.radius;
                            }).map(place => {
                                // Add distance property for sorting
                                const distance = google.maps.geometry.spherical.computeDistanceBetween(
                                    new google.maps.LatLng(userLocation.lat, userLocation.lng),
                                    place.geometry.location
                                );
                                return {
                                    ...place,
                                    distance: distance
                                };
                            }).sort((a, b) => a.distance - b.distance) // Sort by distance (nearest first)
                            .slice(0, MAX_SEARCH_RESULTS); // Limit to only nearest restaurants
                            
                            resolve(filteredResults);
                        } else {
                            console.log('Nearby search failed:', status);
                            resolve([]);
                        }
                    });
                } catch (error) {
                    console.error('Nearby search error:', error);
                    resolve([]);
                }
            });
        }
        
        // Fetch place details helper
        function fetchPlaceDetails(placeId) {
            return new Promise(async (resolve) => {
                try {
                    if (google?.maps?.places?.Place) {
                        const place = new google.maps.places.Place({ id: placeId });
                        await place.fetchFields({
                            fields: [
                                'formattedAddress',
                                'vicinity',
                                'openingHours',
                                'businessStatus',
                                'url',
                                'currentOpeningHours',
                                'utcOffsetMinutes',
                                'photos',
                                'priceLevel',
                                'rating',
                                'userRatingCount',
                                'displayName',
                                'types',
                                'location'
                            ]
                        });

                        const normalized = (function(p) {
                            const loc = p.location ? new google.maps.LatLng(p.location) : null;
                            const photos = Array.isArray(p.photos) ? p.photos.map(ph => ({
                                getUrl: function(opts) {
                                    try { return ph.createUrl ? ph.createUrl(opts || {}) : ''; } catch { return ''; }
                                },
                                width: ph.width,
                                height: ph.height
                            })) : [];
                            const opening_hours = p.openingHours ? {
                                isOpen: function() { try { return !!p.openingHours.openNow; } catch { return false; } },
                                open_now: p.openingHours.openNow === true
                            } : undefined;
                            return {
                                formatted_address: p.formattedAddress,
                                vicinity: p.vicinity,
                                opening_hours: opening_hours,
                                business_status: p.businessStatus,
                                current_opening_hours: p.currentOpeningHours,
                                utc_offset_minutes: p.utcOffsetMinutes,
                                photos: photos,
                                price_level: p.priceLevel,
                                rating: p.rating,
                                user_ratings_total: p.userRatingCount,
                                name: p.displayName?.text || p.displayName || '',
                                types: p.types,
                                geometry: loc ? { location: loc } : undefined,
                                place_id: placeId
                            };
                        })(place);
                        resolve(normalized);
                        return;
                    }
                } catch (e) {
                    console.warn('New Places API failed, falling back to legacy getDetails:', e);
                }

                try {
                    const service = new google.maps.places.PlacesService(map);
                    const request = {
                        placeId: placeId,
                        fields: [
                            'formatted_address',
                            'vicinity',
                            'opening_hours',
                            'url',
                            'business_status',
                            'current_opening_hours',
                            'utc_offset_minutes',
                            'photos',
                            'price_level',
                            'rating',
                            'user_ratings_total',
                            'name',
                            'types',
                            'geometry'
                        ]
                    };
                    service.getDetails(request, (place, status) => {
                        if (status === google.maps.places.PlacesServiceStatus.OK) {
                            resolve(place);
                        } else {
                            console.warn(`Failed to fetch place details for ${placeId}:`, status);
                            resolve({});
                        }
                    });
                } catch (err) {
                    console.error('Legacy PlacesService getDetails failed:', err);
                    resolve({});
                }
            });
        }

        // Text search helper (kept for fallback)
        function textSearchCompat(request) {
            return new Promise(async (resolve) => {
                try {
                    if (google?.maps?.places?.TextSearchService) {
                        const svc = new google.maps.places.TextSearchService();
                        const newReq = {
                            textQuery: request.query,
                            locationBias: (request.location && request.radius) ? {
                                center: request.location,
                                radius: request.radius
                            } : undefined,
                            type: request.type
                        };
                        svc.textSearch(newReq, (results) => {
                            const mapped = (results || []).map(r => {
                                const loc = r.location ? new google.maps.LatLng(r.location) : (r.geometry?.location || null);
                                const photos = Array.isArray(r.photos) ? r.photos.map(ph => ({
                                    getUrl: function(opts) { try { return ph.createUrl ? ph.createUrl(opts || {}) : ''; } catch { return ''; } },
                                    width: ph.width,
                                    height: ph.height
                                })) : [];
                                return {
                                    place_id: r.id || r.place_id,
                                    name: r.displayName?.text || r.name,
                                    formatted_address: r.formattedAddress || r.formatted_address,
                                    rating: r.rating || 0,
                                    user_ratings_total: r.userRatingCount || r.user_ratings_total || 0,
                                    price_level: r.priceLevel || r.price_level || 0,
                                    photos: photos,
                                    geometry: { location: loc },
                                    types: r.types || [],
                                    business_status: r.businessStatus || r.business_status || 'OPERATIONAL'
                                };
                            });
                            resolve(mapped);
                        });
                } else {
                        const service = new google.maps.places.PlacesService(map);
                        const legacyRequest = {
                            query: request.query,
                            location: request.location,
                            radius: request.radius,
                            type: request.type
                        };
                        service.textSearch(legacyRequest, (results, status) => {
                            if (status === google.maps.places.PlacesServiceStatus.OK) {
                                resolve(results || []);
                            } else {
                                resolve([]);
                            }
                        });
                }
            } catch (error) {
                    console.error('Text search error:', error);
                    resolve([]);
                }
            });
        }
        
