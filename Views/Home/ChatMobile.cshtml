            content.addEventListener('click', () => {
                const restaurantDetailsContent = document.getElementById('restaurant-details-content');
                
                if (restaurantDetailsContent && restaurantDetailsContent.style.display === 'flex') {
                    // Panel is already open, update content
                    updateRestaurantDetailsPanel(place);
