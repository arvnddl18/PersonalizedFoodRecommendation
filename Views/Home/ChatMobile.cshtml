                                        <svg style="width: 1.5rem; height: 1.5rem; color: #F7B32B; margin-bottom: 0.25rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 17a2 2 0 100 4 2 2 0 000-4zm8 0a2 2 0 100 4 2 2 0 000-4zM3 12h18M3 12v4a2 2 0 002 2h14a2 2 0 002-2v-4M3 12V8a2 2 0 012-2h14a2 2 0 012 2v4m-7 5h2"/>
                                        </svg>
                                        <span style="font-size: 0.625rem; font-weight: 600; color: #F7B32B;">Drive</span>
