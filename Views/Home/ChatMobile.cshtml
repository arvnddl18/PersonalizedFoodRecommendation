                                    <button onclick="clearRoute()" style="padding: 0.375rem 0.75rem; border-radius: 0.5rem; background: rgba(71,104,44,0.1); color: #47682C; font-size: 0.75rem; font-weight: 500; transition: all 0.2s ease; display: flex; align-items: center; gap: 0.25rem; border: none; cursor: pointer;">
                                        <svg style="width: 0.875rem; height: 0.875rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                        </svg>
                                        Clear
                                    </button>
                                </div>
                                <div id="route-destination-info" style="background: rgba(71,104,44,0.05); border-radius: 0.75rem; padding: 0.75rem;">
                                    <div style="font-size: 0.75rem; color: rgba(71,104,44,0.6); margin-bottom: 0.25rem;">Destination</div>
                                    <div id="route-destination-name" style="font-weight: 600; font-size: 0.875rem;">Restaurant Name</div>
                                    <div id="route-destination-address" style="font-size: 0.75rem; color: rgba(71,104,44,0.7); margin-top: 0.125rem;">Address will appear here</div>
                                </div>
                            </div>

                            <!-- Turn-by-Turn Directions -->
                            <div id="directions-panel-content" style="display: flex; flex-direction: column; gap: 0.75rem;">
                                <!-- Placeholder -->
                                <div id="directions-placeholder" style="background: white; border-radius: 1rem; padding: 2rem; text-align: center; border: 1px solid rgba(71,104,44,0.1);">
                                    <div style="width: 5rem; height: 5rem; margin: 0 auto 1rem; border-radius: 50%; background: linear-gradient(135deg, rgba(247,179,43,0.2) 0%, rgba(247,179,43,0.1) 100%); display: flex; align-items: center; justify-content: center;">
                                        <svg style="width: 2.5rem; height: 2.5rem; color: #F7B32B;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                                        </svg>
