        // Send message functionality
        async function sendMessage() {
            const chatInput = document.getElementById('chat-input');
            const message = chatInput.value.trim();
            if (message === '') return;
            // Guest: block likely personalized queries and show login prompt
            // Allow proactive suggestions to bypass this check for guest users
            if (window.isGuest && !isFromProactiveSuggestion && isLikelyPersonalizedQuery(message)) {
                if (typeof showLoginPrompt === 'function') showLoginPrompt();
                return;
            }
            
            addMessage('You', message);
            chatInput.value = '';
            
            showTypingIndicator();
            
            try {
                const response = await fetch('/api/Chat/send', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        text: message,
                        includeHealthDietRestrictions: healthDietModeEnabled,
                        sessionId: currentSessionId || null
                    })
                });
                
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                
                const data = await response.json();
                hideTypingIndicator();
                
                // Handle different response types
                if (data && data.response) {
                    // Detect personalized recommendation format
                    if (isPersonalizedRecommendation(data.response)) {
                        renderPersonalizedRecommendation(data.response);
                    } else {
                addMessage('FoodieSaur Bot', data.response);
                    }
                    
                    // Check for generalized queries (map search) or personalized queries
                    // Also check for establishment search intent
                    if (data.parameters && (data.parameters.queryType === 'generalized' || data.parameters.intentName === 'establishment_search' || data.parameters.establishmentName)) {
                        await performMobileMapSearch(data.parameters);
                    } else if (isPersonalizedRecommendation(data.response)) {
                        renderActionButtonsFromResponse(data.response);
                    }
                } else {
                    addMessage('FoodieSaur Bot', 'Sorry, I did not get a response.');
                }
                
                if (data.sessionId) {
                    currentSessionId = data.sessionId;
                }
                
                // Hide proactive suggestions only if message was manually typed (not from suggestion)
                if (!isFromProactiveSuggestion) {
                const proactiveSuggestions = document.getElementById('proactive-suggestions');
                if (proactiveSuggestions) {
                    proactiveSuggestions.style.display = 'none';
                    }
                } else {
                    // If message was from proactive suggestion, refresh suggestions after a short delay
                    // to give users new options after they've made a selection
                    setTimeout(() => {
                        fetchProactiveSuggestions();
                    }, 500);
                }
                
                // Reset the flag
                isFromProactiveSuggestion = false;
                
            } catch (error) {
                console.error('Error sending message:', error);
                hideTypingIndicator();
                addMessage('FoodieSaur Bot', 'Sorry, I encountered an error. Please try again.');
            }
        }
            
