            // Hide all search result markers
            if (searchMarkers) {
                searchMarkers.forEach(marker => {
                    marker.setMap(null);
                });
            }
            
            // Close all search result info windows
            if (searchInfoWindows) {
                searchInfoWindows.forEach(infoWindow => {
                    infoWindow.close();
                });
            }
        }
        
        // Show search result markers
        function showSearchResultMarkers() {
            // Show all search result markers
            if (searchMarkers) {
                searchMarkers.forEach(marker => {
                    marker.setMap(map);
                });
            }
            
            // Reopen all search result info windows
            if (searchInfoWindows && searchMarkers) {
                searchInfoWindows.forEach((infoWindow, index) => {
                    if (searchMarkers[index]) {
                        infoWindow.open(map, searchMarkers[index]);
                    }
