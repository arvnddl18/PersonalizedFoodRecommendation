                                            <svg id="route-mode-icon" style="width: 1.5rem; height: 1.5rem; color: #47682C;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
                                            </svg>
                                        </div>
                                        <div>
                                            <div style="font-size: 0.75rem; opacity: 0.8;">Driving Route</div>
                                            <div id="route-mode-text" style="font-size: 1.125rem; font-weight: 700;">31 mins · 2.5 km</div>
