                                        <svg style="width: 1.5rem; height: 1.5rem; color: #47682C; margin-bottom: 0.25rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18a3 3 0 100-6 3 3 0 000 6zm12 0a3 3 0 100-6 3 3 0 000 6zM9 12l3-6m0 0l3 6m-3-6V3m-5 9h10"/>
                                        </svg>
                                        <span style="font-size: 0.625rem; font-weight: 500; color: #47682C;">Bike</span>
                                    </button>
                                </div>
                            </div>

                            <!-- Route Summary Card -->
