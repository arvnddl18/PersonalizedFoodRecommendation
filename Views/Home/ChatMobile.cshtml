        // Initialize draggable panel
        function initializeDraggablePanel() {
            const panel = document.getElementById('mobile-chat-panel');
            const dragHandle = document.getElementById('drag-handle');
            const draggableHeader = document.getElementById('draggable-header');
            const panelContent = document.getElementById('panel-content');
            
            let isDragging = false;
            let startY = 0;
            let startHeight = 0;
            let currentHeight = 0;
            
            draggableHeader.addEventListener('touchstart', handleStart, { passive: false });
            draggableHeader.addEventListener('touchmove', handleMove, { passive: false });
            draggableHeader.addEventListener('touchend', handleEnd, { passive: false });
            
            draggableHeader.addEventListener('mousedown', handleStart);
            document.addEventListener('mousemove', handleMove);
            document.addEventListener('mouseup', handleEnd);
            
            draggableHeader.addEventListener('dragstart', (e) => e.preventDefault());
            
            function handleStart(e) {
                isDragging = true;
                panel.classList.add('dragging');
                dragHandle.classList.add('dragging');
                draggableHeader.classList.add('dragging');
                
                // Disable transitions during drag for immediate response
                panel.style.transition = 'none';
                
                if (e.type === 'touchstart') {
                    startY = e.touches[0].clientY;
                } else {
                    startY = e.clientY;
                }
                
                startHeight = panel.offsetHeight;
                currentHeight = startHeight;
                
                e.preventDefault();
                e.stopPropagation();
            }
            
            function handleMove(e) {
                if (!isDragging) return;
                
                let clientY;
                if (e.type === 'touchmove') {
                    clientY = e.touches[0].clientY;
                } else {
                    clientY = e.clientY;
                }
                
                // Calculate smooth delta with momentum
                const deltaY = startY - clientY;
                const newHeight = Math.max(38, Math.min(window.innerHeight, startHeight + deltaY));
                
                // Immediate response without requestAnimationFrame for native feel
                panel.style.height = newHeight + 'px';
                currentHeight = newHeight;
                
                const halfScreenHeight = window.innerHeight * 0.5;
                const fullScreenHeight = window.innerHeight * 0.9;
                const myLocationBtn = document.getElementById('my-location-btn');
                
                if (newHeight >= fullScreenHeight) {
                    panelContent.classList.remove('collapsed');
                    panelContent.classList.add('expanded');
                    panel.classList.remove('collapsed', 'half-screen');
                    panel.classList.add('full-screen');
                    
                    // Hide location and favorites buttons in full screen
                    if (myLocationBtn) {
                        myLocationBtn.style.display = 'none';
                    }
                    const favoritesHeartBtn = document.getElementById('favorites-heart-btn');
                    if (favoritesHeartBtn) {
                        favoritesHeartBtn.style.display = 'none';
                    }
                    const userMenu = document.getElementById('user-menu');
                    if (userMenu) {
                        userMenu.style.display = 'none';
                    }
                } else if (newHeight >= halfScreenHeight) {
                    panelContent.classList.remove('collapsed');
                    panelContent.classList.add('expanded');
                    panel.classList.remove('collapsed', 'full-screen');
                    panel.classList.add('half-screen');
                    
                    // Show location, favorites, and user profile buttons and position them above panel
                    if (myLocationBtn) {
                        myLocationBtn.style.display = 'flex';
                        myLocationBtn.style.transition = 'none';
                        myLocationBtn.style.top = (window.innerHeight - newHeight - 60) + 'px';
                    }
                    const favoritesHeartBtn = document.getElementById('favorites-heart-btn');
                    if (favoritesHeartBtn) {
                        favoritesHeartBtn.style.display = 'flex';
                        favoritesHeartBtn.style.transition = 'none';
                        favoritesHeartBtn.style.top = (window.innerHeight - newHeight - 120) + 'px';
                    }
                    const userMenu = document.getElementById('user-menu');
                    if (userMenu) {
                        userMenu.style.display = 'block';
                        userMenu.style.transition = 'none';
                        userMenu.style.top = (window.innerHeight - newHeight - 180) + 'px';
                    }
                } else {
                    panelContent.classList.remove('expanded');
                    panelContent.classList.add('collapsed');
                    panel.classList.remove('half-screen', 'full-screen');
                    panel.classList.add('collapsed');
                    
                    // Show location, favorites, and user profile buttons and position them above panel
                    if (myLocationBtn) {
                        myLocationBtn.style.display = 'flex';
                        myLocationBtn.style.transition = 'none';
                        myLocationBtn.style.top = (window.innerHeight - newHeight - 60) + 'px';
                    }
                    const favoritesHeartBtn = document.getElementById('favorites-heart-btn');
                    if (favoritesHeartBtn) {
                        favoritesHeartBtn.style.display = 'flex';
                        favoritesHeartBtn.style.transition = 'none';
                        favoritesHeartBtn.style.top = (window.innerHeight - newHeight - 120) + 'px';
                    }
                    const userMenu = document.getElementById('user-menu');
                    if (userMenu) {
                        userMenu.style.display = 'block';
                        userMenu.style.transition = 'none';
                        userMenu.style.top = (window.innerHeight - newHeight - 180) + 'px';
                    }
                }
                
                e.preventDefault();
            }
            
            function handleEnd(e) {
                if (!isDragging) return;
                
                isDragging = false;
                panel.classList.remove('dragging');
                dragHandle.classList.remove('dragging');
                draggableHeader.classList.remove('dragging');
                
                // Restore smooth transitions for snapping
                panel.style.transition = 'height 0.3s cubic-bezier(0.4, 0, 0.2, 1)';
                
                const halfScreenHeight = window.innerHeight * 0.5;
                const fullScreenHeight = window.innerHeight * 0.9;
                const collapsedHeight = 38;
                const myLocationBtn = document.getElementById('my-location-btn');
                
                if (currentHeight >= fullScreenHeight) {
                    panel.style.height = '100vh';
                    panelContent.classList.remove('collapsed');
                    panelContent.classList.add('expanded');
                    panel.classList.remove('collapsed', 'half-screen');
                    panel.classList.add('full-screen');
                    
                    // Hide location and favorites buttons in full screen
                    if (myLocationBtn) {
                        myLocationBtn.style.display = 'none';
                    }
                    const favoritesHeartBtn = document.getElementById('favorites-heart-btn');
                    if (favoritesHeartBtn) {
                        favoritesHeartBtn.style.display = 'none';
                    }
                    const userMenu = document.getElementById('user-menu');
                    if (userMenu) {
                        userMenu.style.display = 'none';
                    }
                } else if (currentHeight >= halfScreenHeight) {
                    panel.style.height = '50vh';
                    panelContent.classList.remove('collapsed');
                    panelContent.classList.add('expanded');
                    panel.classList.remove('collapsed', 'full-screen');
                    panel.classList.add('half-screen');
                    
                    // Show location and favorites buttons and position them above panel
                    if (myLocationBtn) {
                        myLocationBtn.style.display = 'flex';
                        myLocationBtn.style.transition = 'all 0.3s ease';
                        myLocationBtn.style.top = 'calc(50vh - 60px)';
                    }
                    const favoritesHeartBtn = document.getElementById('favorites-heart-btn');
                    if (favoritesHeartBtn) {
                        favoritesHeartBtn.style.display = 'flex';
                        favoritesHeartBtn.style.transition = 'all 0.3s ease';
                        favoritesHeartBtn.style.top = 'calc(50vh - 120px)';
                    }
                    const userMenu = document.getElementById('user-menu');
                    if (userMenu) {
                        userMenu.style.display = 'block';
                        userMenu.style.transition = 'all 0.3s ease';
                        userMenu.style.top = 'calc(50vh - 180px)';
                    }
                } else {
                    panel.style.height = '38px';
                    panelContent.classList.remove('expanded');
                    panelContent.classList.add('collapsed');
                    panel.classList.remove('half-screen', 'full-screen');
                    panel.classList.add('collapsed');
                    
                    // Show location and favorites buttons and position them above panel
                    if (myLocationBtn) {
                        myLocationBtn.style.display = 'flex';
                        myLocationBtn.style.transition = 'all 0.3s ease';
                        myLocationBtn.style.top = 'calc(100vh - 60px - 60px)';
                    }
                    const favoritesHeartBtn = document.getElementById('favorites-heart-btn');
                    if (favoritesHeartBtn) {
                        favoritesHeartBtn.style.display = 'flex';
                        favoritesHeartBtn.style.transition = 'all 0.3s ease';
                        favoritesHeartBtn.style.top = 'calc(100vh - 60px - 120px)';
                    }
                    const userMenu = document.getElementById('user-menu');
                    if (userMenu) {
                        userMenu.style.display = 'block';
                        userMenu.style.transition = 'all 0.3s ease';
                        userMenu.style.top = 'calc(100vh - 60px - 180px)';
                    }
                }
            }
        }
        
        // Proactive suggestions
        async function fetchProactiveSuggestions() {
            try {
                if (window.isGuest) {
                    const files = [
                        '/data/foodtypes-51-500.json',
                        '/data/foodtypes-501-800.json',
                        '/data/foodtypes-801-1154.json'
                    ];
                    const all = [];
                    await Promise.all(files.map(async (p) => {
                        try {
                            const r = await fetch(p);
                            if (r.ok) {
                                const arr = await r.json();
                                arr.forEach(x => { if (x && x.name) all.push(x.name); });
                            }
                        } catch {}
                    }));
                    const unique = Array.from(new Set(all));
                    for (let i = unique.length - 1; i > 0; i--) {
                        const j = Math.floor(Math.random() * (i + 1));
                        [unique[i], unique[j]] = [unique[j], unique[i]];
                    }
                    const items = unique.slice(0, 12).map(name => ({ food: name }));
                    renderProactiveChips(items);
                    return;
                }
                // Logged-in generalized mode (health off): use randomized suggestions
                if (!healthDietModeEnabled) {
                    const files = [
                        '/data/foodtypes-51-500.json',
                        '/data/foodtypes-501-800.json',
                        '/data/foodtypes-801-1154.json'
                    ];
                    const all = [];
                    await Promise.all(files.map(async (p) => {
                        try {
                            const r = await fetch(p);
                            if (r.ok) {
                                const arr = await r.json();
                                arr.forEach(x => { if (x && x.name) all.push(x.name); });
                            }
                        } catch {}
                    }));
                    const unique = Array.from(new Set(all));
                    for (let i = unique.length - 1; i > 0; i--) {
                        const j = Math.floor(Math.random() * (i + 1));
                        [unique[i], unique[j]] = [unique[j], unique[i]];
                    }
                    const items = unique.slice(0, 12).map(name => ({ food: name }));
                    renderProactiveChips(items);
                    return;
                }
                const url = `/api/Chat/proactive-foods?top=8&includeHealthDietRestrictions=true`;
                const response = await fetch(url, {
                    method: 'GET',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                });
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                const payload = await response.json();
                renderProactiveChips(payload.items || []);
            } catch (error) {
                console.error('Error loading proactive suggestions:', error);
                renderProactiveChips([]);
            }
        }
        
        function renderProactiveChips(items) {
            const wrapper = document.getElementById('proactive-chip-list');
            const container = document.getElementById('proactive-suggestions');
            if (!wrapper || !container) return;
            
            wrapper.innerHTML = '';
            if (!items || !items.length) { 
                const defaultSuggestions = [
                    { food: 'Pizza', reason: 'Popular choice' },
                    { food: 'Sushi', reason: 'Fresh and healthy' },
                    { food: 'Burger', reason: 'Classic comfort food' },
                    { food: 'Pasta', reason: 'Italian favorite' },
                    { food: 'Ramen', reason: 'Warm and satisfying' },
                    { food: 'Salad', reason: 'Light and fresh' }
                ];
                
                container.style.display = 'block';
                defaultSuggestions.slice(0, 6).forEach((item, index) => {
                    const btn = document.createElement('button');
                    btn.type = 'button';
                    btn.className = 'proactive-chip';
                    btn.style.animationDelay = (index * 0.05) + 's';
                    
                    const emoji = getFoodEmoji(item.food);
                    btn.innerHTML = `<span class="emoji">${emoji}</span><span>${item.food}</span>`;
                    btn.title = item.reason;
                    
                    btn.onclick = function() {
                        const message = `I want to try ${item.food}`;
                        
                        // Set flag to indicate this is from proactive suggestion
                        isFromProactiveSuggestion = true;
                        
                        // Set the input value and send message (don't add message manually)
                        const chatInput = document.getElementById('chat-input');
                        chatInput.value = message;
                        sendMessage();
                    };
                    
                    wrapper.appendChild(btn);
                });
                return; 
            }
            
            container.style.display = 'block';
            items.slice(0, 8).forEach((it, index) => {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'proactive-chip';
                btn.style.animationDelay = (index * 0.05) + 's';
                
                const emoji = getFoodEmoji(it.food);
                btn.innerHTML = `<span class="emoji">${emoji}</span><span>${it.food}</span>`;
                btn.title = (it.reason ? ('Reason: ' + it.reason) : '') + (it.safe === false ? ' (may not match restrictions)' : '');
                
                btn.onclick = function() {
                    const message = `I want to try ${it.food}`;
                    
                    // Set flag to indicate this is from proactive suggestion
                    isFromProactiveSuggestion = true;
                    
                    // Set the input value and send message (don't add message manually)
                    const chatInput = document.getElementById('chat-input');
                    chatInput.value = message;
                    sendMessage();
                };
                
                wrapper.appendChild(btn);
            });
        }
        
        function getFoodEmoji(food) {
            const foodLower = food.toLowerCase();
            if (foodLower.includes('pizza')) return '🍕';
            if (foodLower.includes('burger')) return '🍔';
            if (foodLower.includes('sushi')) return '🍣';
            if (foodLower.includes('ramen')) return '🍜';
            if (foodLower.includes('pasta')) return '🍝';
            if (foodLower.includes('salad')) return '🥗';
            if (foodLower.includes('sandwich')) return '🥪';
            if (foodLower.includes('taco')) return '🌮';
            if (foodLower.includes('chicken')) return '🍗';
            if (foodLower.includes('fish')) return '🐟';
            if (foodLower.includes('beef')) return '🥩';
            if (foodLower.includes('rice')) return '🍚';
            if (foodLower.includes('noodle')) return '🍜';
            if (foodLower.includes('soup')) return '🍲';
            if (foodLower.includes('dessert')) return '🍰';
            if (foodLower.includes('cake')) return '🎂';
            if (foodLower.includes('ice cream')) return '🍦';
            if (foodLower.includes('coffee')) return '☕';
            if (foodLower.includes('tea')) return '🍵';
            if (foodLower.includes('drink')) return '🥤';
            return '🍽️';
        }
        
