        }

        // Show review form
        function showReviewForm(placeId, placeName) {
            // Show review form in the chatbot panel
            const messagesDiv = document.getElementById('new-messages');
            if (!messagesDiv) {
                // If chat panel is not visible, show it first
                const chatTab = document.getElementById('chat-tab');
                const chatContent = document.getElementById('chat-content');
                const restaurantDetailsContent = document.getElementById('restaurant-details-content');
                
                if (chatTab && chatContent) {
                    chatTab.click();
                    // Wait for chat to be visible
                    setTimeout(() => {
                        addReviewFormToChat(placeId, placeName);
                    }, 100);
                } else {
                    alert('Please open the chat to submit a review.');
                }
                return;
            }
            
            addReviewFormToChat(placeId, placeName);
        }

        function addReviewFormToChat(placeId, placeName) {
            const messagesDiv = document.getElementById('new-messages');
            if (!messagesDiv) return;
            
            // Create review form
            const reviewForm = document.createElement('div');
            reviewForm.className = 'mb-4 p-4 bg-blue-50 rounded border';
            reviewForm.innerHTML = `
                <h3 class="font-semibold text-blue-800 mb-3">⭐ Review ${placeName}</h3>
                <div class="space-y-3">
                    <div>
                        <label class="block text-sm font-medium text-blue-700 mb-1">Rating</label>
                        <div class="flex gap-2">
                            ${[1, 2, 3, 4, 5].map(rating => `
                                <button onclick="setRating(${rating}, event)" 
                                        class="rating-btn px-3 py-1 border rounded hover:bg-blue-100" 
                                        data-rating="${rating}">
                                    ★ ${rating}
                                </button>
                            `).join('')}
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-blue-700 mb-1">Review</label>
                        <textarea id="review-text" 
                                  placeholder="Share your experience..." 
                                  class="w-full p-2 border rounded resize-none" 
                                  rows="3"></textarea>
                    </div>
                    <div class="flex gap-2">
                        <button onclick="submitReview('${placeId}', '${escapeHtml(placeName)}')" 
                                class="px-4 py-2 bg-green-500 text-white rounded hover:bg-green-600">
                            Submit Review
                        </button>
                        <button onclick="cancelReview()" 
                                class="px-4 py-2 bg-gray-500 text-white rounded hover:bg-gray-600">
                            Cancel
                        </button>
                    </div>
                </div>
            `;
            
            messagesDiv.appendChild(reviewForm);

            // Scroll to bottom
            const chatMessages = document.getElementById('chat-messages');
            if (chatMessages) {
                chatMessages.scrollTop = chatMessages.scrollHeight;
            }
            
            // Add rating selection functionality
            window.setRating = function(rating, event) {
                document.querySelectorAll('.rating-btn').forEach(btn => {
                    btn.classList.remove('bg-blue-200', 'border-blue-500');
                    btn.classList.add('border-gray-300');
                });
                if (event && event.target) {
                    event.target.classList.add('bg-blue-200', 'border-blue-500');
                } else {
                    // Fallback: find button by data-rating
                    const btn = document.querySelector(`.rating-btn[data-rating="${rating}"]`);
                    if (btn) btn.classList.add('bg-blue-200', 'border-blue-500');
                }
                window.selectedRating = rating;
            };
        }

        // Submit review
        async function submitReview(placeId, placeName) {
            const rating = window.selectedRating;
            const reviewText = document.getElementById('review-text')?.value.trim();
            
            if (!rating) {
                addMessage('FoodieSaur Bot', 'Please select a rating.');
                return;
            }
            
            try {
                await fetch('/api/Chat/recommendation/select-self', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        establishmentName: placeName, 
                        rating: rating, 
                        feedback: reviewText || '' 
                    })
                });
                
                // Remove review form
                cancelReview();
                
                // Add user's review to chat
                addMessage('You', `I gave ${placeName} a ${rating}-star rating. ${reviewText ? `My review: "${reviewText}"` : ''}`);
                
                // AI responds and asks follow-up questions
                addMessage('FoodieSaur Bot', `Thank you for your review of ${placeName}! I see you gave it ${rating} stars. ${rating >= 4 ? 'That sounds great!' : rating >= 3 ? 'How was the overall experience?' : 'What could they improve?'} Tell me more about your visit - what did you order and how was the food?`);
                
            } catch (e) {
                console.error(e);
                addMessage('FoodieSaur Bot', 'Failed to submit review.');
            }
        }

        // Cancel review
        function cancelReview() {
            const reviewForm = document.querySelector('#new-messages .bg-blue-50.rounded.border:last-child');
            if (reviewForm) {
                reviewForm.remove();
            }
        }

        function getStoreStatus(place) {
            const hours = place.opening_hours || place.current_opening_hours;
            if (!hours) {
                return { isOpen: false, text: 'Hours not available' };
            }
            
            if (hours.open_now !== undefined) {
                return { 
                    isOpen: hours.open_now, 
                    text: hours.open_now ? 'Open now' : 'Closed now' 
                };
            }
            
            return { isOpen: false, text: 'Hours not available' };
        }

        // Expand Google Maps short URL (matching desktop)
        async function expandGoogleMapsUrl(shortUrl) {
            try {
                console.log('Expanding URL:', shortUrl);
                
                // Use a proxy service to expand the URL
                const response = await fetch('/WebScraping/ExpandGoogleMapsUrl', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `url=${encodeURIComponent(shortUrl)}`
                });
                
                const result = await response.json();
                
                if (result.success && result.expandedUrl) {
                    console.log('URL expanded successfully:', result.expandedUrl);
                    return result.expandedUrl;
                } else {
                    console.warn('URL expansion failed, using original URL:', result.message);
                    return shortUrl;
                }
            } catch (error) {
                console.error('Error expanding URL:', error);
                return shortUrl;
            }
        }

        // Helper: Optimize Google-hosted image URLs for desired size/quality (matching desktop)
        function getOptimizedMenuImageUrl(url, kind) {
            try {
                if (!url || typeof url !== 'string') return url;
                const size = kind === 'full' ? 1600 : 400; // fullscreen vs thumbnail
                let optimized = url;
                // Common Google photo URL patterns
                optimized = optimized.replace(/([=\/-])w\d+-h\d+(-[a-zA-Z-]+)?/g, `$1w${size}-h${size}$2`);
                optimized = optimized.replace(/=s\d+(-[a-zA-Z-]+)?/g, `=s${size}$1`);
                // If no size token found, append one for googleusercontent/ggpht URLs
                if (!/[=\/-]w\d+-h\d+/.test(optimized) && !/=s\d+/.test(optimized) && /(googleusercontent|ggpht|gstatic)\./.test(optimized)) {
                    optimized += (optimized.includes('?') ? '&' : '=') + `s${size}`;
                }
                return optimized;
            } catch (_) {
                return url;
            }
        }

        // Function to fetch menu images from Google Maps (matching desktop)
