        window.openMenuImageModal = function(src) {
            console.log('openMenuImageModal called with:', src);
            const modal = document.getElementById('menu-image-modal');
            const img = document.getElementById('menu-image-modal-img');
            if (!modal || !img) {
                console.error('Menu image modal elements not found', {modal: !!modal, img: !!img});
                return;
            }
            
            // Decode HTML entities if present (from data attributes)
            let decodedSrc = src;
            if (typeof src === 'string' && src) {
                // Decode HTML entities
                const textarea = document.createElement('textarea');
                textarea.innerHTML = src;
                decodedSrc = textarea.value;
            }
            
            // Get optimized full-size URL
            let optimizedSrc = decodedSrc;
            if (typeof getOptimizedMenuImageUrl === 'function') {
                optimizedSrc = getOptimizedMenuImageUrl(decodedSrc, 'full') || decodedSrc;
            }
            
            img.src = optimizedSrc;
            img.onerror = function() {
                console.error('Failed to load image:', optimizedSrc);
                img.src = decodedSrc; // Fallback to original
            };
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
            // Prevent body scroll on mobile
            document.body.style.position = 'fixed';
            document.body.style.width = '100%';
            console.log('Modal opened');
        };

        window.closeMenuImageModal = function() {
            const modal = document.getElementById('menu-image-modal');
            const img = document.getElementById('menu-image-modal-img');
            if (!modal || !img) return;
            modal.style.display = 'none';
            img.src = '';
