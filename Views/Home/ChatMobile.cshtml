        async function calculateDrivingDistance(destination) {
            if (!userLocation || !destination) {
                return { distanceText: 'Distance unavailable', durationText: 'Time unavailable' };
            }
            
            const service = new google.maps.DistanceMatrixService();
            return new Promise((resolve) => {
                service.getDistanceMatrix({
                    origins: [userLocation],
                    destinations: [destination],
                    travelMode: google.maps.TravelMode.DRIVING,
                    unitSystem: google.maps.UnitSystem.METRIC,
                }, (response, status) => {
                    if (status === 'OK' && response.rows[0].elements[0].status === 'OK') {
                        const element = response.rows[0].elements[0];
                        resolve({
                            distanceText: element.distance.text,
                            durationText: element.duration.text
                        });
                    } else {
                        resolve({ distanceText: 'Distance unavailable', durationText: 'Time unavailable' });
                    }
                });
            });
        }

        async function removeFavorite(placeId, buttonElement) {
            try {
                const response = await fetch(`/api/Favorites/remove/${placeId}`, {
                    method: 'DELETE'
                });
                
                if (response.ok) {
                    userFavorites.delete(placeId);
                    favoritesData = favoritesData.filter(fav => fav.placeId !== placeId);
                    
                    if (buttonElement) {
                        buttonElement.textContent = '💔 Removed';
                        buttonElement.style.background = '#6b7280';
                        buttonElement.style.borderColor = '#6b7280';
                        buttonElement.style.color = 'white';
                    }
                    
                    updateFavoritesCount();
                    displayFavorites();
                }
            } catch (error) {
                console.error('Error removing favorite:', error);
            }
        }

        function shareFavorite(placeId) {
            const favorite = favoritesData.find(fav => fav.placeId === placeId);
            if (favorite && navigator.share) {
                navigator.share({
                    title: favorite.name,
                    text: `Check out ${favorite.name} at ${favorite.address}`,
                    url: window.location.href
                });
            } else {
                // Fallback to copying to clipboard
                const text = `Check out ${favorite.name} at ${favorite.address}`;
                navigator.clipboard.writeText(text).then(() => {
                    alert('Restaurant details copied to clipboard!');
                });
            }
        }

        function goToFavorite(placeId) {
            const favorite = favoritesData.find(fav => fav.placeId === placeId);
            if (favorite && favorite.latitude && favorite.longitude) {
                const location = { lat: parseFloat(favorite.latitude), lng: parseFloat(favorite.longitude) };
                map.setCenter(location);
                map.setZoom(16);
                
                // Close favorites panel and show results
                closeFavoritesPanel();
            }
        }

        // Show favorites markers on map
        function showFavoritesMarkers() {
            // Clear existing favorites markers
            hideFavoritesMarkers();
            
            favoritesData.forEach((favorite, index) => {
                if (favorite.latitude && favorite.longitude) {
                    const location = { lat: parseFloat(favorite.latitude), lng: parseFloat(favorite.longitude) };
                    
                    // Create marker with same style as Chat.cshtml
                    const marker = new google.maps.Marker({
                        position: location,
                        map: map,
                        title: favorite.name,
                        icon: {
                            url: '/images/MapPinLine.svg',
                            scaledSize: new google.maps.Size(32, 32)
                        },
                        animation: google.maps.Animation.DROP
                    });
                    
                    // Create info window with same style as Chat.cshtml
                    const closeId = `fav-iw-close-${favorite.placeId}`;
                    const contentHtml = `
                        <div style="background:#47682C; padding:10px 14px; border-radius:6px; position:relative; color:#FFFFFF; font-weight:600;">
                            <div style="display:flex; align-items:center; justify-content:space-between; gap:12px;">
                                <span style="font-size:14px;">${escapeHtml(favorite.name || '')}</span>
                                <button id="${closeId}" style="background:transparent; border:none; font-weight:700; color:#FFFFFF; cursor:pointer;">×</button>
                            </div>
                            <div style="position:absolute; left:24px; bottom:-10px; width:0; height:0; border-left:10px solid transparent; border-right:10px solid transparent; border-top:10px solid #47682C;"></div>
                        </div>`;
                    const infoWindow = new google.maps.InfoWindow({ content: contentHtml, shouldFocus: false });
                    
                    // Add click listener to marker
                    marker.addListener('click', () => {
                        // Close other info windows
                        favoritesInfoWindows.forEach(iw => iw.close());
                        
                        // Open this info window
                        infoWindow.open(map, marker);
                        
                        // Show restaurant detail card
                        showRestaurantDetailCard(favorite, index);
                        
                        // Open restaurant details panel (full panel with all information)
                        openRestaurantDetailsPanel(favorite);
                        
                        // Expand panel to half-screen
                        expandPanelToHalfScreen();
                    });
                    
                    // Automatically open all info windows when favorites are shown
                    infoWindow.open(map, marker);
                    
                    // Add click listener to info window close
                    infoWindow.addListener('closeclick', () => {
                        hideRestaurantDetailCard();
                    });
                    
                    // Add close button functionality
                    setTimeout(() => {
                        const closeBtn = document.getElementById(closeId);
                        if (closeBtn) {
                            closeBtn.addEventListener('click', () => {
                                infoWindow.close();
                                hideRestaurantDetailCard();
                            });
                        }
                    }, 100);
                    
                    favoritesMarkers.push(marker);
                    favoritesInfoWindows.push(infoWindow);
                }
            });
        }

        // Hide favorites markers
        function hideFavoritesMarkers() {
            favoritesMarkers.forEach(marker => marker.setMap(null));
            favoritesInfoWindows.forEach(infoWindow => infoWindow.close());
            favoritesMarkers = [];
            favoritesInfoWindows = [];
        }
        
