        // Identify personalized recommendation
        function isPersonalizedRecommendation(text) {
            const t = String(text ?? '');
            const hasProfileCue = /Based on your comprehensive profile|I know you follow|I've analyzed your preferences|Let me share some personalized|I've curated these options|Here are some fantastic choices|I've discovered some amazing options|Let me present some carefully selected|I've found some excellent choices|Here are some personalized suggestions|I've prepared some wonderful options|Let me share some perfect matches|I've carefully studied your profile|After reviewing your preferences|I've examined your tastes|I've analyzed your requirements|I'd love to present|Allow me to share|I'm excited to present|Let me show you|I've handpicked these selections|I've carefully chosen these options|I've selected these recommendations|I've curated a special list|I've discovered some amazing options|I've found some incredible choices|Here are some wonderful discoveries|I've uncovered some excellent options|I've prepared some wonderful options|I've crafted some special recommendations|I've designed these suggestions|I've put together some perfect options|I've created some custom recommendations|I've tailored these options|I've personalized these suggestions|I'm thrilled to present|I'm excited to share|I can't wait to show you|I'm delighted to present|Based on my analysis|I'm confident these selections|I've identified the perfect options|These recommendations are specifically designed|I've determined the best choices/i.test(t);
            const hasNumberedScores = /\n\s*\d+\.\s*[^\n]+\(Score:\s*\d+(?:\.\d+)?\)/i.test(t);
            const hasChooseSection = /Choose a food type\s*:/i.test(t);
            const hasOrganizedStructure = /Based on your comprehensive profile, I recommend these foods:|Here are my top recommendations for you:|These are the best options I've found for you:|I've selected these foods specifically for you:|Here are the perfect choices for your profile:|These recommendations are tailored to your needs:|I've chosen these options with you in mind:|Here are the ideal selections for your preferences:|These foods are perfectly suited to your profile:|I've picked these recommendations just for you:|Here are the best matches for your taste profile:|These selections are customized for your needs:|I've curated these options specifically for you:|Here are the perfect picks for your preferences:|These recommendations are designed for your profile:|I've handpicked these foods for your enjoyment:|Here are the ideal choices for your taste:|These options are perfectly matched to your needs:|I've selected these foods with your preferences in mind:|Here are the best recommendations for your profile:/i.test(t);
            return hasProfileCue && (hasNumberedScores || hasChooseSection || hasOrganizedStructure);
        }

        // Heuristic: detect if a user message is likely a personalized query (client-side)
        function isLikelyPersonalizedQuery(text) {
            const t = String(text || '').toLowerCase();
            const patterns = [
                /\bmy\b/, /\bfor me\b/, /\bi\s*(am|have|want|prefer)\b/,
                /\bprefer\b/, /\bfavorite\b/, /\bbased on (my|me)\b/,
                /\bdiabet(es|ic)\b/, /\bhypertension\b/, /\bcholesterol\b/, /\bdiet\b/,
                /\bpersonal(ized|ise|ise?d)\b/, /\bprofile\b/
            ];
            return patterns.some((re) => re.test(t));
        }
        
        // Render personalized recommendation
        function renderPersonalizedRecommendation(text) {
            const container = document.getElementById('new-messages');
            let raw = String(text ?? '');
            
            // Remove scores from the text: (Score: X.XX) or (Score: X)
            raw = raw.replace(/\s*\(Score:\s*[\d.]+\)/gi, '');
            
            const paragraphs = raw
                .replace(/\r\n/g, '\n')
                .split(/\n\s*\n+/)
                .map(p => p.trim())
                .filter(Boolean);

            paragraphs.forEach(p => {
                const messageDiv = document.createElement('div');
                messageDiv.style.cssText = 'margin-bottom:1rem; animation:slideInLeft 0.4s ease-out;';
                const safe = escapeHtml(p).replace(/\n/g, '<br>');
                messageDiv.innerHTML = `
                    <div style="background:rgba(71,104,44,0.08); backdrop-filter:blur(4px); color:#47682C; padding:0.875rem 1.125rem; border-radius:1.25rem; border-top-left-radius:0.25rem; border:1px solid rgba(71,104,44,0.1); box-shadow:0 4px 12px rgba(71,104,44,0.12); transition:transform 0.2s ease, box-shadow 0.2s ease; max-width:85%;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 16px rgba(71,104,44,0.18)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 12px rgba(71,104,44,0.12)'">
                        <p style="font-size:0.9rem; margin:0; line-height:1.6; font-weight:500;">${safe}</p>
                    </div>
                `;
                container.appendChild(messageDiv);
            });

            const chatMessages = document.getElementById('chat-messages');
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }
        
        // Render action buttons from response
        function renderActionButtonsFromResponse(text) {
            const messagesDiv = document.getElementById('new-messages');
            const raw = String(text ?? '');
            let names = [];
            
            // Look for the organized format with various headers
            const organizedSection = raw.match(/(?:Based on your comprehensive profile, I recommend these foods:|Here are my top recommendations for you:|These are the best options I've found for you:|I've selected these foods specifically for you:|Here are the perfect choices for your profile:|These recommendations are tailored to your needs:|I've chosen these options with you in mind:|Here are the ideal selections for your preferences:|These foods are perfectly suited to your profile:|I've picked these recommendations just for you:|Here are the best matches for your taste profile:|These selections are customized for your needs:|I've curated these options specifically for you:|Here are the perfect picks for your preferences:|These recommendations are designed for your profile:|I've handpicked these foods for your enjoyment:|Here are the ideal choices for your taste:|These options are perfectly matched to your needs:|I've selected these foods with your preferences in mind:|Here are the best recommendations for your profile:)\s*\n((?:\d+\.\s*[^\n]+\(Score:\s*[\d.]+\)\s*\n?)+)/i);
            if (organizedSection) {
                const foodLines = organizedSection[1].split('\n').filter(line => line.trim());
                names = foodLines.map(line => {
                    // Extract name before "(Score:" and remove any score patterns
                    let name = line.replace(/^\d+\.\s*/, '').trim();
                    // Remove score pattern: (Score: X.XX) or (Score: X)
                    name = name.replace(/\s*\(Score:\s*[\d.]+\).*$/i, '').trim();
                    // Also remove any trailing parentheses with scores
                    name = name.replace(/\s*\([^)]*Score[^)]*\).*$/i, '').trim();
                    // Remove any trailing dashes or separators
                    name = name.split(/[–—-]/)[0].trim();
                    return name;
                }).filter(name => name.length > 0);
                } else {
                // Fallback to original parsing for backward compatibility (matching desktop)
                const byLines = raw.split('\n').filter(l => /^\s*\d+\.\s+\w+/i.test(l));
                if (byLines.length > 0) {
                    names = byLines.map(l => {
                        let name = l.replace(/^\s*\d+\.\s+/, '').trim();
                        // Remove score pattern
                        name = name.replace(/\s*\(Score:\s*[\d.]+\).*$/i, '').trim();
                        name = name.split(/[–—-]/)[0].trim();
                        return name;
                    }).filter(name => name.length > 0);
                } else {
                    const pattern = /(\d+)\.\s*([A-Za-z][A-Za-z\s-()]{1,60})/g;
                    let m;
                    while ((m = pattern.exec(raw)) !== null) {
                        let name = m[2].trim();
                        // Remove score pattern
                        name = name.replace(/\s*\(Score:\s*[\d.]+\).*$/i, '').trim();
                        name = name.split(/[–—-]/)[0].trim();
                        if (name.length > 0) {
                            names.push(name);
                        }
                    }
                }
            }

            if (names.length > 0) {
