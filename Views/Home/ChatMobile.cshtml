        // Handle favorite card click
        function handleFavoriteCardClick(favorite, index) {
            // Set current restaurant list to favorites
            currentRestaurantList = favoritesData;
            currentRestaurantIndex = index;
            
            // Show restaurant detail card
            showRestaurantDetailCard(favorite, index);
            
            // Center map on favorite location and pan upward
            if (favorite.latitude && favorite.longitude) {
                const location = { lat: parseFloat(favorite.latitude), lng: parseFloat(favorite.longitude) };
                map.setCenter(location);
                map.setZoom(16);
                // Pan upward to make marker clearly visible when panel is at 50% height
                map.panBy(0, window.innerHeight * 0.10);
            }
            
            // Expand panel to half-screen
            expandPanelToHalfScreen();
        }

        async function populateRestaurantDetailsPanel(place) {
            const detailsBody = document.getElementById('restaurant-details-body');
            if (!detailsBody) return;

            // Ensure complete details
            let completePlace = place;
            try {
                if (place && place.place_id && (!place.formatted_address || !place.opening_hours || !place.photos || place.price_level == null || !place.reviews)) {
                    const service = new google.maps.places.PlacesService(map);
                    const request = {
                        placeId: place.place_id,
                        fields: ['name', 'rating', 'price_level', 'formatted_address', 'opening_hours', 'types', 'user_ratings_total', 'photos', 'formatted_phone_number', 'reviews']
                    };
                    
                    service.getDetails(request, (placeDetails, status) => {
                        if (status === google.maps.places.PlacesServiceStatus.OK) {
                            completePlace = { ...place, ...placeDetails };
                            renderRestaurantDetailsContent(completePlace);
                        } else {
                            renderRestaurantDetailsContent(place);
                        }
                    });
                } else {
                    renderRestaurantDetailsContent(place);
                }
            } catch (e) {
                console.warn('Failed to fetch complete details:', e);
                renderRestaurantDetailsContent(place);
            }
        }

        function renderRestaurantDetailsContent(place) {
            const detailsBody = document.getElementById('restaurant-details-body');
            if (!detailsBody) return;

            // Get price range text
