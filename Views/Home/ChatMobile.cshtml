        // Enhanced touch/swipe support for mobile
        let touchStartX = 0;
        let touchEndX = 0;
        let touchStartY = 0;
        let touchEndY = 0;
        let isDragging = false;
        let swipeHintTimeout = null;

        function handleTouchStart(e) {
            touchStartX = e.changedTouches[0].screenX;
            touchStartY = e.changedTouches[0].screenY;
            isDragging = true;
            
            // Show swipe hint briefly on first touch
            showSwipeHint();
        }

        function handleTouchMove(e) {
            if (!isDragging) return;
            
            const currentX = e.changedTouches[0].screenX;
            const currentY = e.changedTouches[0].screenY;
            const diffX = touchStartX - currentX;
            const diffY = touchStartY - currentY;
            
            // Only process horizontal swipes (ignore vertical scrolling)
            if (Math.abs(diffX) > Math.abs(diffY)) {
                e.preventDefault(); // Prevent scrolling
                
                // Add visual feedback during swipe - card follows finger precisely
                const card = document.getElementById('restaurant-detail-card');
                if (card) {
                    // Make swipe follow finger more precisely with better limits
                    // Reverse the direction so card moves opposite to finger direction
                    const swipeAmount = Math.max(-80, Math.min(80, -diffX * 0.8));
                    card.style.transform = `translateX(-50%) translateX(${swipeAmount}px)`;
                    card.style.opacity = Math.max(0.7, 1 - Math.abs(swipeAmount) / 160);
                    
                    // Remove rotation to prevent tilting
                    // Add subtle scale effect for better visual feedback instead
                    const scale = Math.max(0.95, 1 - Math.abs(swipeAmount) / 200);
                    card.style.transform += ` scale(${scale})`;
                }
            }
        }

        function handleTouchEnd(e) {
            if (!isDragging) return;
            
            touchEndX = e.changedTouches[0].screenX;
            touchEndY = e.changedTouches[0].screenY;
            isDragging = false;
            
            // Reset card position with smooth transition
            const card = document.getElementById('restaurant-detail-card');
            if (card) {
                card.style.transition = 'all 0.3s cubic-bezier(0.4, 0, 0.2, 1)';
                card.style.transform = 'translateX(-50%) translateX(0) scale(1)';
                card.style.opacity = '1';
                
                // Remove transition after reset
                setTimeout(() => {
                    card.style.transition = '';
                }, 300);
            }
            
            handleSwipe();
        }

        function handleSwipe() {
            const swipeThreshold = 50; // Reduced threshold for more responsive swipes
            const diffX = touchStartX - touchEndX;
            const diffY = touchStartY - touchEndY;
            
            // Only process horizontal swipes with sufficient distance
            if (Math.abs(diffX) > swipeThreshold && Math.abs(diffX) > Math.abs(diffY)) {
                if (diffX > 0) {
                    // User swiped right to left - go to next (card slides left)
                    navigateToNextWithAnimation();
                } else {
                    // User swiped left to right - go to previous (card slides right)
                    navigateToPreviousWithAnimation();
                }
            }
        }

        function showSwipeHint() {
            const hint = document.getElementById('swipe-hint');
            if (hint && !hint.classList.contains('show')) {
                hint.classList.add('show');
                
                // Hide hint after 3 seconds
                clearTimeout(swipeHintTimeout);
                swipeHintTimeout = setTimeout(() => {
                    hint.classList.remove('show');
                }, 3000);
            }
        }

        function updateSwipeIndicators() {
            const indicator = document.getElementById('swipe-indicator');
