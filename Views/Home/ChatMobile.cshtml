                        <p style="margin:0; font-size:1.125rem; font-weight:700; color:#47682C; margin-bottom:0.5rem;">No favorites yet</p>
                        <p style="margin:0; font-size:0.875rem; color:#6b7280; line-height:1.5;">Discover amazing restaurants and<br/>save your favorites by tapping the heart icon</p>
                    </div>
                `;
                return;
            }
            
