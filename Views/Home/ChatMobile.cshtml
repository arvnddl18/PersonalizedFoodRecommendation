        // Check if user has completed tour before
        function hasCompletedTour() {
            return localStorage.getItem('foodiesaur_tour_completed') === 'true';
        }

        function markTourCompleted() {
            localStorage.setItem('foodiesaur_tour_completed', 'true');
        }

        // Get element position for tooltip placement
        function getElementPosition(element) {
            if (!element) return { top: '50%', left: '50%', width: 0, height: 0 };
            const rect = element.getBoundingClientRect();
            return {
                top: rect.top,
                left: rect.left,
                width: rect.width,
                height: rect.height,
                centerX: rect.left + rect.width / 2,
                centerY: rect.top + rect.height / 2
            };
        }

        // Position arrow pointing to clickable element
        function positionArrow(arrowTargetSelector) {
            const arrow = document.getElementById('tour-arrow');
            
            if (!arrowTargetSelector) {
                arrow.style.opacity = '0';
                return;
            }

            // Try to find the arrow target element
            let arrowTargetElement = null;
            
            // Handle different selector types
            if (arrowTargetSelector === '.result-item:first-child') {
                arrowTargetElement = document.querySelector('.result-item');
            } else if (arrowTargetSelector === '#proactive-chip-list') {
                // Try to find the first proactive chip button
                const chipList = document.querySelector(arrowTargetSelector);
                if (chipList) {
                    arrowTargetElement = chipList.querySelector('button') || chipList.firstElementChild;
                }
                // If no chips found, hide arrow
                if (!arrowTargetElement) {
                    arrow.style.opacity = '0';
                    return;
                }
            } else {
                arrowTargetElement = document.querySelector(arrowTargetSelector);
            }

            if (!arrowTargetElement) {
                arrow.style.opacity = '0';
                return;
            }

            const pos = getElementPosition(arrowTargetElement);
            const arrowOffset = 50;

            const arrowIcon = arrow.querySelector('div');
            // Default: place arrow to the LEFT of the element, pointing RIGHT
            arrow.style.left = (pos.left - arrowOffset) + 'px';
            arrow.style.top = (pos.centerY - 40) + 'px';
            if (arrowIcon) { 
                arrowIcon.textContent = '➜';
                arrowIcon.style.transform = 'none';
            }

            arrow.style.opacity = '1';
        }

        // Position tooltip based on target element and position preference
        function positionTooltip(targetElement, position) {
            const tooltip = document.getElementById('tour-tooltip');
            const highlight = document.getElementById('tour-highlight');
            
            if (!targetElement) {
                // Center position
                tooltip.style.top = '50%';
                tooltip.style.left = '50%';
                tooltip.style.transform = 'translate(-50%, -50%)';
                highlight.style.opacity = '0';
                return;
            }

            const pos = getElementPosition(targetElement);
            const padding = 20;
            
            // Temporarily make tooltip visible to measure it
            const wasVisible = tooltip.style.opacity !== '0';
            if (!wasVisible) {
                tooltip.style.opacity = '0';
                tooltip.style.visibility = 'hidden';
                tooltip.style.display = 'block';
            }
            
            const tooltipRect = tooltip.getBoundingClientRect();
            const tooltipWidth = tooltipRect.width || Math.min(window.innerWidth * 0.9, 400);
            const tooltipHeight = tooltipRect.height || 250;

            // Set highlight position
            highlight.style.left = (pos.left - 10) + 'px';
            highlight.style.top = (pos.top - 10) + 'px';
            highlight.style.width = (pos.width + 20) + 'px';
            highlight.style.height = (pos.height + 20) + 'px';
            highlight.style.opacity = '1';

            // Position tooltip - ensure it doesn't cover highlighted element
            let tooltipTop, tooltipLeft;
            
            // Calculate highlight area bounds (with the extra 10px padding from highlight styling)
            const highlightLeft = pos.left - 10;
            const highlightTop = pos.top - 10;
            const highlightRight = pos.left + pos.width + 10;
            const highlightBottom = pos.top + pos.height + 10;
            
            // Function to check if tooltip overlaps with highlight
            function checkOverlap(ttTop, ttLeft) {
                const ttRight = ttLeft + tooltipWidth;
                const ttBottom = ttTop + tooltipHeight;
                return !(ttRight < highlightLeft || ttLeft > highlightRight || ttBottom < highlightTop || ttTop > highlightBottom);
            }
            
            const viewportPadding = 10;
            
            // Function to find best position that doesn't overlap
            function findBestPosition(preferredPosition) {
                let testTop, testLeft;
                const gap = padding + 5; // Extra gap to ensure clear separation
                
                switch(preferredPosition) {
                    case 'top':
                        testTop = highlightTop - tooltipHeight - gap;
                        testLeft = pos.centerX - tooltipWidth / 2;
                        if (!checkOverlap(testTop, testLeft) && testTop >= viewportPadding) {
                            return { top: testTop, left: testLeft, position: 'top' };
                        }
                        // Fall through to try other positions
                        break;
                    case 'bottom':
                        testTop = highlightBottom + gap;
                        testLeft = pos.centerX - tooltipWidth / 2;
                        if (!checkOverlap(testTop, testLeft) && testTop + tooltipHeight <= window.innerHeight - viewportPadding) {
                            return { top: testTop, left: testLeft, position: 'bottom' };
                        }
                        break;
                    case 'left':
                        testTop = pos.centerY - tooltipHeight / 2;
                        testLeft = highlightLeft - tooltipWidth - gap;
                        if (!checkOverlap(testTop, testLeft) && testLeft >= viewportPadding) {
                            return { top: testTop, left: testLeft, position: 'left' };
                        }
                        break;
                    case 'right':
                        testTop = pos.centerY - tooltipHeight / 2;
                        testLeft = highlightRight + gap;
                        if (!checkOverlap(testTop, testLeft) && testLeft + tooltipWidth <= window.innerWidth - viewportPadding) {
                            return { top: testTop, left: testLeft, position: 'right' };
                        }
                        break;
                    default: // center - should not overlap, position away from element
                        // For center, position below or above
                        testTop = highlightBottom + gap;
                        testLeft = pos.centerX - tooltipWidth / 2;
                        if (!checkOverlap(testTop, testLeft)) {
                            return { top: testTop, left: testLeft, position: 'bottom' };
                        }
                        testTop = highlightTop - tooltipHeight - gap;
                        if (!checkOverlap(testTop, testLeft)) {
                            return { top: testTop, left: testLeft, position: 'top' };
                        }
                        break;
                }
                
                // If preferred position doesn't work, try alternative positions
                const alternatives = ['bottom', 'top', 'right', 'left'];
                for (let alt of alternatives) {
                    if (alt === preferredPosition) continue;
                    switch(alt) {
                        case 'top':
                            testTop = highlightTop - tooltipHeight - gap;
                            testLeft = pos.centerX - tooltipWidth / 2;
                            if (!checkOverlap(testTop, testLeft) && testTop >= viewportPadding) {
                                return { top: testTop, left: testLeft, position: 'top' };
                            }
                            break;
                        case 'bottom':
                            testTop = highlightBottom + gap;
                            testLeft = pos.centerX - tooltipWidth / 2;
                            if (!checkOverlap(testTop, testLeft) && testTop + tooltipHeight <= window.innerHeight - viewportPadding) {
                                return { top: testTop, left: testLeft, position: 'bottom' };
                            }
                            break;
                        case 'left':
                            testTop = pos.centerY - tooltipHeight / 2;
                            testLeft = highlightLeft - tooltipWidth - gap;
                            if (!checkOverlap(testTop, testLeft) && testLeft >= viewportPadding) {
                                return { top: testTop, left: testLeft, position: 'left' };
                            }
                            break;
                        case 'right':
                            testTop = pos.centerY - tooltipHeight / 2;
                            testLeft = highlightRight + gap;
                            if (!checkOverlap(testTop, testLeft) && testLeft + tooltipWidth <= window.innerWidth - viewportPadding) {
                                return { top: testTop, left: testLeft, position: 'right' };
                            }
                            break;
                    }
                }
                
                // Last resort: position as far as possible from highlight
                testTop = highlightBottom + gap;
                testLeft = pos.centerX - tooltipWidth / 2;
                return { top: testTop, left: testLeft, position: 'bottom' };
            }
            const bestPosition = findBestPosition(position);
            tooltipTop = bestPosition.top;
            tooltipLeft = bestPosition.left;

            // Keep tooltip within viewport (mobile-optimized)
            const maxLeft = window.innerWidth - tooltipWidth - viewportPadding;
            const maxTop = window.innerHeight - tooltipHeight - viewportPadding;
            tooltipLeft = Math.max(viewportPadding, Math.min(tooltipLeft, maxLeft));
            tooltipTop = Math.max(viewportPadding, Math.min(tooltipTop, maxTop));
            
            // Final overlap check after viewport adjustment - if still overlaps, push further away
            if (checkOverlap(tooltipTop, tooltipLeft)) {
                if (bestPosition.position === 'bottom') {
                    tooltipTop = highlightBottom + padding + 10;
                } else if (bestPosition.position === 'top') {
                    tooltipTop = highlightTop - tooltipHeight - padding - 10;
                } else if (bestPosition.position === 'left') {
                    tooltipLeft = highlightLeft - tooltipWidth - padding - 10;
                } else if (bestPosition.position === 'right') {
                    tooltipLeft = highlightRight + padding + 10;
                }
                // Re-constrain to viewport
                tooltipLeft = Math.max(viewportPadding, Math.min(tooltipLeft, maxLeft));
                tooltipTop = Math.max(viewportPadding, Math.min(tooltipTop, maxTop));
            }

            tooltip.style.top = tooltipTop + 'px';
            tooltip.style.left = tooltipLeft + 'px';
            tooltip.style.transform = 'translate(0, 0)';
            
            if (!wasVisible) {
                tooltip.style.visibility = 'visible';
            }
        }

        // Update tour step
        function updateTourStep(stepIndex) {
            if (stepIndex < 0 || stepIndex >= tourSteps.length) {
                endTour();
                return;
            }

            currentTourStep = stepIndex;
            const step = tourSteps[stepIndex];
            
            // Update content
            document.getElementById('tour-step-number').textContent = stepIndex + 1;
            document.getElementById('tour-step-title').textContent = step.title;
            document.getElementById('tour-current-step').textContent = stepIndex + 1;
            document.getElementById('tour-total-steps').textContent = tourSteps.length;
            document.getElementById('tour-content').innerHTML = step.content;

            // Update button visibility
            const prevBtn = document.getElementById('tour-prev');
            const nextBtn = document.getElementById('tour-next');
            const finishBtn = document.getElementById('tour-finish');
            const backdrop = document.getElementById('tour-backdrop');

            prevBtn.style.display = stepIndex === 0 ? 'none' : 'inline-block';
            
            if (stepIndex === tourSteps.length - 1) {
                nextBtn.style.display = 'none';
                finishBtn.style.display = 'inline-block';
            } else {
                nextBtn.style.display = 'inline-block';
                finishBtn.style.display = 'none';
            }

            // Toggle backdrop background: on for Step 1, off for subsequent steps
            if (backdrop) {
                if (stepIndex === 0) {
                    backdrop.style.background = 'rgba(0,0,0,0.7)';
                } else {
                    backdrop.style.background = 'transparent';
                }
            }

            // Handle special cases - expand panel if needed
            if (step.target === '#mobile-chat-panel') {
                // Expand chat panel if it's collapsed
                const chatPanel = document.querySelector('#mobile-chat-panel');
                if (chatPanel && !chatPanel.classList.contains('expanded') && !chatPanel.classList.contains('half-screen')) {
                    // Temporarily expand it for the tour
                    chatPanel.classList.add('expanded');
                }
            }
            
            // Position tooltip
            const targetElement = step.target ? document.querySelector(step.target) : null;
            
            // If target element doesn't exist, show centered tooltip
            if (!targetElement && step.target) {
                console.warn('Tour target element not found:', step.target);
                positionTooltip(null, 'center');
            } else {
                positionTooltip(targetElement, step.position);
            }

            // Position arrow pointing to clickable element
            if (step.arrowTarget) {
                // Use setTimeout to ensure DOM is ready, especially for dynamically loaded content
                setTimeout(() => {
                    positionArrow(step.arrowTarget);
                }, 200);
            } else {
                positionArrow(null);
            }

            // Show tooltip with animation
            const tooltip = document.getElementById('tour-tooltip');
            // Enable pointer events and visibility when showing tooltip
            tooltip.style.display = 'block';
            tooltip.style.visibility = 'visible';
            tooltip.style.pointerEvents = 'auto';
            setTimeout(() => {
                tooltip.style.opacity = '1';
                if (!targetElement) {
                    tooltip.style.transform = 'translate(-50%, -50%)';
                } else {
                    // Transform will be set by positionTooltip
                }
            }, 150);
        }

        // Start tour
        function startTour() {
            isTourActive = true;
            const overlay = document.getElementById('tour-overlay');
            overlay.style.display = 'block';
            overlay.style.visibility = 'visible';
            // Allow interaction with the app behind the overlay
            overlay.style.pointerEvents = 'none';

            // Ensure tooltip is clickable by placing it at document.body level
            const tooltip = document.getElementById('tour-tooltip');
            if (tooltip && tooltip.parentElement !== document.body) {
                try { document.body.appendChild(tooltip); } catch (_) {}
            }
            // Guarantee tooltip stays above overlay and receives events
            if (tooltip) {
                tooltip.style.display = 'block';
                tooltip.style.visibility = 'visible';
                tooltip.style.zIndex = '10002';
                tooltip.style.position = 'fixed';
                tooltip.style.pointerEvents = 'auto';
            }

            currentTourStep = 0;
            updateTourStep(0);
        }

        // End tour
        function endTour() {
            isTourActive = false;
            const overlay = document.getElementById('tour-overlay');
            const tooltip = document.getElementById('tour-tooltip');
            const highlight = document.getElementById('tour-highlight');
            const backdrop = document.getElementById('tour-backdrop');
            
            // Immediately disable pointer events to prevent blocking interactions
            tooltip.style.pointerEvents = 'none';
            tooltip.style.opacity = '0';
            tooltip.style.visibility = 'hidden';
            highlight.style.opacity = '0';
            overlay.style.pointerEvents = 'none';
            
            // Restore chat panel state if it was expanded just for tour
            const chatPanel = document.querySelector('#mobile-chat-panel');
            // Note: We don't force-close it as the user might want it expanded
            
            setTimeout(() => {
                overlay.style.display = 'none';
                overlay.style.pointerEvents = 'none';
                // Ensure tooltip is also hidden and not blocking
                tooltip.style.display = 'none';
                tooltip.style.pointerEvents = 'none';
                tooltip.style.visibility = 'hidden';
            }, 400);

            // Ensure backdrop is cleared when tour ends
            if (backdrop) {
                backdrop.style.background = 'transparent';
            }

            markTourCompleted();
        }

        // Event listeners
        document.addEventListener('DOMContentLoaded', function() {
            const tourButton = document.getElementById('tour-button');
            const tourOverlay = document.getElementById('tour-overlay');
            const tourClose = document.getElementById('tour-close');
            const tourSkip = document.getElementById('tour-skip');
            const tourPrev = document.getElementById('tour-prev');
            const tourNext = document.getElementById('tour-next');
            const tourFinish = document.getElementById('tour-finish');

            if (tourButton) {
                tourButton.addEventListener('click', startTour);
            }

            if (tourClose) {
                tourClose.addEventListener('click', endTour);
            }

            if (tourSkip) {
                tourSkip.addEventListener('click', endTour);
            }

            if (tourPrev) {
                tourPrev.addEventListener('click', () => {
                    if (currentTourStep > 0) {
                        updateTourStep(currentTourStep - 1);
                    }
                });
            }

            if (tourNext) {
                tourNext.addEventListener('click', () => {
                    if (currentTourStep < tourSteps.length - 1) {
                        updateTourStep(currentTourStep + 1);
                    }
                });
            }

            if (tourFinish) {
                tourFinish.addEventListener('click', endTour);
            }

            // Close on backdrop click
            if (tourOverlay) {
                tourOverlay.addEventListener('click', (e) => {
                    if (e.target.id === 'tour-backdrop' || e.target.id === 'tour-overlay') {
                        endTour();
                    }
                });
            }

            // Close on Escape key
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && isTourActive) {
                    endTour();
                }
            });

            // Auto-start exploration guide: always for guests, once per session for logged-in users
            (function () {
                var isAuthenticated = @User.Identity.IsAuthenticated.ToString().ToLower();
                if (!isAuthenticated) {
                    setTimeout(function () { startTour(); }, 300);
                    return;
                }

                var userId = '@(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "auth")';
                var sessionKey = 'tourSeen_session_' + userId;
                try {
                    if (!sessionStorage.getItem(sessionKey)) {
                        setTimeout(function () {
                            startTour();
                            try { sessionStorage.setItem(sessionKey, '1'); } catch (e) { /* ignore quota errors */ }
                        }, 300);
                    }
                } catch (e) {
                    // sessionStorage unavailable; fall back to showing once immediately
                    setTimeout(function () { startTour(); }, 300);
                }
            })();
        });
    </script>
</body>
</html>