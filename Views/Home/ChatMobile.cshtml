            const openingHours = place.opening_hours || place.current_opening_hours;
            if (openingHours && statusInfo.isOpen && openingHours.weekday_text && openingHours.weekday_text.length > 0) {
                const today = new Date().getDay();
                const dayIndex = (today === 0) ? 6 : today - 1;
                const todayHours = openingHours.weekday_text[dayIndex];
                if (todayHours) {
                    const hoursText = todayHours.split(': ')[1];
                    if (hoursText && hoursText !== 'Closed') {
                        const closingTime = hoursText.split(' – ')[1] || hoursText.split('–')[1] || hoursText.split(' - ')[1] || hoursText.split('-')[1];
