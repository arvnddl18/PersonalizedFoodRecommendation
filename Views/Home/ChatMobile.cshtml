        function displayRestaurantDetails(place) {
            // Set current place for menu images functionality (matching desktop)
            window.currentPlace = place;
            try {
                const content = document.getElementById('restaurant-content');
                if (!content) return;
                
                // Handle both search results and favorites data
                const rating = place.rating || 0;
                const stars = generateStars(rating);
            
            // Format price level - handle both price_level and priceLevel
            const priceLevel = place.price_level || place.priceLevel || 0;
            const priceText = formatPriceLevel(priceLevel);
            
            // Format cuisine types - handle both types arrays and strings
            let cuisineTypes = [];
            if (place.types) {
                if (Array.isArray(place.types)) {
                    cuisineTypes = place.types.filter(type => 
                        ['restaurant', 'food', 'meal_takeaway', 'meal_delivery'].includes(type)
                    ).slice(0, 2);
                } else if (typeof place.types === 'string') {
                    // Handle string types (comma-separated)
                    cuisineTypes = place.types.split(',').map(type => type.trim()).filter(type => 
                        ['restaurant', 'food', 'meal_takeaway', 'meal_delivery'].includes(type)
                    ).slice(0, 2);
                }
            }
            const cuisineText = cuisineTypes.length > 0 ? cuisineTypes[0].replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) : 'Restaurant';
            
            // Format hours - handle both opening_hours and hours
            const hours = place.opening_hours || place.hours;
            let hoursText = 'Hours not available';
            let closeTime = '';
            
            if (hours) {
                if (typeof hours === 'object' && hours.open_now !== undefined) {
                    hoursText = hours.open_now ? 'Open now' : 'Closed now';
                }
                if (hours.weekday_text && Array.isArray(hours.weekday_text)) {
                    closeTime = hours.weekday_text[new Date().getDay()] || '';
                }
            }
            
            // Format address - handle both formatted_address and address
            const address = place.formatted_address || place.address || place.vicinity || 'Address not available';
            
            // Format services
            const services = ['Dine-in', 'Take-out', 'Delivery'];
            
            content.innerHTML = `
                <div class="restaurant-name">${escapeHtml(place.name || 'Restaurant')}</div>
                <div class="restaurant-rating">
                    <span class="rating-score">${rating > 0 ? rating.toFixed(1) : 'N/A'}</span>
                    <div class="rating-stars">${stars}</div>
                </div>
                <div class="restaurant-meta">
                    <span>${priceText}</span>
                    <span class="service-dot">•</span>
                    <span>${cuisineText}</span>
                </div>
                <div class="restaurant-hours">
                    <span class="hours-status">${hoursText}</span>
                    ${closeTime ? `<span class="service-dot">•</span><span class="hours-text">${closeTime}</span>` : ''}
                </div>
                <div class="restaurant-address">${escapeHtml(address)}</div>
                <div class="restaurant-services">
                    ${services.join(' <span class="service-dot">•</span> ')}
                </div>
            `;
            } catch (error) {
                console.error('Error displaying restaurant details:', error);
                const content = document.getElementById('restaurant-content');
                if (content) {
                    content.innerHTML = `
                        <div class="restaurant-name">${escapeHtml(place.name || 'Restaurant')}</div>
                        <div class="restaurant-rating">
                            <span class="rating-score">N/A</span>
                            <div class="rating-stars">⭐⭐⭐⭐⭐</div>
                        </div>
                        <div class="restaurant-meta">
                            <span>Restaurant</span>
                        </div>
                        <div class="restaurant-hours">
                            <span class="hours-status">Hours not available</span>
                        </div>
                        <div class="restaurant-address">${escapeHtml(place.address || place.formatted_address || 'Address not available')}</div>
                        <div class="restaurant-services">
                            Dine-in <span class="service-dot">•</span> Take-out <span class="service-dot">•</span> Delivery
                        </div>
                    `;
                }
            }
        }

        function generateStars(rating) {
            const fullStars = Math.floor(rating);
            const hasHalfStar = rating % 1 >= 0.5;
            const emptyStars = 5 - fullStars - (hasHalfStar ? 1 : 0);
            
            let stars = '';
            for (let i = 0; i < fullStars; i++) {
                stars += '<span class="star">★</span>';
            }
            if (hasHalfStar) {
                stars += '<span class="star">☆</span>';
            }
            for (let i = 0; i < emptyStars; i++) {
                stars += '<span class="star outline">☆</span>';
            }
            return stars;
        }

        function formatPriceLevel(priceLevel) {
            switch(priceLevel) {
                case 0: return 'Free';
                case 1: return '₱100-₱200';
                case 2: return '₱200-₱400';
                case 3: return '₱400-₱600';
                case 4: return '₱600+';
                default: return 'Price not available';
            }
        }

        function hideRestaurantDetailCard() {
            if (restaurantDetailCard) {
                restaurantDetailCard.classList.remove('show');
            }
        }

        function expandPanelToHalfScreen() {
            const panel = document.getElementById('mobile-chat-panel');
            const panelContent = document.getElementById('panel-content');
            
            if (panel && panelContent) {
                // Remove any existing height classes
                panel.classList.remove('collapsed', 'expanded');
                panel.classList.add('half-screen');
                panelContent.classList.remove('collapsed');
                
                // Set explicit height to 50% of viewport
                panel.style.height = '50vh';
            }
        }

