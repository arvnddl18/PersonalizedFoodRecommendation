                const place = window.currentPlace;
                if (!place) {
                    throw new Error('No place information available');
                }
                
                // Get the correct Google Maps URL from the place object
                if (place.url) {
                    // Use the official Google Maps URL from the place object
                    googleMapsUrl = place.url;
                    
                    // If it's a short URL with CID, we need to expand it to get the full URL
                    if (googleMapsUrl.includes('cid=')) {
