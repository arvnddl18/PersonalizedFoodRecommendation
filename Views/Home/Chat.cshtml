        // Populate Top Center Restaurant Card with complete API data
        async function populateTopRestaurantCard(place, forceShow = false) {
            const topCard = document.getElementById('top-restaurant-card');
            const cardImage = document.getElementById('top-card-image');
            const cardImagePlaceholder = document.getElementById('top-card-image-placeholder');
            const cardName = document.getElementById('top-card-name');
            const cardRating = document.getElementById('top-card-rating');
            const cardPrice = document.getElementById('top-card-price');
            const cardAddress = document.getElementById('top-card-address');
            const cardStatus = document.getElementById('top-card-status');
            const cardHours = document.getElementById('top-card-hours');

            // Set current place for menu button access
            window.currentPlace = place;

            // Fetch complete place details if we only have basic data
            let completePlace = place;
            if (place.place_id && (!place.formatted_address || !place.opening_hours)) {
                try {
                    const additionalDetails = await fetchPlaceDetails(place.place_id);
                    // Merge additional details with existing place data
                    completePlace = { ...place, ...additionalDetails };
                } catch (error) {
                    console.warn('Could not fetch complete details for top card:', error);
                    completePlace = place;
                }
            }

            // Set restaurant name - NO DEFAULT
            if (completePlace.name) {
                cardName.textContent = completePlace.name;
            } else {
                cardName.textContent = 'Restaurant name unavailable';
                cardName.style.color = '#9ca3af';
            }

            // Set rating - NO FICTIONAL DEFAULT
            if (completePlace.rating) {
                cardRating.textContent = completePlace.rating.toFixed(1);
                cardRating.style.color = '#111827';
            } else {
                cardRating.textContent = 'N/A';
                cardRating.style.color = '#9ca3af';
            }

            // Set price range - default to ₱100-₱300 when unavailable
            const getPriceRangeText = (level) => {
                const ranges = {
                    0: '₱0-₱100',
                    1: '₱100-₱200',
                    2: '₱200-₱400',
                    3: '₱400-₱800',
                    4: '₱800+'
                };
                return level != null ? ranges[level] : '₱100-₱300';
            };
            
            cardPrice.textContent = getPriceRangeText(completePlace.price_level);
            cardPrice.style.color = '#6b7280';

            // Set address - NO FICTIONAL DEFAULT
            if (completePlace.formatted_address) {
                cardAddress.textContent = completePlace.formatted_address;
                cardAddress.style.color = '#374151';
            } else if (completePlace.vicinity) {
                cardAddress.textContent = completePlace.vicinity;
                cardAddress.style.color = '#374151';
            } else {
                cardAddress.textContent = 'Address not available';
                cardAddress.style.color = '#9ca3af';
                cardAddress.style.fontStyle = 'italic';
            }

            // Set opening status and hours - REAL DATA ONLY
            const statusInfo = getStoreStatus(completePlace);
            
            cardStatus.textContent = statusInfo.text;
            cardStatus.style.fontWeight = '600';
            cardStatus.style.fontSize = '0.95rem';
            
            if (statusInfo.isOpen) {
                cardStatus.style.color = '#10b981'; // Green for open
            } else if (statusInfo.text.includes('Closed')) {
                cardStatus.style.color = '#ef4444'; // Red for closed
            } else {
                cardStatus.style.color = '#9ca3af'; // Gray for unknown
            }

            // Set hours (today's closing time) - REAL DATA ONLY
            cardHours.textContent = ''; // Clear first
            cardHours.style.color = '#6b7280';
            
            if (completePlace.opening_hours || completePlace.current_opening_hours) {
                const openingHours = completePlace.opening_hours || completePlace.current_opening_hours;
                
                if (openingHours.weekday_text && openingHours.weekday_text.length > 0) {
                    const today = new Date().getDay();
                    const dayIndex = (today === 0) ? 6 : today - 1; // Convert Sunday (0) to 6, rest to 0-5
                    const todayHours = openingHours.weekday_text[dayIndex];
                    
                    if (todayHours) {
                        const hoursText = todayHours.split(': ')[1];
                        if (hoursText && hoursText !== 'Closed') {
                            // Try different separators for closing time
                            const closingTime = hoursText.split(' – ')[1] || 
                                              hoursText.split('–')[1] || 
                                              hoursText.split(' - ')[1] ||
                                              hoursText.split('-')[1];
                            
                            if (closingTime && statusInfo.isOpen) {
                                cardHours.textContent = `• Closes at ${closingTime.trim()}`;
                            }
                        }
                    }
                }
            }
            
            // If no closing time available but is open, show generic message
            if (!cardHours.textContent && statusInfo.isOpen) {
                cardHours.textContent = ''; // Don't show anything if we don't have real data
            }

            // Set image with carousel support - use complete place data
            if (completePlace.photos && completePlace.photos.length > 0) {
                const photoUrl = completePlace.photos[0].getUrl({ maxWidth: 600, maxHeight: 600 });
                cardImage.src = photoUrl;
                cardImage.style.display = 'block';
                cardImage.alt = completePlace.name || 'Restaurant';
                cardImagePlaceholder.style.display = 'none';
                
                // Add carousel dots if multiple images
                const dotsContainer = document.getElementById('top-card-image-dots');
                if (completePlace.photos.length > 1) {
                    dotsContainer.innerHTML = '';
                    let currentPhotoIndex = 0;
                    
                    // Create dots for up to 5 photos
                    completePlace.photos.slice(0, 5).forEach((photo, index) => {
                        const dot = document.createElement('div');
                        dot.style.cssText = 'width:8px; height:8px; border-radius:50%; background:' + (index === 0 ? '#ffffff' : 'rgba(255,255,255,0.5)') + '; cursor:pointer; transition:background 0.3s;';
                        dot.onclick = () => {
                            currentPhotoIndex = index;
                            cardImage.src = completePlace.photos[index].getUrl({ maxWidth: 600, maxHeight: 600 });
                            updateDots();
                        };
                        dotsContainer.appendChild(dot);
                    });
                    
                    const updateDots = () => {
                        dotsContainer.querySelectorAll('div').forEach((dot, i) => {
                            dot.style.background = i === currentPhotoIndex ? '#ffffff' : 'rgba(255,255,255,0.5)';
                        });
                    };
                    
                    dotsContainer.style.display = 'flex';
                } else {
                    dotsContainer.style.display = 'none';
                }
            } else {
                // No photos available - show placeholder
                cardImage.style.display = 'none';
                cardImagePlaceholder.style.display = 'flex';
                document.getElementById('top-card-image-dots').style.display = 'none';
            }

            // Show the card (unless user dismissed it)
            if (forceShow) topRestaurantCardDismissed = false;
            topCard.style.display = (topRestaurantCardDismissed && !forceShow) ? 'none' : 'block';
            
            // Update navigation arrows and counter
            updateNavigationState();
        }

        // Update navigation arrow states and counter badge
        function updateNavigationState() {
            const prevBtn = document.getElementById('prev-restaurant-btn');
            const nextBtn = document.getElementById('next-restaurant-btn');
            const counterBadge = document.getElementById('restaurant-counter-badge');
            
            if (!prevBtn || !nextBtn || !counterBadge) return;
            
            const listLength = currentRestaurantList.length;
            
            if (listLength === 0) {
                // No list to navigate
                prevBtn.style.display = 'none';
                nextBtn.style.display = 'none';
                counterBadge.style.display = 'none';
                return;
            }
            
            // Show/hide arrows based on position
            if (currentRestaurantIndex <= 0) {
                prevBtn.disabled = true;
            } else {
                prevBtn.disabled = false;
            }
            
            if (currentRestaurantIndex >= listLength - 1) {
                nextBtn.disabled = true;
            } else {
                nextBtn.disabled = false;
            }
            
            // Update counter badge
            if (listLength > 1) {
                counterBadge.textContent = `${currentRestaurantIndex + 1} / ${listLength}`;
                counterBadge.style.display = 'block';
            } else {
                counterBadge.style.display = 'none';
            }
        }

