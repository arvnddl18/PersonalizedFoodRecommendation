                    this.style.boxShadow = 'none';
                };
                const started = new Date(s.startedAt ?? s.StartedAt);
                const title = document.createElement('span');
                title.textContent = started.toLocaleString();
                title.style.cssText = 'font-size:0.85rem; color:#47682C; font-weight:600;';
                const count = document.createElement('span');
                const mc = s.messageCount ?? s.MessageCount ?? 0;
                count.textContent = mc.toString();
