        async function getDirections(placeId, placeName) {
            try {
                // Show loading message
                addMessage('FoodieSaur Bot', `Getting directions to ${placeName}...`);

                // Check if placeId is valid
                if (!placeId || placeId === 'undefined' || placeId === 'null') {
                    console.warn('Invalid place_id, using fallback method');
                    await getDirectionsBySearch(placeName);
                    return;
                }

                // Get place details to get coordinates using compat helper
                const place = await fetchPlaceDetails(placeId);
                if (place && place.geometry && place.geometry.location) {
                    calculateAndDisplayRoute(place.geometry.location, placeName, place.formatted_address);
                } else {
                    console.log('Falling back to search-based directions');
                    await getDirectionsBySearch(placeName);
                }
            } catch (error) {
                console.error('Error getting directions:', error);
                addMessage('FoodieSaur Bot', 'Error calculating directions.');
            }
        }

        // Fallback method: Get directions by searching for the restaurant
        async function getDirectionsBySearch(placeName) {
            try {
                const request = {
                    query: placeName + ' Davao City',
                    location: userLocation,
                    radius: 10000
                };
                const results = await textSearchCompat(request);
                if (results && results.length > 0) {
                    const place = results[0];
                    calculateAndDisplayRoute(place.geometry.location, placeName, place.formatted_address);
                } else {
                    addMessage('FoodieSaur Bot', `Unable to find location for ${placeName}. Please try searching for it first.`);
                }
            } catch (error) {
                console.error('Error in fallback directions:', error);
                addMessage('FoodieSaur Bot', 'Error finding place location.');
            }
        }

        // Calculate and display route
        function calculateAndDisplayRoute(destination, placeName, address) {
            const request = {
                origin: userLocation,
                destination: destination,
                travelMode: google.maps.TravelMode.DRIVING,
                unitSystem: google.maps.UnitSystem.METRIC,
                avoidHighways: false,
                avoidTolls: false
            };

            directionsService.route(request, (result, status) => {
                if (status === 'OK') {
                    // Display the route on the map
                    directionsRenderer.setDirections(result);

                    // Store current route
                    currentRoute = result;
                    currentRoute.placeName = placeName;
                    currentRoute.address = address;

                    // Show directions panel above search and favorites panels
                    showDirectionsPanel();

                    // Ensure no travel mode is pre-selected as active by default
                    document.querySelectorAll('.travel-mode-btn').forEach(btn => {
                        btn.classList.remove('active');
                    });

                    // Add route summary to chat (only once)
                    const route = result.routes[0];
                    const leg = route.legs[0];
                    const duration = leg.duration.text;
                    const distance = leg.distance.text;

                    addMessage('FoodieSaur Bot', `🗺️ **Directions to ${placeName}**\n\n` +
                        `📍 **From:** Your current location\n` +
                        `🎯 **To:** ${address || placeName}\n\n` +
                        `⏱️ **Duration:** ${duration}\n` +
                        `📏 **Distance:** ${distance}\n\n` +
                        `Check the directions panel for turn-by-turn instructions!`);

                    // Update directions panel with route info
                    updateDirectionsPanelHeader(result, google.maps.TravelMode.DRIVING, placeName, address);

                    // Center map on the route
                    const bounds = new google.maps.LatLngBounds();
                    bounds.extend(userLocation);
                    bounds.extend(destination);
                    map.fitBounds(bounds);

                } else {
                    console.error('Directions request failed:', status);
                    addMessage('FoodieSaur Bot', 'Unable to calculate directions. Please try again.');
                }
            });
        }

        // Change travel mode for directions
        function changeTravelMode(travelMode) {
            if (!currentRoute) return;

            // Store place info before updating
            const placeName = currentRoute.placeName;
            const address = currentRoute.address;

            // Update active button
            document.querySelectorAll('.travel-mode-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            const clickedButton = (event && (event.currentTarget || event.target.closest('.travel-mode-btn')));
            if (clickedButton) {
                clickedButton.classList.add('active');
            }

            const request = {
                origin: currentRoute.request.origin,
                destination: currentRoute.request.destination,
                travelMode: travelMode,
                unitSystem: google.maps.UnitSystem.METRIC,
                avoidHighways: false,
                avoidTolls: false
            };

            directionsService.route(request, (result, status) => {
                if (status === 'OK') {
                    directionsRenderer.setDirections(result);
                    currentRoute = result;
                    currentRoute.placeName = placeName;
                    currentRoute.address = address;

                    // Update directions panel with new route info (no chat spam)
                    updateDirectionsPanelHeader(result, travelMode, placeName, address);
                } else {
                    // Only show error in chat if it's a critical failure
                    addMessage('FoodieSaur Bot', 'Unable to calculate route for this travel mode.');
                }
            });
        }

        // Update directions panel with route info - FoodieSaur branded design
        function updateDirectionsPanelHeader(result, travelMode, placeName, address) {
            const route = result.routes[0];
            const leg = route.legs[0];
            const duration = leg.duration.text;
            const distance = leg.distance.text;
            const mode = getTravelModeText(travelMode);

            // Hide placeholder and show route summary
            const placeholder = document.getElementById('directions-placeholder');
            const routeSummary = document.getElementById('route-summary');
            if (placeholder) placeholder.classList.add('hidden');
            if (routeSummary) routeSummary.classList.remove('hidden');

            // Update route summary card
            const routeModeText = document.getElementById('route-mode-text');
            const routeDestinationName = document.getElementById('route-destination-name');
            const routeDestinationAddress = document.getElementById('route-destination-address');
            const routeModeIcon = document.getElementById('route-mode-icon');
            
            if (routeModeText) {
                routeModeText.textContent = `${duration} · ${distance}`;
            }
            
            if (routeDestinationName) {
                routeDestinationName.textContent = placeName || 'Restaurant';
            }
            
            if (routeDestinationAddress) {
                routeDestinationAddress.textContent = address || '';
            }

            // Update mode icon based on travel mode
            if (routeModeIcon) {
                let iconHtml = '';
                switch (travelMode) {
                    case google.maps.TravelMode.WALKING:
                        iconHtml = '<img src="/images/cil-walk2.svg" alt="Walk" style="width: 1.5rem; height: 1.5rem;">';
                        break;
                    case google.maps.TravelMode.TRANSIT:
                        iconHtml = '<img src="/images/bus-side.svg" alt="Transit" style="width: 1.5rem; height: 1.5rem;">';
                        break;
                    case google.maps.TravelMode.BICYCLING:
                        iconHtml = '<img src="/images/bike.svg" alt="Bike" style="width: 1.5rem; height: 1.5rem;">';
                        break;
                    default: // DRIVING
                        iconHtml = '<img src="/images/car-side.svg" alt="Drive" style="width: 1.5rem; height: 1.5rem;">';
                }
                routeModeIcon.innerHTML = iconHtml;
            }

            // Update the mode label in the summary card
            const modeLabel = document.querySelector('#route-summary .text-xs.opacity-80');
            if (modeLabel) {
                modeLabel.textContent = `${mode} Route`;
            }
        }

        // Get travel mode text
        function getTravelModeText(travelMode) {
            switch (travelMode) {
                case google.maps.TravelMode.DRIVING: return 'Driving';
                case google.maps.TravelMode.WALKING: return 'Walking';
                case google.maps.TravelMode.TRANSIT: return 'Public Transit';
                case google.maps.TravelMode.BICYCLING: return 'Bicycling';
                default: return 'Unknown';
            }
        }

