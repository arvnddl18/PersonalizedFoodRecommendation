        async function openOwnerRestaurantModal() {
            if (window.isGuest || window.currentUserId == null) {
                alert('Please login as a verified restaurant owner to manage your restaurant.');
                return;
            }

            const els = getOwnerRestaurantModalEls();
            if (!els.modal || !els.select) return;

            els.modal.style.display = 'flex';
            setOwnerRestaurantModalEditing(false);
            els.select.innerHTML = `<option value="">Loading…</option>`;
            if (els.hint) els.hint.textContent = '';
            if (els.status) {
                els.status.textContent = 'Loading your restaurants…';
                els.status.style.display = 'block';
            }

            try {
                const res = await fetch('/api/RestaurantOwner/my-restaurants', { credentials: 'same-origin' });
                const data = res.ok ? await res.json() : [];
                ownerRestaurantModalState.restaurants = Array.isArray(data) ? data : [];

                const verified = ownerRestaurantModalState.restaurants.filter(r => (r.verificationStatus || '') === 'Verified');
                if (verified.length === 0) {
                    els.select.innerHTML = `<option value="">No verified restaurants</option>`;
                    if (els.hint) els.hint.textContent = 'You need a verified restaurant claim to edit details.';
                    if (els.status) {
                        els.status.textContent = 'No verified restaurants found for this account.';
                        els.status.style.display = 'block';
                    }
                    if (els.editToggle) els.editToggle.style.display = 'none';
                    if (els.history) els.history.style.display = 'none';
                    return;
                }

                els.select.innerHTML = verified.map(r => {
                    const nm = escapeHtml(r.restaurantName || 'Restaurant');
                    const pid = escapeHtml(r.placeId || '');
                    return `<option value="${pid}">${nm} (Verified)</option>`;
                }).join('');

                const first = verified[0];
                ownerRestaurantModalState.selectedPlaceId = first.placeId;
                els.select.value = first.placeId;
                if (els.hint) els.hint.textContent = 'View details first. Click Edit to make changes.';
                if (els.status) els.status.style.display = 'none';

                await loadOwnerRestaurantModalPlace(first.placeId);
            } catch (e) {
                console.error('Failed to load owner restaurants:', e);
                if (els.status) {
                    els.status.textContent = 'Failed to load your restaurants.';
                    els.status.style.display = 'block';
                }
                els.select.innerHTML = `<option value="">Failed to load</option>`;
            }
        }

        async function loadOwnerRestaurantModalPlace(placeId) {
            const els = getOwnerRestaurantModalEls();
            if (!placeId) return;

            ownerRestaurantModalState.selectedPlaceId = placeId;
            setOwnerRestaurantModalEditing(false);
            if (els.status) {
                els.status.textContent = 'Loading restaurant details…';
                els.status.style.display = 'block';
            }

            // Clear fields first
            const clear = (el) => { if (el) el.value = ''; };
            [els.name, els.address, els.phone, els.website, els.description, els.cuisine, els.price, els.facebook, els.instagram, els.serviceoptions, els.popularfor, els.menuitemsText].forEach(clear);

            try {
                const verRes = await fetch(`/api/RestaurantEdit/current/${encodeURIComponent(placeId)}`, { credentials: 'same-origin' });
                const ver = verRes.ok ? await verRes.json() : null;

                const nameVal = (ver && ver.name) ? ver.name : (ownerRestaurantModalState.restaurants.find(r => r.placeId === placeId)?.restaurantName || '');
                const addressVal = (ver && ver.address) ? ver.address : '';
                const phoneVal = (ver && ver.phoneNumber) ? ver.phoneNumber : '';
                const websiteVal = (ver && ver.website) ? ver.website : '';
                const descVal = (ver && ver.description) ? ver.description : '';
                const cuisineVal = (ver && ver.cuisineType) ? ver.cuisineType : '';
                const priceVal = (ver && ver.priceRange) ? ver.priceRange : '';
                const fbVal = (ver && ver.facebookUrl) ? ver.facebookUrl : '';
                const igVal = (ver && ver.instagramUrl) ? ver.instagramUrl : '';
                const serviceVal = (ver && ver.serviceOptions) ? ver.serviceOptions : '';
                const popularVal = (ver && ver.popularFor) ? ver.popularFor : '';
                const menuVal = (ver && ver.menuItemsAndIngredients) ? ver.menuItemsAndIngredients : '';

                // Fill edit fields
                if (els.name) els.name.value = nameVal || '';
                if (els.address) els.address.value = addressVal || '';
                if (els.phone) els.phone.value = phoneVal || '';
                if (els.website) els.website.value = websiteVal || '';
                if (els.description) els.description.value = descVal || '';
                if (els.cuisine) els.cuisine.value = cuisineVal || '';
                if (els.price) els.price.value = priceVal || '';
                if (els.facebook) els.facebook.value = fbVal || '';
                if (els.instagram) els.instagram.value = igVal || '';
                if (els.serviceoptions) els.serviceoptions.value = serviceVal || '';
                if (els.popularfor) els.popularfor.value = popularVal || '';
                if (els.menuitemsText) els.menuitemsText.value = menuVal || '';

                // Fill view fields
                if (els.viewName) els.viewName.textContent = nameVal || 'Not available';
                if (els.viewAddress) els.viewAddress.textContent = addressVal || 'Not available';
                if (els.viewPhone) els.viewPhone.textContent = phoneVal || 'Not available';
                if (els.viewCuisine) els.viewCuisine.textContent = cuisineVal || 'Not available';
                if (els.viewPrice) els.viewPrice.textContent = priceVal || 'Not available';
                if (els.viewDescription) els.viewDescription.textContent = descVal || 'Not available';

                // Website link
                if (els.viewWebsite) {
                    const w = normalizeExternalUrl(websiteVal || '');
                    if (w) {
                        els.viewWebsite.textContent = w;
                        els.viewWebsite.href = w;
                        els.viewWebsite.style.pointerEvents = 'auto';
                        els.viewWebsite.style.opacity = '1';
                    } else {
                        els.viewWebsite.textContent = 'Not available';
                        els.viewWebsite.href = '#';
                        els.viewWebsite.style.pointerEvents = 'none';
                        els.viewWebsite.style.opacity = '0.6';
                    }
                }

                // Social links
                if (els.viewFacebook) {
                    const u = normalizeExternalUrl(fbVal || '');
                    els.viewFacebook.href = u || '#';
                    els.viewFacebook.style.pointerEvents = u ? 'auto' : 'none';
                    els.viewFacebook.style.opacity = u ? '1' : '0.55';
                }
                if (els.viewInstagram) {
                    const u = normalizeExternalUrl(igVal || '');
                    els.viewInstagram.href = u || '#';
                    els.viewInstagram.style.pointerEvents = u ? 'auto' : 'none';
                    els.viewInstagram.style.opacity = u ? '1' : '0.55';
                }

                // Chips for service/popular
                if (els.viewServiceOptions) els.viewServiceOptions.innerHTML = listTextToInlineHtml(serviceVal || '');
                if (els.viewPopularFor) els.viewPopularFor.innerHTML = listTextToInlineHtml(popularVal || '');

                // Menu cards
                if (els.viewMenuItems) els.viewMenuItems.innerHTML = menuTextToHtml(menuVal || '');

                // Modal header actions
                if (els.history) {
                    els.history.href = `/Restaurant/History?placeId=${encodeURIComponent(placeId)}`;
                    els.history.style.display = 'inline-flex';
                }
                if (els.editToggle) els.editToggle.style.display = 'inline-flex';
                setOwnerRestaurantModalEditing(false);

                // Prep menu tags / preview
                ensureOwnerModalMenuTagCheckboxesPopulated();
                refreshOwnerModalMenuPreview();

                if (els.status) els.status.style.display = 'none';
            } catch (e) {
                console.error('Failed to load current version for modal:', e);
                if (els.status) {
                    els.status.textContent = 'Failed to load restaurant details.';
                    els.status.style.display = 'block';
                }
            }
        }

        async function saveOwnerRestaurantModal() {
            const els = getOwnerRestaurantModalEls();
            const placeId = ownerRestaurantModalState.selectedPlaceId;
            if (!placeId) return;
            if (!ownerRestaurantModalState.isEditing) return;

            const name = (els.name && els.name.value) ? els.name.value.trim() : '';
            if (!name) {
                alert('Restaurant name is required.');
                return;
            }

            const editData = {
                placeId,
                name,
                address: (els.address && els.address.value) ? els.address.value : '',
                phoneNumber: (els.phone && els.phone.value) ? els.phone.value : '',
                website: (els.website && els.website.value) ? els.website.value : '',
                description: (els.description && els.description.value) ? els.description.value : '',
                cuisineType: (els.cuisine && els.cuisine.value) ? els.cuisine.value : '',
                priceRange: (els.price && els.price.value) ? els.price.value : '',
                openingHours: '',
                specialFeatures: '',
                facebookUrl: normalizeExternalUrl((els.facebook && els.facebook.value) ? els.facebook.value : ''),
                instagramUrl: normalizeExternalUrl((els.instagram && els.instagram.value) ? els.instagram.value : ''),
                serviceOptions: (els.serviceoptions && els.serviceoptions.value) ? els.serviceoptions.value : '',
                popularFor: (els.popularfor && els.popularfor.value) ? els.popularfor.value : '',
                menuItemsAndIngredients: (els.menuitemsText && els.menuitemsText.value) ? els.menuitemsText.value : ''
            };

            try {
                const btn = els.save;
                if (btn) { btn.disabled = true; btn.style.opacity = '0.8'; btn.textContent = 'Saving…'; }

                const response = await fetch('/api/RestaurantEdit/create', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(editData)
                });

                const contentType = response.headers.get('content-type') || '';
                const responseBody = contentType.includes('application/json')
                    ? await response.json()
                    : await response.text();

                if (response.ok) {
                    const result = responseBody;
                    alert('Your changes have been saved! ' + (result.status === 'Current' ? 'They were automatically approved.' : 'They are pending approval.'));

                    // If the details panel is currently showing this place, refresh it.
                    try {
                        if (currentRestaurantDetails && currentRestaurantDetails.place_id === placeId) {
                            displayRestaurantDetails(currentRestaurantDetails);
                        }
                    } catch (_) {}

                    closeOwnerRestaurantModal();
                } else {
                    console.error('Failed to save owner modal edit:', response.status, responseBody);
                    const message = (responseBody && typeof responseBody === 'object' && responseBody.message)
                        ? responseBody.message
                        : `Request failed (${response.status}). Please try again.`;
                    alert('Failed to save: ' + message);
                }
            } catch (e) {
                console.error('Error saving owner modal edit:', e);
                alert('An error occurred while saving. Please try again.');
            } finally {
                const btn = els.save;
                if (btn) { btn.disabled = false; btn.style.opacity = '1'; btn.textContent = 'Save changes'; }
            }
        }

        // Modal event listeners
        (function setupOwnerRestaurantModalListeners() {
            const els = getOwnerRestaurantModalEls();
            if (els.close) els.close.addEventListener('click', closeOwnerRestaurantModal);
            if (els.cancel) els.cancel.addEventListener('click', closeOwnerRestaurantModal);
            if (els.save) els.save.addEventListener('click', saveOwnerRestaurantModal);
            if (els.editToggle) els.editToggle.addEventListener('click', () => {
                // toggle edit mode
                setOwnerRestaurantModalEditing(!ownerRestaurantModalState.isEditing);
                if (ownerRestaurantModalState.isEditing) {
                    ensureOwnerModalMenuTagCheckboxesPopulated();
                    refreshOwnerModalMenuPreview();
                    try { els.name?.focus(); } catch (_) {}
                }
            });
            if (els.select) els.select.addEventListener('change', (e) => {
                const val = e.target && e.target.value ? String(e.target.value) : '';
                if (val) loadOwnerRestaurantModalPlace(val);
            });
            if (els.menuAddBtn) els.menuAddBtn.addEventListener('click', addOwnerModalMenuItemLine);
            if (els.menuClearBtn) els.menuClearBtn.addEventListener('click', clearOwnerModalMenuItemBuilder);
            if (els.menuitemsText) els.menuitemsText.addEventListener('input', () => {
                if (ownerRestaurantModalState.isEditing) refreshOwnerModalMenuPreview();
            });
            if (els.modal) {
                els.modal.addEventListener('click', (e) => {
                    // Click outside dialog closes
                    if (e && e.target === els.modal) closeOwnerRestaurantModal();
                });
            }
        })();

        async function loadFavorites() {
            if (window.isGuest) {
                // Guests cannot load favorites
                return;
            }
            try {
                const response = await fetch('/api/Favorites');
                if (!response.ok) return;
                
                const favorites = await response.json();
                favoritesData = favorites;
                userFavorites.clear();
                
                favorites.forEach(fav => {
                    userFavorites.add(fav.placeId);
                });
                
                updateFavoritesCount();
                updateFavoritesHeartIcon();
            } catch (error) {
                console.error('Error loading favorites:', error);
            }
        }

        function updateFavoritesCount() {
            const count = userFavorites.size;
            const badge = document.getElementById('favorites-count-badge');
            const controlBadge = document.getElementById('favorites-control-badge');
            
            if (badge) badge.textContent = count;
            if (controlBadge) {
                controlBadge.textContent = count;
                controlBadge.style.display = count > 0 ? 'flex' : 'none';
            }
        }

        function updateFavoritesHeartIcon() {
            // Heart icon is now static in the map control button
            // No need to update it dynamically
        }

        function toggleFavoritesPanel() {
            const isFavoritesOpen = favoritesPanel.style.transform === 'translateX(0px)';
            
            if (isFavoritesOpen) {
                closeFavorites();
            } else {
                openFavorites();
            }
        }

        function openFavorites() {
            // Hide search panel, show favorites panel
            searchPanel.style.transform = 'translateX(-100%)';
            favoritesPanel.style.transform = 'translateX(0)';
            if (dietaryTagsPanel) dietaryTagsPanel.style.transform = 'translateX(-100%)';
            restaurantDetailsPanel.style.display = 'none';
            toggleSearchBtn.style.left = '26rem';
            toggleSearchBtn.setAttribute('aria-expanded', 'true');
            toggleSearchBtn.querySelector('span').textContent = '‹';
            
            // Restore top restaurant card if we have restaurant details
            const topCard = document.getElementById('top-restaurant-card');
            if (topCard && currentRestaurantDetails) {
                populateTopRestaurantCard(currentRestaurantDetails);
            }
            
            // Track active panel
            lastActivePanel = 'favorites';
            
            // Display favorites
            displayFavorites();
        }

        function closeFavorites() {
            favoritesPanel.style.transform = 'translateX(-100%)';
            toggleSearchBtn.style.left = '0';
            toggleSearchBtn.setAttribute('aria-expanded', 'false');
            toggleSearchBtn.querySelector('span').textContent = '›';
            
            // Don't reset lastActivePanel - keep it as 'favorites' so toggle can reopen it
            
            // Clear favorites markers
            clearFavoritesOverlays();
        }

        function backToSearch() {
            favoritesPanel.style.transform = 'translateX(-100%)';
            if (dietaryTagsPanel) dietaryTagsPanel.style.transform = 'translateX(-100%)';
            searchPanel.style.transform = 'translateX(0)';
            restaurantDetailsPanel.style.display = 'none';
            toggleSearchBtn.style.left = '26rem';
            toggleSearchBtn.setAttribute('aria-expanded', 'true');
            toggleSearchBtn.querySelector('span').textContent = '‹';
            
            // Track active panel
            lastActivePanel = 'search';
            
            clearFavoritesOverlays();
            clearDietaryTagsOverlays();
        }

        async function loadCommunityDietaryRestrictions() {
            try
            {
                if (dietaryTagsGuestHint) {
                    dietaryTagsGuestHint.style.display = window.isGuest ? 'block' : 'none';
                }

                const res = await fetch('/Account/GetDietaryRestrictions');
                if (!res.ok) return;
                const list = await res.json();
                if (!Array.isArray(list)) return;
                
                dietaryRestrictionsList = list;

                if (dietaryTagSelect) {
                    dietaryTagSelect.innerHTML = '';
                    const placeholder = document.createElement('option');
                    placeholder.value = '';
                    placeholder.textContent = 'Select a tag…';
                    dietaryTagSelect.appendChild(placeholder);

                    list.forEach(dr => {
                        const opt = document.createElement('option');
                        opt.value = dr.dietaryRestrictionId;
                        opt.textContent = dr.name;
                        dietaryTagSelect.appendChild(opt);
                    });

                    // Default to first tag if available
                    if (list.length > 0) {
                        selectedCommunityDietaryRestrictionId = list[0].dietaryRestrictionId;
                        dietaryTagSelect.value = String(selectedCommunityDietaryRestrictionId);
                    }
                }

                // Preload count for default selection (and update badge)
                if (selectedCommunityDietaryRestrictionId != null) {
                    await loadCommunityTaggedShops(selectedCommunityDietaryRestrictionId);
                    updateDietaryTagsCount();
                    await refreshCommunityDietaryTagStatusForCurrentResults();
                    if (dietaryFilterEnabled) applyDietaryFilterToCards();
                }
            }
            catch (e)
            {
                console.error('Failed to load dietary restrictions for community tags:', e);
            }
        }

        function toggleDietaryTagsPanel() {
            const isOpen = dietaryTagsPanel && dietaryTagsPanel.style.transform === 'translateX(0px)';
            if (isOpen) {
                closeDietaryTags();
            } else {
                openDietaryTags();
            }
        }

        async function openDietaryTags() {
            // Public panel: allow guests to open/browse
            searchPanel.style.transform = 'translateX(-100%)';
            favoritesPanel.style.transform = 'translateX(-100%)';
            if (dietaryTagsPanel) dietaryTagsPanel.style.transform = 'translateX(0)';
            restaurantDetailsPanel.style.display = 'none';
            toggleSearchBtn.style.left = '26rem';
            toggleSearchBtn.setAttribute('aria-expanded', 'true');
            toggleSearchBtn.querySelector('span').textContent = '‹';

            lastActivePanel = 'dietary';

            // Render list for selected tag
            if (dietaryTagSelect) {
                const id = parseInt(dietaryTagSelect.value || '', 10);
                if (!Number.isNaN(id) && id > 0) {
                    selectedCommunityDietaryRestrictionId = id;
                }
            }

            if (selectedCommunityDietaryRestrictionId != null) {
                await loadCommunityTaggedShops(selectedCommunityDietaryRestrictionId);
                displayDietaryTags();
            }
        }

        function closeDietaryTags() {
            if (dietaryTagsPanel) dietaryTagsPanel.style.transform = 'translateX(-100%)';
            toggleSearchBtn.style.left = '0';
            toggleSearchBtn.setAttribute('aria-expanded', 'false');
            toggleSearchBtn.querySelector('span').textContent = '›';
            clearDietaryTagsOverlays();
        }

        function backToSearchFromDietary() {
            if (dietaryTagsPanel) dietaryTagsPanel.style.transform = 'translateX(-100%)';
            searchPanel.style.transform = 'translateX(0)';
            restaurantDetailsPanel.style.display = 'none';
            toggleSearchBtn.style.left = '26rem';
            toggleSearchBtn.setAttribute('aria-expanded', 'true');
            toggleSearchBtn.querySelector('span').textContent = '‹';
            lastActivePanel = 'search';
            clearDietaryTagsOverlays();
        }

        async function loadCommunityTaggedShops(dietaryRestrictionId) {
            try {
                const res = await fetch(`/api/DietaryTagVotes/shops?dietaryRestrictionId=${encodeURIComponent(dietaryRestrictionId)}`);
                if (!res.ok) { dietaryTagsData = []; return; }
                const list = await res.json();
                dietaryTagsData = Array.isArray(list) ? list : [];
            } catch (e) {
                console.error('Failed to load community-tagged shops:', e);
                dietaryTagsData = [];
            }
        }

        function updateDietaryTagsCount() {
            const count = Array.isArray(dietaryTagsData) ? dietaryTagsData.length : 0;
            const badge = document.getElementById('dietary-tags-count-badge');
            const controlBadge = document.getElementById('dietary-tags-control-badge');
            if (badge) badge.textContent = String(count);
            if (controlBadge) {
                controlBadge.textContent = String(count);
                controlBadge.style.display = count > 0 ? 'flex' : 'none';
            }
        }

        function clearDietaryTagsOverlays() {
            dietaryTagsMarkers.forEach(m => { try { m.setMap(null); } catch {} });
            dietaryTagsMarkers = [];
            dietaryTagsInfoWindows.forEach(iw => { try { iw.close(); } catch {} });
            dietaryTagsInfoWindows = [];
        }

        function displayDietaryTags() {
            const resultsDiv = document.getElementById('dietary-tags-results');
            if (!resultsDiv) return;
            resultsDiv.innerHTML = '';

            updateDietaryTagsCount();
            clearDietaryTagsOverlays();

            if (!Array.isArray(dietaryTagsData) || dietaryTagsData.length === 0) {
                resultsDiv.innerHTML = `
                    <div class="dt-empty">
                        <div class="dt-empty__icon">🥗</div>
                        <p class="dt-empty__title">No community-tagged places yet</p>
                        <p class="dt-empty__subtitle">Once votes reach the threshold, places will appear here.</p>
                    </div>
                `;
                return;
            }

            const bounds = new google.maps.LatLngBounds();

            dietaryTagsData.forEach((shop, index) => {
                const card = document.createElement('div');
                card.className = 'dietary-tag-result-card';

                card.innerHTML = `
                    <div class="dt-card__header">
                        <div style="min-width:0; flex:1;">
                            <div class="dt-card__title">${escapeHtml(shop.name || 'Unknown')}</div>
                            <div class="dt-card__meta">${escapeHtml(shop.address || 'Address unavailable')}</div>
                        </div>
                        <div class="dt-card__stats">
                            <div class="dt-stat-pill"><span aria-hidden="true">▲</span> ${shop.voteCount ?? 0}</div>
                        </div>
                    </div>
                    <div class="dt-card__actions">
                        <button class="dt-btn dt-btn--primary open-community-btn"
                                type="button"
                                data-place-id="${escapeHtml(shop.placeId || '')}"
                                data-place-name="${escapeHtml(shop.name || '')}">
                            <svg class="dt-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M8 10h8M8 14h5m9-2a8 8 0 11-16 0 8 8 0 0116 0z"/>
                            </svg>
                            View Community
                        </button>
                    </div>
                `;

                card.addEventListener('click', () => {
                    try {
                        if (shop.latitude != null && shop.longitude != null) {
                            map.setCenter({ lat: parseFloat(shop.latitude), lng: parseFloat(shop.longitude) });
                            map.setZoom(16);
                        }
                    } catch {}
                    showRestaurantCard(shop.placeId || '', shop.name || '', -1, 'search');
                });

                resultsDiv.appendChild(card);

                if (shop.latitude != null && shop.longitude != null) {
                    const loc = { lat: parseFloat(shop.latitude), lng: parseFloat(shop.longitude) };
                    bounds.extend(loc);
                    const marker = new google.maps.Marker({
                        position: loc,
                        map: map,
                        title: shop.name,
                        icon: {
                            url: '/images/MapPinLine.svg',
                            scaledSize: new google.maps.Size(32, 32)
                        }
                    });
                    dietaryTagsMarkers.push(marker);

                    const closeId = `dt-iw-close-${shop.placeId || index}`;
                    const contentHtml = `
                        <div style="background:#47682C; padding:10px 14px; border-radius:6px; position:relative; color:#FFFFFF; font-weight:600;">
                            <div style="display:flex; align-items:center; justify-content:space-between; gap:12px;">
                                <span style="font-size:14px;">${escapeHtml(shop.name || '')}</span>
                                <button id="${closeId}" style="background:transparent; border:none; font-weight:700; color:#FFFFFF; cursor:pointer;">×</button>
                            </div>
                            <div style="position:absolute; left:24px; bottom:-10px; width:0; height:0; border-left:10px solid transparent; border-right:10px solid transparent; border-top:10px solid #e5e7eb;"></div>
                        </div>`;
                    const infoWindow = new google.maps.InfoWindow({ content: contentHtml, shouldFocus: false });
                    dietaryTagsInfoWindows.push(infoWindow);
                    infoWindow.open(map, marker);

                    infoWindow.addListener('domready', () => {
                        const btn = document.getElementById(closeId);
                        if (btn) btn.onclick = () => infoWindow.close();
                    });

                    marker.addListener('click', () => {
                        infoWindow.open(map, marker);
                        showRestaurantCard(shop.placeId || '', shop.name || '', -1, 'search');
                    });
                }
            });

            try {
                if (!bounds.isEmpty()) {
                    map.fitBounds(bounds);
                }
            } catch {}
        }

        async function displayFavorites() {
            const resultsDiv = document.getElementById('favorites-results');
            resultsDiv.innerHTML = '';
            
            if (favoritesData.length === 0) {
                resultsDiv.innerHTML = `
                    <div style="text-align:center; padding:2rem 1rem; color:#6b7280;">
                        <div style="font-size:3rem; margin-bottom:0.5rem;">❤️</div>
                        <p style="margin:0; font-size:1rem; font-weight:600; color:#374151;">No favorites yet</p>
                        <p style="margin:0.5rem 0 0 0; font-size:0.875rem;">Add restaurants to your favorites by clicking the heart icon</p>
                    </div>
                `;
                return;
            }
            
            // Clear previous overlays
            clearFavoritesOverlays();
            
            // Create bounds to fit all favorites
            const bounds = new google.maps.LatLngBounds();
            
            // Display each favorite
            for (let i = 0; i < favoritesData.length; i++) {
                const favorite = favoritesData[i];
                await displayFavoriteCard(favorite, resultsDiv, i);
                
                // Extend bounds if location exists
                if (favorite.latitude && favorite.longitude) {
                    bounds.extend({ lat: parseFloat(favorite.latitude), lng: parseFloat(favorite.longitude) });
                }
            }
            
            // Fit map to show all favorite markers
            if (favoritesData.length > 0) {
                map.fitBounds(bounds);
            }
        }

        async function displayFavoriteCard(favorite, container, index = 0) {
            const location = favorite.latitude && favorite.longitude 
                ? { lat: parseFloat(favorite.latitude), lng: parseFloat(favorite.longitude) }
                : null;
            
            let distanceInfo = { distanceText: 'Distance unavailable', durationText: 'Time unavailable' };
            if (location) {
                try {
                    distanceInfo = await calculateDrivingDistance(location);
                } catch (error) {
                    console.warn('Failed to calculate distance for favorite:', error);
                }
            }
            
            // Get favorite details to extract photos (new API preferred via helper)
            fetchPlaceDetails(favorite.placeId).then((place) => {
                let imageUrls = [];
                let cuisineTypes = ['Restaurant'];
                let priceLevel = '₱₱';
