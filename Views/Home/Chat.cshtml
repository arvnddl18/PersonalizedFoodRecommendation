        // Add to favorites from restaurant details panel
        async function addToFavorites(placeId, placeName) {
            if (window.isGuest) {
                addMessage('FoodieSaur Bot', 'Please log in to use Favorites.');
                return;
            }
            try {
                // Check if already favorited
                const isFavorite = userFavorites.has(placeId);
                
                if (isFavorite) {
                    // Remove from favorites
                    const response = await fetch(`/api/Favorites/remove/${placeId}`, {
                        method: 'DELETE'
                    });
                    
                    if (response.ok) {
                        userFavorites.delete(placeId);
                        updateFavoriteButtonUI(placeId, false);
                        await loadFavorites();
                        addMessage('FoodieSaur Bot', `${placeName} has been removed from your favorites.`);
                    } else {
                        addMessage('FoodieSaur Bot', 'Failed to remove from favorites.');
                    }
                } else {
                    // Add to favorites - need to get full place details
                    if (!currentRestaurantDetails) {
                        addMessage('FoodieSaur Bot', 'Loading restaurant details...');
                        return;
                    }
                    
                    const place = currentRestaurantDetails;
                    const favoriteData = {
                        placeId: placeId,
                        name: place.name || placeName,
                        address: place.vicinity || place.formatted_address || '',
                        rating: place.rating || null,
                        priceLevel: place.price_level || null,
                        photoReference: place.photos?.[0]?.photo_reference || null,
                        latitude: place.geometry?.location?.lat() || null,
                        longitude: place.geometry?.location?.lng() || null,
                        phoneNumber: place.formatted_phone_number || null,
                        website: place.website || null,
                        types: place.types || []
                    };
                    
                    const response = await fetch('/api/Favorites/add', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(favoriteData)
                    });
                    
                    if (response.ok) {
                        userFavorites.add(placeId);
                        updateFavoriteButtonUI(placeId, true);
                        await loadFavorites();
                        addMessage('FoodieSaur Bot', `${placeName} has been added to your favorites! ❤️`);
                    } else {
                        addMessage('FoodieSaur Bot', 'Failed to add to favorites.');
                    }
                }
            } catch (e) {
                console.error(e);
                addMessage('FoodieSaur Bot', 'Failed to update favorites.');
            }
        }

