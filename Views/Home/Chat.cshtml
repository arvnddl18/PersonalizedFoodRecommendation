        // Highlight the selected restaurant card in the panel
        function highlightSelectedRestaurantCard(index) {
            // Determine which panel is active
            const isSearchActive = searchPanel.style.transform === 'translateX(0px)';
            const isFavoritesActive = favoritesPanel.style.transform === 'translateX(0px)';
            
            let panelToSearch = null;
            let cardSelector = '';
            if (isSearchActive) {
                panelToSearch = document.getElementById('search-results');
                cardSelector = '.result-item';
            } else if (isFavoritesActive) {
                panelToSearch = document.getElementById('favorites-results');
                cardSelector = '.favorite-result-card';
            }
            
            if (!panelToSearch) return;
            
            // Remove all previous highlights
            panelToSearch.querySelectorAll(cardSelector).forEach(card => {
                card.style.borderLeft = 'none';
                card.style.background = '#ffffff';
            });
            
            // Highlight the current card
            const cards = panelToSearch.querySelectorAll(cardSelector);
            if (cards[index]) {
                cards[index].style.borderLeft = '4px solid #47682C';
                cards[index].style.background = 'linear-gradient(90deg, rgba(71,104,44,0.05) 0%, #ffffff 100%)';
                
                // Scroll the card into view
                cards[index].scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
        }

        // Display detailed restaurant information - ACTIVE for generalized queries
        async function displayRestaurantDetails(place) {
            const detailsPanel = document.getElementById('restaurant-details-panel');
            const detailsContent = document.getElementById('restaurant-details-content');
            const actionsContent = document.getElementById('restaurant-details-actions');
            detailsContent.innerHTML = '';
            actionsContent.innerHTML = '';

            // Ensure complete details (fetch missing fields; no fictional defaults)
            let completePlace = place;
            try {
                if (place && place.place_id && (!place.formatted_address || !place.opening_hours || !place.photos || place.price_level == null || !place.reviews)) {
                    const extra = await fetchPlaceDetails(place.place_id);
                    completePlace = { ...place, ...extra };
                }
            } catch (e) {
                console.warn('Failed to fetch complete details for details panel:', e);
            }

            // Update current references
            currentRestaurantDetails = completePlace;
            place = completePlace;

            // Get user ID for edit/history buttons
            const userId = @(HttpContextAccessor.HttpContext.Session.GetInt32("UserId")?.ToString() ?? "null");

            // Populate Top Center Restaurant Card
            populateTopRestaurantCard(place, true);

            // Get price range text - default to ₱100-₱300 when unavailable
            const getPriceRangeText = (level) => {
                const ranges = {
                    0: '₱0-₱100',
                    1: '₱100-₱200',
                    2: '₱200-₱400',
                    3: '₱400-₱800',
                    4: '₱800+'
                };
                return level != null ? ranges[level] : '₱100-₱300';
            };

            const priceRange = getPriceRangeText(place.price_level);
            const heroPhoto = (place.photos && place.photos.length > 0) ? place.photos[0].getUrl({ maxWidth: 1200, maxHeight: 600 }) : '';

            // Build opening status text with real data only
            const statusInfo = getStoreStatus(place);
            const openingColor = statusInfo.isOpen ? '#10b981' : (statusInfo.text && statusInfo.text.includes('Closed') ? '#ef4444' : '#6b7280');
            let closingInfo = '';
            const openingHours = place.opening_hours || place.current_opening_hours;
            if (openingHours && statusInfo.isOpen && openingHours.weekday_text && openingHours.weekday_text.length > 0) {
                const today = new Date().getDay();
                const dayIndex = (today === 0) ? 6 : today - 1;
                const todayHours = openingHours.weekday_text[dayIndex];
                if (todayHours) {
                    const hoursText = todayHours.split(': ')[1];
                    if (hoursText && hoursText !== 'Closed') {
                        const closingTime = hoursText.split(' – ')[1] || hoursText.split('–')[1] || hoursText.split(' - ')[1] || hoursText.split('-')[1];
                        if (closingTime) {
                            closingInfo = ` · Closes ${closingTime.trim()}`;
                        }
                    }
                }
            }
            const openingLine = `${statusInfo.text}${closingInfo}`;

            // Fetch current version data for this restaurant
            let currentVersion = null;
            let isOwner = false;
            let isAdmin = false;
            let canEdit = false;
            let hasVerifiedOwner = false;
            try {
                const versionResponse = await fetch(`/api/RestaurantEdit/current/${place.place_id}`);
                if (versionResponse.ok) {
                    currentVersion = await versionResponse.json();
                }
                
                // Check if user is owner
                if (userId !== null && currentVersion) {
                    try {
                        const ownerResponse = await fetch(`/api/RestaurantOwner/owner/${place.place_id}`);
                        if (ownerResponse.ok) {
                            hasVerifiedOwner = true;
                            const ownerData = await ownerResponse.json();
                            // Check if current user is the owner and verified
                            isOwner = ownerData.userId === parseInt(userId) && ownerData.verificationStatus === 'Verified';
                        }
                    } catch (e) {
                        // Owner check failed, continue without owner status
                        console.warn('Failed to check owner status:', e);
                    }
                }

                // Check if user can edit (owner/admin)
                if (userId !== null) {
                    try {
                        const permsResp = await fetch(`/api/RestaurantEdit/permissions/${place.place_id}`);
                        if (permsResp.ok) {
                            const perms = await permsResp.json();
                            isAdmin = !!perms.isAdmin;
