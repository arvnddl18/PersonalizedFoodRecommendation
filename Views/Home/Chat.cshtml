		// Render action buttons from response
        function renderActionButtonsFromResponse(text) {
            const messagesDiv = document.getElementById('new-messages');

            // Enhanced parsing for organized response format
            const raw = String(text ?? '');
            let names = [];
            
            // Look for the organized format with various headers
            const organizedSection = raw.match(/(?:Based on your comprehensive profile, I recommend these foods:|Here are my top recommendations for you:|These are the best options I've found for you:|I've selected these foods specifically for you:|Here are the perfect choices for your profile:|These recommendations are tailored to your needs:|I've chosen these options with you in mind:|Here are the ideal selections for your preferences:|These foods are perfectly suited to your profile:|I've picked these recommendations just for you:|Here are the best matches for your taste profile:|These selections are customized for your needs:|I've curated these options specifically for you:|Here are the perfect picks for your preferences:|These recommendations are designed for your profile:|I've handpicked these foods for your enjoyment:|Here are the ideal choices for your taste:|These options are perfectly matched to your needs:|I've selected these foods with your preferences in mind:|Here are the best recommendations for your profile:)\s*\n((?:\d+\.\s*[^\n]+\(Score:\s*[\d.]+\)\s*\n?)+)/i);
            if (organizedSection) {
                const foodLines = organizedSection[1].split('\n').filter(line => line.trim());
                names = foodLines.map(line => {
                    // Extract name before "(Score:" and remove any score patterns
                    let name = line.replace(/^\d+\.\s*/, '').trim();
                    // Remove score pattern: (Score: X.XX) or (Score: X)
                    name = name.replace(/\s*\(Score:\s*[\d.]+\).*$/i, '').trim();
                    // Also remove any trailing parentheses with scores
                    name = name.replace(/\s*\([^)]*Score[^)]*\).*$/i, '').trim();
                    // Remove any trailing dashes or separators
                    name = name.split(/[–—-]/)[0].trim();
                    return name;
                }).filter(name => name.length > 0);
            } else {
                // Fallback to original parsing for backward compatibility
                const byLines = raw.split('\n').filter(l => /^\s*\d+\.\s+\w+/i.test(l));
                if (byLines.length > 0) {
                    names = byLines.map(l => {
                        let name = l.replace(/^\s*\d+\.\s+/, '').trim();
                        // Remove score pattern
                        name = name.replace(/\s*\(Score:\s*[\d.]+\).*$/i, '').trim();
                        name = name.split(/[–—-]/)[0].trim();
                        return name;
                    }).filter(name => name.length > 0);
                } else {
                    const pattern = /(\d+)\.\s*([A-Za-z][A-Za-z\s-()]{1,60})/g;
                    let m;
                    while ((m = pattern.exec(raw)) !== null) {
                        let name = m[2].trim();
                        // Remove score pattern
                        name = name.replace(/\s*\(Score:\s*[\d.]+\).*$/i, '').trim();
                        name = name.split(/[–—-]/)[0].trim();
                        if (name.length > 0) {
                            names.push(name);
                        }
                    }
                }
            }
            
            if (names.length === 0) return;

            // Enhanced title with brand colors
            const title = document.createElement('div');
            title.style.cssText = 'font-size:0.875rem; color:#47682C; font-weight:600; margin-top:0.75rem; margin-bottom:0.5rem;';
            title.textContent = '✨ Choose a food type:';
            messagesDiv.appendChild(title);

			// Enhanced button list container with brand styling
			const container = document.createElement('div');
			container.style.marginTop = '0.5rem';
			container.style.marginBottom = '1rem';
			container.style.display = 'flex';
			container.style.flexDirection = 'column';
			container.style.gap = '0.625rem';
			container.style.animation = 'fadeIn 0.4s ease-out';
			names.forEach((name, index) => {
                const btn = document.createElement('button');
                btn.type = 'button';
				btn.textContent = name;
				btn.style.cssText = `
					padding: 0.75rem 1rem;
					border-radius: 0.875rem;
					font-size: 0.9rem;
					border: 1.5px solid rgba(71,104,44,0.2);
					background: rgba(255,255,255,0.95);
					color: #47682C;
					cursor: pointer;
					box-shadow: 0 2px 6px rgba(71,104,44,0.08);
					transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
					font-weight: 600;
					text-align: left;
					animation: slideInLeft 0.4s ease-out;
					animation-delay: ${index * 0.05}s;
					opacity: 0;
					animation-fill-mode: forwards;
				`;
				btn.onmouseenter = function() {
					this.style.background = '#F7B32B';
					this.style.borderColor = '#F7B32B';
					this.style.color = '#ffffff';
					this.style.transform = 'translateX(4px)';
					this.style.boxShadow = '0 4px 12px rgba(247,179,43,0.3)';
				};
				btn.onmouseleave = function() {
					this.style.background = 'rgba(255,255,255,0.95)';
					this.style.borderColor = 'rgba(71,104,44,0.2)';
					this.style.color = '#47682C';
					this.style.transform = 'translateX(0)';
					this.style.boxShadow = '0 2px 6px rgba(71,104,44,0.08)';
				};
                btn.onclick = () => selectRecommendation(name);
                container.appendChild(btn);
            });
            messagesDiv.appendChild(container);

            // Scroll to bottom
            const chatMessages = document.getElementById('chat-messages');
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        function escapeHtml(s) {
            return s
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function normalizeExternalUrl(url) {
            if (!url) return '';
            const trimmed = url.trim();
            if (!trimmed) return '';
            // If user enters "facebook.com/page", prepend https://
            if (!/^https?:\/\//i.test(trimmed)) return `https://${trimmed}`;
            return trimmed;
        }

        // Allow http(s) URLs or same-origin absolute paths ("/images/...").
        // Blocks dangerous schemes like "javascript:" and "data:".
        function normalizeMenuImageUrl(url) {
            if (!url) return '';
            const trimmed = String(url).trim();
            if (!trimmed) return '';
            if (/^(javascript|data):/i.test(trimmed)) return '';
            if (trimmed.startsWith('/')) return trimmed;
            if (!/^https?:\/\//i.test(trimmed)) return `https://${trimmed}`;
            return trimmed;
        }

        function listTextToInlineHtml(text, options = null) {
            const raw = (text || '').toString().trim();
            if (!raw) return `<span style="color:#9ca3af; font-size:0.8125rem;">Not available</span>`;
            const items = raw
                .split(/[\n,]+/g)
                .map(s => s.trim())
                .filter(Boolean)
                .slice(0, 10);
            if (items.length === 0) return `<span style="color:#9ca3af; font-size:0.8125rem;">Not available</span>`;
            const bg = options?.bg || 'var(--pf-chip-bg, #f9fafb)';
            const border = options?.border || 'var(--pf-chip-border, #e5e7eb)';
            const color = options?.color || 'var(--pf-chip-color, #6b7280)';
            const fontWeight = options?.fontWeight || '700';
            return items.map(i => `<span style="display:inline-block; margin:0.125rem 0.25rem; padding:0.125rem 0.5rem; border:1px solid ${border}; border-radius:999px; font-size:0.75rem; color:${color}; background:${bg}; font-weight:${fontWeight};">${escapeHtml(i)}</span>`).join('');
        }

        function menuTextToHtml(text) {
            const raw = (text || '').toString().trim();
            if (!raw) return `<div style="text-align:center; color:#9ca3af; font-size:0.8125rem;">Not available</div>`;
            const lines = raw.split(/\r?\n/g).map(s => s.trim()).filter(Boolean).slice(0, 30);
            if (lines.length === 0) return `<div style="text-align:center; color:#9ca3af; font-size:0.8125rem;">Not available</div>`;
            return lines.map(line => {
                const parsed = parseMenuLine(line);
                return buildMenuCardHtml(parsed);
            }).join('');
        }

        function slugifyMenuGroupId(s) {
            return String(s || '')
                .toLowerCase()
                .replace(/[^a-z0-9]+/g, '-')
                .replace(/-+/g, '-')
                .replace(/(^-|-$)/g, '')
                .slice(0, 40) || 'group';
        }

        function buildMenuCardHtml(parsed, opts = null) {
            const p = parsed || {};
            const highlight = !!opts?.highlight;
            const minWidth = opts?.minWidth ? String(opts.minWidth) : '';
            const title = p.name ? `<div style="font-weight:900; color:#111827; font-size:0.875rem; margin-bottom:0.25rem;">${escapeHtml(p.name)}</div>` : '';
            const imgUrl = normalizeMenuImageUrl(p.imgUrl || p.imageUrl || '');
            const imgHtml = imgUrl
                ? `
                    <div style="margin:-0.15rem 0 0.65rem 0; border-radius:0.75rem; overflow:hidden; border:1px solid rgba(15,23,42,0.08); background:#f3f4f6;">
                        <img src="${escapeHtml(imgUrl)}"
                             alt="${escapeHtml(p.name ? `${p.name} photo` : 'Menu item photo')}"
                             style="width:100%; height:140px; object-fit:cover; display:block;"
                             loading="lazy"
                             onerror="this.style.display='none';" />
                    </div>
                `
                : '';
            const metaBits = [];
            if (p.caloriesKcal != null && Number.isFinite(p.caloriesKcal)) metaBits.push(`${Math.round(p.caloriesKcal)} kcal`);
            if (p.serving) metaBits.push(escapeHtml(p.serving));
            const metaHtml = metaBits.length > 0
                ? `<div style="margin:-0.125rem 0 0.375rem 0; font-size:0.75rem; color:#6b7280; font-weight:800;">${metaBits.join(' · ')}</div>`
                : '';
            const bodyText = String(p.body || '').trim();
            const bodyHtml = bodyText
                ? `<div style="font-size:0.8125rem; color:#374151; line-height:1.55; white-space:pre-wrap;">${escapeHtml(bodyText)}</div>`
                : '';
            const tagsHtml = (p.tags && p.tags.length > 0)
                ? `
                    <div style="display:flex; flex-wrap:wrap; gap:0.375rem; margin-top:0.5rem;">
                        ${p.tags.map(t => `
                            <span style="display:inline-block; padding:0.125rem 0.5rem; border-radius:999px; font-size:0.75rem; font-weight:900; color:#47682C; background:rgba(71,104,44,0.10); border:1px solid rgba(71,104,44,0.22);">
                                ${escapeHtml(t)}
                            </span>
                        `).join('')}
                    </div>
                `
                : '';

            const border = highlight ? 'rgba(247,179,43,0.85)' : '#e5e7eb';
            const bg = highlight ? 'linear-gradient(135deg, rgba(247,179,43,0.14) 0%, rgba(71,104,44,0.06) 100%)' : '#ffffff';
            const boxShadow = highlight ? '0 10px 22px rgba(247,179,43,0.16)' : '0 2px 10px rgba(17,24,39,0.05)';

            return `
                <div style="border:1px solid ${border}; border-radius:0.85rem; padding:0.75rem; background:${bg}; box-shadow:${boxShadow}; ${minWidth ? `min-width:${escapeHtml(minWidth)};` : ''}">
                    ${imgHtml}
                    ${title}
                    ${metaHtml}
                    ${bodyHtml}
                    ${tagsHtml}
                </div>
            `;
        }

        function getLastDesiredFood() {
            try {
                const p = window.lastSearchParameters || {};
                const food = String(p.food || '').trim();
                if (food) return food;
                // Fallback: if user used keyword-style search, use extracted keyword
                const rawUserText = String(window.lastUserMessage || '').trim();
                const kw = (typeof extractKeywordFromUserMessage === 'function') ? String(extractKeywordFromUserMessage(rawUserText) || '').trim() : '';
                return kw || '';
            } catch (_) { return ''; }
        }

        function getLastDesiredDietary() {
            try {
                const p = window.lastSearchParameters || {};
                const d = String(p.dietary || '').trim();
                if (d) return d;
                // Fallback: use selected community dietary filter (if any)
                if (typeof selectedCommunityDietaryRestrictionId !== 'undefined' && selectedCommunityDietaryRestrictionId != null) {
                    const found = Array.isArray(dietaryRestrictionsList)
                        ? dietaryRestrictionsList.find(x => String(x?.dietaryRestrictionId) === String(selectedCommunityDietaryRestrictionId))
                        : null;
                    const name = String(found?.name || '').trim();
                    if (name) return name;
                }
                return '';
            } catch (_) { return ''; }
        }

        function normalizeForMatch(s) {
            return String(s || '').toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim();
        }

        function tokenizeForMatch(s) {
            return normalizeForMatch(s).split(/\s+/g).map(t => t.trim()).filter(t => t.length >= 3).slice(0, 8);
        }

        function scoreMenuMatch(item, desiredFood, desiredDietary) {
            const text = normalizeForMatch([item?.type, item?.name, item?.body, ...(item?.tags || [])].join(' '));
            let foodScore = 0;
            let dietaryScore = 0;

            const foodTokens = tokenizeForMatch(desiredFood);
            if (foodTokens.length > 0) {
                const hit = foodTokens.filter(t => text.includes(t)).length;
                foodScore = hit / foodTokens.length;
            }

            const desiredDiet = String(desiredDietary || '').trim();
            if (desiredDiet) {
                const dNorm = normalizeDietaryName(desiredDiet);
                const tags = Array.isArray(item?.tags) ? item.tags : [];
                const tagHit = tags.some(t => normalizeDietaryName(t) === dNorm);
                dietaryScore = tagHit ? 1 : (text.includes(dNorm) ? 0.6 : 0);
            }

            const hasFood = !!String(desiredFood || '').trim();
            const hasDiet = !!String(desiredDietary || '').trim();
            const bothBonus = (hasFood && hasDiet && foodScore >= 0.8 && dietaryScore >= 0.8) ? 0.25 : 0;

            // weight food slightly higher; dietary is typically a strict filter
            const score = (hasFood ? 0.7 * foodScore : 0) + (hasDiet ? 0.3 * dietaryScore : 0) + bothBonus;
            return Math.max(0, Math.min(1, score));
        }

        function scrollMenuCarousel(placeId, groupId, dir) {
            try {
                const el = document.getElementById(`menu-carousel-${placeId}-${groupId}`);
                if (!el) return;
                const card = el.querySelector('[data-menu-card="1"]');
                const step = card ? (card.getBoundingClientRect().width + 12) : 260;
                el.scrollBy({ left: (dir >= 0 ? step : -step), behavior: 'smooth' });
            } catch (_) { }
        }

        // -------------------------
        // Menu "See all" modal
        // -------------------------
        function getMenuSeeAllEls() {
            return {
                overlay: document.getElementById('menu-seeall-overlay'),
                title: document.getElementById('menu-seeall-title'),
                close: document.getElementById('menu-seeall-close'),
                chips: document.getElementById('menu-seeall-chips'),
                search: document.getElementById('menu-seeall-search'),
                dietary: document.getElementById('menu-seeall-dietary'),
                list: document.getElementById('menu-seeall-list'),
            };
        }

        function closeMenuSeeAllModal() {
            const els = getMenuSeeAllEls();
            if (!els.overlay) return;
            els.overlay.style.display = 'none';
            els.overlay.setAttribute('aria-hidden', 'true');
            if (els.search) els.search.value = '';
            if (els.list) els.list.innerHTML = '';
            if (els.chips) els.chips.innerHTML = '';
            if (els.dietary) els.dietary.innerHTML = '';
            if (window.__menuSeeAllState) window.__menuSeeAllState.selectedDietary = [];
        }

        function openMenuSeeAllModal(placeId, groupId = 'all') {
            try {
                const store = window.__menuItemsModalData?.[placeId];
                const els = getMenuSeeAllEls();
                if (!store || !els.overlay || !els.list) return;

                const state = (window.__menuSeeAllState = window.__menuSeeAllState || {});
                state.placeId = placeId;
                // Always show all category "tabs" in the modal; opening from a category
                // simply selects that category as the active tab.
                state.activeGroupId = (groupId && groupId !== 'all') ? groupId : 'all';
                state.selectedDietary = Array.isArray(state.selectedDietary) ? state.selectedDietary : [];

                els.overlay.style.display = 'flex';
                els.overlay.setAttribute('aria-hidden', 'false');

                // Chips (always visible so user can switch categories)
                if (els.chips) {
                    const chipsHtml = [
                        `<button type="button" class="menu-chip ${state.activeGroupId === 'all' ? 'active' : ''}" data-menu-chip="all">All</button>`,
                        ...(store.groups || []).map(g => `
                            <button type="button" class="menu-chip ${state.activeGroupId === g.id ? 'active' : ''}" data-menu-chip="${escapeHtml(g.id)}">
                                ${escapeHtml(g.name)}
                            </button>
                        `)
                    ].join('');
                    els.chips.innerHTML = chipsHtml;
                }

                // Dietary filter chips (multi-select)
                if (els.dietary) {
                    const opts = (typeof getDietaryTagOptions === 'function') ? (getDietaryTagOptions() || []) : [];
                    const selected = new Set((state.selectedDietary || []).map(s => String(s || '').trim()).filter(Boolean));
                    const chips = opts.map(t => `
                        <button type="button"
                                class="menu-filter-chip ${selected.has(t) ? 'active' : ''}"
                                data-menu-dietary="${escapeHtml(t)}">
                            ${escapeHtml(t)}
                        </button>
                    `).join('');
                    const clearBtn = `<button type="button" class="menu-filter-clear" data-menu-dietary-clear="1">Clear</button>`;
                    els.dietary.innerHTML = `${chips}${opts.length ? clearBtn : ''}`;
                }

                // Title
                const activeGroup = (store.groups || []).find(g => g.id === state.activeGroupId);
                if (els.title) {
                    els.title.textContent = activeGroup ? `${activeGroup.name}` : 'All menu items';
                }

                renderMenuSeeAllList();

                // focus search for fast browsing
                try { els.search?.focus(); } catch (_) {}
            } catch (_) { }
        }

        function renderMenuSeeAllList() {
            const els = getMenuSeeAllEls();
            const state = window.__menuSeeAllState || {};
            const placeId = state.placeId;
            if (!placeId) return;
            const store = window.__menuItemsModalData?.[placeId];
            if (!store || !els.list) return;

            const q = String(els.search?.value || '').trim().toLowerCase();
            const selectedDietary = Array.isArray(state.selectedDietary) ? state.selectedDietary : [];
            const selectedDietaryNorm = selectedDietary
                .map(t => String(t || '').trim())
                .filter(Boolean)
                .map(t => (typeof normalizeDietaryName === 'function' ? normalizeDietaryName(t) : t.toLowerCase()));

            let items = [];
            if (state.activeGroupId && state.activeGroupId !== 'all') {
                const g = (store.groups || []).find(x => x.id === state.activeGroupId);
                items = g?.items || [];
            } else {
                items = store.all || [];
            }

            const filtered = items.filter(it => {
                // text filter
                if (q) {
                    const hay = String([it?.type, it?.name, it?.body, ...(it?.tags || [])].join(' ')).toLowerCase();
                    if (!hay.includes(q)) return false;
                }

                // dietary filter (OR match)
                if (selectedDietaryNorm.length > 0) {
                    const tags = Array.isArray(it?.tags) ? it.tags : [];
                    const tagNorm = tags.map(t => String(t || '').trim()).filter(Boolean)
                        .map(t => (typeof normalizeDietaryName === 'function' ? normalizeDietaryName(t) : t.toLowerCase()));
                    const hit = selectedDietaryNorm.some(sel => tagNorm.includes(sel));
                    if (!hit) return false;
                }

                return true;
            });

            if (filtered.length === 0) {
                els.list.innerHTML = `<div style="text-align:center; color:#64748b; font-weight:800; padding:1.75rem 1rem;">No menu items found.</div>`;
                return;
            }

            els.list.innerHTML = filtered.map(it => buildMenuCardHtml(it, { minWidth: '100%', highlight: false })).join('');
        }

        // Modal listeners (once)
        (function setupMenuSeeAllModalListeners() {
            const els = getMenuSeeAllEls();
            if (!els.overlay) return;

            if (els.close) els.close.addEventListener('click', closeMenuSeeAllModal);
            if (els.search) els.search.addEventListener('input', () => renderMenuSeeAllList());

            els.overlay.addEventListener('click', (e) => {
                // click outside dialog closes
                if (e && e.target === els.overlay) closeMenuSeeAllModal();
            });

            // Dietary chip interactions (delegate)
            els.overlay.addEventListener('click', (e) => {
                const clear = e.target?.closest?.('[data-menu-dietary-clear]');
                const chip = e.target?.closest?.('[data-menu-dietary]');
                const ov = document.getElementById('menu-seeall-overlay');
                if (!ov || ov.style.display !== 'flex') return;
                const state = (window.__menuSeeAllState = window.__menuSeeAllState || {});
                state.selectedDietary = Array.isArray(state.selectedDietary) ? state.selectedDietary : [];

                if (clear) {
                    state.selectedDietary = [];
                    const wrap = document.getElementById('menu-seeall-dietary');
                    if (wrap) wrap.querySelectorAll('.menu-filter-chip').forEach(x => x.classList.remove('active'));
                    renderMenuSeeAllList();
                    return;
                }

                if (chip) {
                    const tag = String(chip.getAttribute('data-menu-dietary') || '').trim();
                    if (!tag) return;
                    const idx = state.selectedDietary.findIndex(x => String(x || '').trim() === tag);
                    if (idx >= 0) {
                        state.selectedDietary.splice(idx, 1);
                        chip.classList.remove('active');
                    } else {
                        state.selectedDietary.push(tag);
                        chip.classList.add('active');
                    }
                    renderMenuSeeAllList();
                }
            });

            document.addEventListener('keydown', (e) => {
                if (e && e.key === 'Escape') {
                    const ov = document.getElementById('menu-seeall-overlay');
                    if (ov && ov.style.display === 'flex') closeMenuSeeAllModal();
                }
            });

            document.addEventListener('click', (e) => {
                const btn = e.target?.closest?.('[data-menu-chip]');
                if (!btn) return;
                const ov = document.getElementById('menu-seeall-overlay');
                if (!ov || ov.style.display !== 'flex') return;
                const id = btn.getAttribute('data-menu-chip') || 'all';
                const state = (window.__menuSeeAllState = window.__menuSeeAllState || {});
                state.activeGroupId = id;
                // re-render chips active state + title
                const store = window.__menuItemsModalData?.[state.placeId];
                const chips = document.getElementById('menu-seeall-chips');
                if (store && chips) {
                    chips.querySelectorAll('.menu-chip').forEach(c => c.classList.remove('active'));
                    const active = chips.querySelector(`[data-menu-chip="${CSS.escape(id)}"]`);
                    if (active) active.classList.add('active');
                    const titleEl = document.getElementById('menu-seeall-title');
                    if (titleEl) {
                        const activeGroup = (store.groups || []).find(g => g.id === id);
                        titleEl.textContent = activeGroup ? `${activeGroup.name}` : 'All menu items';
                    }
                }
                renderMenuSeeAllList();
            });
        })();

        function menuTextToCarouselHtml(text, placeId, opts = null) {
            const raw = (text || '').toString().trim();
            if (!raw) return `<div style="text-align:center; color:#9ca3af; font-size:0.8125rem;">Not available</div>`;
            const lines = raw.split(/\r?\n/g).map(s => s.trim()).filter(Boolean).slice(0, 40);
            if (lines.length === 0) return `<div style="text-align:center; color:#9ca3af; font-size:0.8125rem;">Not available</div>`;

            const parsedItems = lines.map(line => parseMenuLine(line));
            const groups = [];
            const groupMap = new Map();

            parsedItems.forEach((it) => {
                const type = String(it?.type || '').trim();
                const groupName = type || 'Menu items';
                if (!groupMap.has(groupName)) {
                    groupMap.set(groupName, []);
                    groups.push(groupName);
                }
                groupMap.get(groupName).push(it);
            });

            // Cache for modal "see all"
            try {
                window.__menuItemsModalData = window.__menuItemsModalData || {};
                window.__menuItemsModalData[placeId] = {
                    all: parsedItems,
                    groups: groups.map(name => ({
                        id: slugifyMenuGroupId(name),
                        name,
                        items: groupMap.get(name) || []
                    }))
                };
            } catch (_) { }

            return groups.map((groupName) => {
                const groupId = slugifyMenuGroupId(groupName);
                const items = groupMap.get(groupName) || [];
                const cards = items.map(p => `
                    <div data-menu-card="1" style="flex:0 0 auto; scroll-snap-align:start;">
                        ${buildMenuCardHtml(p, { minWidth: '240px', highlight: false })}
                    </div>
                `).join('');

                return `
                    <div class="menu-cat">
                        <div class="menu-cat__header">
                            <div class="menu-cat__title">${escapeHtml(groupName)}</div>
                            <button type="button" class="menu-seeall-btn" onclick="openMenuSeeAllModal('${placeId}','${groupId}')">
                                <svg class="dt-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                                See all
                            </button>
                        </div>
                        <div id="menu-carousel-${placeId}-${groupId}"
                             style="display:flex; gap:0.75rem; overflow-x:auto; padding:0.25rem 0 0.5rem 0; scroll-snap-type:x mandatory; scroll-padding-left:0.25rem; overscroll-behavior-x:contain;">
                            ${cards}
                        </div>
                        <div class="menu-cat__controls">
                            <button type="button" class="menu-icon-btn" onclick="scrollMenuCarousel('${placeId}','${groupId}',-1)" aria-label="Scroll left">‹</button>
                            <button type="button" class="menu-icon-btn" onclick="scrollMenuCarousel('${placeId}','${groupId}',1)" aria-label="Scroll right">›</button>
                        </div>
                    </div>
                `;
            }).join('');
        }

        function menuTextToDetailsHtml(text, placeId) {
            const raw = (text || '').toString().trim();
            if (!raw) return `<div style="text-align:center; color:#9ca3af; font-size:0.8125rem;">Not available</div>`;

            const desiredFood = getLastDesiredFood();
            const desiredDietary = getLastDesiredDietary();

            // Parse once for scoring
            const lines = raw.split(/\r?\n/g).map(s => s.trim()).filter(Boolean).slice(0, 40);
            const parsedItems = lines.map(line => parseMenuLine(line));

            let promotedHtml = '';
            const hasAnyIntent = !!String(desiredFood || '').trim() || !!String(desiredDietary || '').trim();
            if (hasAnyIntent && parsedItems.length > 0) {
                const scored = parsedItems
                    .map((it, idx) => ({ it, idx, score: scoreMenuMatch(it, desiredFood, desiredDietary) }))
                    .sort((a, b) => b.score - a.score);

                const best = scored[0];
                const threshold = (String(desiredFood || '').trim() && String(desiredDietary || '').trim()) ? 0.55 : 0.65;

                if (best && best.score >= threshold) {
                    const phrase = [desiredDietary, desiredFood].map(s => String(s || '').trim()).filter(Boolean).join(' ');
                    const hasFood = !!String(desiredFood || '').trim();
                    const hasDiet = !!String(desiredDietary || '').trim();
                    // When the user asked for BOTH (e.g. "vegetarian pasta"), show a few "other relevant"
                    // items that likely match at least one dimension (food-only ≈ 0.7, dietary-only ≈ 0.3).
                    const otherMinScore = (hasFood && hasDiet) ? 0.28 : Math.max(0.55, threshold - 0.1);
                    const other = scored.slice(1).filter(x => x.score >= otherMinScore).slice(0, 3);

                    const othersHtml = other.length > 0 ? `
                        <div style="margin-top:0.75rem;">
                            <div style="font-size:0.75rem; font-weight:900; color:#47682C; letter-spacing:0.06em; text-transform:uppercase; margin-bottom:0.5rem;">
                                Other relevant picks
                            </div>
                            <div style="display:flex; gap:0.75rem; overflow-x:auto; padding-bottom:0.25rem; scroll-snap-type:x mandatory; overscroll-behavior-x:contain;">
                                ${other.map(x => `
                                    <div data-menu-card="1" style="flex:0 0 auto; scroll-snap-align:start;">
                                        ${buildMenuCardHtml(x.it, { minWidth: '220px', highlight: false })}
                                    </div>
                                `).join('')}
                            </div>
                        </div>
                    ` : '';

                    promotedHtml = `
                        <div id="menuitems-promoted-${placeId}"
                             style="padding:0.9rem; border:1px solid rgba(247,179,43,0.55); border-radius:1rem; background:linear-gradient(135deg, rgba(247,179,43,0.18) 0%, rgba(71,104,44,0.06) 100%); box-shadow:0 10px 22px rgba(247,179,43,0.12);">
                            <div style="font-size:0.75rem; font-weight:900; color:#47682C; letter-spacing:0.06em; text-transform:uppercase; margin-bottom:0.4rem;">
                                Promoted for you
                            </div>
                            <div style="font-size:0.875rem; color:#374151; font-weight:900; margin-bottom:0.65rem; line-height:1.25;">
                                It seems that you are looking for ${escapeHtml(phrase || 'this')}
                            </div>
                            ${buildMenuCardHtml(best.it, { highlight: true })}
                            ${othersHtml}
                        </div>
                    `;
                }
            }

            const carousel = menuTextToCarouselHtml(raw, placeId);
            return `${promotedHtml}${carousel}`;
        }

        // Parse a menu line with optional tags suffix.
        // Supported formats:
        // - "Bulgogi - ... [tags: Halal, Gluten-Free]"
        // - "Bulgogi - ... (dietary tags: Vegan, Dairy-Free)"
        function parseMenuLine(line) {
            const original = (line || '').toString().trim();
            if (!original) return { type: '', name: '', body: '', tags: [], caloriesKcal: null, serving: '', imgUrl: '' };

            // We support multiple bracket/paren suffixes at the end (in any order), e.g.
            // "... [cal: 450 kcal] [serving: 1 bowl] [tags: Vegan]"
            let working = original;
            let tags = [];
            let caloriesKcal = null;
            let serving = '';
            let type = '';
            let imgUrl = '';

            for (let i = 0; i < 6; i++) {
                const m = working.match(/\s*(?:\(|\[)\s*([a-zA-Z ]+?)\s*:\s*([^\)\]]+?)\s*(?:\)|\])\s*$/);
                if (!m) break;
                const key = (m[1] || '').trim().toLowerCase();
                const val = (m[2] || '').trim();

                if (key === 'tags' || key === 'dietary tag' || key === 'dietary tags') {
                    const parsedTags = val.split(/[,|]/g).map(s => s.trim()).filter(Boolean).slice(0, 10);
                    // prepend so last-specified still ends up included; order isn't critical
                    tags = [...parsedTags, ...tags];
                } else if (key === 'type' || key === 'category' || key === 'group') {
                    if (!type) type = val;
                } else if (key === 'cal' || key === 'cals' || key === 'calorie' || key === 'calories' || key === 'kcal') {
                    const numMatch = val.match(/(\d+(?:\.\d+)?)/);
                    if (numMatch) {
                        const n = parseFloat(numMatch[1]);
                        if (Number.isFinite(n)) caloriesKcal = n;
                    }
                } else if (key === 'serving' || key === 'servingsize' || key === 'serving size') {
                    if (!serving) serving = val;
                } else if (key === 'img' || key === 'image' || key === 'photo' || key === 'pic' || key === 'picture') {
                    if (!imgUrl) imgUrl = val;
                }

                working = working.slice(0, m.index).trim();
            }

            // Also support a leading "Type: Item - ..." format (if type isn't already specified)
            if (!type) {
                const tm = working.match(/^([^:]{2,30})\s*:\s*(.+)$/);
                if (tm) {
                    const maybeType = String(tm[1] || '').trim();
                    const rest = String(tm[2] || '').trim();
                    if (maybeType && rest && !/https?:\/\//i.test(maybeType)) {
                        type = maybeType;
                        working = rest;
                    }
                }
            }

            // de-dupe tags
            if (tags.length > 0) {
                const seen = new Set();
                tags = tags.filter(t => {
                    const k = t.toLowerCase();
                    if (seen.has(k)) return false;
                    seen.add(k);
                    return true;
                }).slice(0, 10);
            }

            const m = working.match(/^(.+?)\s*-\s*(.+)$/);
            // If the user didn't provide a " - description", treat the whole line as the item name.
            // This ensures the title renders with the same typography as other cards.
            const name = m ? (m[1] || '').trim() : working;
            const body = m ? (m[2] || '').trim() : '';

            return { type, name, body, tags, caloriesKcal, serving, imgUrl };
        }

