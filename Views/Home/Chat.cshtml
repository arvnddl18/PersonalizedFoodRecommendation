            const img = document.getElementById('menu-image-modal-img');
            if (!modal || !img) {
                console.error('Menu image modal elements not found', {modal: !!modal, img: !!img});
                return;
            }
            
            // Decode HTML entities if present (from data attributes)
            let decodedSrc = src;
            if (typeof src === 'string' && src) {
                // Decode HTML entities
                const textarea = document.createElement('textarea');
                textarea.innerHTML = src;
                decodedSrc = textarea.value;
            }
            
            // Get optimized full-size URL
            let optimizedSrc = decodedSrc;
            if (typeof getOptimizedMenuImageUrl === 'function') {
                optimizedSrc = getOptimizedMenuImageUrl(decodedSrc, 'full') || decodedSrc;
            }
            
            img.src = optimizedSrc;
            img.onerror = function() {
                console.error('Failed to load image:', optimizedSrc);
                img.src = decodedSrc; // Fallback to original
            };
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
            // Prevent body scroll
            document.body.style.position = 'fixed';
            document.body.style.width = '100%';
            console.log('Modal opened');
        };

        window.closeMenuImageModal = function() {
            const modal = document.getElementById('menu-image-modal');
            const img = document.getElementById('menu-image-modal-img');
            if (!modal || !img) return;
            modal.style.display = 'none';
            img.src = '';
            // Restore body scroll
            document.body.style.overflow = '';
            document.body.style.position = '';
            document.body.style.width = '';
        };

        // Close when clicking outside the image or on the image itself
        function attachMenuImageModalHandlers() {
            const modal = document.getElementById('menu-image-modal');
            if (!modal) {
                console.warn('Menu image modal not found during initialization');
                return;
            }
            
            // Ensure modal is attached directly to body to avoid clipping from ancestor overflow/transform
            if (modal.parentElement !== document.body) {
                try { document.body.appendChild(modal); } catch (e) { 
                    console.error('Failed to move modal to body:', e);
                }
            }
            
            // Close when clicking the background (but not the image)
            modal.addEventListener('click', function (e) {
                if (e.target === modal) {
                    closeMenuImageModal();
                }
            });
            
            // Close when clicking the image itself
            const modalImg = document.getElementById('menu-image-modal-img');
            if (modalImg) {
                modalImg.addEventListener('click', function (e) {
                    e.stopPropagation();
                    closeMenuImageModal();
                });
            }
            
            // Close on Escape key
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape' && modal.style.display === 'flex') {
                    closeMenuImageModal();
                }
            });
            
            console.log('Menu image modal handlers attached');
        }
        
        // Initialize modal handlers when DOM is ready
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', attachMenuImageModalHandlers);
        } else {
            attachMenuImageModalHandlers();
        }

