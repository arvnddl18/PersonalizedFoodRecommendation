        async function addFavorite(placeId, restaurantData, buttonElement) {
            try {
                // Prepare favorite data
                const favoriteData = {
                    placeId: placeId,
                    name: restaurantData?.name || '',
                    address: restaurantData?.vicinity || restaurantData?.formatted_address || '',
                    rating: restaurantData?.rating || null,
                    priceLevel: restaurantData?.price_level || null,
                    photoReference: restaurantData?.photos?.[0]?.photo_reference || null,
                    latitude: restaurantData?.geometry?.location?.lat() || null,
                    longitude: restaurantData?.geometry?.location?.lng() || null,
                    phoneNumber: restaurantData?.formatted_phone_number || null,
                    website: restaurantData?.website || null,
                    types: restaurantData?.types || []
                };
                
                const response = await fetch('/api/Favorites/add', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(favoriteData)
                });
                
                if (response.ok) {
                    const result = await response.json();
                    userFavorites.add(placeId);
                    
                    if (buttonElement) {
                        updateFavoriteButtonIconOnly(buttonElement, true);
                    }
                    updateFavoriteButtonsForPlace(placeId);
                    
                    await loadFavorites();
                    addMessage('FoodieSaur Bot', `Added "${favoriteData.name}" to your favorites! ❤️`);
                } else {
                    console.error('Failed to add favorite');
                }
            } catch (error) {
                console.error('Error adding favorite:', error);
            }
        }

        async function removeFavorite(placeId, buttonElement) {
            try {
                const response = await fetch(`/api/Favorites/remove/${placeId}`, {
                    method: 'DELETE'
                });
                
                if (response.ok) {
                    userFavorites.delete(placeId);
                    
                    if (buttonElement) {
                        updateFavoriteButtonIconOnly(buttonElement, false);
                    }
                    updateFavoriteButtonsForPlace(placeId);
                    
                    await loadFavorites();
                    
                    // Refresh favorites panel if currently viewing
                    if (favoritesPanel.style.transform === 'translateX(0px)') {
                        displayFavorites();
                    }
                    
                    addMessage('FoodieSaur Bot', 'Removed from favorites.');
                } else {
                    console.error('Failed to remove favorite');
                }
            } catch (error) {
                console.error('Error removing favorite:', error);
            }
        }

        async function updateLastViewed(placeId) {
            try {
                await fetch(`/api/Favorites/update-viewed/${placeId}`, {
                    method: 'POST'
                });
            } catch (error) {
                console.error('Error updating last viewed:', error);
            }
        }

        // Event listeners for favorites
        if (viewFavoritesBtn) {
            viewFavoritesBtn.addEventListener('click', function() {
                if (window.isGuest) { if (typeof showLoginPrompt === 'function') showLoginPrompt(); return; }
                openFavorites();
            });
        }

        // Dietary vote modal listeners
        {
            const { modal, close, cancel, save } = getDietaryVoteModalEls();
            if (close) close.addEventListener('click', closeDietaryVoteModal);
            if (cancel) cancel.addEventListener('click', closeDietaryVoteModal);
            if (save) save.addEventListener('click', saveDietaryVoteModal);
            if (modal) {
                modal.addEventListener('click', function(e) {
                    if (e.target === modal) closeDietaryVoteModal();
                });
            }
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') closeDietaryVoteModal();
            });
        }

        // Event listeners for community dietary tags panel (public)
        if (viewDietaryTagsBtn) {
            viewDietaryTagsBtn.addEventListener('click', function() {
                openDietaryTags();
            });
        }
        
        if (backToSearchFromDietaryBtn) {
            backToSearchFromDietaryBtn.addEventListener('click', backToSearchFromDietary);
        }

        const openCommunityFromTagsBtn = document.getElementById('open-community-from-tags-btn');
        if (openCommunityFromTagsBtn) {
            openCommunityFromTagsBtn.addEventListener('click', function() {
                if (selectedCommunityDietaryRestrictionId) {
                    openCommunity(selectedCommunityDietaryRestrictionId);
                } else {
                    alert('Please select a dietary tag first.');
                }
            });
        }
        
        if (dietaryTagSelect) {
            dietaryTagSelect.addEventListener('change', async function() {
                const id = parseInt(this.value || '', 10);
                selectedCommunityDietaryRestrictionId = (!Number.isNaN(id) && id > 0) ? id : null;
                if (selectedCommunityDietaryRestrictionId != null) {
                    await loadCommunityTaggedShops(selectedCommunityDietaryRestrictionId);
                    await refreshCommunityDietaryTagStatusForCurrentResults();
                } else {
                    dietaryTagsData = [];
                }
                updateDietaryTagsCount();
                if (dietaryFilterEnabled) applyDietaryFilterToCards();
                if (dietaryTagsPanel && dietaryTagsPanel.style.transform === 'translateX(0px)') {
                    displayDietaryTags();
                }
            });
        }

        // Community Modal Functions
        const communityOverlay = document.getElementById('community-modal-overlay');
        const communityPanel = document.getElementById('community-panel');
        const communityCloseBtn = document.getElementById('community-close-btn');
        const communityTabLounge = document.getElementById('community-tab-lounge');
        const communityTabCorner = document.getElementById('community-tab-corner');
        const communityTabOwner = document.getElementById('community-tab-owner');
        const communityRestaurantSelector = document.getElementById('community-restaurant-selector');
        const communityRestaurantSelect = document.getElementById('community-restaurant-select');
        const communityViewToggle = document.getElementById('community-view-toggle');
        const communityComposer = document.getElementById('community-composer');
        const communityGuestHint = document.getElementById('community-guest-hint');
        const communityPostTitle = document.getElementById('community-post-title');
        const communityPostBody = document.getElementById('community-post-body');
        const communityPostCharCount = document.getElementById('community-post-char-count');
        const communityPostImage = document.getElementById('community-post-image');
        const communityPostImageName = document.getElementById('community-post-image-name');
        const communityPostSubmit = document.getElementById('community-post-submit');
        const communityFeed = document.getElementById('community-feed');
        const communityTagName = document.getElementById('community-tag-name');
        const communityToggleComposerBtn = document.getElementById('community-toggle-composer-btn');

        let currentCommunityTab = 'lounge';
        let currentCommunityView = 'recent'; // 'recent' or 'trending'
        let currentCommunityPlaceId = null;
        let currentCommunityPlaceName = null;
        let currentCommunityPostType = 'Discussion';
        let communityPosts = [];

        // Check if user is logged in
        function isUserLoggedIn() {
            return !window.isGuest && window.currentUserId !== null;
        }

        function openCommunity(dietaryRestrictionId, placeId = null, placeName = null) {
            if (!communityOverlay || !communityPanel) return;

            selectedCommunityDietaryRestrictionId = dietaryRestrictionId;
            currentCommunityPlaceId = placeId;
            currentCommunityPlaceName = placeName;

            // Update tag name
            const tag = dietaryRestrictionsList.find(t => t.dietaryRestrictionId === dietaryRestrictionId);
            if (communityTagName) {
                communityTagName.textContent = tag ? tag.name : 'Community';
            }

            // Show/hide restaurant selector based on tab
            updateCommunityRestaurantSelector();

            // Initially hide composer (user can toggle it with "New Post" button)
            if (communityComposer) {
                communityComposer.style.display = 'none';
            }

            // Open modal (do NOT alter other panels; this is an overlay)
            communityOverlay.style.display = 'flex';
            try { document.body.style.overflow = 'hidden'; } catch (_) { }

            // Ensure correct controls for tab
            setActiveCommunityTab(currentCommunityTab);
            applyCommunityTabUiRules();

            // If the user opened Restaurant Corner/Announcements but we haven't loaded tagged shops yet,
            // fetch them so the restaurant selector has options.
            try {
                if ((currentCommunityTab === 'corner' || currentCommunityTab === 'owner') &&
                    selectedCommunityDietaryRestrictionId != null &&
                    (!Array.isArray(dietaryTagsData) || dietaryTagsData.length === 0) &&
                    typeof loadCommunityTaggedShops === 'function') {
                    loadCommunityTaggedShops(selectedCommunityDietaryRestrictionId).catch(() => {});
                }
            } catch (_) { }

            // Load feed
            loadCommunityFeed();
        }

        function closeCommunity() {
            if (communityOverlay) communityOverlay.style.display = 'none';
            try { document.body.style.overflow = ''; } catch (_) { }
        }

        function updateCommunityRestaurantSelector() {
            if (!communityRestaurantSelector || !communityRestaurantSelect) return;

            const needsSelector = currentCommunityTab === 'corner' || currentCommunityTab === 'owner';
            communityRestaurantSelector.style.display = needsSelector ? 'block' : 'none';

            if (needsSelector && dietaryTagsData.length > 0) {
                communityRestaurantSelect.innerHTML = '<option value="">Select a restaurant...</option>';
                dietaryTagsData.forEach(shop => {
                    const opt = document.createElement('option');
                    opt.value = shop.placeId || '';
                    opt.textContent = shop.name || 'Unknown';
                    if (currentCommunityPlaceId && shop.placeId === currentCommunityPlaceId) {
                        opt.selected = true;
                    }
                    communityRestaurantSelect.appendChild(opt);
                });
            }
        }

        function setActiveCommunityTab(active) {
            const tabs = [communityTabLounge, communityTabCorner, communityTabOwner];
            tabs.forEach(t => {
                if (!t) return;
                const isActive = t.dataset.tab === active;
                t.style.background = isActive ? '#47682C' : '#ffffff';
                t.style.color = isActive ? '#ffffff' : '#47682C';
                t.style.borderColor = isActive ? 'rgba(71,104,44,0.25)' : 'rgba(71,104,44,0.18)';
            });
        }

        function applyCommunityTabUiRules() {
            // Announcements: "Trending" isn't very meaningful; keep it focused.
            if (communityViewToggle) {
                communityViewToggle.style.display = (currentCommunityTab === 'owner') ? 'none' : 'flex';
            }
            if (currentCommunityTab === 'owner') currentCommunityView = 'recent';

            // Restaurant selector needed only on restaurant-specific tabs
            updateCommunityRestaurantSelector();

            // Composer post types: hide type chips on Announcements (forced OwnerUpdate)
            const typeRow = document.getElementById('community-post-type-row');
            if (typeRow) typeRow.style.display = (currentCommunityTab === 'owner') ? 'none' : 'flex';

            // Update composer CTA label so it matches the tab and isn't confusing
            if (communityToggleComposerBtn) {
                const isCancel = /Cancel/i.test(communityToggleComposerBtn.textContent || '');
                if (currentCommunityTab === 'owner') {
                    communityToggleComposerBtn.innerHTML = isCancel ? '<span>✕</span> Cancel' : '<span>📣</span> New Announcement';
                } else {
                    communityToggleComposerBtn.innerHTML = isCancel ? '<span>✕</span> Cancel' : '<span>✏️</span> New Post';
                }
            }
        }

        async function loadCommunityFeed() {
            if (!communityFeed) return;

            communityFeed.innerHTML = '<div style="text-align:center; padding:2rem 1rem; color:#6b7280;">Loading...</div>';

            try {
                let url = currentCommunityView === 'trending' ? '/api/Community/trending?' : '/api/Community/feed?';
                const params = new URLSearchParams();

                if (selectedCommunityDietaryRestrictionId) {
                    params.append('dietaryRestrictionId', selectedCommunityDietaryRestrictionId);
                }

                if (currentCommunityTab === 'corner' || currentCommunityTab === 'owner') {
                    const placeId = currentCommunityPlaceId || (communityRestaurantSelect?.value || '');
                    if (placeId) {
                        params.append('placeId', placeId);
                    }
                }

                if (currentCommunityTab === 'owner') {
                    params.append('type', 'OwnerUpdate');
                }

                params.append('limit', '20');

                const res = await fetch(url + params.toString());
                if (!res.ok) throw new Error('Failed to load feed');

                const data = await res.json();
                communityPosts = data.posts || [];
                renderCommunityFeed();
            } catch (error) {
                console.error('Error loading community feed:', error);
                communityFeed.innerHTML = '<div style="text-align:center; padding:2rem 1rem; color:#ef4444;">Error loading feed. Please try again.</div>';
            }
        }

        function renderCommunityFeed() {
            if (!communityFeed) return;

            if (communityPosts.length === 0) {
                communityFeed.innerHTML = `
                    <div style="text-align:center; padding:2rem 1rem; color:#6b7280;">
                        <div style="font-size:3rem; margin-bottom:0.5rem;">💬</div>
                        <p style="margin:0; font-size:1rem; font-weight:700; color:#374151;">No posts yet</p>
                        <p style="margin:0.5rem 0 0 0; font-size:0.875rem;">Be the first to share your thoughts!</p>
                    </div>
                `;
                return;
            }

            communityFeed.innerHTML = communityPosts.map(post => {
                const reactionsHtml = (post.reactions || []).map(r => 
                    `<span style="display:inline-flex; align-items:center; gap:0.25rem; padding:0.25rem 0.5rem; border-radius:0.5rem; background:#f3f4f6; font-size:0.75rem; color:#374151;">
                        ${getReactionEmoji(r.type)} ${r.count}
                    </span>`
                ).join(' ');

                const verifiedBadge = post.isVerifiedPoster 
                    ? `<span style="display:inline-flex; align-items:center; gap:0.25rem; padding:0.25rem 0.5rem; border-radius:0.5rem; background:#dbeafe; color:#1e40af; font-size:0.75rem; font-weight:600;">
                        ✓ ${post.verifiedByRole || 'Verified'}
                    </span>`
                    : '';

                const imageSection = post.imageUrl
                    ? `<div style="margin-top:0.5rem;">
                            <img src="${post.imageUrl}" alt="Post image" style="max-width:100%; border-radius:0.75rem; border:1px solid #e5e7eb; max-height:260px; object-fit:cover;" loading="lazy" />
                       </div>`
                    : '';

                return `
                    <div style="margin-bottom:1rem; padding:1rem; background:#ffffff; border-radius:0.75rem; border:1px solid rgba(71,104,44,0.1); box-shadow:0 2px 8px rgba(0,0,0,0.05);">
                        <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:0.75rem; margin-bottom:0.5rem;">
                            <div style="flex:1;">
                                <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.25rem;">
                                    <span style="font-weight:700; color:#1f2937; font-size:0.875rem;">${escapeHtml(post.author?.name || 'User')}</span>
                                    ${verifiedBadge}
                                    <span style="padding:0.25rem 0.5rem; border-radius:0.5rem; background:#e0e7ff; color:#4338ca; font-size:0.75rem; font-weight:600;">${escapeHtml(post.postType || 'Discussion')}</span>
                                </div>
                                ${post.title ? `<div style="font-weight:700; color:#1f2937; font-size:0.9375rem; margin-bottom:0.375rem;">${escapeHtml(post.title)}</div>` : ''}
                                <div style="color:#374151; font-size:0.875rem; line-height:1.5; white-space:pre-wrap;">${escapeHtml(post.body || '')}</div>
                                ${imageSection}
                            </div>
                        </div>
                        <div style="display:flex; align-items:center; justify-content:space-between; gap:0.75rem; margin-top:0.75rem; padding-top:0.75rem; border-top:1px solid #f3f4f6;">
                            <div style="display:flex; gap:0.5rem; flex-wrap:wrap; align-items:center;">
                                ${reactionsHtml}
                                ${post.supporterCount ? `<span style="display:inline-flex; align-items:center; gap:0.25rem; padding:0.25rem 0.5rem; border-radius:0.5rem; background:#dbeafe; font-size:0.75rem; color:#1e40af; font-weight:600;">
                                    ▲ ${post.supporterCount} supporters
                                </span>` : ''}
                            </div>
                            <div style="font-size:0.75rem; color:#6b7280;">
                                ${formatTimeAgoCommunity(new Date(post.createdAt))}
                            </div>
                        </div>
                        <div style="margin-top:0.5rem; display:flex; gap:0.5rem; flex-wrap:wrap;">
                            <button onclick="reactToCommunityPost(${post.postId}, 'Helpful')" 
                                    style="padding:0.375rem 0.75rem; border-radius:0.5rem; background:${(post.userReactions || []).includes('Helpful') ? '#dbeafe' : '#f3f4f6'}; color:#374151; font-size:0.75rem; font-weight:600; border:none; cursor:pointer;">
                                👍 Helpful
                            </button>
                            <button onclick="reactToCommunityPost(${post.postId}, 'Interested')" 
                                    style="padding:0.375rem 0.75rem; border-radius:0.5rem; background:${(post.userReactions || []).includes('Interested') ? '#dbeafe' : '#f3f4f6'}; color:#374151; font-size:0.75rem; font-weight:600; border:none; cursor:pointer;">
                                👀 Interested
                            </button>
                            <button onclick="reactToCommunityPost(${post.postId}, 'Tried')" 
                                    style="padding:0.375rem 0.75rem; border-radius:0.5rem; background:${(post.userReactions || []).includes('Tried') ? '#dbeafe' : '#f3f4f6'}; color:#374151; font-size:0.75rem; font-weight:600; border:none; cursor:pointer;">
                                ✅ Tried
                            </button>
                            <button onclick="reactToCommunityPost(${post.postId}, 'Saved')" 
                                    style="padding:0.375rem 0.75rem; border-radius:0.5rem; background:${(post.userReactions || []).includes('Saved') ? '#dbeafe' : '#f3f4f6'}; color:#374151; font-size:0.75rem; font-weight:600; border:none; cursor:pointer;">
                                🔖 Save
                            </button>
                            <button onclick="loadCommunityComments(${post.postId})" style="padding:0.375rem 0.75rem; border-radius:0.5rem; background:#f3f4f6; color:#374151; font-size:0.75rem; font-weight:600; border:none; cursor:pointer;">
                                💬 ${post.commentCount || 0}
                            </button>
                        </div>
                    </div>
                `;
            }).join('');
        }

        function getReactionEmoji(type) {
            const emojis = { Helpful: '👍', Interested: '👀', Tried: '✅', Saved: '🔖' };
            return emojis[type] || '👍';
        }

        function formatTimeAgoCommunity(date) {
            const seconds = Math.floor((new Date() - date) / 1000);
            if (seconds < 60) return 'just now';
            const minutes = Math.floor(seconds / 60);
            if (minutes < 60) return `${minutes}m ago`;
            const hours = Math.floor(minutes / 60);
            if (hours < 24) return `${hours}h ago`;
            const days = Math.floor(hours / 24);
            if (days < 7) return `${days}d ago`;
            return date.toLocaleDateString();
        }

        async function reactToCommunityPost(postId, reactionType) {
            if (!isUserLoggedIn()) {
                alert('Please log in to react to posts.');
                return;
            }

            try {
                const res = await fetch('/api/Community/react', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ postId, reactionType })
                });

                if (!res.ok) {
                    const error = await res.json();
                    alert(error.message || 'Failed to react. Please try again.');
                    return;
                }

                // Reload feed to show updated reactions
                await loadCommunityFeed();
            } catch (error) {
                console.error('Error reacting to post:', error);
                alert('Error reacting. Please try again.');
            }
        }

        async function loadCommunityComments(postId) {
            // Simple implementation - could be expanded with a modal
            alert('Comments feature coming soon!');
        }

        // Close handlers
        if (communityCloseBtn) communityCloseBtn.addEventListener('click', closeCommunity);
        if (communityOverlay) {
            communityOverlay.addEventListener('click', function(e) {
                if (e.target === communityOverlay) closeCommunity();
            });
        }
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && communityOverlay && communityOverlay.style.display !== 'none') {
                closeCommunity();
            }
        });

        // Tab switching
        [communityTabLounge, communityTabCorner, communityTabOwner].forEach(tab => {
            if (tab) {
                tab.addEventListener('click', function() {
                    currentCommunityTab = this.dataset.tab;
                    setActiveCommunityTab(currentCommunityTab);
                    applyCommunityTabUiRules();
                    loadCommunityFeed();
                });
            }
        });

        // View switching (Recent vs Trending)
        const communityViewRecent = document.getElementById('community-view-recent');
        const communityViewTrending = document.getElementById('community-view-trending');
        [communityViewRecent, communityViewTrending].forEach(btn => {
            if (btn) {
                btn.addEventListener('click', function() {
                    // Announcements: keep focused to Recent only
                    if (currentCommunityTab === 'owner') return;
                    currentCommunityView = this.dataset.view;
                    
                    // Update view button styles
                    [communityViewRecent, communityViewTrending].forEach(b => {
                        if (b) {
                            b.style.background = b === this ? '#ffffff' : '#f3f4f6';
                            b.style.color = b === this ? '#47682C' : '#6b7280';
                            b.style.borderColor = b === this ? 'rgba(71,104,44,0.15)' : 'transparent';
                        }
                    });

                    loadCommunityFeed();
                });
            }
        });

        // Toggle composer button
        if (communityToggleComposerBtn) {
            communityToggleComposerBtn.addEventListener('click', function() {
                if (!isUserLoggedIn()) {
                    // Show guest hint in composer if it exists
                    if (communityComposer && communityGuestHint) {
                        communityComposer.style.display = 'block';
                        communityGuestHint.style.display = 'block';
                        setTimeout(() => {
                            communityComposer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                        }, 100);
                    } else {
                        alert('Please log in to create a post.');
                    }
                    return;
                }

                if (communityComposer) {
                    const isVisible = communityComposer.style.display !== 'none';
                    communityComposer.style.display = isVisible ? 'none' : 'block';
                    
                    // Show/hide guest hint
                    if (communityGuestHint) {
                        communityGuestHint.style.display = 'none';
                    }
                    
                    // Update button text
                    this.innerHTML = isVisible 
                        ? '<span>✏️</span> New Post'
                        : '<span>✕</span> Cancel';
                    
                    // Scroll to composer when opening
                    if (!isVisible) {
                        setTimeout(() => {
                            communityComposer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                        }, 100);
                    }
                }
            });
        }

        // Restaurant selector change
        if (communityRestaurantSelect) {
            communityRestaurantSelect.addEventListener('change', function() {
                currentCommunityPlaceId = this.value || null;
                const selectedOption = this.options[this.selectedIndex];
                currentCommunityPlaceName = selectedOption ? selectedOption.textContent : null;
                loadCommunityFeed();
            });
        }

        // Post type buttons
        document.querySelectorAll('.community-post-type-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                currentCommunityPostType = this.dataset.type;
                document.querySelectorAll('.community-post-type-btn').forEach(b => {
                    b.style.opacity = b === this ? '1' : '0.6';
                });
            });
        });

        // Character count
        if (communityPostBody) {
            communityPostBody.addEventListener('input', function() {
                const count = this.value.length;
                if (communityPostCharCount) {
                    communityPostCharCount.textContent = `${count} / 2000`;
                    communityPostCharCount.style.color = count > 2000 ? '#ef4444' : '#6b7280';
                }
            });
        }

        // Image selection (optional)
        if (communityPostImage) {
            communityPostImage.addEventListener('change', function () {
                if (this.files && this.files[0]) {
                    const file = this.files[0];
                    if (communityPostImageName) {
                        communityPostImageName.textContent = file.name;
                    }
                } else if (communityPostImageName) {
                    communityPostImageName.textContent = '';
                }
            });
        }

        // Submit post
        if (communityPostSubmit) {
            communityPostSubmit.addEventListener('click', async function() {
                if (!isUserLoggedIn()) {
                    alert('Please log in to post.');
                    return;
                }

                const body = (communityPostBody?.value || '').trim();
                if (body.length < 10) {
                    alert('Post must be at least 10 characters long.');
                    return;
                }

                if (body.length > 2000) {
                    alert('Post is too long (maximum 2000 characters).');
                    return;
                }

                if (currentCommunityTab === 'corner' || currentCommunityTab === 'owner') {
                    const placeId = currentCommunityPlaceId || (communityRestaurantSelect?.value || '');
                    if (!placeId) {
                        alert('Please select a restaurant first.');
                        return;
                    }
                }

                try {
                    const placeIdValue = (currentCommunityTab === 'corner' || currentCommunityTab === 'owner')
                        ? (currentCommunityPlaceId || communityRestaurantSelect?.value)
                        : null;

                    const hasImage = communityPostImage && communityPostImage.files && communityPostImage.files.length > 0;
                    let res;

                    if (hasImage) {
                        const formData = new FormData();
                        if (selectedCommunityDietaryRestrictionId) {
                            formData.append('DietaryRestrictionId', selectedCommunityDietaryRestrictionId);
                        }
                        if (placeIdValue) {
                            formData.append('PlaceId', placeIdValue);
                        }
                        formData.append('PostType', currentCommunityTab === 'owner' ? 'OwnerUpdate' : currentCommunityPostType);
                        if (communityPostTitle && communityPostTitle.value.trim()) {
                            formData.append('Title', communityPostTitle.value.trim());
                        }
                        formData.append('Body', body);
                        formData.append('Image', communityPostImage.files[0]);

                        res = await fetch('/api/Community/post-with-image', {
                            method: 'POST',
                            body: formData
                        });
                    } else {
                        const payload = {
                            dietaryRestrictionId: selectedCommunityDietaryRestrictionId,
                            placeId: placeIdValue,
                            postType: currentCommunityTab === 'owner' ? 'OwnerUpdate' : currentCommunityPostType,
                            title: communityPostTitle?.value?.trim() || null,
                            body: body
                        };

                        res = await fetch('/api/Community/post', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        });
                    }

                    if (!res.ok) {
                        const error = await res.json();
