<!-- FoodieSaur Directions Panel - Unique Brand Design -->
<aside id="directions-panel" class="fixed top-0 left-0 h-screen w-[26rem] max-w-[90vw] z-[25] flex flex-col -translate-x-full transition-transform duration-300 ease-in-out invisible">
    <!-- Solid White Background -->
    <div class="absolute inset-0 bg-white"></div>
    
    <!-- Header -->
    <div class="relative flex items-center justify-between p-4 border-b border-[#47682C]/10 bg-white">
        <div class="flex items-center gap-3">
            <button id="back-to-panels" 
                    class="flex items-center gap-1.5 px-3 py-2 rounded-xl bg-gradient-to-r from-[#47682C] to-[#47682C]/90 text-white text-sm font-semibold shadow-md hover:shadow-lg hover:scale-105 transition-all duration-200" 
                    aria-label="Back to search results">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                Back
            </button>
            <h1 class="text-xl font-bold text-[#47682C]" id="directions-header">Directions</h1>
        </div>
        <button id="close-directions" 
                class="w-8 h-8 rounded-lg bg-[#FE395C]/10 text-[#FE395C] hover:bg-[#FE395C] hover:text-white transition-all duration-200 flex items-center justify-center font-bold text-xl" 
                aria-label="Close directions">
            ×
        </button>
    </div>

    <!-- Content Area -->
    <div id="directions-content" class="relative flex-1 overflow-y-auto p-4 space-y-4">
        <!-- Transport Mode Selection -->
        <div class="bg-white rounded-2xl p-4 border border-[#47682C]/10 shadow-sm">
            <h3 class="text-xs font-semibold text-[#47682C]/70 mb-3 uppercase tracking-wider">Choose Transport</h3>
            <div class="grid grid-cols-4 gap-2">
                <!-- Walking -->
                <button onclick="changeTravelMode(google.maps.TravelMode.WALKING)"
                        class="travel-mode-btn group relative flex flex-col items-center justify-center p-3 rounded-xl border-2 border-[#47682C]/20 bg-white hover:bg-[#47682C]/5 hover:border-[#47682C] transition-all duration-200 cursor-pointer"
                        data-mode="walking">
                    <img src="/images/cil-walk2.svg" alt="Walk" style="width: 1.5rem; height: 1.5rem;">
                    <span class="text-[10px] font-medium text-[#47682C]">Walk</span>
                </button>
                
                <!-- Transit -->
                <button onclick="changeTravelMode(google.maps.TravelMode.TRANSIT)"
                        class="travel-mode-btn group relative flex flex-col items-center justify-center p-3 rounded-xl border-2 border-[#47682C]/20 bg-white hover:bg-[#47682C]/5 hover:border-[#47682C] transition-all duration-200 cursor-pointer"
                        data-mode="transit">
                    <img src="/images/bus-side.svg" alt="Transit" style="width: 1.5rem; height: 1.5rem;">
                    <span class="text-[10px] font-medium text-[#47682C]">Transit</span>
                </button>
                
                <!-- Driving (Default Active) -->
                <button onclick="changeTravelMode(google.maps.TravelMode.DRIVING)"
                        class="travel-mode-btn group relative flex flex-col items-center justify-center p-3 rounded-xl border-2 border-[#F7B32B] bg-gradient-to-br from-[#F7B32B]/10 to-[#F7B32B]/5 hover:border-[#F7B32B] transition-all duration-200 cursor-pointer shadow-sm"
                        data-mode="driving">
                    <img src="/images/car-side.svg" alt="Driving" style="width: 1.5rem; height: 1.5rem;">
                    <span class="text-[10px] font-semibold text-[#F7B32B]">Drive</span>
                </button>
                
                <!-- Bicycling -->
                <button onclick="changeTravelMode(google.maps.TravelMode.BICYCLING)"
                        class="travel-mode-btn group relative flex flex-col items-center justify-center p-3 rounded-xl border-2 border-[#47682C]/20 bg-white hover:bg-[#47682C]/5 hover:border-[#47682C] transition-all duration-200 cursor-pointer"
                        data-mode="bicycling">
                    <img src="/images/bike.svg" alt="Bicycle" style="width: 1.5rem; height: 1.5rem;">
                    <span class="text-[10px] font-medium text-[#47682C]">Bike</span>
                </button>
            </div>
        </div>

        <!-- Route Summary Card -->
        <div id="route-summary" class="hidden bg-white rounded-2xl p-5 shadow-lg text-[#47682C] border border-[#47682C]/10">
            <div class="flex items-center justify-between mb-3">
                <div class="flex items-center gap-2">
                    <div class="w-10 h-10 rounded-full bg-[#47682C]/10 flex items-center justify-center">
                        <div id="route-mode-icon" class="w-6 h-6"></div>
                    </div>
                    <div>
                        <div class="text-xs opacity-80">Driving Route</div>
                        <div id="route-mode-text" class="text-lg font-bold">31 mins · 2.5 km</div>
                    </div>
                </div>
                <button onclick="clearRoute()" 
                        class="px-3 py-1.5 rounded-lg bg-[#47682C]/10 hover:bg-[#47682C]/20 text-xs font-medium transition-all duration-200 flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                    Clear
                </button>
            </div>
            <div id="route-destination-info" class="bg-[#47682C]/5 rounded-xl px-3 py-2">
                <div class="text-xs text-[#47682C]/60 mb-1">Destination</div>
                <div class="font-semibold text-sm" id="route-destination-name">Restaurant Name</div>
                <div class="text-xs text-[#47682C]/70 mt-0.5" id="route-destination-address">Address will appear here</div>
            </div>
        </div>

        <!-- Turn-by-Turn Directions -->
        <div id="directions-panel-content" class="space-y-3">
            <!-- Placeholder -->
            <div id="directions-placeholder" class="bg-white rounded-2xl p-8 text-center border border-[#47682C]/10">
                <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-gradient-to-br from-[#F7B32B]/20 to-[#F7B32B]/10 flex items-center justify-center">
                    <svg class="w-10 h-10 text-[#F7B32B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                    </svg>
                </div>
                <p class="text-[#47682C] font-medium mb-1">Ready to Navigate</p>
                <p class="text-[#47682C]/60 text-sm">Click "Get Directions" on any restaurant to see turn-by-turn directions here.</p>
            </div>
        </div>
    </div>
</aside>

