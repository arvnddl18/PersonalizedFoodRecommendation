        // Sort results by actual driving distance using Routes API
        async function sortResultsByDistance(results, parameters) {
            const resultsDiv = document.getElementById('search-results');
            const statusDiv = document.getElementById('sorting-status');

            try {
                // Calculate distances for all results
                const resultsWithDistance = await Promise.all(
                    results.map(async (place, index) => {
                        try {
                            const distance = await calculateDrivingDistance(place.geometry.location);
                            return {
                                ...place,
                                drivingDistance: distance.distance,
                                drivingDuration: distance.duration,
                                distanceText: distance.distanceText,
                                durationText: distance.durationText
                            };
                        } catch (error) {
                            console.warn(`Failed to calculate distance for ${place.name}:`, error);
                            return {
                                ...place,
                                drivingDistance: Infinity, // Put at end if calculation fails
                                drivingDuration: Infinity,
                                distanceText: 'Distance unavailable',
                                durationText: 'Time unavailable'
                            };
                        }
                    })
                );

                // Sort by driving distance
                resultsWithDistance.sort((a, b) => a.drivingDistance - b.drivingDistance);

                // Update status with enhanced design
                if (statusDiv) {
                    statusDiv.innerHTML = `
                        <div style="display:flex; align-items:center; gap:0.5rem; padding:0.75rem; background:rgba(34,197,94,0.05); border:1px solid rgba(34,197,94,0.1); border-radius:0.75rem; font-size:0.875rem; font-weight:600; color:#16a34a;">
                            <svg style="width:1rem; height:1rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            <span>Sorted by nearest driving distance</span>
                        </div>
                    `;
                }

                // Display sorted results
                displaySortedResults(resultsWithDistance, parameters);

            } catch (error) {
                console.error('Error sorting results by distance:', error);
                if (statusDiv) {
                    statusDiv.innerHTML = `
                        <div style="display:flex; align-items:center; gap:0.5rem; padding:0.75rem; background:rgba(245,158,11,0.05); border:1px solid rgba(245,158,11,0.1); border-radius:0.75rem; font-size:0.875rem; font-weight:600; color:#d97706;">
                            <svg style="width:1rem; height:1rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                            </svg>
                            <span>Using default order (distance calculation failed)</span>
                        </div>
                    `;
                }
                // Fallback to original order
                displaySortedResults(results.map(place => ({
                    ...place,
                    drivingDistance: 0,
                    drivingDuration: 0,
                    distanceText: 'Distance unavailable',
                    durationText: 'Time unavailable'
                })), parameters);
            }
        }

        // Calculate driving distance using Routes API
        function calculateDrivingDistance(destination) {
            return new Promise((resolve, reject) => {
                const request = {
                    origin: userLocation,
                    destination: destination,
                    travelMode: google.maps.TravelMode.DRIVING,
                    unitSystem: google.maps.UnitSystem.METRIC
                };

                directionsService.route(request, (result, status) => {
                    if (status === 'OK' && result.routes && result.routes.length > 0) {
                        const route = result.routes[0];
                        const leg = route.legs[0];
                        const distance = leg.distance.value; // in meters
                        const duration = leg.duration.value; // in seconds

                        resolve({
                            distance: distance,
                            duration: duration,
                            distanceText: leg.distance.text,
                            durationText: leg.duration.text
                        });
                    } else {
                        reject(new Error(`Route calculation failed: ${status}`));
                    }
                });
            });
        }

        // Fetch full place details preferring the new Places API (Place), with legacy fallback
        function fetchPlaceDetails(placeId) {
            return new Promise(async (resolve) => {
                try {
                    if (google?.maps?.places?.Place) {
                        const place = new google.maps.places.Place({ id: placeId });
                        await place.fetchFields({
                            fields: [
                                'formattedAddress',
                                'vicinity',
                                'openingHours',
                                'businessStatus',
                                'url',
                                'currentOpeningHours',
                                'utcOffsetMinutes',
                                'photos',
                                'priceLevel',
                                'rating',
                                'userRatingCount',
                                'displayName',
                                'types',
                                'location'
                            ]
                        });

                        const normalized = (function(p) {
                            const loc = p.location ? new google.maps.LatLng(p.location) : null;
                            const photos = Array.isArray(p.photos) ? p.photos.map(ph => ({
                                getUrl: function(opts) {
                                    try { return ph.createUrl ? ph.createUrl(opts || {}) : ''; } catch { return ''; }
                                },
                                width: ph.width,
                                height: ph.height
                            })) : [];
                            const opening_hours = p.openingHours ? {
                                isOpen: function() { try { return !!p.openingHours.openNow; } catch { return false; } },
                                open_now: p.openingHours.openNow === true
                            } : undefined;
                            return {
                                formatted_address: p.formattedAddress,
                                vicinity: p.vicinity,
                                opening_hours: opening_hours,
                                business_status: p.businessStatus,
                                current_opening_hours: p.currentOpeningHours,
                                utc_offset_minutes: p.utcOffsetMinutes,
                                photos: photos,
                                price_level: p.priceLevel,
                                rating: p.rating,
                                user_ratings_total: p.userRatingCount,
                                name: p.displayName?.text || p.displayName || '',
                                types: p.types,
                                geometry: loc ? { location: loc } : undefined,
                                place_id: placeId
                            };
                        })(place);
                        resolve(normalized);
                        return;
                    }
                } catch (e) {
                    console.warn('New Places API failed, falling back to legacy getDetails:', e);
                }

                try {
                    const service = new google.maps.places.PlacesService(map);
                    const request = {
                        placeId: placeId,
                        fields: [
                            'formatted_address',
                            'vicinity',
                            'opening_hours',
                            'url',
                            'business_status',
                            'current_opening_hours',
                            'utc_offset_minutes',
                            'photos',
                            'price_level',
                            'rating',
                            'user_ratings_total',
                            'name',
                            'types',
                            'geometry'
                        ]
                    };
                    service.getDetails(request, (place, status) => {
                        if (status === google.maps.places.PlacesServiceStatus.OK) {
                            resolve(place);
                        } else {
                            console.warn(`Failed to fetch place details for ${placeId}:`, status);
                            resolve({});
                        }
                    });
                } catch (err) {
                    console.error('Legacy PlacesService getDetails failed:', err);
                    resolve({});
                }
            });
        }

        // Text search helper preferring new TextSearchService, with legacy fallback
        function textSearchCompat(request) {
            return new Promise(async (resolve) => {
                try {
                    if (google?.maps?.places?.TextSearchService) {
                        const svc = new google.maps.places.TextSearchService();
                        const newReq = {
                            textQuery: request.query,
                            locationBias: (request.location && request.radius) ? {
                                center: request.location,
                                radius: request.radius
                            } : undefined,
                            type: request.type
                        };
                        svc.textSearch(newReq, (results) => {
                            const mapped = (results || []).map(r => {
                                const loc = r.location ? new google.maps.LatLng(r.location) : (r.geometry?.location || null);
                                const photos = Array.isArray(r.photos) ? r.photos.map(ph => ({
                                    getUrl: function(opts) { try { return ph.createUrl ? ph.createUrl(opts || {}) : ''; } catch { return ''; } },
                                    width: ph.width,
                                    height: ph.height
                                })) : [];
                                return {
                                    place_id: r.id || r.placeId || r.place_id,
                                    name: r.displayName?.text || r.displayName || r.name,
                                    formatted_address: r.formattedAddress || r.formatted_address,
                                    rating: r.rating,
                                    user_ratings_total: r.userRatingCount || r.user_ratings_total,
                                    price_level: r.priceLevel || r.price_level,
                                    photos: photos,
                                    geometry: loc ? { location: loc } : r.geometry
                                };
                            });
                            resolve(mapped);
                        });
                        return;
                    }
                } catch (e) {
                    console.warn('New TextSearchService failed, falling back to legacy textSearch:', e);
                }

                try {
                    const service = new google.maps.places.PlacesService(map);
                    service.textSearch(request, (results, status) => {
                        if (status === google.maps.places.PlacesServiceStatus.OK && results) {
                            resolve(results);
                        } else {
                            resolve([]);
                        }
                    });
                } catch (err) {
                    console.error('Legacy textSearch failed:', err);
                    resolve([]);
                }
            });
        }

        // Nearby keyword search (legacy PlacesService). This is usually closer to Maps UI for "thing near me" queries.
        function nearbySearchKeyword({ keyword, location, radius }) {
            return new Promise((resolve) => {
                try {
                    const service = new google.maps.places.PlacesService(map);
                    const req = {
                        location,
                        radius,
                        keyword
                    };
                    service.nearbySearch(req, (results, status) => {
                        if (status === google.maps.places.PlacesServiceStatus.OK && results) {
                            resolve(results);
                        } else {
                            resolve([]);
                        }
                    });
                } catch (err) {
                    console.error('nearbySearchKeyword failed:', err);
                    resolve([]);
                }
            });
        }

        function dedupePlacesById(places) {
            const seen = new Set();
            return (places || []).filter(p => {
                const id = p?.place_id || p?.placeId || p?.id;
                if (!id) return true;
                if (seen.has(id)) return false;
                seen.add(id);
                return true;
            });
        }

        function keywordVariants(term) {
            const base = String(term || '').trim();
            if (!base) return [];

            const lower = base.toLowerCase();
            const variants = [base];

            // Minimal synonym expansion to better match Google Maps UI behavior.
            // Example: "yogurt" often maps to "frozen yogurt" / "froyo" shops.
            if (/\byogurt\b/.test(lower)) {
                variants.push('frozen yogurt', 'froyo', 'frozen yogurt shop');
            }

            return Array.from(new Set(variants));
        }

        function extractKeywordFromUserMessage(text) {
            const t = String(text || '').trim();
            if (!t) return '';

            // Examples:
            // - "find yogurt"
            // - "search for frozen yogurt near me"
            // - "locate yoh froz"
            const m = t.match(/^(?:find|search(?:\s+for)?|locate)\s+(.+)$/i);
            if (!m) return '';

            let term = String(m[1] || '').trim();
            term = term.replace(/\b(near me|nearby)\b/gi, '').trim();
            term = term.replace(/[?.!]+$/g, '').trim();
            term = term.replace(/^(?:a|an|the)\s+/i, '').trim();
            return term;
        }

        // Get store status (open/closed) from place data
        function getStoreStatus(place) {
            // Check business_status first
            if (place.business_status === 'CLOSED_PERMANENTLY') {
                return { isOpen: false, text: 'Permanently Closed' };
            }
            if (place.business_status === 'CLOSED_TEMPORARILY') {
                return { isOpen: false, text: 'Temporarily Closed' };
            }

            // Check opening_hours
            if (place.opening_hours) {
                if (place.opening_hours.isOpen !== undefined) {
                    if (place.opening_hours.isOpen()) {
                        return { isOpen: true, text: 'Open Now' };
                    } else {
                        return { isOpen: false, text: 'Closed' };
                    }
                } else if (place.opening_hours.open_now !== undefined) {
                    if (place.opening_hours.open_now) {
                        return { isOpen: true, text: 'Open Now' };
                    } else {
                        return { isOpen: false, text: 'Closed' };
                    }
                }
            }

            // Check current_opening_hours as fallback
            if (place.current_opening_hours) {
                if (place.current_opening_hours.open_now !== undefined) {
                    if (place.current_opening_hours.open_now) {
                        return { isOpen: true, text: 'Open Now' };
                    } else {
                        return { isOpen: false, text: 'Closed' };
                    }
                }
            }

            // Default status if no information available
            return { isOpen: true, text: 'Hours Unknown' };
        }

