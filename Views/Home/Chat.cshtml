        function getDietaryRestrictionNameById(id) {
            const found = Array.isArray(dietaryRestrictionsList)
                ? dietaryRestrictionsList.find(x => String(x.dietaryRestrictionId) === String(id))
                : null;
            return found?.name || 'Dietary Tag';
        }

        // Modal voting (select multiple tags per shop)
        let dietaryVoteModalState = {
            placeId: null,
            index: null,
            place: null,
            initialVotesByTagId: new Map() // id -> userHasVoted
        };

        function getDietaryVoteModalEls() {
            return {
                modal: document.getElementById('dietary-vote-modal'),
                title: document.getElementById('dietary-vote-modal-title'),
                list: document.getElementById('dietary-vote-modal-list'),
                close: document.getElementById('dietary-vote-modal-close'),
                cancel: document.getElementById('dietary-vote-modal-cancel'),
                save: document.getElementById('dietary-vote-modal-save'),
                guestHint: document.getElementById('dietary-vote-modal-guest-hint')
            };
        }

        function closeDietaryVoteModal() {
            const { modal } = getDietaryVoteModalEls();
            if (modal) modal.style.display = 'none';
            dietaryVoteModalState = { placeId: null, index: null, place: null, initialVotesByTagId: new Map() };
        }

        async function openDietaryVoteModal(placeId, index) {
            try {
                if (!dietaryRestrictionsList || dietaryRestrictionsList.length === 0) {
                    await loadCommunityDietaryRestrictions();
                }

                const { modal, title, list, guestHint, save } = getDietaryVoteModalEls();
                if (!modal || !list) return;

                const place = (Array.isArray(searchResultsData) && index != null) ? searchResultsData[index] : null;

                dietaryVoteModalState.placeId = placeId;
                dietaryVoteModalState.index = index;
                dietaryVoteModalState.place = place;
                dietaryVoteModalState.initialVotesByTagId = new Map();

                if (guestHint) guestHint.style.display = window.isGuest ? 'block' : 'none';
                if (save) {
                    save.disabled = !!window.isGuest;
                    save.style.opacity = window.isGuest ? '0.6' : '1';
                    save.style.cursor = window.isGuest ? 'not-allowed' : 'pointer';
                }

                if (title) {
                    const name = place?.name || document.querySelector(`.result-item[data-place-id="${placeId}"]`)?.dataset?.name || 'This place';
                    title.textContent = `Tags for ${name}`;
                }

                // Load status for all tags for this place
                const tagIds = dietaryRestrictionsList.map(x => x.dietaryRestrictionId);
                const res = await fetch('/api/DietaryTagVotes/status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ placeIds: [placeId], dietaryRestrictionIds: tagIds })
                });

                const statusList = res.ok ? await res.json() : [];
                const statuses = Array.isArray(statusList) ? statusList : [];
                const byTagId = new Map(statuses.map(s => [String(s.dietaryRestrictionId), s]));

                list.innerHTML = '';
                dietaryRestrictionsList.forEach(dr => {
                    const status = byTagId.get(String(dr.dietaryRestrictionId)) || { voteCount: 0, userHasVoted: false, isTagActive: false };
                    dietaryVoteModalState.initialVotesByTagId.set(String(dr.dietaryRestrictionId), !!status.userHasVoted);

                    const row = document.createElement('label');
                    row.style.cssText = `
                        display:flex;
                        align-items:center;
                        justify-content:space-between;
                        gap:0.75rem;
                        padding:0.75rem 0.875rem;
                        border:1px solid rgba(71,104,44,0.12);
                        border-radius:0.875rem;
                        background:#ffffff;
                        cursor:${window.isGuest ? 'default' : 'pointer'};
                    `;

                    const left = document.createElement('div');
                    left.style.cssText = 'display:flex; align-items:center; gap:0.75rem; min-width:0; flex:1;';

                    const cb = document.createElement('input');
                    cb.type = 'checkbox';
                    cb.checked = !!status.userHasVoted;
                    cb.disabled = !!window.isGuest;
                    cb.dataset.tagId = String(dr.dietaryRestrictionId);
                    cb.style.width = '1.1rem';
                    cb.style.height = '1.1rem';

                    const text = document.createElement('div');
                    text.style.cssText = 'min-width:0;';
                    text.innerHTML = `
                        <div style="font-weight:800; color:#111827; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                            ${escapeHtml(dr.name)}
                        </div>
                        <div style="margin-top:0.25rem; display:flex; gap:0.5rem; flex-wrap:wrap;">
                            ${status.isTagActive ? `<span style="padding:0.2rem 0.5rem; border-radius:9999px; font-size:0.75rem; font-weight:800; background:rgba(34,197,94,0.12); color:rgb(22,101,52); border:1px solid rgba(34,197,94,0.18);">Active</span>` : ''}
                            <span style="padding:0.2rem 0.5rem; border-radius:9999px; font-size:0.75rem; font-weight:800; background:rgba(71,104,44,0.06); color:#47682C; border:1px solid rgba(71,104,44,0.14);">
                                Votes: ${status.voteCount ?? 0}
                            </span>
                        </div>
                    `;

                    left.appendChild(cb);
                    left.appendChild(text);

                    const right = document.createElement('div');
                    right.style.cssText = 'flex-shrink:0; display:flex; align-items:center; gap:0.5rem;';
                    right.innerHTML = status.userHasVoted
                        ? `<span style="font-size:0.75rem; font-weight:900; color:#47682C;">VOTED</span>`
                        : '';

                    row.appendChild(left);
                    row.appendChild(right);
                    list.appendChild(row);
                });

                // Show modal
                modal.style.display = 'flex';
            } catch (e) {
                console.error('Failed to open dietary vote modal:', e);
            }
        }

        async function saveDietaryVoteModal() {
            if (window.isGuest) { if (typeof showLoginPrompt === 'function') showLoginPrompt(); return; }
            const { list, save } = getDietaryVoteModalEls();
            if (!list || !dietaryVoteModalState.placeId) return;

            const placeId = dietaryVoteModalState.placeId;
            const place = dietaryVoteModalState.place;

            const checkboxes = Array.from(list.querySelectorAll('input[type="checkbox"][data-tag-id]'));
            const desired = new Map(checkboxes.map(cb => [String(cb.dataset.tagId), cb.checked]));

            const ops = [];
            desired.forEach((want, tagId) => {
                const had = dietaryVoteModalState.initialVotesByTagId.get(String(tagId)) || false;
                if (want === had) return;

                const dietaryRestrictionId = parseInt(tagId, 10);
                if (want) {
                    const payload = {
                        placeId,
                        dietaryRestrictionId,
                        name: place?.name || '',
                        address: place?.vicinity || place?.formatted_address || '',
                        rating: place?.rating || null,
                        priceLevel: place?.price_level || null,
                        photoReference: place?.photos?.[0]?.photo_reference || null,
                        latitude: place?.geometry?.location?.lat?.() || null,
                        longitude: place?.geometry?.location?.lng?.() || null,
                        phoneNumber: place?.formatted_phone_number || null,
                        website: place?.website || null,
                        types: place?.types || []
                    };
                    ops.push(fetch('/api/DietaryTagVotes/vote', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    }));
                } else {
                    ops.push(fetch(`/api/DietaryTagVotes/unvote/${encodeURIComponent(placeId)}/${encodeURIComponent(dietaryRestrictionId)}`, { method: 'DELETE' }));
                }
            });

            try {
                if (save) {
                    save.disabled = true;
                    save.style.opacity = '0.7';
                }
                await Promise.all(ops);
            } catch (e) {
                console.error('Failed saving dietary votes:', e);
            } finally {
                if (save) {
                    save.disabled = false;
                    save.style.opacity = '1';
                }
            }

            // Refresh UI for currently selected tag (badges/buttons + filters + panel list)
            await refreshCommunityDietaryTagStatusForCurrentResults();
            if (dietaryFilterEnabled) applyDietaryFilterToCards();

            if (dietaryTagsPanel && dietaryTagsPanel.style.transform === 'translateX(0px)') {
                if (selectedCommunityDietaryRestrictionId != null) {
                    await loadCommunityTaggedShops(selectedCommunityDietaryRestrictionId);
                    displayDietaryTags();
                }
            }

            closeDietaryVoteModal();
        }

        async function refreshCommunityDietaryTagStatusForCurrentResults() {
            if (selectedCommunityDietaryRestrictionId == null) return;

            const placeIds = (Array.isArray(searchResultsData) ? searchResultsData : [])
                .map(p => p?.place_id)
                .filter(Boolean);

            if (placeIds.length === 0) return;

            try {
                const res = await fetch('/api/DietaryTagVotes/status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        placeIds,
                        dietaryRestrictionIds: [selectedCommunityDietaryRestrictionId]
                    })
                });
                if (!res.ok) return;
                const statusList = await res.json();
                if (!Array.isArray(statusList)) return;

                statusList.forEach(s => {
                    updateCommunityDietaryUiForPlaceTag(s.placeId, s.dietaryRestrictionId, s);
                });
            } catch (e) {
                console.error('Failed to load community dietary tag status:', e);
            }
        }

        async function renderDietaryTagsInDetails(placeId) {
            try {
                if (!placeId) return;

                // Ensure tags list is loaded
                if (!Array.isArray(dietaryRestrictionsList) || dietaryRestrictionsList.length === 0) {
                    await loadCommunityDietaryRestrictions();
                }
                if (!Array.isArray(dietaryRestrictionsList) || dietaryRestrictionsList.length === 0) return;

                const tagIds = dietaryRestrictionsList.map(x => x.dietaryRestrictionId);
                const res = await fetch('/api/DietaryTagVotes/status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ placeIds: [placeId], dietaryRestrictionIds: tagIds })
                });

                if (!res.ok) return;
                const raw = await res.json();
                const list = Array.isArray(raw) ? raw : (raw?.value ?? []);
                const statuses = Array.isArray(list) ? list : [];

                const active = statuses.filter(s => !!s.isTagActive);
                const container = document.getElementById(`dietarytags-display-${placeId}`);
                const chips = document.getElementById(`dietarytags-chips-${placeId}`);
                if (!container || !chips) return;

                if (active.length === 0) {
                    container.style.display = 'none';
                    chips.innerHTML = '';
                    return;
                }

                chips.innerHTML = active.map(s => {
                    const name = getDietaryRestrictionNameById(s.dietaryRestrictionId);
                    const voted = !!s.userHasVoted;
                    return `
                        <span style="
                            display:inline-flex; align-items:center; gap:0.375rem;
                            padding:0.375rem 0.625rem;
                            border-radius:9999px;
                            background:${voted ? 'rgba(71,104,44,0.12)' : 'rgba(71,104,44,0.08)'};
                            border:1px solid rgba(71,104,44,0.18);
                            color:#47682C;
                            font-size:0.75rem;
                            font-weight:800;
                        ">
                            🥗 ${escapeHtml(name)}
                        </span>
                    `;
                }).join('');

                container.style.display = 'block';
            } catch (e) {
                console.error('Failed to render dietary tags in details panel:', e);
            }
        }

        function updateCommunityDietaryUiForPlaceTag(placeId, dietaryRestrictionId, status) {
            const card = document.querySelector(`.result-item[data-place-id="${placeId}"]`);
            if (!card) return;

            // Persist state for filtering
            card.dataset.communityTagActive = status?.isTagActive ? 'true' : 'false';
            card.dataset.communityTagId = String(dietaryRestrictionId ?? '');

            // Badge
            const badgeContainer = card.querySelector('.community-tag-badges');
            if (badgeContainer) {
                if (status?.isTagActive) {
                    const tagName = getDietaryRestrictionNameById(dietaryRestrictionId);
                    badgeContainer.innerHTML = `
                        <span style="display:inline-flex; align-items:center; gap:0.375rem; padding:0.375rem 0.625rem; background:rgba(71,104,44,0.08); border:1px solid rgba(71,104,44,0.18); border-radius:9999px; color:#47682C; font-size:0.75rem; font-weight:800;">
                            🥗 ${escapeHtml(tagName)}
                        </span>
                    `;
                } else {
                    badgeContainer.innerHTML = '';
                }
            }

            // Vote button state
            const voteBtn = card.querySelector('.dietary-vote-btn');
            if (voteBtn) {
                const voteCount = status?.voteCount ?? 0;
                const userHasVoted = !!status?.userHasVoted;

                voteBtn.dataset.userHasVoted = userHasVoted ? 'true' : 'false';
                voteBtn.dataset.voteCount = String(voteCount);
                voteBtn.dataset.dietaryRestrictionId = String(dietaryRestrictionId ?? '');

                if (window.isGuest) {
                    voteBtn.disabled = true;
                    voteBtn.style.opacity = '0.55';
                    voteBtn.style.cursor = 'not-allowed';
                    voteBtn.title = 'Login to vote';
                    voteBtn.innerHTML = `<span aria-hidden="true">🏷️</span>`;
                } else {
                    voteBtn.disabled = false;
                    voteBtn.style.opacity = '1';
                    voteBtn.style.cursor = 'pointer';
                    voteBtn.title = 'Select dietary tags to vote';
                    voteBtn.innerHTML = `<span aria-hidden="true">🏷️</span>`;
                }
            }
        }

        function updateFavoriteButtonIconOnly(btn, isFavorite) {
