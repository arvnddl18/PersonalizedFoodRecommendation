        // Guest login prompt modal (lazy created)
        function showLoginPrompt() {
            let modal = document.getElementById('guest-login-modal');
            
            // Temporarily hide tour overlay/tooltip if active to prevent z-index conflicts
            const tourOverlay = document.getElementById('tour-overlay');
            const tourTooltip = document.getElementById('tour-tooltip');
            let wasTourVisible = false;
            let tourOverlayDisplay = '';
            let tourTooltipOpacity = '';
            
            if (tourOverlay && tourOverlay.style.display !== 'none') {
                wasTourVisible = true;
                tourOverlayDisplay = tourOverlay.style.display;
                tourOverlay.style.display = 'none';
            }
            if (tourTooltip) {
                tourTooltipOpacity = tourTooltip.style.opacity || '1';
                tourTooltip.style.opacity = '0';
                tourTooltip.style.pointerEvents = 'none';
            }
            
            // Function to restore tour visibility
            const restoreTour = () => {
                if (wasTourVisible && tourOverlay) {
                    tourOverlay.style.display = tourOverlayDisplay || 'block';
                }
                if (tourTooltip && tourTooltipOpacity !== '') {
                    tourTooltip.style.opacity = tourTooltipOpacity;
                    tourTooltip.style.pointerEvents = 'auto';
                }
            };
            
            if (!modal) {
                modal = document.createElement('div');
                modal.id = 'guest-login-modal';
                // Use z-index higher than tour tooltip (10002) to ensure modal is on top
                modal.style.cssText = 'position:fixed; inset:0; display:flex; align-items:center; justify-content:center; background:rgba(0,0,0,0.35); z-index:10005;';
                modal.innerHTML = `
                    <div role="dialog" aria-modal="true" style="background:#ffffff; border-radius:16px; width:90%; max-width:420px; padding:20px; box-shadow:0 12px 32px rgba(0,0,0,0.2); border:1px solid rgba(71,104,44,0.15); z-index:10006; pointer-events:auto;">
                        <div style="display:flex; align-items:center; gap:10px; margin-bottom:10px;">
                            <div style="width:36px; height:36px; border-radius:50%; background:#47682C; color:#fff; display:flex; align-items:center; justify-content:center; font-weight:700;">i</div>
                            <h3 style="margin:0; color:#47682C; font-size:1.05rem;">Log in required</h3>
                        </div>
                        <p style="margin:0 0 16px 0; color:#374151; line-height:1.5;">Please log in to use Health & Dietary Mode and other personalized features.</p>
                        <div style="display:flex; gap:10px; justify-content:flex-end;">
                            <button id="guest-login-cancel" style="padding:10px 14px; border-radius:10px; background:#ffffff; border:1px solid #d1d5db; color:#374151; cursor:pointer;">Cancel</button>
                            <button id="guest-login-cta" style="padding:10px 14px; border-radius:10px; background:#47682C; border:1px solid #47682C; color:#ffffff; font-weight:700; cursor:pointer;">Log in</button>
                        </div>
                    </div>
                `;
                document.body.appendChild(modal);
                
                // Close handler that always checks for current restore function
                const closeModal = () => {
                    modal.style.display = 'none';
                    // Always check for the current restore function (updated on each show)
                    if (modal._restoreTour) {
                        modal._restoreTour();
                    }
                };
                
                const cancelBtn = document.getElementById('guest-login-cancel');
                const ctaBtn = document.getElementById('guest-login-cta');
                cancelBtn.addEventListener('click', closeModal);
                ctaBtn.addEventListener('click', () => { window.location.href = '/Auth/Login'; });
                modal.addEventListener('click', (e) => { 
                    if (e.target === modal) {
                        closeModal();
                    }
                });
                
                // Handle escape key - use a named function so we can remove it later if needed
                const escapeHandler = (e) => { 
                    if (e.key === 'Escape' && modal && modal.style.display !== 'none') {
                        closeModal();
                    }
                };
                document.addEventListener('keydown', escapeHandler);
                modal._escapeHandler = escapeHandler;
            }
            
            // Always update restore function and tour state (for both new and existing modals)
            modal._restoreTour = restoreTour;
            modal._wasTourVisible = wasTourVisible;
            
            // Ensure modal has highest z-index
            modal.style.zIndex = '10005';
            
            modal.style.display = 'flex';
        }

		// Enhanced Send message with typing indicator
		async function sendMessage() {
			const input = document.getElementById('message-input');
			const message = input.value.trim();
			if (!message) return;

			// Guest: block likely personalized queries and show login prompt
			if (window.isGuest && isLikelyPersonalizedQuery(message)) {
				if (typeof showLoginPrompt === 'function') showLoginPrompt();
				return;
			}

            // Contextual follow‑up: "Only ones open now" – filter to currently open restaurants
            if (isOpenFilterFollowUpMessage(message) && Array.isArray(searchResultsData) && searchResultsData.length > 0) {
                addMessage('You', message);
                input.value = '';

                const openPlaces = filterOpenPlacesFromResults(searchResultsData);
                if (openPlaces.length === 0) {
                    addMessage('FoodieSaur Bot', 'From the restaurants I just showed you, none are currently marked as open.');
                } else {
                    const names = openPlaces.map(p => p.name).filter(Boolean);
                    let reply;
                    if (names.length === 1) {
                        reply = `From the restaurants I just showed you, the one that’s currently open is ${names[0]}.`;
                    } else {
                        const listText = names.map((n, i) => `${i + 1}. ${n}`).join('\n');
                        reply = `Here are the restaurants from that list that are currently open:\n${listText}`;
                    }
                    addMessage('FoodieSaur Bot', reply);
                }
                return;
            }

            // Contextual follow‑up: "Which one is closest?" and similar
            // If we already have a list of search results, handle this purely on the client
            if (isClosestFollowUpMessage(message) && Array.isArray(searchResultsData) && searchResultsData.length > 0) {
                // Add user message to chat
                addMessage('You', message);
                input.value = '';

                const closestPlace = findClosestPlaceFromResults(searchResultsData);
                if (closestPlace) {
                    const distanceText = closestPlace.distanceText || 'distance unavailable';
                    const durationText = closestPlace.durationText || '';
                    const extra = durationText ? `, around ${durationText} drive` : '';
                    const reply = `Looking at the restaurants I just showed you, the closest one is **${closestPlace.name}** (${distanceText}${extra}).`;
                    addMessage('FoodieSaur Bot', reply);
                } else {
                    addMessage('FoodieSaur Bot', 'I couldn’t determine which restaurant is closest from the current list.');
                }
                return;
            }

			// Keep last user message for client-side search heuristics (e.g., "find yogurt")
			window.lastUserMessage = message;

			// Add user message to chat
			addMessage('You', message);
			input.value = '';

			// Show typing indicator
			const typingIndicator = document.getElementById('typing-indicator');
			if (typingIndicator) {
				typingIndicator.style.display = 'block';
				
				// Scroll to show typing indicator
				const chatMessages = document.getElementById('chat-messages');
				chatMessages.scrollTop = chatMessages.scrollHeight;
			}

			try {
				const response = await fetch('/api/Chat/send', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
					},
					body: JSON.stringify({
						text: message,
						includeHealthDietRestrictions: healthDietModeEnabled,
						sessionId: window.currentSessionId || null
					})
				});

				const data = await response.json();
				
				// Hide typing indicator
				if (typingIndicator) {
					typingIndicator.style.display = 'none';
				}
				
				if (data && data.sessionId) {
					window.currentSessionId = data.sessionId;
				}
				if (data && data.response) {
					// Detect personalized recommendation format and render neatly with neutral bubbles
					if (isPersonalizedRecommendation(data.response)) {
						renderPersonalizedRecommendation(data.response);
					} else {
						addMessage('FoodieSaur Bot', data.response);
					}
                    
                    // DUAL FLOW: Check if we have parameters for generalized queries (map search)
                    // OR if food preferences were ranked (personalized queries)
                    // Also check for establishment search intent
                    if (data.parameters && (data.parameters.queryType === 'generalized' || data.parameters.intentName === 'establishment_search' || data.parameters.establishmentName)) {
                        await performMapSearch(data.parameters);
                    }
                    
					renderActionButtonsFromResponse(data.response);
                } else {
                    addMessage('FoodieSaur Bot', 'Sorry, I did not get a response.');
                }
            } catch (error) {
                console.error('Error:', error);
                
                // Hide typing indicator on error
                if (typingIndicator) {
					typingIndicator.style.display = 'none';
				}
				
                addMessage('FoodieSaur Bot', 'Sorry, there was an error processing your message.');
            }

		// Identify the personalized recommendation blob by key phrases and a numbered list with scores
		function isPersonalizedRecommendation(text) {
			const t = String(text ?? '');
			const hasProfileCue = /Based on your comprehensive profile|I know you follow|I've analyzed your preferences|Let me share some personalized|I've curated these options|Here are some fantastic choices|I've discovered some amazing options|Let me present some carefully selected|I've found some excellent choices|Here are some personalized suggestions|I've prepared some wonderful options|Let me share some perfect matches|I've carefully studied your profile|After reviewing your preferences|I've examined your tastes|I've analyzed your requirements|I'd love to present|Allow me to share|I'm excited to present|Let me show you|I've handpicked these selections|I've carefully chosen these options|I've selected these recommendations|I've curated a special list|I've discovered some amazing options|I've found some incredible choices|Here are some wonderful discoveries|I've uncovered some excellent options|I've prepared some wonderful options|I've crafted some special recommendations|I've designed these suggestions|I've put together some perfect options|I've created some custom recommendations|I've tailored these options|I've personalized these suggestions|I'm thrilled to present|I'm excited to share|I can't wait to show you|I'm delighted to present|Based on my analysis|I'm confident these selections|I've identified the perfect options|These recommendations are specifically designed|I've determined the best choices/i.test(t);
			const hasNumberedScores = /\n\s*\d+\.\s*[^\n]+\(Score:\s*\d+(?:\.\d+)?\)/i.test(t);
			const hasChooseSection = /Choose a food type\s*:/i.test(t);
			const hasOrganizedStructure = /Based on your comprehensive profile, I recommend these foods:|Here are my top recommendations for you:|These are the best options I've found for you:|I've selected these foods specifically for you:|Here are the perfect choices for your profile:|These recommendations are tailored to your needs:|I've chosen these options with you in mind:|Here are the ideal selections for your preferences:|These foods are perfectly suited to your profile:|I've picked these recommendations just for you:|Here are the best matches for your taste profile:|These selections are customized for your needs:|I've curated these options specifically for you:|Here are the perfect picks for your preferences:|These recommendations are designed for your profile:|I've handpicked these foods for your enjoyment:|Here are the ideal choices for your taste:|These options are perfectly matched to your needs:|I've selected these foods with your preferences in mind:|Here are the best recommendations for your profile:/i.test(t);
			return hasProfileCue && (hasNumberedScores || hasChooseSection || hasOrganizedStructure);
		}

        // Detect follow‑ups like "Only ones open now"
        function isOpenFilterFollowUpMessage(text) {
            const t = String(text || '').toLowerCase().trim();
            if (!t) return false;

            const patterns = [
                /\bonly\s+ones?\s+open\s+now\??$/,
                /\bonly\s+the\s+ones?\s+open\??$/,
                /\bjust\s+the\s+open\s+ones?\??$/,
                /\bshow\s+only\s+open\s+ones?\??$/,
                /\bonly\s+open\s+restaurants?\??$/
            ];

            return patterns.some((re) => re.test(t));
        }

        // Detect follow‑ups like "Which one is closest?"
        function isClosestFollowUpMessage(text) {
            const t = String(text || '').toLowerCase().trim();
            if (!t) return false;

            const patterns = [
                /\bwhich\s+one\s+is\s+closest\??$/,
                /\bwhich\s+is\s+closest\??$/,
                /\bclosest\s+one\??$/,
                /\bwhat'?s\s+the\s+closest\s+one\??$/,
                /\bwhich\s+restaurant\s+is\s+closest\??$/
            ];

            return patterns.some((re) => re.test(t));
        }

        // From an array of search results, pick the one with the smallest driving distance
        function findClosestPlaceFromResults(results) {
            if (!Array.isArray(results) || results.length === 0) return null;

            let closest = null;
            let bestDistance = Number.POSITIVE_INFINITY;

            results.forEach(place => {
                if (!place) return;
                const d = typeof place.drivingDistance === 'number' && !isNaN(place.drivingDistance)
                    ? place.drivingDistance
                    : (typeof place.distance === 'number' && !isNaN(place.distance) ? place.distance : null);
                if (d == null) return;
                if (d < bestDistance) {
                    bestDistance = d;
                    closest = place;
                }
            });

            // Fallback: if no numeric distance, just return the first item
            return closest || results[0] || null;
        }

        // Filter an array of places down to those that are currently open
        function filterOpenPlacesFromResults(results) {
            if (!Array.isArray(results)) return [];

            const openPlaces = [];
            results.forEach(place => {
                if (!place) return;
                // Reuse existing helper that inspects opening_hours / business_status
                const status = getStoreStatus(place);
                if (status && status.isOpen) {
                    openPlaces.push(place);
                }
            });

            return openPlaces;
        }

        // Heuristic: detect if a user message is likely a personalized query
        function isLikelyPersonalizedQuery(text) {
            const t = String(text || '').toLowerCase();
            // First person intent + preference/health cues
            const patterns = [
                /\bmy\b/, /\bfor me\b/, /\bi\s*(am|have|want|prefer)\b/,
                /\bprefer\b/, /\bfavorite\b/, /\bbased on (my|me)\b/,
                /\bdiabet(es|ic)\b/, /\bhypertension\b/, /\bcholesterol\b/, /\bdiet\b/,
                /\bpersonal(ized|ise|ise?d)\b/, /\bprofile\b/
            ];
            return patterns.some((re) => re.test(t));
        }

		// Render the personalized recommendation with clean left-aligned neutral bubbles per paragraph
		function renderPersonalizedRecommendation(text) {
			const container = document.getElementById('new-messages');
			let raw = String(text ?? '');
			
			// Remove scores from the text: (Score: X.XX) or (Score: X)
			raw = raw.replace(/\s*\(Score:\s*[\d.]+\)/gi, '');
			
			// Normalize line breaks; split paragraphs by blank lines
			const paragraphs = raw
				.replace(/\r\n/g, '\n')
				.split(/\n\s*\n+/)
				.map(p => p.trim())
				.filter(Boolean);

			paragraphs.forEach(p => {
				const messageDiv = document.createElement('div');
				messageDiv.style.cssText = 'margin-bottom:1rem; animation:slideInLeft 0.4s ease-out;';
				const safe = escapeHtml(p).replace(/\n/g, '<br>');
				// Enhanced bot bubble with brand colors
				messageDiv.innerHTML = `
					<div style="background:rgba(71,104,44,0.08); backdrop-filter:blur(4px); color:#47682C; padding:0.875rem 1.125rem; border-radius:1.25rem; border-top-left-radius:0.25rem; border:1px solid rgba(71,104,44,0.1); box-shadow:0 4px 12px rgba(71,104,44,0.12); transition:transform 0.2s ease, box-shadow 0.2s ease; max-width:85%;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 16px rgba(71,104,44,0.18)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 12px rgba(71,104,44,0.12)'">
						<p style="font-size:0.9rem; margin:0; line-height:1.6; font-weight:500;">${safe}</p>
					</div>
				`;
				container.appendChild(messageDiv);
			});

			// Scroll to bottom
			const chatMessages = document.getElementById('chat-messages');
			chatMessages.scrollTop = chatMessages.scrollHeight;
		}
        }

        // Perform map search using extracted parameters - ACTIVE for generalized queries
        async function performMapSearch(parameters) {
            try {
                // Store parameters for back button functionality
                window.lastSearchParameters = parameters;
                
                const rawUserText = String(window.lastUserMessage || '').trim();
                const rawKeyword = extractKeywordFromUserMessage(rawUserText);
                const wantsRestaurantExplicitly = /\brestaurant(s)?\b|\beat\b|\bdine\b|\blunch\b|\bdinner\b|\bbreakfast\b/i.test(rawUserText);

                const hasOnlyFood =
                    !!parameters.food &&
                    !parameters.cuisine &&
                    !parameters.dietary &&
                    !parameters.price &&
                    !parameters.establishmentName;

                // If the user asks like "find X" and doesn't explicitly mention restaurants,
                // treat it as a general place/keyword search (closer to Google Maps behavior).
                const treatAsKeywordSearch =
                    !!parameters.establishmentName ||
                    parameters.intentName === 'establishment_search' ||
                    (!!rawKeyword && !wantsRestaurantExplicitly) ||
                    (hasOnlyFood && !wantsRestaurantExplicitly);

                if (treatAsKeywordSearch) {
                    const term = String(parameters.establishmentName || rawKeyword || parameters.food || rawUserText).trim();
                    const baseRadius = 8000;
                    const expandedRadius = 20000;

                    const variants = keywordVariants(term);
                    let results = [];
                    for (const kw of variants) {
                        const r = await nearbySearchKeyword({
                            keyword: kw,
                            location: userLocation,
                            radius: baseRadius
                        });
                        results = dedupePlacesById([...(results || []), ...(r || [])]);
                    }

                    if (!results || results.length < 5) {
                        for (const kw of variants) {
                            const more = await nearbySearchKeyword({
                                keyword: kw,
                                location: userLocation,
                                radius: expandedRadius
                            });
                            results = dedupePlacesById([...(results || []), ...(more || [])]);
                        }
                    }

                    if (!results || results.length < 5) {
                        const locSuffix =
                            parameters.location && parameters.location !== 'nearby' && parameters.location !== 'near me'
                                ? ` in ${parameters.location}`
                                : '';
                        const fallbacks = variants.flatMap(v => ([
                            `${v}${locSuffix}`,
                            `${v} shop${locSuffix}`,
                            `${v} store${locSuffix}`,
                            `${v} near me`
                        ]));

                        for (const q of fallbacks) {
                            const more = await textSearchCompat({
                                query: q,
                                location: userLocation,
                                radius: expandedRadius
                                // no type restriction here on purpose
                            });
                            results = dedupePlacesById([...(results || []), ...(more || [])]);
                            if (results.length >= 10) break;
                        }
                    }

                    // Merge in owner-provided menu matches (food + dietary)
                    results = await mergeMenuMatchesIntoResults(results, parameters);
                    // Merge in community dietary-tagged shops ONLY for dietary-only searches.
                    results = await mergeCommunityDietaryTaggedShopsIntoResults(results, parameters);

                    // For food+dietary searches, prepare a separate "Also <dietary>" section
                    window._fsSecondaryDietarySection = await prepareSecondaryDietarySection(parameters);

                    if (results && results.length) {
                        displaySearchResults(results, parameters);
                        openSearch();
                    } else {
                        addMessage('FoodieSaur Bot', `No places found for "${term}". Try a more specific keyword (e.g., "frozen yogurt").`);
                    }
                    return;
                }

                let searchQuery = '';

                // Generalized search (no implicit "restaurant" forcing)
                if (parameters.food) searchQuery += parameters.food + ' ';
                if (parameters.cuisine) searchQuery += parameters.cuisine + ' ';
                if (parameters.dietary) searchQuery += parameters.dietary + ' ';
                if (parameters.price) searchQuery += parameters.price + ' ';

                // Add location context
                if (parameters.location === 'nearby' || parameters.location === 'near me') {
                    searchQuery += 'near me';
                } else if (parameters.location) {
                    searchQuery += `in ${parameters.location}`;
                } else {
                    // no default suffix
                }

                // Multi-intent fallback: if structured parameters are sparse, fall back to the user's full phrase
                // e.g., "Cheap Korean food near downtown" -> let Maps interpret the combined intent directly.
                if (!searchQuery.trim() && rawUserText) {
                    searchQuery = rawUserText;
                }

                // Search using compatibility helper (prefers new API with legacy fallback)
                const request = {
                    query: searchQuery.trim(),
                    location: userLocation,
                    radius: 5000
                };
                let results = await textSearchCompat(request);
                results = await mergeMenuMatchesIntoResults(results, parameters);
                results = await mergeCommunityDietaryTaggedShopsIntoResults(results, parameters);
                window._fsSecondaryDietarySection = await prepareSecondaryDietarySection(parameters);
                if (results && results.length) {
                    displaySearchResults(results, parameters);
                    openSearch();
                } else {
                    addMessage('FoodieSaur Bot', 'No places found matching your criteria.');
                }
            } catch (error) {
                console.error('Error performing map search:', error);
                addMessage('FoodieSaur Bot', 'Error searching for places.');
            }
        }

        // If the owner added menu items + dietary tags, include those restaurants in search results.
        async function mergeMenuMatchesIntoResults(results, parameters) {
            try {
                const food = String(parameters?.food || '').trim();
                const dietary = String(parameters?.dietary || '').trim();
                if (!food && !dietary) return results || [];

                const qs = new URLSearchParams();
                if (food) qs.set('term', food);
                if (dietary) qs.set('dietary', dietary);
                qs.set('limit', '25');

                const res = await fetch(`/api/RestaurantEdit/menu-matches?${qs.toString()}`, { credentials: 'same-origin' });
                if (!res.ok) return results || [];
                const data = await res.json();
                const placeIds = Array.isArray(data?.placeIds) ? data.placeIds : [];
                if (!placeIds.length) return results || [];

                const existing = new Set((results || []).map(p => p?.place_id).filter(Boolean));
                const extras = [];

                for (const pid of placeIds) {
                    const placeId = String(pid || '').trim();
                    if (!placeId || existing.has(placeId)) continue;

                    const place = await fetchPlaceDetails(placeId);
                    const normalized = place && typeof place === 'object' ? place : {};

                    // Ensure minimal fields for sorting/rendering
                    if (!normalized.place_id) normalized.place_id = placeId;
                    if (!normalized.geometry || !normalized.geometry.location) {
                        // Try to map new Places API location to legacy geometry
                        let loc = null;
                        const rawLoc = normalized.location;
                        if (rawLoc) {
                            // rawLoc may already be a LatLng
                            if (typeof rawLoc.lat === 'function' && typeof rawLoc.lng === 'function') {
                                loc = rawLoc;
                            } else if (typeof rawLoc.lat === 'number' && typeof rawLoc.lng === 'number') {
                                loc = new google.maps.LatLng(rawLoc.lat, rawLoc.lng);
                            } else if (rawLoc.latitude != null && rawLoc.longitude != null) {
                                loc = new google.maps.LatLng(rawLoc.latitude, rawLoc.longitude);
                            }
                        }
                        if (loc) normalized.geometry = { location: loc };
                    }

                    if (normalized.geometry && normalized.geometry.location) {
                        // Mark as menu match so we can prioritize/display if needed
                        normalized._fsMenuMatch = true;
                        extras.push(normalized);
                        existing.add(placeId);
                    }
                }

                // IMPORTANT: put menu matches first so they appear in the top 10 cards
                return dedupePlacesById([...extras, ...(results || [])]);
            } catch (e) {
                console.warn('mergeMenuMatchesIntoResults failed:', e);
                return results || [];
            }
        }

        function normalizeDietaryName(s) {
            return String(s || '')
                .toLowerCase()
                .replace(/[^a-z0-9]+/g, ' ')
                .trim();
        }

        async function mergeCommunityDietaryTaggedShopsIntoResults(results, parameters) {
            try {
                const dietary = String(parameters?.dietary || '').trim();
                if (!dietary) return results || [];
                // If the user also asked for a food item (e.g. "bulgogi that is nut-free"),
                // do NOT mix in dietary-tagged shops into the main results list.
                // We'll show dietary-tag shops in a separate section instead (see secondary section rendering).
                if (String(parameters?.food || '').trim()) return results || [];

                // Ensure restrictions list is loaded so we can map "Vegetarian" -> dietaryRestrictionId
                if (!Array.isArray(dietaryRestrictionsList) || dietaryRestrictionsList.length === 0) {
                    try { await loadCommunityDietaryRestrictions(); } catch (_) { }
                }

                const target = normalizeDietaryName(dietary);
                if (!target) return results || [];

                const match = Array.isArray(dietaryRestrictionsList)
                    ? dietaryRestrictionsList.find(dr => normalizeDietaryName(dr?.name) === target)
                    : null;

                // If tag isn't recognized in our dietary restrictions list, skip (prevents false positives).
                const dietaryRestrictionId = match?.dietaryRestrictionId;
                if (!dietaryRestrictionId) return results || [];

                const res = await fetch(`/api/DietaryTagVotes/shops?dietaryRestrictionId=${encodeURIComponent(dietaryRestrictionId)}`);
                if (!res.ok) return results || [];
                const shops = await res.json();
                if (!Array.isArray(shops) || shops.length === 0) return results || [];

                const existing = new Set((results || []).map(p => p?.place_id).filter(Boolean));
                const extras = [];

                for (const shop of shops) {
                    const placeId = String(shop?.placeId || '').trim();
                    if (!placeId || existing.has(placeId)) continue;

                    const lat = (shop?.latitude != null) ? parseFloat(shop.latitude) : NaN;
                    const lng = (shop?.longitude != null) ? parseFloat(shop.longitude) : NaN;
                    const hasLoc = Number.isFinite(lat) && Number.isFinite(lng);

                    // Prefer cached fields to avoid additional API calls
                    const place = {
                        place_id: placeId,
                        name: shop?.name || 'Restaurant',
                        formatted_address: shop?.address || '',
                        vicinity: shop?.address || '',
                        rating: (shop?.rating != null) ? Number(shop.rating) : null,
                        price_level: (shop?.priceLevel != null) ? Number(shop.priceLevel) : null,
                        geometry: hasLoc ? { location: new google.maps.LatLng(lat, lng) } : undefined,
                        photos: [] // will fall back to placeholder in UI
                    };

                    // Mark so we can debug/recognize these results
                    place._fsCommunityDietaryTagMatch = true;

                    // If we don't have cached lat/lng, fall back to fetching place details
                    if (!place.geometry || !place.geometry.location) {
                        try {
                            const details = await fetchPlaceDetails(placeId);
                            if (details && typeof details === 'object') {
                                Object.assign(place, details);
                            }
                        } catch (_) { }
                    }

                    if (place.geometry && place.geometry.location) {
                        extras.push(place);
                        existing.add(placeId);
                    }
                }

                // Put community-tag matches near the top too (after menu matches if already merged earlier)
                return dedupePlacesById([...extras, ...(results || [])]);
            } catch (e) {
                console.warn('mergeCommunityDietaryTaggedShopsIntoResults failed:', e);
                return results || [];
            }
        }

        async function getDietaryRestrictionIdByName(dietaryName) {
            const dietary = String(dietaryName || '').trim();
            if (!dietary) return null;
            if (!Array.isArray(dietaryRestrictionsList) || dietaryRestrictionsList.length === 0) {
                try { await loadCommunityDietaryRestrictions(); } catch (_) { }
            }
            const target = normalizeDietaryName(dietary);
            const match = Array.isArray(dietaryRestrictionsList)
                ? dietaryRestrictionsList.find(dr => normalizeDietaryName(dr?.name) === target)
                : null;
            return match?.dietaryRestrictionId ?? null;
        }

        async function prepareSecondaryDietarySection(parameters) {
            try {
                const food = String(parameters?.food || '').trim();
                const dietary = String(parameters?.dietary || '').trim();
                if (!food || !dietary) return null;

                const dietaryRestrictionId = await getDietaryRestrictionIdByName(dietary);
                if (!dietaryRestrictionId) return null;

                // Get places that SERVE the requested food (from owner menu edits)
                let foodPlaceIds = [];
                try {
                    const qs = new URLSearchParams({ term: food, limit: '100' });
                    const r = await fetch(`/api/RestaurantEdit/menu-matches?${qs.toString()}`, { credentials: 'same-origin' });
                    const data = r.ok ? await r.json() : null;
                    foodPlaceIds = Array.isArray(data?.placeIds) ? data.placeIds : [];
                } catch (_) { foodPlaceIds = []; }
                const foodSet = new Set(foodPlaceIds.map(x => String(x || '').trim()).filter(Boolean));

                // Get community-tagged shops for the dietary tag
                const res = await fetch(`/api/DietaryTagVotes/shops?dietaryRestrictionId=${encodeURIComponent(dietaryRestrictionId)}`);
                if (!res.ok) return null;
                const shops = await res.json();
                if (!Array.isArray(shops) || shops.length === 0) return null;

                // Keep only those that are dietary-tagged BUT do not serve the requested food.
                const filtered = shops.filter(s => {
                    const pid = String(s?.placeId || '').trim();
                    if (!pid) return false;
                    return !foodSet.has(pid);
                });

                if (filtered.length === 0) return null;
                return { food, dietary, shops: filtered.slice(0, 15) };
            } catch (e) {
                console.warn('prepareSecondaryDietarySection failed:', e);
                return null;
            }
        }

