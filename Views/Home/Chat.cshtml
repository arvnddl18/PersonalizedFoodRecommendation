        async function loadSessionMessages(sessionId) {
            try {
                const res = await fetch(`/api/Chat/sessions/${sessionId}/messages`);
                if (!res.ok) return;
                const payload = await res.json();
                const list = payload.messages ?? payload.Messages ?? [];
                // Clear chat
                document.getElementById('new-messages').innerHTML = '';
                // Render messages
                for (const m of list) {
                    const sender = (m.sender ?? m.Sender) === 'user' ? 'You' : 'Nomsaur';
                    addMessage(sender, m.messageText ?? m.MessageText);
                }
            } catch {}
        }

