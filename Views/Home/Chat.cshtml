        function refreshOwnerModalMenuPreview() {
            const els = getOwnerRestaurantModalEls();
            if (!els.menuPreview) return;
            const raw = (els.menuitemsText && els.menuitemsText.value) ? els.menuitemsText.value : '';
            els.menuPreview.innerHTML = menuTextToHtml(raw || '');
        }

        function addOwnerModalMenuItemLine() {
            const els = getOwnerRestaurantModalEls();
            if (!els.menuitemsText) return;

            const placeId = ownerRestaurantModalState.selectedPlaceId;
            const type = (els.menuItemType?.value || '').trim();
            const name = (els.menuItemName?.value || '').trim();
            const caloriesRaw = (els.menuItemCalories?.value || '').toString().trim();
            const serving = (els.menuItemServing?.value || '').trim();
            const imageRaw = (els.menuItemImage?.value || '').trim();
            const desc = (els.menuItemDesc?.value || '').trim();
            const selectedTags = els.menuItemTags
                ? Array.from(els.menuItemTags.querySelectorAll('input[type="checkbox"]:checked') || []).map(cb => (cb.value || '').trim()).filter(Boolean)
                : [];

            if (!name) {
                alert('Please enter an item name.');
                return;
            }

            let line = name;
            if (desc) line += ` - ${desc}`;
            if (type) line += ` [type: ${type}]`;
            if (caloriesRaw) {
                const n = parseFloat(caloriesRaw);
                if (Number.isFinite(n) && n >= 0) line += ` [cal: ${Math.round(n)} kcal]`;
            }
            if (serving) line += ` [serving: ${serving}]`;
            if (imageRaw) {
                const img = normalizeMenuImageUrl(imageRaw);
                if (!img) {
                    alert('Invalid image URL. Please use a normal http(s) link or a /path on this site.');
                    return;
                }
                line += ` [img: ${img}]`;
            }
            if (selectedTags.length > 0) line += ` [tags: ${selectedTags.join(', ')}]`;

            const current = (els.menuitemsText.value || '').trimEnd();
            els.menuitemsText.value = current ? `${current}\n${line}\n` : `${line}\n`;

            refreshOwnerModalMenuPreview();
            clearOwnerModalMenuItemBuilder();
            try { els.menuItemName?.focus(); } catch (_) {}
        }

        // Owner modal menu builder: file upload + preview
        document.addEventListener('change', async (e) => {
            const input = e.target;
            if (!input || input.tagName !== 'INPUT' || input.type !== 'file') return;
            if (input.id !== 'owner-modal-menuitem-image-file') return;

            const placeId = ownerRestaurantModalState.selectedPlaceId;
            if (!placeId) {
                alert('Please select a restaurant first.');
                input.value = '';
                return;
            }

            const els = getOwnerRestaurantModalEls();
            const hidden = document.getElementById('owner-modal-menuitem-image');
            const status = document.getElementById('owner-modal-menuitem-image-status');
            const preview = document.getElementById('owner-modal-menuitem-image-preview');

            const file = input.files && input.files[0] ? input.files[0] : null;
            if (!file) return;

            // local preview immediately
            try {
                if (preview) {
                    preview.src = URL.createObjectURL(file);
                    preview.style.display = 'block';
                }
            } catch (_) { }

            input.disabled = true;
            try {
                await uploadMenuItemImage(placeId, file, { hidden, status });
                if (status) {
                    status.style.display = 'block';
                    status.style.color = '#47682C';
                    status.textContent = 'Image uploaded.';
                }
                // keep in modal state for addOwnerModalMenuItemLine
                if (els.menuItemImage) els.menuItemImage.value = hidden?.value || '';
            } catch (err) {
                if (status) {
                    status.style.display = 'block';
                    status.style.color = '#ef4444';
                    status.textContent = err?.message || 'Upload failed.';
                }
                if (hidden) hidden.value = '';
                if (els.menuItemImage) els.menuItemImage.value = '';
            } finally {
                input.disabled = false;
            }
        });

