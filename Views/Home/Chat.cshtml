        // NEW: Search for establishments serving a specific food preference
        async function performFoodPreferenceSearch(foodName) {
            try {
                // Store search info
                window.lastFoodPreferenceSearch = foodName;
                
                // IMPORTANT:
                // Don't force everything into "restaurant". For queries like "yogurt",
                // the closest match to Google Maps behavior is usually a nearby keyword search.
                const baseRadius = 8000;
                const expandedRadius = 15000;

                // 1) Nearby keyword search (closest to "near me")
                let results = await nearbySearchKeyword({
                    keyword: foodName,
                    location: userLocation,
                    radius: baseRadius
                });

                // 2) Expand radius if too few results
                if (!results || results.length < 5) {
                    const more = await nearbySearchKeyword({
                        keyword: foodName,
                        location: userLocation,
                        radius: expandedRadius
                    });
                    results = dedupePlacesById([...(results || []), ...(more || [])]);
                }

                // 3) Fallback to text search without "type=restaurant" and without appending "restaurant"
                if (!results || results.length < 5) {
                    const fallbacks = [
                        `${foodName} shop`,
                        `${foodName} store`,
                        `${foodName} near me`
                    ];

                    for (const q of fallbacks) {
                        const more = await textSearchCompat({
                            query: q,
                            location: userLocation,
                            radius: expandedRadius
                            // no type restriction here on purpose
                        });
                        results = dedupePlacesById([...(results || []), ...(more || [])]);
                        if (results.length >= 8) break;
                    }
                }

                if (results && results.length) {
                    displayFoodPreferenceResults(results, foodName);
                    openSearch();
                } else {
                    addMessage('FoodieSaur Bot', `No restaurants found serving ${foodName} nearby.`);
                }
            } catch (error) {
                console.error('Error searching for food preference:', error);
                addMessage('FoodieSaur Bot', `Error searching for restaurants serving ${foodName}.`);
            }
        }

        // Display search results for food preference selection
        function displayFoodPreferenceResults(results, foodName) {
            const resultsDiv = document.getElementById('search-results');
            resultsDiv.innerHTML = '';

            // Clear any previous markers/info windows
            clearSearchOverlays();

            // Add search summary
            const summary = document.createElement('div');
            summary.className = 'mb-4 p-3 bg-green-50 rounded';
            summary.innerHTML = `
                <h3 class="font-semibold text-green-800">Restaurants Serving ${foodName}</h3>
                <p class="text-sm text-green-600">
                    Based on your food preference selection
                </p>
                <div id="sorting-status" class="text-xs text-green-500 mt-2">
                    🔄 Calculating distances and sorting by nearest...
                </div>
            `;
            resultsDiv.appendChild(summary);

            // Sort results by distance using Routes API
            sortFoodPreferenceResultsByDistance(results.slice(0, 10), foodName);
        }

        // Sort food preference results by actual driving distance using Routes API
        async function sortFoodPreferenceResultsByDistance(results, foodName) {
            const resultsDiv = document.getElementById('search-results');
            const statusDiv = document.getElementById('sorting-status');

            try {
                // Calculate distances for all results
                const resultsWithDistance = await Promise.all(
                    results.map(async (place, index) => {
                        try {
                            const distance = await calculateDrivingDistance(place.geometry.location);
                            return {
                                ...place,
                                drivingDistance: distance.distance,
                                drivingDuration: distance.duration,
                                distanceText: distance.distanceText,
                                durationText: distance.durationText
                            };
                        } catch (error) {
                            console.warn(`Failed to calculate distance for ${place.name}:`, error);
                            return {
                                ...place,
                                drivingDistance: Infinity, // Put at end if calculation fails
                                drivingDuration: Infinity,
                                distanceText: 'Distance unavailable',
                                durationText: 'Time unavailable'
                            };
                        }
                    })
                );

                // Sort by driving distance
                resultsWithDistance.sort((a, b) => a.drivingDistance - b.drivingDistance);

                // Update status
                if (statusDiv) {
                    statusDiv.innerHTML = `✅ Sorted by nearest driving distance`;
                }

                // Display sorted results
                await displaySortedFoodPreferenceResults(resultsWithDistance, foodName);

            } catch (error) {
                console.error('Error sorting food preference results by distance:', error);
                if (statusDiv) {
                    statusDiv.innerHTML = `⚠️ Using default order (distance calculation failed)`;
                }
                // Fallback to original order
                await displaySortedFoodPreferenceResults(results.map(place => ({
                    ...place,
                    drivingDistance: 0,
                    drivingDuration: 0,
                    distanceText: 'Distance unavailable',
                    durationText: 'Time unavailable'
                })), foodName);
            }
        }

