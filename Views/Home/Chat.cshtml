            if (currentRestaurantIndex <= 0 || currentRestaurantList.length === 0) return;
            
            currentRestaurantIndex--;
            const restaurant = currentRestaurantList[currentRestaurantIndex];
            
            // Handle different data structures for search vs favorites
            let restaurantData = restaurant;
            if (currentListType === 'favorites' && restaurant.placeId) {
                // For favorites, we need to fetch the complete place details
                showRestaurantCard(restaurant.placeId, restaurant.name, currentRestaurantIndex, 'favorites');
                return;
            }
            
            // Update the current restaurant details
            currentRestaurantDetails = restaurantData;
            
            // Populate the top card with the new restaurant
            populateTopRestaurantCard(restaurantData, true);
            
            // Update the restaurant details panel if it's open - SYNCHRONIZATION FIX
            const detailsPanel = document.getElementById('restaurant-details-panel');
            if (detailsPanel && detailsPanel.style.display === 'flex') {
                displayRestaurantDetails(restaurantData);
            }
            
            // Highlight the selected card in the list
            highlightSelectedRestaurantCard(currentRestaurantIndex);
            
            // Center map on the new restaurant
