                `;
                
                // Add hover effect with brand color shadow
                card.addEventListener('mouseenter', () => {
                    card.style.boxShadow = '0 8px 24px rgba(254,57,92,0.2), 0 4px 12px rgba(0,0,0,0.08)';
                    card.style.transform = 'translateY(-4px)';
                });

                card.addEventListener('mouseleave', () => {
                    card.style.boxShadow = '0 2px 12px rgba(254,57,92,0.1)';
                    card.style.transform = 'translateY(0)';
                });
                
                // Add carousel functionality if multiple images
                if (imageUrls.length > 1) {
                    const carousel = card.querySelector('.fav-image-carousel');
                    const indicators = card.querySelectorAll('.fav-carousel-indicator');
                    let currentIndex = 0;
                    let autoSlideInterval;
                    
                    const updateCarousel = (index) => {
                        currentIndex = index;
                        carousel.style.transform = `translateX(-${index * 100}%)`;
                        carousel.dataset.index = index;
                        
                        indicators.forEach((ind, idx) => {
                            ind.style.background = idx === index ? '#FE395C' : 'rgba(255,255,255,0.5)';
                            ind.style.width = idx === index ? '1.25rem' : '0.5rem';
                        });
                    };
                    
                    const startAutoSlide = () => {
                        autoSlideInterval = setInterval(() => {
                            const nextIndex = (currentIndex + 1) % imageUrls.length;
                            updateCarousel(nextIndex);
                        }, 3000);
                    };
                    
                    const stopAutoSlide = () => {
                        clearInterval(autoSlideInterval);
                    };
                    
                    indicators.forEach((indicator, idx) => {
                        indicator.addEventListener('click', (e) => {
                            e.stopPropagation();
                            stopAutoSlide();
                            updateCarousel(idx);
                            startAutoSlide();
                        });
                    });
                    
                    card.addEventListener('mouseenter', startAutoSlide);
                    card.addEventListener('mouseleave', stopAutoSlide);
                }
                
                // Add button hover effects
                card.querySelectorAll('.action-btn').forEach(btn => {
                    btn.addEventListener('mouseenter', function() {
                        this.style.transform = 'translateY(-2px)';
                        if (this.classList.contains('favorite-heart-btn')) {
                            this.style.boxShadow = '0 4px 8px rgba(254,57,92,0.2)';
                        } else if (this.classList.contains('share-btn')) {
                            this.style.background = 'rgba(25,110,243,0.1)';
                            this.style.boxShadow = '0 4px 8px rgba(25,110,243,0.15)';
                        } else if (this.classList.contains('directions-btn')) {
                            this.style.boxShadow = '0 4px 12px rgba(247,179,43,0.35)';
                        }
                    });
                    
                    btn.addEventListener('mouseleave', function() {
                        this.style.transform = 'translateY(0)';
                        if (this.classList.contains('favorite-heart-btn')) {
                            this.style.boxShadow = 'none';
                        } else if (this.classList.contains('share-btn')) {
                            this.style.background = 'rgba(25,110,243,0.05)';
                            this.style.boxShadow = 'none';
                        } else if (this.classList.contains('directions-btn')) {
                            this.style.boxShadow = '0 2px 4px rgba(247,179,43,0.2)';
                        }
                    });
                });
                
                card.addEventListener('click', () => {
                    if (location) {
                        map.setCenter(location);
                        map.setZoom(16);
                        updateLastViewed(favorite.placeId);
                    }
                    showRestaurantCard(favorite.placeId, favorite.name, index, 'favorites');
                });
                
                container.appendChild(card);
            });
            
            container.appendChild(document.createElement('div')); // Placeholder until details load
            
            // Add marker to map
            if (location) {
                const marker = new google.maps.Marker({
                    position: location,
                    map: map,
                    title: favorite.name,
                    icon: {
                        url: '/images/MapPinLine.svg',
                        scaledSize: new google.maps.Size(32, 32)
                    },
                    animation: google.maps.Animation.DROP
                });
                
                const closeId = `fav-iw-close-${favorite.placeId}`;
                const contentHtml = `
                    <div style="background:#47682C; padding:10px 14px; border-radius:6px; position:relative; color:#FFFFFF; font-weight:600;">
                        <div style="display:flex; align-items:center; justify-content:space-between; gap:12px;">
                            <span style="font-size:14px;">${escapeHtml(favorite.name || '')}</span>
                            <button id="${closeId}" style="background:transparent; border:none; font-weight:700; color:#FFFFFF; cursor:pointer;">×</button>
                        </div>
                        <div style="position:absolute; left:24px; bottom:-10px; width:0; height:0; border-left:10px solid transparent; border-right:10px solid transparent; border-top:10px solid #47682C;"></div>
                    </div>`;
                const infoWindow = new google.maps.InfoWindow({ content: contentHtml, shouldFocus: false });
                
                marker.addListener('click', () => {
                    // Don't close other InfoWindows - keep them all open
                    // Just ensure this one is open (in case user closed it)
                    if (!infoWindow.getMap()) {
                        infoWindow.open(map, marker);
                        
                        // Add close button listener after InfoWindow opens
                        google.maps.event.addListenerOnce(infoWindow, 'domready', () => {
                            const closeBtn = document.getElementById(closeId);
                            if (closeBtn) {
                                closeBtn.addEventListener('click', () => {
                                    infoWindow.close();
                                });
                            }
                        });
                    }
                    
                    updateLastViewed(favorite.placeId);
                    // Open restaurant details panel
                    showRestaurantDetails(favorite.placeId, favorite.name);
                });
                
                // Automatically open the InfoWindow when favorites panel is displayed
                infoWindow.open(map, marker);
                
                // Add close button listener for auto-opened InfoWindow
                google.maps.event.addListenerOnce(infoWindow, 'domready', () => {
                    const closeBtn = document.getElementById(closeId);
                    if (closeBtn) {
                        closeBtn.addEventListener('click', () => {
                            infoWindow.close();
                        });
                    }
                });
                
                favoritesMarkers.push(marker);
                favoritesInfoWindows.push(infoWindow);
            }
        }

