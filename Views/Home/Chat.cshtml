            const arrow = document.getElementById('tour-arrow');
            
            if (!arrowTargetSelector) {
                arrow.style.opacity = '0';
                return;
            }

            // Try to find the arrow target element
            let arrowTargetElement = null;
            
            // Handle different selector types
            if (arrowTargetSelector === '.result-item:first-child') {
                arrowTargetElement = document.querySelector('.result-item');
            } else if (arrowTargetSelector === '#proactive-chip-list') {
                // Try to find the first proactive chip button
                const chipList = document.querySelector(arrowTargetSelector);
                if (chipList) {
                    arrowTargetElement = chipList.querySelector('button') || chipList.firstElementChild;
                }
                // If no chips found, hide arrow
                if (!arrowTargetElement) {
                    arrow.style.opacity = '0';
                    return;
                }
            } else {
                arrowTargetElement = document.querySelector(arrowTargetSelector);
            }

            if (!arrowTargetElement) {
                arrow.style.opacity = '0';
                return;
            }

            const pos = getElementPosition(arrowTargetElement);
            const arrowOffset = 50;

            const arrowIcon = arrow.querySelector('div');
            if (typeof currentTourStep !== 'undefined' && currentTourStep === 2) {
                // Step 3: Place arrow to the RIGHT of the SEARCH PANEL and point LEFT
                const searchPanel = document.querySelector('#search-panel');
                if (searchPanel) {
                    const panelRect = searchPanel.getBoundingClientRect();
                    arrow.style.left = (panelRect.right + arrowOffset) + 'px';
                    // align vertically with the first result item
                    arrow.style.top = (pos.centerY - 40) + 'px';
                    if (arrowIcon) { 
                        arrowIcon.textContent = '➜';
                        arrowIcon.style.transform = 'scaleX(-1)';
                    }
                } else {
                    // Fallback to default behavior if panel not found
                    arrow.style.left = (pos.left - arrowOffset) + 'px';
                    arrow.style.top = (pos.centerY - 40) + 'px';
                    if (arrowIcon) { 
                        arrowIcon.textContent = '➜';
                        arrowIcon.style.transform = 'none';
                    }
                }
            } else {
                // Default: place arrow to the LEFT of the element, pointing RIGHT
                arrow.style.left = (pos.left - arrowOffset) + 'px';
                arrow.style.top = (pos.centerY - 40) + 'px';
                if (arrowIcon) { 
                    arrowIcon.textContent = '➜';
                    arrowIcon.style.transform = 'none';
                }
            }

            arrow.style.opacity = '1';
        }

        // Position tooltip based on target element and position preference
        function positionTooltip(targetElement, position) {
            const tooltip = document.getElementById('tour-tooltip');
            const highlight = document.getElementById('tour-highlight');
            
            if (!targetElement) {
                // Center position
                tooltip.style.top = '50%';
                tooltip.style.left = '50%';
                tooltip.style.transform = 'translate(-50%, -50%)';
                highlight.style.opacity = '0';
                return;
            }

            const pos = getElementPosition(targetElement);
            const padding = 20;
            
            // Temporarily make tooltip visible to measure it
            const wasVisible = tooltip.style.opacity !== '0';
            if (!wasVisible) {
                tooltip.style.opacity = '0';
                tooltip.style.visibility = 'hidden';
                tooltip.style.display = 'block';
            }
            
            const tooltipRect = tooltip.getBoundingClientRect();
            const tooltipWidth = tooltipRect.width || 400;
            const tooltipHeight = tooltipRect.height || 300;

            // Set highlight position
            highlight.style.left = (pos.left - 10) + 'px';
            highlight.style.top = (pos.top - 10) + 'px';
            highlight.style.width = (pos.width + 20) + 'px';
            highlight.style.height = (pos.height + 20) + 'px';
            highlight.style.opacity = '1';

            // Position tooltip
            let tooltipTop, tooltipLeft;
            
            switch(position) {
                case 'top':
                    tooltipTop = pos.top - tooltipHeight - padding;
                    tooltipLeft = pos.centerX - tooltipWidth / 2;
                    break;
                case 'bottom':
                    tooltipTop = pos.bottom + padding;
                    tooltipLeft = pos.centerX - tooltipWidth / 2;
                    break;
                case 'left':
                    tooltipTop = pos.centerY - tooltipHeight / 2;
                    tooltipLeft = pos.left - tooltipWidth - padding;
                    break;
                case 'right':
                    tooltipTop = pos.centerY - tooltipHeight / 2;
                    tooltipLeft = pos.right + padding;
                    break;
                default: // center
                    tooltipTop = pos.centerY - tooltipHeight / 2;
                    tooltipLeft = pos.centerX - tooltipWidth / 2;
            }

            // Keep tooltip within viewport
            const maxLeft = window.innerWidth - tooltipWidth - padding;
            const maxTop = window.innerHeight - tooltipHeight - padding;
            tooltipLeft = Math.max(padding, Math.min(tooltipLeft, maxLeft));
            tooltipTop = Math.max(padding, Math.min(tooltipTop, maxTop));

            tooltip.style.top = tooltipTop + 'px';
            tooltip.style.left = tooltipLeft + 'px';
            tooltip.style.transform = 'translate(0, 0)';
            
            if (!wasVisible) {
                tooltip.style.visibility = 'visible';
            }
        }

        // Update tour step
        function updateTourStep(stepIndex) {
            if (stepIndex < 0 || stepIndex >= tourSteps.length) {
                endTour();
                return;
            }

            currentTourStep = stepIndex;
            const step = tourSteps[stepIndex];
            
            // Update content
            document.getElementById('tour-step-number').textContent = stepIndex + 1;
            document.getElementById('tour-step-title').textContent = step.title;
            document.getElementById('tour-current-step').textContent = stepIndex + 1;
            document.getElementById('tour-total-steps').textContent = tourSteps.length;
            document.getElementById('tour-content').innerHTML = step.content;

            // Update button visibility
            const prevBtn = document.getElementById('tour-prev');
            const nextBtn = document.getElementById('tour-next');
            const finishBtn = document.getElementById('tour-finish');
            const backdrop = document.getElementById('tour-backdrop');

            prevBtn.style.display = stepIndex === 0 ? 'none' : 'inline-block';
            
            if (stepIndex === tourSteps.length - 1) {
                nextBtn.style.display = 'none';
                finishBtn.style.display = 'inline-block';
            } else {
                nextBtn.style.display = 'inline-block';
                finishBtn.style.display = 'none';
            }

            // Toggle backdrop background: on for Step 1, off for subsequent steps
            if (backdrop) {
                if (stepIndex === 0) {
                    backdrop.style.background = 'rgba(0,0,0,0.7)';
                } else {
                    backdrop.style.background = 'transparent';
                }
            }

            // Handle special cases - open panels if needed
            if (step.target === '#search-panel') {
                // Open search panel if it's closed
                const searchPanel = document.querySelector('#search-panel');
                if (searchPanel && searchPanel.style.transform === 'translateX(-100%)') {
                    // Temporarily open it for the tour
                    searchPanel.style.transform = 'translateX(0)';
                }
            }
            
            // Position tooltip
            const targetElement = step.target ? document.querySelector(step.target) : null;
            
            // If target element doesn't exist, show centered tooltip
            if (!targetElement && step.target) {
                console.warn('Tour target element not found:', step.target);
                positionTooltip(null, 'center');
            } else {
                positionTooltip(targetElement, step.position);
            }

            // Position arrow pointing to clickable element
            if (step.arrowTarget) {
                // Use setTimeout to ensure DOM is ready, especially for dynamically loaded content
                setTimeout(() => {
                    positionArrow(step.arrowTarget);
                }, 200);
            } else {
                positionArrow(null);
            }

            // Show tooltip with animation
            const tooltip = document.getElementById('tour-tooltip');
            // Enable pointer events and visibility when showing tooltip
            tooltip.style.display = 'block';
            tooltip.style.visibility = 'visible';
            tooltip.style.pointerEvents = 'auto';
            setTimeout(() => {
                tooltip.style.opacity = '1';
                if (!targetElement) {
                    tooltip.style.transform = 'translate(-50%, -50%)';
                } else {
                    // Transform will be set by positionTooltip
                }
            }, 150);
        }

        // Start tour
        function startTour() {
            isTourActive = true;
            const overlay = document.getElementById('tour-overlay');
            overlay.style.display = 'block';
            // Allow interaction with the app behind the overlay
            overlay.style.pointerEvents = 'none';

            // Ensure tooltip is clickable by placing it at document.body level
            const tooltip = document.getElementById('tour-tooltip');
            if (tooltip && tooltip.parentElement !== document.body) {
                try { document.body.appendChild(tooltip); } catch (_) {}
            }
            // Guarantee tooltip stays above overlay and receives events
            if (tooltip) {
                tooltip.style.zIndex = '10002';
                tooltip.style.position = 'fixed';
                tooltip.style.pointerEvents = 'auto';
            }

            currentTourStep = 0;
            updateTourStep(0);
        }

        // End tour
        function endTour() {
            isTourActive = false;
            const overlay = document.getElementById('tour-overlay');
            const tooltip = document.getElementById('tour-tooltip');
            const highlight = document.getElementById('tour-highlight');
            const backdrop = document.getElementById('tour-backdrop');
            
            tooltip.style.opacity = '0';
            tooltip.style.pointerEvents = 'none';
            
            tooltip.style.visibility = 'hidden';
            highlight.style.opacity = '0';
            
            // Restore search panel state if it was opened just for tour
            const searchPanel = document.querySelector('#search-panel');
            // Note: We don't force-close it as the user might want it open
            
            setTimeout(() => {
                overlay.style.display = 'none';
                overlay.style.pointerEvents = 'none';
                // Ensure tooltip is completely hidden and doesn't block interactions
                tooltip.style.display = 'none';
                tooltip.style.pointerEvents = 'none';
            }, 400);

            // Ensure backdrop is cleared when tour ends
            if (backdrop) {
                backdrop.style.background = 'transparent';
            }

            markTourCompleted();
        }

        // === INLINE RESTAURANT EDITING FUNCTIONS ===
        
        // Toggle edit mode for restaurant details
        function toggleEditMode(placeId) {
            const editBtn = document.getElementById(`edit-btn-${placeId}`);
            const editControls = document.getElementById(`edit-controls-${placeId}`);
            
            if (!editControls) return;
            
            const isEditing = editControls.style.display !== 'none';
            
            if (isEditing) {
                // Cancel edit mode
                cancelRestaurantEdit(placeId);
            } else {
                // Enter edit mode
                editControls.style.display = 'flex';
                
                // Name uses a single fixed display id (top details card)
                const nameDisplay = document.getElementById('restaurant-name-display');
                const nameEdit = document.getElementById(`name-edit-${placeId}`);
                if (nameDisplay && nameEdit) {
                    nameDisplay.style.display = 'none';
                    nameEdit.style.display = 'block';
                    try { nameEdit.focus(); } catch (_) {}
                }
                
                // Show edit inputs, hide displays (and unhide optional sections so user can add missing info)
                const fields = ['address', 'phone', 'website', 'description', 'cuisine', 'price', 'serviceoptions', 'popularfor', 'menuitems'];
                fields.forEach(field => {
                    const section = document.getElementById(`${field}-section-${placeId}`);
                    if (section && (section.style.display === 'none' || getComputedStyle(section).display === 'none')) {
                        section.dataset.fsWasHidden = '1';
                        section.style.display = (field === 'description' || field === 'serviceoptions' || field === 'popularfor' || field === 'menuitems') ? 'block' : 'flex';
                    }
                    
                    const display = document.getElementById(`${field}-display-${placeId}`);
                    const edit = document.getElementById(`${field}-edit-${placeId}`);
                    if (display) display.style.display = 'none';
                    if (edit) edit.style.display = (field === 'description') ? 'block' : 'block';
                });

                const menuHelp = document.getElementById(`menuitems-help-${placeId}`);
                if (menuHelp) menuHelp.style.display = 'block';

                const menuBuilder = document.getElementById(`menuitems-tagbuilder-${placeId}`);
                if (menuBuilder) {
                    ensureMenuTagCheckboxesPopulated(placeId);
                    menuBuilder.style.display = 'block';
                }

                const socialEdit = document.getElementById(`social-edit-${placeId}`);
                if (socialEdit) socialEdit.style.display = 'flex';
                
                // Update button to show cancel icon
                if (editBtn) {
                    editBtn.innerHTML = `
                        <svg style="width:1rem; height:1rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    `;
                    editBtn.title = 'Cancel Edit';
                }
            }
        }
        
        // Save restaurant edit
        async function saveRestaurantEdit(placeId) {
            try {
                // Get edited restaurant name
                const nameEdit = document.getElementById(`name-edit-${placeId}`);
                const name = nameEdit ? nameEdit.value.trim() : '';
                
                if (!name) {
                    alert('Restaurant name is required.');
                    return;
                }
                
                // Collect edited values
                const editData = {
                    placeId: placeId,
                    name: name,
                    address: document.getElementById(`address-edit-${placeId}`)?.value || '',
                    phoneNumber: document.getElementById(`phone-edit-${placeId}`)?.value || '',
                    website: document.getElementById(`website-edit-${placeId}`)?.value || '',
                    description: document.getElementById(`description-edit-${placeId}`)?.value || '',
                    cuisineType: document.getElementById(`cuisine-edit-${placeId}`)?.value || '',
                    priceRange: document.getElementById(`price-edit-${placeId}`)?.value || '',
                    openingHours: '',
                    specialFeatures: '',
                    facebookUrl: normalizeExternalUrl(document.getElementById(`facebook-edit-${placeId}`)?.value || ''),
                    instagramUrl: normalizeExternalUrl(document.getElementById(`instagram-edit-${placeId}`)?.value || ''),
                    serviceOptions: document.getElementById(`serviceoptions-edit-${placeId}`)?.value || '',
                    popularFor: document.getElementById(`popularfor-edit-${placeId}`)?.value || '',
                    menuItemsAndIngredients: document.getElementById(`menuitems-edit-${placeId}`)?.value || ''
                };
                
                // Submit edit via API
                const response = await fetch('/api/RestaurantEdit/create', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(editData)
                });

                const contentType = response.headers.get('content-type') || '';
                const responseBody = contentType.includes('application/json')
                    ? await response.json()
                    : await response.text();
                
                if (response.ok) {
                    const result = responseBody;
                    
                    // Update display values
                    updateDisplayValues(placeId, editData);
                    
                    // Exit edit mode
                    cancelRestaurantEdit(placeId);
                    
                    // Show success message
                    alert('Your edit has been submitted successfully! ' + 
                          (result.status === 'Current' ? 'It has been automatically approved.' : 'It is pending approval.'));
                    
                    // Reload restaurant details to show updated version info
                    if (currentRestaurantDetails) {
                        displayRestaurantDetails(currentRestaurantDetails);
                    }
                } else {
                    console.error('Failed to save restaurant edit:', response.status, responseBody);
                    const message = (responseBody && typeof responseBody === 'object' && responseBody.message)
                        ? responseBody.message
                        : `Request failed (${response.status}). Please try again.`;
                    alert('Failed to save edit: ' + message);
                }
            } catch (error) {
                console.error('Error saving restaurant edit:', error);
                alert('An error occurred while saving your edit. Please try again.');
            }
        }
        
        // Cancel restaurant edit
        function cancelRestaurantEdit(placeId) {
            const editBtn = document.getElementById(`edit-btn-${placeId}`);
            const editControls = document.getElementById(`edit-controls-${placeId}`);
            
            if (!editControls) return;
            
            // Hide edit controls
            editControls.style.display = 'none';
            
            // Restore name display/input
            const nameDisplay = document.getElementById('restaurant-name-display');
            const nameEdit = document.getElementById(`name-edit-${placeId}`);
            if (nameDisplay) nameDisplay.style.display = 'block';
            if (nameEdit) nameEdit.style.display = 'none';
            
            // Show displays, hide edit inputs (and re-hide sections that were originally hidden)
            const fields = ['address', 'phone', 'website', 'description', 'cuisine', 'price', 'serviceoptions', 'popularfor', 'menuitems'];
            fields.forEach(field => {
                const display = document.getElementById(`${field}-display-${placeId}`);
                const edit = document.getElementById(`${field}-edit-${placeId}`);
                if (display) display.style.display = (field === 'menuitems') ? 'flex' : 'block';
                if (edit) edit.style.display = 'none';
                
                const section = document.getElementById(`${field}-section-${placeId}`);
                if (section && section.dataset.fsWasHidden === '1') {
                    section.style.display = 'none';
                    delete section.dataset.fsWasHidden;
                }
            });

            const menuHelp = document.getElementById(`menuitems-help-${placeId}`);
            if (menuHelp) menuHelp.style.display = 'none';

            const menuBuilder = document.getElementById(`menuitems-tagbuilder-${placeId}`);
            if (menuBuilder) {
                menuBuilder.style.display = 'none';
                try { clearMenuItemBuilder(placeId); } catch (_) { }
            }

            const socialEdit = document.getElementById(`social-edit-${placeId}`);
            if (socialEdit) socialEdit.style.display = 'none';
            
            // Reset button to edit icon
            if (editBtn) {
                editBtn.innerHTML = `
                    <svg style="width:1rem; height:1rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                `;
                editBtn.title = 'Edit Restaurant';
            }
        }
        
        // Update display values after edit
        function updateDisplayValues(placeId, data) {
            const nameDisplay = document.getElementById(`restaurant-name-display`);
            const addressDisplay = document.getElementById(`address-display-${placeId}`);
            const phoneDisplay = document.getElementById(`phone-display-${placeId}`);
            const websiteDisplay = document.getElementById(`website-display-${placeId}`);
            const descriptionDisplay = document.getElementById(`description-display-${placeId}`);
            const cuisineDisplay = document.getElementById(`cuisine-display-${placeId}`);
            const priceDisplay = document.getElementById(`price-display-${placeId}`);
            const serviceOptionsDisplay = document.getElementById(`serviceoptions-display-${placeId}`);
            const serviceOptionsText = document.getElementById(`serviceoptions-text-${placeId}`);
            const popularForDisplay = document.getElementById(`popularfor-display-${placeId}`);
            const popularForText = document.getElementById(`popularfor-text-${placeId}`);
            const menuItemsDisplay = document.getElementById(`menuitems-display-${placeId}`);
            const facebookLink = document.getElementById(`facebook-link-${placeId}`);
            const instagramLink = document.getElementById(`instagram-link-${placeId}`);
            
            if (nameDisplay && data.name) nameDisplay.textContent = data.name;
            if (addressDisplay && data.address) addressDisplay.textContent = data.address;
            if (phoneDisplay && data.phoneNumber) phoneDisplay.textContent = data.phoneNumber;
            if (websiteDisplay && data.website) {
                websiteDisplay.href = data.website;
                websiteDisplay.textContent = data.website;
            }
            if (descriptionDisplay && data.description) descriptionDisplay.textContent = data.description;
            if (cuisineDisplay && data.cuisineType) cuisineDisplay.textContent = data.cuisineType;
            if (priceDisplay && data.priceRange) priceDisplay.textContent = data.priceRange;

            if (serviceOptionsText) {
                serviceOptionsText.innerHTML = listTextToInlineHtml(data.serviceOptions || '', { fontWeight: '700' });
            } else if (serviceOptionsDisplay) {
                serviceOptionsDisplay.innerHTML = listTextToInlineHtml(data.serviceOptions || '');
            }
            if (popularForText) {
                popularForText.innerHTML = listTextToInlineHtml(data.popularFor || '', { fontWeight: '700' });
            } else if (popularForDisplay) {
                // Fallback for older markup
                popularForDisplay.innerHTML = listTextToInlineHtml(data.popularFor || '');
            }
            if (menuItemsDisplay) {
                menuItemsDisplay.innerHTML = menuTextToDetailsHtml(data.menuItemsAndIngredients || '', placeId);
            }

            // Refresh dietary tags highlight if present
            try { renderDietaryTagsInDetails(placeId); } catch (_) {}

            if (facebookLink) {
                const fb = normalizeExternalUrl(data.facebookUrl || '');
                const has = !!fb;
                facebookLink.href = has ? fb : '#';
                facebookLink.style.opacity = has ? '1' : '0.35';
                facebookLink.style.pointerEvents = has ? 'auto' : 'none';
                facebookLink.title = has ? 'Open Facebook' : 'Facebook link not set';
                facebookLink.target = '_blank';
                facebookLink.rel = 'noopener noreferrer';
            }
            if (instagramLink) {
                const ig = normalizeExternalUrl(data.instagramUrl || '');
                const has = !!ig;
                instagramLink.href = has ? ig : '#';
                instagramLink.style.opacity = has ? '1' : '0.35';
                instagramLink.style.pointerEvents = has ? 'auto' : 'none';
                instagramLink.title = has ? 'Open Instagram' : 'Instagram link not set';
                instagramLink.target = '_blank';
                instagramLink.rel = 'noopener noreferrer';
            }
        }

        // Event listeners
        document.addEventListener('DOMContentLoaded', function() {
            const tourButton = document.getElementById('tour-button');
            const tourOverlay = document.getElementById('tour-overlay');
            const tourClose = document.getElementById('tour-close');
            const tourSkip = document.getElementById('tour-skip');
            const tourPrev = document.getElementById('tour-prev');
            const tourNext = document.getElementById('tour-next');
            const tourFinish = document.getElementById('tour-finish');
            const disclaimerModal = document.getElementById('disclaimer-modal');
            const disclaimerClose = document.getElementById('disclaimer-close');
            const disclaimerAccept = document.getElementById('disclaimer-accept');
            const disclaimerTour = document.getElementById('disclaimer-tour');

            if (tourButton) {
                tourButton.addEventListener('click', startTour);
            }

            if (tourClose) {
                tourClose.addEventListener('click', endTour);
            }

            if (tourSkip) {
                tourSkip.addEventListener('click', endTour);
            }

            if (tourPrev) {
                tourPrev.addEventListener('click', () => {
                    if (currentTourStep > 0) {
                        updateTourStep(currentTourStep - 1);
                    }
                });
            }

            if (tourNext) {
                tourNext.addEventListener('click', () => {
                    if (currentTourStep < tourSteps.length - 1) {
                        updateTourStep(currentTourStep + 1);
                    }
                });
            }

            if (tourFinish) {
                tourFinish.addEventListener('click', endTour);
            }

            // Close on backdrop click
            if (tourOverlay) {
                tourOverlay.addEventListener('click', (e) => {
                    if (e.target.id === 'tour-backdrop' || e.target.id === 'tour-overlay') {
                        endTour();
                    }
                });
            }

            // Close on Escape key
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && isTourActive) {
                    endTour();
                }
            });

            function getDisclaimerStorageKey(userId) {
                return 'foodiesaur_disclaimer_accepted_v1_' + (userId || 'auth');
            }

            function hasAcceptedDisclaimer(userId) {
                const key = getDisclaimerStorageKey(userId);
                try {
                    return localStorage.getItem(key) === 'true' || sessionStorage.getItem(key) === 'true';
                } catch (e) {
                    return false;
                }
            }

            function setAcceptedDisclaimer(userId) {
                const key = getDisclaimerStorageKey(userId);
                try { localStorage.setItem(key, 'true'); } catch (e) { /* ignore */ }
                try { sessionStorage.setItem(key, 'true'); } catch (e) { /* ignore */ }
            }

            function showDisclaimer() {
                if (!disclaimerModal) return;
                disclaimerModal.style.display = 'flex';
            }

            function hideDisclaimer() {
                if (!disclaimerModal) return;
                disclaimerModal.style.display = 'none';
            }

            if (disclaimerClose) disclaimerClose.addEventListener('click', hideDisclaimer);
            if (disclaimerModal) {
                disclaimerModal.addEventListener('click', (e) => {
                    if (e.target === disclaimerModal) hideDisclaimer();
                });
            }

            // Auto-start: show disclaimer first for logged-in users; keep tour auto-start for guests
            (function () {
                var isAuthenticated = @User.Identity.IsAuthenticated.ToString().ToLower();
                if (!isAuthenticated) {
                    setTimeout(function () { startTour(); }, 300);
                    return;
                }

                var userId = '@(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "auth")';
                if (!hasAcceptedDisclaimer(userId)) {
                    setTimeout(function () { showDisclaimer(); }, 250);
                }

                if (disclaimerAccept) {
                    disclaimerAccept.addEventListener('click', function () {
                        setAcceptedDisclaimer(userId);
                        hideDisclaimer();
                    });
                }

                if (disclaimerTour) {
                    disclaimerTour.addEventListener('click', function () {
                        setAcceptedDisclaimer(userId);
                        hideDisclaimer();
                        setTimeout(function () { startTour(); }, 250);
                    });
                }
            })();
        });
    </script>

