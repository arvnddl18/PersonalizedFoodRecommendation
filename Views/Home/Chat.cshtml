            </div>

            <div id="claim-modal-chat-alert" style="display:none; padding:0.75rem 1.25rem; border-bottom:1px solid #e5e7eb;"></div>

            <form id="claim-modal-chat-form" style="padding:1rem 1.25rem;" enctype="multipart/form-data">
                <input type="hidden" id="claimPlaceId" name="PlaceId" />

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;">
                    <div style="grid-column:1 / -1;">
                        <label style="display:block; font-weight:700; color:#47682C; font-size:0.875rem; margin-bottom:0.25rem;">Restaurant Name *</label>
                        <input id="claimRestaurantName" name="RestaurantName" required
                               style="width:100%; padding:0.5rem 0.75rem; border:1px solid #d1d5db; border-radius:0.5rem;" />
                    </div>
                    <div>
                        <label style="display:block; font-weight:700; color:#47682C; font-size:0.875rem; margin-bottom:0.25rem;">Business Name</label>
                        <input name="BusinessName" style="width:100%; padding:0.5rem 0.75rem; border:1px solid #d1d5db; border-radius:0.5rem;" />
                    </div>
                    <div>
                        <label style="display:block; font-weight:700; color:#47682C; font-size:0.875rem; margin-bottom:0.25rem;">Business Email</label>
                        <input name="BusinessEmail" type="email" style="width:100%; padding:0.5rem 0.75rem; border:1px solid #d1d5db; border-radius:0.5rem;" />
                    </div>
                    <div>
                        <label style="display:block; font-weight:700; color:#47682C; font-size:0.875rem; margin-bottom:0.25rem;">Business Phone</label>
                        <input name="BusinessPhone" style="width:100%; padding:0.5rem 0.75rem; border:1px solid #d1d5db; border-radius:0.5rem;" />
                    </div>
                    <div>
                        <label style="display:block; font-weight:700; color:#47682C; font-size:0.875rem; margin-bottom:0.25rem;">Business Address</label>
                        <textarea name="BusinessAddress" rows="2" style="width:100%; padding:0.5rem 0.75rem; border:1px solid #d1d5db; border-radius:0.5rem;"></textarea>
                    </div>
                    <div style="grid-column:1 / -1;">
                        <label style="display:block; font-weight:700; color:#47682C; font-size:0.875rem; margin-bottom:0.25rem;">Business License Document</label>
                        <input name="BusinessLicense" type="file" accept=".pdf,.jpg,.jpeg,.png" />
                        <div style="color:#6b7280; font-size:0.8125rem; margin-top:0.25rem;">PDF/JPG/PNG accepted.</div>
                    </div>
                    <div style="grid-column:1 / -1;">
                        <label style="display:block; font-weight:700; color:#47682C; font-size:0.875rem; margin-bottom:0.25rem;">Additional Notes</label>
                        <textarea name="AdditionalNotes" rows="3" style="width:100%; padding:0.5rem 0.75rem; border:1px solid #d1d5db; border-radius:0.5rem;"></textarea>
                    </div>
                </div>

                <div style="display:flex; justify-content:flex-end; gap:0.5rem; margin-top:1rem;">
                    <button type="button" onclick="closeClaimModalChat()"
                            style="padding:0.5rem 0.75rem; border-radius:0.5rem; border:1px solid #d1d5db; background:#f3f4f6; cursor:pointer;">
                        Cancel
                    </button>
                    <button id="claim-submit-btn" type="submit"
                            style="padding:0.5rem 0.75rem; border-radius:0.5rem; border:none; background:#F7B32B; color:#47682C; font-weight:800; cursor:pointer;">
                        Submit Claim
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        let claimModalChatPlaceId = null;

        function openClaimModalChat(placeId, restaurantName) {
            claimModalChatPlaceId = placeId;
            const modal = document.getElementById('claim-modal-chat');
            const alertBox = document.getElementById('claim-modal-chat-alert');
            if (alertBox) alertBox.style.display = 'none';

            document.getElementById('claimPlaceId').value = placeId;
            document.getElementById('claimRestaurantName').value = restaurantName || '';

            modal.style.display = 'flex';
        }

        function closeClaimModalChat() {
            const modal = document.getElementById('claim-modal-chat');
            const form = document.getElementById('claim-modal-chat-form');
            if (form) form.reset();
            modal.style.display = 'none';
            claimModalChatPlaceId = null;
        }

        document.getElementById('claim-modal-chat')?.addEventListener('click', (e) => {
            if (e.target && e.target.id === 'claim-modal-chat') closeClaimModalChat();
        });

        document.getElementById('claim-modal-chat-form')?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const form = e.target;
            const submitBtn = document.getElementById('claim-submit-btn');
            const alertBox = document.getElementById('claim-modal-chat-alert');

            const tokenInput = document.querySelector('#claim-antiforgery-form input[name="__RequestVerificationToken"]');
            const token = tokenInput ? tokenInput.value : null;

            const fd = new FormData(form);
            if (token) fd.append('__RequestVerificationToken', token);

            const placeId = fd.get('PlaceId');
            if (!placeId) return;

            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.style.opacity = '0.75';
                submitBtn.textContent = 'Submitting...';
            }

            try {
                const url = '@Url.Action("Claim", "Restaurant")' + `?placeId=${encodeURIComponent(placeId)}`;
                const resp = await fetch(url, {
                    method: 'POST',
                    body: fd,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin'
                });

                const isJson = (resp.headers.get('content-type') || '').includes('application/json');
                const payload = isJson ? await resp.json().catch(() => null) : null;

                if (resp.ok) {
                    if (alertBox) {
                        alertBox.style.display = 'block';
                        alertBox.style.background = '#ecfdf5';
                        alertBox.style.borderBottom = '1px solid #bbf7d0';
                        alertBox.innerHTML = `<div style="color:#166534; font-weight:700; font-size:0.875rem;">${escapeHtml(payload?.message || 'Claim submitted successfully.')}</div>`;
                    }

                    // Close after a short delay to let user read the message
                    setTimeout(() => {
                        closeClaimModalChat();
                    }, 900);

                    return;
                }

                const message = payload?.message || `Request failed (${resp.status}). Please try again.`;
                if (alertBox) {
                    alertBox.style.display = 'block';
                    alertBox.style.background = '#fef2f2';
                    alertBox.style.borderBottom = '1px solid #fecaca';
                    alertBox.innerHTML = `<div style="color:#991b1b; font-weight:700; font-size:0.875rem;">${escapeHtml(message)}</div>`;
                }
            } catch (err) {
                if (alertBox) {
                    alertBox.style.display = 'block';
                    alertBox.style.background = '#fef2f2';
                    alertBox.style.borderBottom = '1px solid #fecaca';
                    alertBox.innerHTML = `<div style="color:#991b1b; font-weight:700; font-size:0.875rem;">An error occurred. Please try again.</div>`;
                }
                console.error('Claim submission failed:', err);
            } finally {
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.style.opacity = '1';
                    submitBtn.textContent = 'Submit Claim';
                }
            }
        });
    </script>

    <!-- SignalR client for Direct Messages -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

    <!-- Direct Messages widget (map icon + expandable panel) -->
    <script>
        (function () {
            const isGuest = !!window.isGuest;
            const currentUserId = window.currentUserId;

            const btnToggle = document.getElementById('dm-toggle-btn');
            const panel = document.getElementById('dm-panel');
            const btnClose = document.getElementById('dm-close-btn');
            const btnBack = document.getElementById('dm-back-btn');
            const badge = document.getElementById('dm-control-badge');

            const inboxView = document.getElementById('dm-inbox-view');
            const threadView = document.getElementById('dm-thread-view');
            const listEl = document.getElementById('dm-conversation-list');
            const emptyEl = document.getElementById('dm-empty-state');
            const selectedBtn = document.getElementById('dm-message-selected-btn');
            const selectedHint = document.getElementById('dm-selected-hint');
            const threadTitle = document.getElementById('dm-thread-title');
            const threadSub = document.getElementById('dm-thread-sub');
            const msgsEl = document.getElementById('dm-messages');
            const inputEl = document.getElementById('dm-input');
            const sendBtn = document.getElementById('dm-send-btn');

            if (!btnToggle || !panel || !btnClose || !inboxView || !threadView || !listEl) return;

            let isOpen = false;
            let activeConversationId = null;
            let activePlaceId = null;
            let connection = null;
            let connectionStarted = false;

            const convoCache = new Map(); // conversationId -> convo
            const placeNameCache = new Map(); // placeId -> name
            const unreadByConvo = new Map(); // conversationId -> count

            function setBadgeCount(total) {
                if (!badge) return;
                if (!total || total <= 0) {
                    badge.style.display = 'none';
                    badge.textContent = '0';
                    return;
                }
                badge.style.display = 'flex';
                badge.textContent = String(Math.min(total, 99));
            }

            function totalUnread() {
                let t = 0;
                unreadByConvo.forEach(v => { t += (v || 0); });
                return t;
            }

            function showPanel() {
                panel.style.display = 'block';
                isOpen = true;
                showInbox();
                refreshSelectedHint();
                loadConversations();
                ensureConnection();

                // Restore last opened conversation so messages look "saved" on reopen
                try {
                    const lastId = parseInt(localStorage.getItem('dm:lastConversationId') || '', 10);
                    if (lastId && !Number.isNaN(lastId)) {
                        setTimeout(() => {
                            if (inboxView.style.display !== 'none') {
                                openConversation(lastId);
                            }
                        }, 60);
                    }
                } catch (_) { }
            }

            function hidePanel() {
                panel.style.display = 'none';
                isOpen = false;
            }

            function showInbox() {
                if (btnBack) btnBack.style.display = 'none';
                inboxView.style.display = 'flex';
                threadView.style.display = 'none';
                activeConversationId = null;
                activePlaceId = null;
            }

            function showThread() {
                if (btnBack) btnBack.style.display = 'inline-block';
                inboxView.style.display = 'none';
                threadView.style.display = 'flex';
            }

            function refreshSelectedHint() {
                if (!selectedHint) return;
                const pid = (window.currentRestaurantDetails && window.currentRestaurantDetails.place_id) ? window.currentRestaurantDetails.place_id : null;
                const name = (window.currentRestaurantDetails && window.currentRestaurantDetails.name) ? window.currentRestaurantDetails.name : null;
                if (pid && name) {
                    selectedHint.textContent = `Selected: ${name}`;
                } else {
                    selectedHint.textContent = 'Select a restaurant on the map, then tap the button.';
                }
            }

            async function getPlaceName(placeId) {
                const pid = String(placeId || '').trim();
                if (!pid) return 'Restaurant';
                if (placeNameCache.has(pid)) return placeNameCache.get(pid);
                try {
                    if (typeof fetchPlaceDetails === 'function') {
                        const place = await fetchPlaceDetails(pid);
                        const n = place?.name || 'Restaurant';
                        placeNameCache.set(pid, n);
                        return n;
                    }
                } catch (_) { /* ignore */ }
                return 'Restaurant';
            }

            async function loadConversations() {
                if (isGuest || currentUserId == null) return;
                try {
                    const res = await fetch('/api/directmessages/conversations', { credentials: 'same-origin' });
                    if (!res.ok) return;
                    const data = await res.json();
                    const items = Array.isArray(data?.items) ? data.items : [];

                    convoCache.clear();
                    items.forEach(c => convoCache.set(c.conversationId, c));

                    // Render list
                    listEl.innerHTML = '';
                    if (items.length === 0) {
                        if (emptyEl) emptyEl.style.display = 'block';
                        listEl.appendChild(emptyEl);
                        return;
                    }
                    if (emptyEl) emptyEl.style.display = 'none';

                    for (const c of items) {
                        const restaurantName = await getPlaceName(c.placeId);
                        const otherName = c.otherUserName || 'User';
                        const unread = unreadByConvo.get(c.conversationId) || 0;
                        const last = c.lastMessage || null;
                        const lastText = (last && last.body) ? String(last.body) : '';
                        const lastWhen = (last && last.sentAt) ? new Date(last.sentAt) : (c.lastMessageAt ? new Date(c.lastMessageAt) : null);
                        const whenText = lastWhen ? lastWhen.toLocaleString() : '';
                        const preview = lastText ? (lastText.slice(0, 70) + (lastText.length > 70 ? '…' : '')) : '';

                        const row = document.createElement('button');
                        row.type = 'button';
                        row.style.cssText = [
                            'display:flex',
                            'flex-direction:column',
                            'align-items:flex-start',
                            'gap:4px',
                            'padding:10px 12px',
                            'border-radius:12px',
                            'border:1px solid rgba(71,104,44,0.12)',
                            'background:#ffffff',
                            'cursor:pointer',
                            'text-align:left'
                        ].join(';');

                        row.innerHTML = `
                            <div style="width:100%; display:flex; align-items:center; justify-content:space-between; gap:8px;">
                                <div style="font-weight:900; color:#111827; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; max-width:245px;">
                                    ${escapeHtml(restaurantName)}
                                </div>
                                ${unread ? `<span style="min-width:22px; height:22px; border-radius:9999px; background:#47682C; color:white; font-weight:900; font-size:12px; display:flex; align-items:center; justify-content:center; padding:0 6px;">${Math.min(unread, 99)}</span>` : ''}
                            </div>
                            <div style="font-size:12px; color:#6b7280; display:flex; gap:6px; flex-wrap:wrap;">
                                <span>${escapeHtml(c.role || '')} chat</span>
                                <span>•</span>
                                <span>with ${escapeHtml(otherName)}</span>
                                ${whenText ? `<span>•</span><span>${escapeHtml(whenText)}</span>` : ``}
                            </div>
                            ${preview ? `<div style="font-size:12px; color:#374151; opacity:0.9; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; width:100%;">${escapeHtml(preview)}</div>` : `<div style="font-size:12px; color:#9ca3af;">No messages yet</div>`}
                        `;

                        row.addEventListener('click', () => openConversation(c.conversationId));
                        listEl.appendChild(row);
                    }
                } catch (err) {
                    console.warn('DM loadConversations failed', err);
                }
            }

            async function ensureConnection() {
                if (isGuest || currentUserId == null) return;
                if (connection && connectionStarted) return;
                if (!window.signalR) return;

                connection = new signalR.HubConnectionBuilder()
                    .withUrl('/hubs/directmessages', { withCredentials: true })
                    .withAutomaticReconnect()
                    .build();

                connection.on('message', (msg) => {
                    const cid = msg?.conversationId;
                    if (!cid) return;

                    // If this is the active thread, render it live
                    if (activeConversationId === cid) {
                        appendMessageBubble(msg);
                        scrollMessagesToBottom();
                        return;
                    }

                    // Otherwise count as unread
                    unreadByConvo.set(cid, (unreadByConvo.get(cid) || 0) + 1);
                    setBadgeCount(totalUnread());
                    // If panel open, refresh list to show unread badges
                    if (isOpen) loadConversations();
                });

                try {
                    await connection.start();
                    connectionStarted = true;
                } catch (err) {
                    console.warn('SignalR connect failed', err);
                }
            }

            function scrollMessagesToBottom() {
                if (!msgsEl) return;
                msgsEl.scrollTop = msgsEl.scrollHeight;
            }

            function appendMessageBubble(msg) {
                if (!msgsEl) return;
                const mine = (msg.senderUserId === currentUserId || String(msg.senderUserId) === String(currentUserId));
                const wrap = document.createElement('div');
                wrap.style.cssText = `display:flex; justify-content:${mine ? 'flex-end' : 'flex-start'};`;

                const bubble = document.createElement('div');
                bubble.style.cssText = [
                    'max-width:78%',
                    'padding:10px 12px',
                    'border-radius:14px',
                    mine ? 'border-top-right-radius:4px' : 'border-top-left-radius:4px',
                    mine ? 'background:linear-gradient(135deg, #47682C 0%, #5a823a 100%)' : 'background:#ffffff',
                    mine ? 'color:white' : 'color:#111827',
                    'border:1px solid rgba(71,104,44,0.12)',
                    'box-shadow:0 2px 8px rgba(0,0,0,0.06)'
                ].join(';');

                const who = msg.senderName ? `<div style="font-size:11px; opacity:${mine ? '0.85' : '0.7'}; font-weight:900; margin-bottom:4px;">${escapeHtml(msg.senderName)}</div>` : '';
                bubble.innerHTML = `${who}<div style="white-space:pre-wrap; word-break:break-word;">${escapeHtml(msg.body || '')}</div>`;

                wrap.appendChild(bubble);
                msgsEl.appendChild(wrap);
            }

            async function openConversation(conversationId) {
                if (isGuest || currentUserId == null) return;
                activeConversationId = conversationId;
                const c = convoCache.get(conversationId);
                activePlaceId = c?.placeId || null;

                // reset unread for this conversation
                unreadByConvo.set(conversationId, 0);
                setBadgeCount(totalUnread());

                const restaurantName = activePlaceId ? await getPlaceName(activePlaceId) : 'Restaurant';
                if (threadTitle) threadTitle.textContent = restaurantName;
                if (threadSub) threadSub.textContent = c?.otherUserName ? `with ${c.otherUserName}` : '';

                showThread();

                if (msgsEl) msgsEl.innerHTML = '';

                try {
                    const res = await fetch(`/api/directmessages/conversations/${conversationId}/messages?limit=200`, { credentials: 'same-origin' });
                    if (res.ok) {
                        const data = await res.json();
                        const messages = Array.isArray(data?.messages) ? data.messages : [];
                        messages.forEach(appendMessageBubble);
                        scrollMessagesToBottom();
                    }
                } catch (err) {
                    console.warn('DM openConversation history failed', err);
                }

                await ensureConnection();
                if (connection && connectionStarted) {
                    try {
                        await connection.invoke('JoinConversation', conversationId);
                    } catch (err) {
                        console.warn('JoinConversation failed', err);
                    }
                }

                try { localStorage.setItem('dm:lastConversationId', String(conversationId)); } catch (_) { }

                // refresh list badges if panel open
                if (isOpen) loadConversations();
            }

            async function sendActiveMessage() {
                if (isGuest || currentUserId == null) return;
                if (!activeConversationId) return;
                const text = (inputEl?.value || '').trim();
                if (!text) return;
                if (inputEl) inputEl.value = '';

                await ensureConnection();
                if (connection && connectionStarted) {
                    try {
                        await connection.invoke('SendMessage', activeConversationId, text);
                        return;
                    } catch (err) {
                        console.warn('Hub SendMessage failed; falling back to REST', err);
                    }
                }

                // Fallback REST
                try {
                    await fetch(`/api/directmessages/conversations/${activeConversationId}/messages`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'same-origin',
                        body: JSON.stringify({ body: text })
                    });
                } catch (err) {
                    console.warn('REST send message failed', err);
                }
            }

            async function messageSelectedRestaurant() {
                if (isGuest || currentUserId == null) return;
                const pid = (window.currentRestaurantDetails && window.currentRestaurantDetails.place_id) ? String(window.currentRestaurantDetails.place_id).trim() : '';
                if (!pid) {
                    refreshSelectedHint();
                    return;
                }

                try {
                    await window.openDmForPlaceId(pid, (window.currentRestaurantDetails && window.currentRestaurantDetails.name) ? String(window.currentRestaurantDetails.name) : 'Restaurant');
                } catch (err) {
                    console.warn('messageSelectedRestaurant failed', err);
                }
            }

            // Public API: open DM panel and start chat for a specific placeId
            window.openDmForPlaceId = async function (placeId, placeName) {
                const pid = String(placeId || '').trim();
                if (!pid) return;

                if (window.isGuest || window.currentUserId == null) {
                    if (typeof showLoginPrompt === 'function') showLoginPrompt();
                    else window.location.href = '/Auth/Login';
                    return;
                }

                if (!isOpen) showPanel();
                refreshSelectedHint();

                try {
                    const res = await fetch('/api/directmessages/conversations', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        credentials: 'same-origin',
                        body: JSON.stringify({ placeId: pid })
                    });
                    const payload = await res.json().catch(() => null);
                    if (!res.ok) {
                        const msg = payload?.message || 'Unable to start conversation.';
                        if (typeof showToast === 'function') showToast(msg);
                        else alert(msg);
                        return;
                    }

                    if (placeName) placeNameCache.set(pid, String(placeName));

                    await loadConversations();
                    if (payload?.conversationId) {
                        await openConversation(payload.conversationId);
                    }
                } catch (err) {
                    console.warn('openDmForPlaceId failed', err);
                }
            };

            // UI events
            btnToggle.addEventListener('click', function () {
                if (window.isGuest || window.currentUserId == null) {
                    if (typeof showLoginPrompt === 'function') showLoginPrompt();
                    else window.location.href = '/Auth/Login';
                    return;
                }
                if (!isOpen) showPanel(); else hidePanel();
            });

            btnClose.addEventListener('click', function () { hidePanel(); });
            if (btnBack) btnBack.addEventListener('click', function () { showInbox(); loadConversations(); });
            if (sendBtn) sendBtn.addEventListener('click', sendActiveMessage);
            if (selectedBtn) selectedBtn.addEventListener('click', messageSelectedRestaurant);

            // Keep CTA hint in sync when restaurant selection changes (best-effort)
            const origDisplayRestaurantDetails = window.displayRestaurantDetails;
            if (typeof origDisplayRestaurantDetails === 'function') {
                window.displayRestaurantDetails = function () {
                    const r = origDisplayRestaurantDetails.apply(this, arguments);
                    if (isOpen) refreshSelectedHint();
                    return r;
                };
            }

            // Initialize badge state
            setBadgeCount(0);
        })();
    </script>
    
    <!-- Load Google Maps API after initMap is defined -->
    <script src="https://maps.googleapis.com/maps/api/js?key=@Configuration[&quot;GoogleMaps:ApiKey&quot;]&libraries=places,routes&loading=async&callback=initMap" async defer></script>
}


