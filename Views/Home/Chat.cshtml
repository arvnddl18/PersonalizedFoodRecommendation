        function clearMenuItemBuilder(placeId) {
            const type = document.getElementById(`menuitem-type-${placeId}`);
            const name = document.getElementById(`menuitem-name-${placeId}`);
            const calories = document.getElementById(`menuitem-calories-${placeId}`);
            const serving = document.getElementById(`menuitem-serving-${placeId}`);
            const image = document.getElementById(`menuitem-image-${placeId}`);
            const imageFile = document.getElementById(`menuitem-image-file-${placeId}`);
            const imageStatus = document.getElementById(`menuitem-image-status-${placeId}`);
            const imagePreview = document.getElementById(`menuitem-image-preview-${placeId}`);
            const desc = document.getElementById(`menuitem-desc-${placeId}`);
            const tags = document.getElementById(`menuitem-tags-${placeId}`);
            if (type) type.value = '';
            if (name) name.value = '';
            if (calories) calories.value = '';
            if (serving) serving.value = '';
            if (image) image.value = '';
            if (imageFile) imageFile.value = '';
            if (imageStatus) { imageStatus.style.display = 'none'; imageStatus.textContent = ''; }
            if (imagePreview) { imagePreview.style.display = 'none'; imagePreview.src = ''; }
            if (desc) desc.value = '';
            if (tags) {
                Array.from(tags.querySelectorAll('input[type="checkbox"]') || []).forEach(cb => { cb.checked = false; });
            }
        }

        function addMenuItemLine(placeId) {
            try {
                const typeEl = document.getElementById(`menuitem-type-${placeId}`);
                const nameEl = document.getElementById(`menuitem-name-${placeId}`);
                const caloriesEl = document.getElementById(`menuitem-calories-${placeId}`);
                const servingEl = document.getElementById(`menuitem-serving-${placeId}`);
                const imageEl = document.getElementById(`menuitem-image-${placeId}`);
                const descEl = document.getElementById(`menuitem-desc-${placeId}`);
                const tagsEl = document.getElementById(`menuitem-tags-${placeId}`);
                const textarea = document.getElementById(`menuitems-edit-${placeId}`);

                if (!textarea) return;

                const type = (typeEl?.value || '').trim();
                const name = (nameEl?.value || '').trim();
                const caloriesRaw = (caloriesEl?.value || '').toString().trim();
                const serving = (servingEl?.value || '').trim();
                const imageRaw = (imageEl?.value || '').trim();
                const desc = (descEl?.value || '').trim();
                const selectedTags = tagsEl
                    ? Array.from(tagsEl.querySelectorAll('input[type="checkbox"]:checked') || []).map(cb => (cb.value || '').trim()).filter(Boolean)
                    : [];

                if (!name) {
                    alert('Please enter an item name.');
                    return;
                }

                let line = name;
                if (desc) line += ` - ${desc}`;
                if (type) line += ` [type: ${type}]`;
                if (caloriesRaw) {
                    const n = parseFloat(caloriesRaw);
                    if (Number.isFinite(n) && n >= 0) {
                        line += ` [cal: ${Math.round(n)} kcal]`;
                    }
                }
                if (serving) line += ` [serving: ${serving}]`;
                if (imageRaw) {
                    const img = normalizeMenuImageUrl(imageRaw);
                    if (!img) {
                        alert('Invalid image URL. Please use a normal http(s) link or a /path on this site.');
                        return;
                    }
                    line += ` [img: ${img}]`;
                }
                if (selectedTags.length > 0) line += ` [tags: ${selectedTags.join(', ')}]`;

                const current = (textarea.value || '').trimEnd();
                textarea.value = current ? `${current}\n${line}\n` : `${line}\n`;

                // Optional: quick visual confirmation in the display list if it's visible
                const display = document.getElementById(`menuitems-display-${placeId}`);
                if (display && getComputedStyle(display).display !== 'none') {
                    display.innerHTML = menuTextToDetailsHtml(textarea.value || '', placeId);
                }

                clearMenuItemBuilder(placeId);
                try { nameEl?.focus(); } catch (_) { }
            } catch (e) {
                console.error('addMenuItemLine failed', e);
                alert('Failed to add menu item. Please try again.');
            }
        }

        async function uploadMenuItemImage(placeId, file, els) {
            if (!placeId) throw new Error('placeId missing');
            if (!file) throw new Error('No file selected');
            const fd = new FormData();
            fd.append('placeId', placeId);
            fd.append('image', file);

            if (els.status) {
                els.status.style.display = 'block';
                els.status.style.color = '#6b7280';
                els.status.textContent = 'Uploading image…';
            }

            const res = await fetch('/api/MenuItemImages/upload', {
                method: 'POST',
                credentials: 'same-origin',
                body: fd
            });
            const data = await res.json().catch(() => ({}));
            if (!res.ok) {
                throw new Error(data?.message || `Upload failed (${res.status})`);
            }
            const url = String(data?.url || '').trim();
            if (!url) throw new Error('Upload failed (no url returned)');
            if (els.hidden) els.hidden.value = url;
            return url;
        }

        // Inline menu builder: file upload + preview
        document.addEventListener('change', async (e) => {
            const input = e.target;
            if (!input || input.tagName !== 'INPUT' || input.type !== 'file') return;
            const id = input.id || '';
            if (!id.startsWith('menuitem-image-file-')) return;

            const placeId = id.replace('menuitem-image-file-', '');
            const hidden = document.getElementById(`menuitem-image-${placeId}`);
            const status = document.getElementById(`menuitem-image-status-${placeId}`);
            const preview = document.getElementById(`menuitem-image-preview-${placeId}`);

            const file = input.files && input.files[0] ? input.files[0] : null;
            if (!file) return;

            // local preview immediately
            try {
                if (preview) {
                    preview.src = URL.createObjectURL(file);
                    preview.style.display = 'block';
                }
            } catch (_) { }

            input.disabled = true;
            try {
                await uploadMenuItemImage(placeId, file, { hidden, status });
                if (status) {
                    status.style.display = 'block';
                    status.style.color = '#47682C';
                    status.textContent = 'Image uploaded.';
                }
            } catch (err) {
                if (status) {
                    status.style.display = 'block';
                    status.style.color = '#ef4444';
                    status.textContent = err?.message || 'Upload failed.';
                }
                if (hidden) hidden.value = '';
            } finally {
                input.disabled = false;
            }
        });

        function formatTimeAgo(dateStr) {
            try {
                const d = new Date(dateStr);
                const diffMs = Date.now() - d.getTime();
                const mins = Math.floor(diffMs / 60000);
                if (mins < 1) return 'just now';
                if (mins < 60) return `${mins}m ago`;
                const hrs = Math.floor(mins / 60);
                if (hrs < 24) return `${hrs}h ago`;
                const days = Math.floor(hrs / 24);
                return `${days}d ago`;
            } catch (_) {
                return '';
            }
        }

        async function loadHealthQa(placeId) {
            const list = document.getElementById(`healthqa-list-${placeId}`);
            if (!list) return;
            list.innerHTML = `<div style="text-align:center; color:#9ca3af; font-size:0.8125rem;">Loading questions…</div>`;
            try {
                const res = await fetch(`/api/RestaurantQa/${encodeURIComponent(placeId)}?limit=20`, { credentials: 'same-origin' });
                const data = await res.json();
                if (!res.ok) throw new Error(data?.message || `Request failed (${res.status})`);
                renderHealthQa(placeId, data.questions || []);
            } catch (e) {
                console.error('Failed to load Health Q&A:', e);
                list.innerHTML = `<div style="text-align:center; color:#ef4444; font-size:0.8125rem;">Failed to load Q&amp;A.</div>`;
            }
        }

        function renderHealthQa(placeId, questions) {
            const list = document.getElementById(`healthqa-list-${placeId}`);
            if (!list) return;

            if (!questions || questions.length === 0) {
                list.innerHTML = `<div style="text-align:center; color:#9ca3af; font-size:0.8125rem;">No questions yet. Be the first to ask!</div>`;
                return;
            }

            const userId = @(HttpContextAccessor.HttpContext.Session.GetInt32("UserId")?.ToString() ?? "null");
            const auth = (window.healthQaAuth && window.healthQaAuth[placeId]) ? window.healthQaAuth[placeId] : null;
            const currentUserId = (auth && auth.userId != null) ? auth.userId : (userId !== null ? parseInt(userId) : null);
            const isOwnerForPlace = !!(auth && auth.isOwner);

            list.innerHTML = questions.map(q => {
                const answers = (q.answers || []);
                const answersHtml = answers.length
                    ? answers.map(a => {
                        const verified = !!a.isVerified;
                        const role = a.verifiedByRole || '';
                        const bg = verified ? (role === 'Owner' ? 'rgba(247,179,43,0.18)' : 'rgba(25,110,243,0.12)') : '#f9fafb';
                        const border = verified ? (role === 'Owner' ? '#F7B32B' : '#196EF3') : '#e5e7eb';
                        const badge = verified
                            ? `<span style="font-size:0.6875rem; padding:0.125rem 0.375rem; border-radius:999px; background:${role === 'Owner' ? '#F7B32B' : '#196EF3'}; color:#ffffff; font-weight:700;">${role === 'Owner' ? '✓ Owner Reply' : '✓ Admin Reply'}</span>`
                            : '';
                        return `
                            <div style="padding:0.5rem; border:1px solid ${border}; background:${bg}; border-radius:0.5rem;">
                                <div style="display:flex; align-items:center; justify-content:space-between; gap:0.5rem; margin-bottom:0.25rem;">
                                    <div style="font-size:0.75rem; color:#374151; font-weight:600;">${escapeHtml(a.answeredBy?.name || 'User')}</div>
                                    <div style="display:flex; align-items:center; gap:0.5rem;">
                                        ${badge}
                                        <div style="font-size:0.6875rem; color:#9ca3af;">${formatTimeAgo(a.createdAt)}</div>
                                    </div>
                                </div>
                                <div style="font-size:0.8125rem; color:#374151; line-height:1.4;">${escapeHtml(a.answerText || '')}</div>
                            </div>
                        `;
                    }).join('')
                    : `<div style="color:#9ca3af; font-size:0.8125rem; text-align:center; padding:0.5rem 0;">No replies yet.</div>`;

                const askerId =
                    (q.askedBy && (q.askedBy.userId ?? q.askedBy.id)) ??
                    q.askedByUserId ??
                    q.askedById ??
                    q.userId ??
                    q.createdByUserId ??
                    null;
                const canReply = (currentUserId !== null) && (isOwnerForPlace || (askerId !== null && currentUserId === askerId));

                const replyBox = canReply ? `
                    <div style="display:flex; gap:0.5rem; margin-top:0.5rem;">
                        <input id="healthqa-answer-input-${q.questionId}" type="text" placeholder="Write a reply…"
                               style="flex:1; padding:0.5rem 0.625rem; border:1px solid #e5e7eb; border-radius:0.5rem; font-size:0.8125rem;" />
                        <button onclick="submitHealthAnswer(${q.questionId}, '${placeId}')"
                                style="padding:0.5rem 0.75rem; background:#196EF3; color:#ffffff; border:none; border-radius:0.5rem; font-size:0.8125rem; font-weight:600; cursor:pointer;">
                            Reply
                        </button>
                    </div>
                ` : '';

                return `
                    <div style="border:1px solid #e5e7eb; border-radius:0.75rem; padding:0.75rem; background:#ffffff;">
                        <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:0.5rem; margin-bottom:0.5rem;">
                            <div style="flex:1;">
                                <div style="font-size:0.75rem; color:#374151; font-weight:700;">Q: ${escapeHtml(q.questionText || '')}</div>
                                <div style="margin-top:0.25rem; font-size:0.6875rem; color:#9ca3af;">
                                    Asked by ${escapeHtml(q.askedBy?.name || 'User')} · ${formatTimeAgo(q.createdAt)}
                                </div>
                            </div>
                        </div>
                        <div style="display:flex; flex-direction:column; gap:0.5rem;">
                            ${answersHtml}
                        </div>
                        ${replyBox}
                    </div>
                `;
            }).join('');
        }

        async function submitHealthQuestion(placeId) {
            const input = document.getElementById(`healthqa-question-input-${placeId}`);
            if (!input) return;
            const text = (input.value || '').trim();
            if (text.length < 5) {
                alert('Please enter a longer question.');
                return;
            }
            try {
                const res = await fetch('/api/RestaurantQa/question', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ placeId, questionText: text })
                });
                const ct = res.headers.get('content-type') || '';
                const body = ct.includes('application/json') ? await res.json() : await res.text();
                if (!res.ok) {
                    const msg = (body && typeof body === 'object' && body.message) ? body.message : `Request failed (${res.status})`;
                    throw new Error(msg);
                }
                input.value = '';
                await loadHealthQa(placeId);
            } catch (e) {
                console.error(e);
                alert(`Failed to post question: ${e.message || 'Unknown error'}`);
            }
        }

        async function submitHealthAnswer(questionId, placeId) {
            const input = document.getElementById(`healthqa-answer-input-${questionId}`);
            if (!input) return;
            const text = (input.value || '').trim();
            if (text.length < 2) {
                alert('Please enter a reply.');
                return;
            }
            try {
                const res = await fetch('/api/RestaurantQa/answer', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ questionId, answerText: text })
                });
                const ct = res.headers.get('content-type') || '';
                const body = ct.includes('application/json') ? await res.json() : await res.text();
                if (!res.ok) {
                    const msg = (body && typeof body === 'object' && body.message) ? body.message : `Request failed (${res.status})`;
                    throw new Error(msg);
                }
                input.value = '';
                await loadHealthQa(placeId);
            } catch (e) {
                console.error(e);
                alert(`Failed to post reply: ${e.message || 'Unknown error'}`);
            }
        }

