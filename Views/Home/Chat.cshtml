</style>


@section Scripts {
    <script>
        // Global variables
        let map;
        let userLocation = { lat: 7.1907, lng: 125.4553 }; // Default Davao City
        let directionsService;
        let directionsRenderer;
        let currentRoute = null;
        let searchMarkers = [];
        let searchInfoWindows = [];

        // Health & Dietary toggle state: OFF for guests, ON for logged-in users
        let healthDietModeEnabled = (window.isGuest ? false : true);

        // Current chat session context
        window.currentSessionId = null;

        // Track which panel was last active
        let lastActivePanel = 'search'; // 'search', 'favorites', or 'details'
        let previousActivePanel = 'search'; // Track what panel was active before opening details

        // Favorites tracking
        let userFavorites = new Set(); // Store place IDs of favorite restaurants
        let favoritesData = []; // Store complete favorite restaurant data
        let favoritesMarkers = [];
        let favoritesInfoWindows = [];

        // Community dietary tags (votes)
        let dietaryRestrictionsList = [];
        let selectedCommunityDietaryRestrictionId = null;
        let dietaryTagsData = []; // community-tagged shops for selected tag
        let dietaryTagsMarkers = [];
        let dietaryTagsInfoWindows = [];
        
        // Store current place details for favorites functionality
        let currentRestaurantDetails = null;
        let currentMobileRestaurantDetails = null;
        let topRestaurantCardDismissed = false;
        
        // Track current restaurant index for navigation
        let currentRestaurantIndex = -1;
        let currentRestaurantList = []; // Current active list (search or favorites)
        let currentListType = 'search'; // 'search' or 'favorites'

        // Initialize Google Map
        window.initMap = function() {
            map = new google.maps.Map(document.getElementById('map'), {
                center: userLocation,
                zoom: 13,
                mapTypeId: google.maps.MapTypeId.ROADMAP,
                streetViewControl: false, // We'll create our own
                mapTypeControl: false,
                fullscreenControl: false,
                gestureHandling: "greedy",
                scrollwheel: true,
                zoomControl: false,
                // Disable all default UI controls
                disableDefaultUI: true,
                backgroundColor: '#ffffff'
            });


            // Get user's current location
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(
                    (pos) => {
                        userLocation = { lat: pos.coords.latitude, lng: pos.coords.longitude };
                        map.setCenter(userLocation);
                        
                        // Add user location marker
                        new google.maps.Marker({ 
                            position: userLocation, 
                            map, 
                            title: 'You are here',
                            icon: {
                               url: '/images/state=search.svg',  // relative path from wwwroot
                               scaledSize: new google.maps.Size(60, 60) // adjust size if needed
                            }
                        });
                    },
                    () => { /* keep default center on failure */ }
                );
            }

            // Initialize panel states
            initializePanels();
            
            // Ensure chat panel is open by default
            initializeChatPanel();

            // Initialize map controls
            initializeMapControls();

            // Initialize directions service
            directionsService = new google.maps.DirectionsService();
            directionsRenderer = new google.maps.DirectionsRenderer({
                draggable: true,
                map: map,
                panel: document.getElementById('directions-panel-content')
            });
        };

        // Initialize panel states
        function initializePanels() {
            // Stacked layout initialization: search hidden, details hidden
            const restaurantDetailsPanel = document.getElementById('restaurant-details-panel');
            const searchPanel = document.getElementById('search-panel');
            if (restaurantDetailsPanel) {
                restaurantDetailsPanel.style.display = 'none';
                restaurantDetailsPanel.style.visibility = 'hidden';
            }
            // Hide top restaurant card on initialization
            const topCard = document.getElementById('top-restaurant-card');
            if (topCard) {
                topCard.style.display = 'none';
            }
            if (searchPanel) {
                searchPanel.style.display = 'flex';
                searchPanel.style.transform = 'translateX(-100%)';
            }
            
            // Initialize lastActivePanel to match the initial state
            lastActivePanel = 'search';
            
            // Ensure toggle button starts at left edge (collapsed state)
            const toggleSearchBtn = document.getElementById('toggle-search');
            if (toggleSearchBtn) {
                toggleSearchBtn.style.left = '0';
                toggleSearchBtn.setAttribute('aria-expanded', 'false');
                toggleSearchBtn.querySelector('span').textContent = '›';
            }
            
            // Initialize search panel enhancements
            initializeSearchPanelEnhancements();
        }

        // Initialize search panel enhancements (filters, sort, etc.)
        function initializeSearchPanelEnhancements() {
            // Filter toggle functionality
            const filterToggle = document.getElementById('filter-toggle');
            const filterChipsContainer = document.getElementById('filter-chips-container');
            const filterChips = document.querySelectorAll('.filter-chip');
            
            if (filterToggle && filterChipsContainer) {
                filterToggle.addEventListener('click', function() {
                    const isVisible = filterChipsContainer.style.display !== 'none';
                    filterChipsContainer.style.display = isVisible ? 'none' : 'block';
                    
                    // Add animation
                    if (!isVisible) {
                        filterChipsContainer.style.opacity = '0';
                        filterChipsContainer.style.transform = 'translateY(-10px)';
                        setTimeout(() => {
                            filterChipsContainer.style.transition = 'all 0.3s cubic-bezier(0.4,0,0.2,1)';
                            filterChipsContainer.style.opacity = '1';
                            filterChipsContainer.style.transform = 'translateY(0)';
                        }, 10);
                    }
                });
            }
            
            // Filter chip functionality
            filterChips.forEach(chip => {
                chip.addEventListener('click', function() {
                    const filterType = this.dataset.filter;
                    this.classList.toggle('active');
                    
                    // Add bounce animation
                    this.style.animation = 'bounceIn 0.4s cubic-bezier(0.4,0,0.2,1)';
                    setTimeout(() => {
                        this.style.animation = '';
                    }, 400);
                    
                    // Apply filter logic here
                    applySearchFilter(filterType, this.classList.contains('active'));
                });
            });
            
            // Sort toggle functionality
            const sortToggle = document.getElementById('sort-toggle');
            if (sortToggle) {
                sortToggle.addEventListener('click', function() {
                    // Cycle through sort options
                    const sortOptions = ['distance', 'rating', 'price', 'name'];
                    const currentSort = this.dataset.sort || 'distance';
                    const currentIndex = sortOptions.indexOf(currentSort);
                    const nextIndex = (currentIndex + 1) % sortOptions.length;
                    const nextSort = sortOptions[nextIndex];
                    
                    this.dataset.sort = nextSort;
                    
                    // Add rotation animation
                    this.style.transform = 'rotate(180deg)';
                    setTimeout(() => {
                        this.style.transform = 'rotate(0deg)';
                    }, 300);
                    
                    // Apply sort logic
                    applySearchSort(nextSort);
                });
            }
        }

        // Apply search filter
        let dietaryFilterEnabled = false;
        
        async function applySearchFilter(filterType, isActive) {
            console.log(`Filter ${filterType} ${isActive ? 'applied' : 'removed'}`);

            if (filterType === 'dietary') {
                dietaryFilterEnabled = isActive;

                // If we don't have a selected tag yet, try to default to the first available.
                if (dietaryFilterEnabled && (selectedCommunityDietaryRestrictionId == null)) {
                    if (dietaryTagSelect && dietaryTagSelect.value) {
                        const id = parseInt(dietaryTagSelect.value, 10);
                        if (!Number.isNaN(id) && id > 0) selectedCommunityDietaryRestrictionId = id;
                    } else if (dietaryRestrictionsList && dietaryRestrictionsList.length > 0) {
                        selectedCommunityDietaryRestrictionId = dietaryRestrictionsList[0].dietaryRestrictionId;
                    }
                }

                if (dietaryFilterEnabled) {
                    await refreshCommunityDietaryTagStatusForCurrentResults();
                }

                applyDietaryFilterToCards();
                return;
            }

            // Other filters can be implemented later
        }

        function applyDietaryFilterToCards() {
            const searchResultsContainer = document.getElementById('search-results');
            if (!searchResultsContainer) return;

            const cards = Array.from(searchResultsContainer.querySelectorAll('.result-item'));
            cards.forEach(card => {
                if (!dietaryFilterEnabled) {
                    card.style.display = '';
                    return;
                }

                const isActive = (card.dataset.communityTagActive === 'true');
                card.style.display = isActive ? '' : 'none';
            });
        }

        // Apply search sort
        // Global variable to track current sort state
        let currentSortState = 'none'; // 'none', 'distance-asc', 'distance-desc'
        
        function applySearchSort(sortType) {
            console.log(`Sorting by ${sortType}`);
            
            // Get current search results from the DOM
            const searchResultsContainer = document.getElementById('search-results');
            if (!searchResultsContainer) return;
            
            const resultCards = Array.from(searchResultsContainer.querySelectorAll('.result-item'));
            if (resultCards.length === 0) return;
            
            // Determine sort direction based on current state
            let sortDirection = 'asc';
            if (currentSortState === 'distance-asc') {
                sortDirection = 'desc';
                currentSortState = 'distance-desc';
            } else {
                sortDirection = 'asc';
                currentSortState = 'distance-asc';
            }
            
            // Sort the cards based on distance
            const sortedCards = resultCards.sort((a, b) => {
                const distanceA = parseFloat(a.dataset.distance) || Infinity;
                const distanceB = parseFloat(b.dataset.distance) || Infinity;
                
                if (sortDirection === 'asc') {
                    return distanceA - distanceB; // Nearest first
                } else {
                    return distanceB - distanceA; // Farthest first
                }
            });
            
            // Clear the container and re-append sorted cards with animation
            searchResultsContainer.innerHTML = '';
            
            // Add cards back with staggered animation
            sortedCards.forEach((card, index) => {
                setTimeout(() => {
                    searchResultsContainer.appendChild(card);
                    // Add entrance animation
                    card.style.opacity = '0';
                    card.style.transform = 'translateY(20px)';
                    card.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                    
                    setTimeout(() => {
                        card.style.opacity = '1';
                        card.style.transform = 'translateY(0)';
                    }, 50);
                }, index * 50); // Stagger the animations
            });
            
            // Update sort button visual state
            const sortButton = document.getElementById('sort-toggle');
            if (sortButton) {
                const sortLabels = {
                    'distance-asc': 'Distance (Nearest First)',
                    'distance-desc': 'Distance (Farthest First)'
                };
                sortButton.title = `Sorted by: ${sortLabels[currentSortState]}`;
                
                // Add visual feedback to button
                sortButton.style.background = 'rgba(71, 104, 44, 0.1)';
                sortButton.style.transform = 'scale(0.95)';
                setTimeout(() => {
                    sortButton.style.background = '';
                    sortButton.style.transform = '';
                }, 150);
            }
            
            // Show notification
            showSortNotification(`Sorted by distance (${sortDirection === 'asc' ? 'nearest first' : 'farthest first'})`);
        }
        
        // Show sort notification
        function showSortNotification(message) {
            // Remove existing notification if any
            const existingNotification = document.querySelector('.sort-notification');
            if (existingNotification) {
                existingNotification.remove();
            }
            
            // Create notification element
            const notification = document.createElement('div');
            notification.className = 'sort-notification';
            notification.style.cssText = `
                position: fixed;
                top: 20px;
                right: 20px;
                background: rgba(71, 104, 44, 0.95);
                color: white;
                padding: 12px 20px;
                border-radius: 8px;
                font-size: 14px;
                font-weight: 600;
                z-index: 1000;
                backdrop-filter: blur(10px);
                box-shadow: 0 4px 12px rgba(71, 104, 44, 0.3);
                transform: translateX(100%);
                transition: transform 0.3s ease;
                border: 1px solid rgba(255, 255, 255, 0.2);
            `;
            notification.textContent = message;
            
            document.body.appendChild(notification);
            
            // Animate in
            setTimeout(() => {
                notification.style.transform = 'translateX(0)';
            }, 10);
            
            // Remove after 2.5 seconds
            setTimeout(() => {
                notification.style.transform = 'translateX(100%)';
                setTimeout(() => {
                    if (notification.parentNode) {
                        notification.parentNode.removeChild(notification);
                    }
                }, 300);
            }, 2500);
        }

        // Carousel functionality for search result images
        function goToSlide(placeId, slideIndex) {
            const carousel = document.querySelector(`.image-carousel[data-place-id="${placeId}"]`);
            if (!carousel) return;
            
            const totalSlides = carousel.children.length;
            if (slideIndex < 0 || slideIndex >= totalSlides) return;
            
            // Update carousel position
            carousel.style.transform = `translateX(-${slideIndex * 100}%)`;
            carousel.dataset.index = slideIndex;
            
            // Update dots
            const dots = document.querySelectorAll(`.carousel-dot[data-place-id="${placeId}"]`);
            dots.forEach((dot, index) => {
                dot.style.background = index === slideIndex ? 'rgba(255,255,255,0.9)' : 'rgba(255,255,255,0.4)';
            });
        }

        function nextSlide(placeId) {
            const carousel = document.querySelector(`.image-carousel[data-place-id="${placeId}"]`);
            if (!carousel) return;
            
            const currentIndex = parseInt(carousel.dataset.index) || 0;
            const totalSlides = carousel.children.length;
            const nextIndex = (currentIndex + 1) % totalSlides;
            
            goToSlide(placeId, nextIndex);
        }

        function previousSlide(placeId) {
            const carousel = document.querySelector(`.image-carousel[data-place-id="${placeId}"]`);
            if (!carousel) return;
            
            const currentIndex = parseInt(carousel.dataset.index) || 0;
            const totalSlides = carousel.children.length;
            const prevIndex = currentIndex === 0 ? totalSlides - 1 : currentIndex - 1;
            
            goToSlide(placeId, prevIndex);
        }

        // Auto-advance carousel for search results
        function startCarouselAutoAdvance(placeId) {
            const carousel = document.querySelector(`.image-carousel[data-place-id="${placeId}"]`);
            if (!carousel || carousel.children.length <= 1) return;
            
            // Clear any existing interval
            if (carousel.autoSlideInterval) {
                clearInterval(carousel.autoSlideInterval);
            }
            
            // Start auto-advance every 4 seconds
            carousel.autoSlideInterval = setInterval(() => {
                nextSlide(placeId);
            }, 4000);
        }

        function stopCarouselAutoAdvance(placeId) {
            const carousel = document.querySelector(`.image-carousel[data-place-id="${placeId}"]`);
            if (!carousel) return;
            
            if (carousel.autoSlideInterval) {
                clearInterval(carousel.autoSlideInterval);
                carousel.autoSlideInterval = null;
            }
        }

        // Proactive suggestions
        async function fetchProactiveSuggestions() {
            try {
                if (window.isGuest) {
                    // Load full food list from static JSON files and randomize
                    const files = [
                        '/data/foodtypes-51-500.json',
                        '/data/foodtypes-501-800.json',
                        '/data/foodtypes-801-1154.json'
                    ];
                    const all = [];
                    await Promise.all(files.map(async (p) => {
                        try {
                            const r = await fetch(p);
                            if (r.ok) {
                                const arr = await r.json();
                                arr.forEach(x => { if (x && x.name) all.push(x.name); });
                            }
                        } catch {}
                    }));
                    // De-duplicate and shuffle
                    const unique = Array.from(new Set(all));
                    for (let i = unique.length - 1; i > 0; i--) {
                        const j = Math.floor(Math.random() * (i + 1));
                        [unique[i], unique[j]] = [unique[j], unique[i]];
                    }
                    const items = unique.slice(0, 12).map(name => ({ food: name }));
                    renderProactiveChips(items);
                    return;
                }
                // Logged-in generalized mode (health off): use randomized list like guest
                if (!healthDietModeEnabled) {
                    const files = [
                        '/data/foodtypes-51-500.json',
                        '/data/foodtypes-501-800.json',
                        '/data/foodtypes-801-1154.json'
                    ];
                    const all = [];
                    await Promise.all(files.map(async (p) => {
                        try {
                            const r = await fetch(p);
                            if (r.ok) {
                                const arr = await r.json();
                                arr.forEach(x => { if (x && x.name) all.push(x.name); });
                            }
                        } catch {}
                    }));
                    const unique = Array.from(new Set(all));
                    for (let i = unique.length - 1; i > 0; i--) {
                        const j = Math.floor(Math.random() * (i + 1));
                        [unique[i], unique[j]] = [unique[j], unique[i]];
                    }
                    const items = unique.slice(0, 12).map(name => ({ food: name }));
                    renderProactiveChips(items);
                    return;
                }
                const url = '/api/Chat/proactive-foods?top=8&includeHealthDietRestrictions=true';
                const res = await fetch(url);
                if (!res.ok) return;
                const payload = await res.json();
                renderProactiveChips(payload.items || []);
            } catch {}
        }

        // Enhanced proactive chips with brand colors and animations
        function renderProactiveChips(items) {
            const wrapper = document.getElementById('proactive-chip-list');
            const container = document.getElementById('proactive-suggestions');
            if (!wrapper || !container) return;
            wrapper.innerHTML = '';
            if (!items || !items.length) {
                // Fallback defaults for guests or empty payloads
                const defaults = [
                    { food: 'Pizza' }, { food: 'Burger' }, { food: 'Fried Chicken' }, { food: 'Sushi' },
                    { food: 'Pasta' }, { food: 'Ramen' }, { food: 'Tacos' }, { food: 'Milk Tea' }
                ];
                items = defaults;
                container.style.display = 'block';
            }
            container.style.display = 'block';
            items.slice(0, 8).forEach((it, index) => {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'rounded-full text-sm';
                btn.style.cssText = 'padding:10px 18px; border-radius:9999px; background:rgba(255,245,225,0.9); backdrop-filter:blur(4px); border:1.5px solid rgba(247,179,43,0.3); color:#47682C; box-shadow:0 3px 8px rgba(247,179,43,0.15); display:inline-flex; align-items:center; gap:8px; font-weight:600; cursor:pointer; transition:all 0.3s cubic-bezier(0.4,0,0.2,1); animation:fadeIn 0.5s ease-out; animation-delay:' + (index * 0.05) + 's; opacity:0; animation-fill-mode:forwards;';
                const emoji = getFoodEmoji(it.food);
                btn.innerHTML = `<span style="font-size:1.2rem;">${emoji}</span><span>${it.food}</span>`;
                btn.title = (it.reason ? ('Reason: ' + it.reason) : '') + (it.safe ? '' : ' (may not match restrictions)');
                btn.onmouseover = function() {
                    this.style.backgroundColor = '#F7B32B';
                    this.style.borderColor = '#F7B32B';
                    this.style.color = '#ffffff';
                    this.style.transform = 'translateY(-3px) scale(1.05)';
                    this.style.boxShadow = '0 6px 16px rgba(247,179,43,0.35)';
                };
                btn.onmouseout = function() {
                    this.style.backgroundColor = 'rgba(255,245,225,0.9)';
                    this.style.borderColor = 'rgba(247,179,43,0.3)';
                    this.style.color = '#47682C';
                    this.style.transform = 'translateY(0) scale(1)';
                    this.style.boxShadow = '0 3px 8px rgba(247,179,43,0.15)';
                };
                btn.onclick = () => selectRecommendation(it.food);
                wrapper.appendChild(btn);
            });
        }

        function getFoodEmoji(name) {
            const n = (name || '').toLowerCase();
            if (n.includes('pizza')) return '🍕';
            if (n.includes('burger')) return '🍔';
            if (n.includes('sushi')) return '🍣';
            if (n.includes('noodle') || n.includes('ramen')) return '🍜';
            if (n.includes('vegg') || n.includes('salad')) return '🥗';
            if (n.includes('sweet') || n.includes('dessert')) return '🍰';
            if (n.includes('chicken')) return '🍗';
            if (n.includes('bbq')) return '🍖';
            return '🍽️';
        }

