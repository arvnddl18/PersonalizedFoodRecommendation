                            this.style.boxShadow = '0 4px 8px rgba(71,104,44,0.15)';
                        } else if (this.classList.contains('dietary-vote-btn')) {
                            this.style.background = 'rgba(71,104,44,0.10)';
                            this.style.boxShadow = '0 4px 12px rgba(71,104,44,0.16)';
                        } else if (this.classList.contains('share-btn')) {
                            this.style.background = 'rgba(25,110,243,0.1)';
                            this.style.boxShadow = '0 4px 8px rgba(25,110,243,0.15)';
                        } else if (this.classList.contains('directions-btn')) {
                            this.style.boxShadow = '0 4px 12px rgba(247,179,43,0.35)';
                        }
                    });
                    
                    btn.addEventListener('mouseleave', function() {
                        this.style.transform = 'translateY(0)';
                        if (this.classList.contains('favorite-heart-btn')) {
                            this.style.boxShadow = 'none';
                        } else if (this.classList.contains('dietary-vote-btn')) {
                            this.style.background = 'rgba(71,104,44,0.06)';
                            this.style.boxShadow = '0 2px 8px rgba(71,104,44,0.08)';
                        } else if (this.classList.contains('share-btn')) {
                            this.style.background = 'rgba(25,110,243,0.05)';
                            this.style.boxShadow = 'none';
                        } else if (this.classList.contains('directions-btn')) {
                            this.style.boxShadow = '0 2px 4px rgba(247,179,43,0.2)';
                        }
                    });
                });

                // Add click to show restaurant details
                resultDiv.addEventListener('click', () => {
                    // Center map and add marker
                    map.setCenter(place.geometry.location);
                    map.setZoom(16);

                    // Open the corresponding info window
                    const iw = searchInfoWindows[index];
                    if (iw) { iw.open(map, searchMarkers[index]); }

                    // Show only the top restaurant card (don't open details panel)
                    showRestaurantCard(place.place_id || '', place.name, index, 'search');
                });
                
                resultsDiv.appendChild(resultDiv);

                // Add a marker with a name bubble (InfoWindow) for each result
                const marker = new google.maps.Marker({
                    position: place.geometry.location,
                    map: map,
                    title: place.name,
                    icon: {
                        url: '/images/MapPinLine.svg',
                        scaledSize: new google.maps.Size(32, 32)
                    }
                });
                searchMarkers.push(marker);

                const closeId = `iw-close-${place.place_id || index}`;
                const contentHtml = `
                    <div style="background:#47682C; padding:10px 14px; border-radius:6px; position:relative; color:#FFFFFF; font-weight:600;">
                        <div style="display:flex; align-items:center; justify-content:space-between; gap:12px;">
                            <span style="font-size:14px;">${escapeHtml(place.name || '')}</span>
                            <button id="${closeId}" style="background:transparent; border:none; font-weight:700; color:#FFFFFF; cursor:pointer;">×</button>
                        </div>
                        <div style="position:absolute; left:24px; bottom:-10px; width:0; height:0; border-left:10px solid transparent; border-right:10px solid transparent; border-top:10px solid #e5e7eb;"></div>
                    </div>`;
                const infoWindow = new google.maps.InfoWindow({ content: contentHtml, shouldFocus: false });
                searchInfoWindows.push(infoWindow);

                // Open all name bubbles automatically
                infoWindow.open(map, marker);

                // Wire close button once DOM is ready
                infoWindow.addListener('domready', () => {
                    const btn = document.getElementById(closeId);
                    if (btn) {
                        btn.onclick = () => infoWindow.close();
                    }
                    // Hide Google's default close button to avoid redundancy
                    try {
                        document.querySelectorAll('.gm-ui-hover-effect').forEach(el => {
                            el.style.display = 'none';
                        });
                    } catch {}
                });

                // Clicking a marker re-opens the bubble and shows restaurant details
                marker.addListener('click', () => {
                    infoWindow.open(map, marker);
                    // Show only the top restaurant card (don't open details panel)
                    showRestaurantCard(place.place_id || '', place.name, index, 'search');
                });

                bounds.extend(place.geometry.location);
            }

            // Fit the map to show all markers
            if (!bounds.isEmpty()) {
                map.fitBounds(bounds);
            }

            // Batch-load community dietary tag status for rendered cards (selected tag)
            await refreshCommunityDietaryTagStatusForCurrentResults();
            applyDietaryFilterToCards();

            // If we prepared a secondary dietary section (food+dietary queries), render it after the main results.
            try {
                const section = window._fsSecondaryDietarySection;
                if (section && resultsDiv) {
                    // Only render once per search render cycle
                    window._fsSecondaryDietarySection = null;
                    renderSecondaryDietarySection(resultsDiv, section);
                }
            } catch (_) { }
        }

        // Show detailed restaurant information - ACTIVE for generalized queries
        async function showRestaurantDetails(placeId, placeName) {
            try {
                // Get detailed place information from Google Places API
                const service = new google.maps.places.PlacesService(map);
                const request = {
                    placeId: placeId,
                    fields: ['name', 'formatted_address', 'formatted_phone_number', 'website', 'opening_hours', 'price_level', 'rating', 'user_ratings_total', 'types', 'photos', 'reviews', 'geometry', 'place_id', 'editorial_summary', 'current_opening_hours', 'utc_offset_minutes', 'business_status', 'formatted_phone_number', 'international_phone_number', 'vicinity', 'adr_address']
                };

                service.getDetails(request, async (place, status) => {
                    if (status === google.maps.places.PlacesServiceStatus.OK) {
                        // Enhance place data with additional photo categorization
                        if (place.photos && place.photos.length > 0) {
                            // Sort photos by quality and relevance
                            place.photos.sort((a, b) => {
                                // Prioritize higher resolution photos
                                const aRes = (a.width || 0) * (a.height || 0);
                                const bRes = (b.width || 0) * (b.height || 0);
                                return bRes - aRes;
                            });
                        }
                        
                        displayRestaurantDetails(place);
                    } else {
                        console.log('Failed to get place details:', status);
                        addMessage('FoodieSaur Bot', 'Unable to load restaurant details.');
                    }
                });
            } catch (error) {
                console.error('Error getting restaurant details:', error);
                addMessage('FoodieSaur Bot', 'Error loading restaurant details.');
            }
        }

        // Show only the top restaurant card without opening details panel
        async function showRestaurantCard(placeId, placeName, index = -1, listType = 'search') {
            try {
                // Get detailed place information from Google Places API
                const service = new google.maps.places.PlacesService(map);
                const request = {
                    placeId: placeId,
                    fields: ['name', 'formatted_address', 'formatted_phone_number', 'website', 'opening_hours', 'price_level', 'rating', 'user_ratings_total', 'types', 'photos', 'reviews', 'geometry', 'place_id', 'editorial_summary', 'current_opening_hours', 'utc_offset_minutes', 'business_status', 'formatted_phone_number', 'international_phone_number', 'vicinity', 'adr_address']
                };

                service.getDetails(request, async (place, status) => {
                    if (status === google.maps.places.PlacesServiceStatus.OK) {
                        // Enhance place data with additional photo categorization
                        if (place.photos && place.photos.length > 0) {
                            // Sort photos by quality and relevance
                            place.photos.sort((a, b) => {
                                // Prioritize higher resolution photos
                                const aRes = (a.width || 0) * (a.height || 0);
                                const bRes = (b.width || 0) * (b.height || 0);
                                return bRes - aRes;
                            });
                        }
                        
                        // Store current place details for later use
                        currentRestaurantDetails = place;
                        
                        // Update navigation tracking
                        currentRestaurantIndex = index;
                        currentListType = listType;
                        
                        // Set current restaurant list based on type
                        if (listType === 'search') {
                            currentRestaurantList = searchResultsData;
                        } else if (listType === 'favorites') {
                            currentRestaurantList = favoritesData;
                        }
                        
                        // Only populate the top card, don't open details panel
                        populateTopRestaurantCard(place, true);
                        
                        // Update the restaurant details panel if it's open - SYNCHRONIZATION FIX
                        const detailsPanel = document.getElementById('restaurant-details-panel');
                        if (detailsPanel && detailsPanel.style.display === 'flex') {
                            displayRestaurantDetails(place);
                        }
                        
                        // Highlight the selected card
                        if (index >= 0) {
                            highlightSelectedRestaurantCard(index);
                        }
                    } else {
                        console.log('Failed to get place details:', status);
                    }
                });
            } catch (error) {
                console.error('Error getting restaurant details:', error);
            }
